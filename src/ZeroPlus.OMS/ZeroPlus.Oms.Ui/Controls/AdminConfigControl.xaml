<UserControl x:Class="ZeroPlus.Oms.Ui.Controls.AdminConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:local="clr-namespace:ZeroPlus.Oms.Ui.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:ModuleViewModelBase}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <StackPanel Grid.Row="0"
                Margin="0,0,0,5"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
        <Label Content="Admin Configs: " />
        <dxe:ComboBoxEdit MinWidth="200"
                          Margin="5,0"
                          HorizontalAlignment="Right"
                          DisplayMember="Title"
                          EditValue="{Binding SelectedConfig, UpdateSourceTrigger=PropertyChanged}"
                          IsTextEditable="False"
                          ItemsSource="{Binding AdminConfigs}"
                          PopupClosed="ComboBoxEdit_PopupClosed" />
        <dx:SimpleButton Width="20"
                         VerticalAlignment="Top"
                         Click="SimpleButton_Click"
                         Glyph="{dx:DXImage 'Images/Actions/Refresh2_16x16.png'}"
                         ToolTip="Reload Configs" />
    </StackPanel>
</UserControl>
