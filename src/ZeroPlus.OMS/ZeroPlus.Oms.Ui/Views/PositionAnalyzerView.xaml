<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.PositionAnalyzerView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxgt="http://schemas.devexpress.com/winfx/2008/xaml/grid/themekeys"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="1800"
                 Height="700"
                 MinWidth="400"
                 MinHeight="300"
                 Padding="0"
                 d:DataContext="{d:DesignInstance Type=ViewModels:PositionAnalyzerViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:PositionAnalyzerViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:LoadCustomColumnService />
        <services:OmsMessageBoxService />
        <dxmvvm:DispatcherService />
    </dxmvvm:Interaction.Behaviors>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <dx:DropDownButton Grid.Row="0"
                               Grid.Column="12"
                               Width="115"
                               Margin="2"
                               Padding="3,1,7,1"
                               HorizontalAlignment="Right"
                               Content="Settings"
                               Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Settings.svg}"
                               GlyphHeight="15">
                <ItemsControl>
                    <StackPanel Orientation="Vertical">
                        <dx:SuperTipItemControlSeparator />
                        <MenuItem Click="ClearSortingClick"
                                  Header="Clear Sorting" />
                    </StackPanel>
                </ItemsControl>
            </dx:DropDownButton>

            <dx:SimpleButton Width="23"
                             Margin="2"
                             HorizontalAlignment="Right"
                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                             GlyphHeight="17">
                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupControlContainer>
                        <ItemsControl>
                            <StackPanel>
                                <MenuItem Height="25"
                                          Click="CloneClick"
                                          Header="Clone">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="ShareLayout"
                                          Header="Share Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="SaveLayout"
                                          Header="Save Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="BrowseLayout"
                                          Header="Browse Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="LoadLayout"
                                          Header="Load Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </StackPanel>
                        </ItemsControl>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>
        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <dx:ThemedWindow.Resources>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToStateColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#039C23" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#D11C1C" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:SignToBrushConverter x:Key="TitleSignToBrushConverter"
                                     NegativeBrush="#FF0000"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#10e411" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#02F302" />

        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="AddToTopToGlyphConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <Image Width="20"
                       Height="20"
                       Source="{dx:DXImage SvgImages/Spreadsheet/FillUp.svg}" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <Image Width="20"
                       Height="20"
                       Source="{dx:DXImage SvgImages/Spreadsheet/FillDown.svg}" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="FeedStateTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                SUBSCRIBED
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                DOWN
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TraderStateTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                AUTO TRADER RUNNING
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                AUTO TRADER STOPPED
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TraderStateButtonTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Stop Trader
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Start Trader
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToStatusColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Green" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="DarkRed" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                             Inverse="True" />
        <helper:SignToBrushConverter x:Key="CountdownToBrushConverter"
                                     Limit="3"
                                     NegativeBrush="#F05126"
                                     PositiveBrush="#F1F1F1"
                                     ZeroBrush="#F05126" />
        <Style x:Key="PositionsRowStyle"
               TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="#1d3c52" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="#1d3c52" />
                </Trigger>
                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#39393A" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#3E596B" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </dx:ThemedWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="5,5,5,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0"
                   Grid.Column="0"
                   Margin="5,0,0,0"
                   Content="Symbol" />

            <dxe:TextEdit Grid.Row="0"
                          Grid.Column="1"
                          Grid.ColumnSpan="4"
                          Margin="5,0,0,0"
                          CharacterCasing="Upper"
                          EditValue="{Binding InputString, UpdateSourceTrigger=PropertyChanged}"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

            <dx:SimpleButton Grid.Row="0"
                             Grid.Column="5"
                             Margin="5,0,0,0"
                             Command="{Binding AddCommand}"
                             Content="Load Position"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                             GlyphHeight="15"
                             GlyphWidth="15"
                             IsDefault="True" />

        </Grid>

        <Slider x:Name="PositionsGridScale"
                Grid.Row="1"
                Maximum="4"
                Minimum="0.1"
                Visibility="Hidden"
                Value="1" />

        <dxg:GridControl x:Name="PositionsGrid"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,5,0,0"
                         dx:DXSerializer.StoreLayoutMode="All"
                         dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                         AutoGenerateColumns="AddNew"
                         AutoGeneratedColumns="Grid_ColumnsPopulated"
                         CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                         EnableSmartColumnsGeneration="True"
                         ItemsSource="{Binding Positions}"
                         PreviewMouseWheel="OnZoomMouseWheel"
                         RestoreStateOnSourceChange="True"
                         SelectionMode="Row">
            <dxg:GridControl.LayoutTransform>
                <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=PositionsGridScale, Path=Value}" ScaleY="{Binding ElementName=PositionsGridScale, Path=Value}" />
            </dxg:GridControl.LayoutTransform>
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
                <Style x:Key="RowStyle"
                       TargetType="dxg:RowControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=IsSelected}"
                                     Value="True">
                            <Setter Property="Background" Value="#1d3c52" />
                        </DataTrigger>
                        <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                            <Setter Property="Background" Value="#1d3c52" />
                        </Trigger>
                        <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#39393A" />
                        </Trigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#3E596B" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </dxg:GridControl.Resources>
            <dxmvvm:Interaction.Behaviors>
                <services:UiUpdateService />
            </dxmvvm:Interaction.Behaviors>
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False"
                               AllowSorting="False"
                               AutoWidth="True"
                               EnableSelectedRowAppearance="True"
                               GroupSummaryDisplayMode="AlignByColumns"
                               NavigationStyle="Row"
                               RowStyle="{StaticResource RowStyle}"
                               ShowFilterPanelMode="Never"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.TotalSummaryContentStyle>
                        <Style TargetType="dx:DataContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </dxg:TableView.TotalSummaryContentStyle>
                    <dxg:TableView.TotalSummaryItemTemplate>
                        <DataTemplate>
                            <TextBlock Padding="2"
                                       Foreground="{Binding Column.TotalSummaryText, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding Column.TotalSummaryText, StringFormat='{}{0:C0}'}" />
                        </DataTemplate>
                    </dxg:TableView.TotalSummaryItemTemplate>
                    <dxg:TableView.GroupColumnSummaryItemTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Right"
                                       Foreground="{Binding Value, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding Value}" />
                        </DataTemplate>
                    </dxg:TableView.GroupColumnSummaryItemTemplate>
                    <dxg:TableView.GroupValueTemplate>
                        <DataTemplate>
                            <TextBlock Margin="10,0,0,0"
                                       Text="{Binding Value}" />
                        </DataTemplate>
                    </dxg:TableView.GroupValueTemplate>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="Symbol"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn FieldName="Side"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn FieldName="Quantity"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn FieldName="Mid"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding RowData.Row.Mid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Delta"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.Delta, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.Delta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Gamma"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.Gamma, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.Gamma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Theta"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.Theta, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.Theta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Vega"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.Vega, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.Vega, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="NetDelta"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.NetDelta, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.NetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="NetGamma"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.NetGamma, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.NetGamma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="NetTheta"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.NetTheta, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.NetTheta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>

        <Grid Grid.Row="2"
              Margin="0,5,0,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="5" />
            </Grid.ColumnDefinitions>

            <Label Grid.Row="1"
                   Grid.Column="0"
                   Margin="5,0,0,0"
                   Content="Quantity" />

            <dxe:SpinEdit Grid.Row="1"
                          Grid.Column="1"
                          Width="70"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding Quantity}"
                          EditValueType="{x:Type sys:Int32}"
                          Mask="N0"
                          MaskUseAsDisplayFormat="True"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

            <Label Grid.Row="1"
                   Grid.Column="2"
                   Margin="5,0,0,0"
                   Content="Side" />

            <dxe:ComboBoxEdit Grid.Row="1"
                              Grid.Column="3"
                              Width="70"
                              Margin="5,0,0,0"
                              IsSynchronizedWithCurrentItem="True"
                              IsTextEditable="False"
                              ItemsSource="{Binding Sides}"
                              SelectedItem="{Binding Side}" />

            <Label Grid.Row="1"
                   Grid.Column="4"
                   Margin="5,0,0,0"
                   Content="Base Price" />

            <dxe:SpinEdit Grid.Row="1"
                          Grid.Column="5"
                          Width="76"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding BasePrice}"
                          EditValueType="{x:Type sys:Double}"
                          Increment="0.01"
                          Mask="N2"
                          MaskUseAsDisplayFormat="True"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

            <Label Grid.Row="1"
                   Grid.Column="6"
                   Margin="5,0,0,0"
                   Content="DTE Offset" />

            <dxe:TrackBarEdit Grid.Row="1"
                              Grid.Column="7"
                              Width="150"
                              Margin="5,0,0,0"
                              EditValue="{Binding DaysToExpirationOffSet}"
                              EditValueType="{x:Type sys:Int32}"
                              IsSnapToStepEnabled="True"
                              LargeStep=".1"
                              Maximum="{Binding DaysToExpiration}"
                              Minimum="0"
                              SmallStep="1"
                              TickFrequency="1"
                              TickItemDisplayMode="Tick"
                              TickPlacement="BottomRight"
                              ValueToolTipPlacement="TopLeft" />

            <Label Grid.Row="1"
                   Grid.Column="9"
                   Margin="5,0,0,0"
                   Content="Count" />

            <dxe:SpinEdit Grid.Row="1"
                          Grid.Column="10"
                          Width="76"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Int32}"
                          Increment="1"
                          Mask="D"
                          MaskUseAsDisplayFormat="True"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding UpdatePositionsListCommand}"
                                           EventName="EditValueChanged" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:SpinEdit>

            <Label Grid.Row="1"
                   Grid.Column="11"
                   Margin="5,0,0,0"
                   Content="Step %" />

            <dxe:SpinEdit Grid.Row="1"
                          Grid.Column="12"
                          Width="76"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding StepPercent, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          Increment=".01"
                          Mask="P2"
                          MaskUseAsDisplayFormat="True"
                          MaxValue="1"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding UpdatePositionsListCommand}"
                                           EventName="EditValueChanged" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:SpinEdit>

            <Label Grid.Row="1"
                   Grid.Column="13"
                   Margin="5,0,0,0"
                   Content="IV +/-" />

            <dxe:SpinEdit Grid.Row="1"
                          Grid.Column="14"
                          Width="76"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding IvOffset, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          Increment=".01"
                          Mask="P2"
                          MaskUseAsDisplayFormat="True"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

        </Grid>
        <Slider x:Name="ModelsMainGridScale"
                Grid.Row="3"
                Maximum="4"
                Minimum="0.1"
                Visibility="Hidden"
                Value="1" />

        <dxg:GridControl x:Name="ModelsMainGrid"
                         Grid.Row="3"
                         Grid.Column="1"
                         Margin="0,5"
                         dx:DXSerializer.StoreLayoutMode="All"
                         dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                         AutoGenerateColumns="AddNew"
                         AutoGeneratedColumns="Grid_ColumnsPopulated"
                         CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                         EnableSmartColumnsGeneration="True"
                         ItemsSource="{Binding PositionsRisk}"
                         PreviewMouseWheel="OnZoomMouseWheel"
                         RestoreStateOnSourceChange="True"
                         SelectionMode="Row">
            <dxg:GridControl.LayoutTransform>
                <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=ModelsMainGridScale, Path=Value}" ScaleY="{Binding ElementName=ModelsMainGridScale, Path=Value}" />
            </dxg:GridControl.LayoutTransform>
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
                <Style x:Key="RowStyle"
                       TargetType="dxg:RowControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=IsSelected}"
                                     Value="True">
                            <Setter Property="Background" Value="#1d3c52" />
                        </DataTrigger>
                        <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                            <Setter Property="Background" Value="#1d3c52" />
                        </Trigger>
                        <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#39393A" />
                        </Trigger>
                        <DataTrigger Binding="{Binding Path=Row.IsCurrent}"
                                     Value="True">
                            <Setter Property="Background" Value="#8a7750" />
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#3E596B" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </dxg:GridControl.Resources>
            <dxmvvm:Interaction.Behaviors>
                <services:UiUpdateService />
            </dxmvvm:Interaction.Behaviors>
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False"
                               AllowSorting="False"
                               AutoWidth="True"
                               EnableSelectedRowAppearance="True"
                               GroupSummaryDisplayMode="AlignByColumns"
                               NavigationStyle="Row"
                               RowStyle="{StaticResource RowStyle}"
                               ShowFilterPanelMode="Never"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.TotalSummaryContentStyle>
                        <Style TargetType="dx:DataContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </dxg:TableView.TotalSummaryContentStyle>
                    <dxg:TableView.TotalSummaryItemTemplate>
                        <DataTemplate>
                            <TextBlock Padding="2"
                                       Foreground="{Binding Column.TotalSummaryText, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding Column.TotalSummaryText, StringFormat='{}{0:C0}'}" />
                        </DataTemplate>
                    </dxg:TableView.TotalSummaryItemTemplate>
                    <dxg:TableView.GroupColumnSummaryItemTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Right"
                                       Foreground="{Binding Value, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding Value}" />
                        </DataTemplate>
                    </dxg:TableView.GroupColumnSummaryItemTemplate>
                    <dxg:TableView.GroupValueTemplate>
                        <DataTemplate>
                            <TextBlock Margin="10,0,0,0"
                                       Text="{Binding Value}" />
                        </DataTemplate>
                    </dxg:TableView.GroupValueTemplate>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="Percentage"
                            Header="% Change"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.Percentage, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.Percentage, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.P2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="UnderlyingPrice"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding RowData.Row.UnderlyingPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="NetDelta"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.NetDelta, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.NetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="NetTheta"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.NetTheta, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.NetTheta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="NetGamma"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.NetGamma, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.NetGamma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Pnl"
                            Header="PnL"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.Pnl, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.Pnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>
    </Grid>
</dx:ThemedWindow>
