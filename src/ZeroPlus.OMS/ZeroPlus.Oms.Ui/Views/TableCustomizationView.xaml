<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.TableCustomizationView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Table Customization"
                 Width="1200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 DataContext="{startuphelpers:DISource Type=ViewModels:TableCustomizationViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <dx:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <helper:SelectedColorExtractor x:Key="SelectedColorExtractor" />
        <helper:CamelCaseFormatter x:Key="CamelCaseFormatter" />
        <helper:MultiValueCloneConverter x:Key="MultiValueCloneConverter" />
        <Style x:Key="RowStyle"
               TargetType="dxg:RowControl">
            <Style.Setters>
                <Setter Property="Background" Value="#36363a" />
                <Setter Property="Foreground" Value="#f1f1f1" />
            </Style.Setters>
        </Style>
    </Window.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <dxg:GridControl Name="HiddenColumnsGrid"
                         Grid.Row="1"
                         Grid.Column="1"
                         Width="200"
                         ItemsSource="{Binding HiddenColumns}"
                         SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView MaxHeight="5000"
                               AllowColumnFiltering="False"
                               AllowEditing="False"
                               AllowGrouping="False"
                               AllowSorting="True"
                               AutoWidth="True"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn Width="90"
                            FieldName="FieldName"
                            Header="Hidden Fields"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True"
                            SortIndex="0">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Padding="2"
                                   Text="{Binding RowData.Row.FieldName, Converter={StaticResource CamelCaseFormatter}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>
        <StackPanel Grid.Row="1"
                    Grid.Column="2"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    Orientation="Vertical">
            <dx:SimpleButton Width="20"
                             Height="20"
                             Margin="0,5"
                             Command="{Binding HideCommand}"
                             CommandParameter="{Binding ElementName=VisibleColumnsGrid, Path=SelectedItems}"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Arrow1Left.svg}" />
            <dx:SimpleButton Width="20"
                             Height="20"
                             Margin="0,5"
                             Command="{Binding ShowCommand}"
                             CommandParameter="{Binding ElementName=HiddenColumnsGrid, Path=SelectedItems}"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Arrow1Right.svg}" />
        </StackPanel>
        <dxg:GridControl Name="VisibleColumnsGrid"
                         Grid.Row="1"
                         Grid.Column="3"
                         ItemsSource="{Binding VisibleColumns}">
            <dxg:GridControl.View>
                <dxg:TableView MaxHeight="5000"
                               AllowColumnFiltering="False"
                               AllowGrouping="False"
                               AllowSorting="True"
                               AutoWidth="True"
                               RowStyle="{StaticResource RowStyle}"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn Width="90"
                            FieldName="FieldName"
                            Header="Field"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True"
                            ReadOnly="True"
                            SortIndex="0" />

            <dxg:GridColumn FieldName="Header"
                            Header="Header"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:TextEdit EditValue="{Binding Data.Header, UpdateSourceTrigger=PropertyChanged}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Type"
                            Header="Type"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:ComboBoxEdit Height="24"
                                          AllowUpdateTwoWayBoundPropertiesOnSynchronization="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding View.DataContext.UnboundColumnTypes}"
                                          SelectedItem="{Binding Data.UnboundType, UpdateSourceTrigger=PropertyChanged}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding View.DataContext.TypeChangedCommand}"
                                                       EventName="EditValueChanged">
                                    <dxmvvm:EventToCommand.CommandParameter>
                                        <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                                            <Binding Path="RowData.Row" />
                                            <Binding Path="EditValue"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type dxe:ComboBoxEdit}}" />
                                        </MultiBinding>
                                    </dxmvvm:EventToCommand.CommandParameter>
                                </dxmvvm:EventToCommand>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:ComboBoxEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Font"
                            Header="Font"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit AllowSpinOnMouseWheel="True"
                                      EditValueType="{x:Type sys:Double}"
                                      Mask="N2"
                                      MinValue="0"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True"
                                      Value="{Binding Data.Font}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding View.DataContext.FontChangedCommand}"
                                                       EventName="EditValueChanged">
                                    <dxmvvm:EventToCommand.CommandParameter>
                                        <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                                            <Binding Path="RowData.Row" />
                                            <Binding Path="EditValue"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type dxe:SpinEdit}}" />
                                        </MultiBinding>
                                    </dxmvvm:EventToCommand.CommandParameter>
                                </dxmvvm:EventToCommand>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:SpinEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Alignment"
                            Header="Alignment"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:ComboBoxEdit Height="24"
                                          AllowUpdateTwoWayBoundPropertiesOnSynchronization="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding View.DataContext.EditSettingsHorizontalAlignments}"
                                          SelectedItem="{Binding Data.ActualEditSettings.HorizontalContentAlignment, UpdateSourceTrigger=PropertyChanged}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding View.DataContext.HorizontalAlignmentChangedCommand}"
                                                       EventName="EditValueChanged">
                                    <dxmvvm:EventToCommand.CommandParameter>
                                        <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                                            <Binding Path="RowData.Row" />
                                            <Binding Path="EditValue"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type dxe:ComboBoxEdit}}" />
                                        </MultiBinding>
                                    </dxmvvm:EventToCommand.CommandParameter>
                                </dxmvvm:EventToCommand>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:ComboBoxEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Foreground"
                            Header="Foreground"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:DropDownButton Glyph="{dx:DXImage SvgImages/Dashboards/EditColors.svg}"
                                           GlyphHeight="15">
                            <dx:DropDownButton.Style>
                                <Style TargetType="dx:DropDownButton">
                                    <Setter Property="Background" Value="{Binding ElementName=ForegroundSelector, Path=Color, Converter={StaticResource ColorToBrushConverter}}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{Binding ElementName=ForegroundSelector, Path=Color, Converter={StaticResource ColorToBrushConverter}}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </dx:DropDownButton.Style>
                            <dxe:ColorEdit x:Name="ForegroundSelector"
                                           Grid.Column="0"
                                           ChipSize="Small"
                                           ColumnCount="8"
                                           DefaultColor="Transparent"
                                           Color="{Binding RowData, Converter={StaticResource SelectedColorExtractor}, ConverterParameter='FG'}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding View.DataContext.ForegroundChangedCommand}"
                                                           EventName="EditValueChanged">
                                        <dxmvvm:EventToCommand.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                                                <Binding Path="RowData.Row" />
                                                <Binding Path="Color"
                                                         RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                         AncestorType={x:Type dxe:ColorEdit}}" />
                                            </MultiBinding>
                                        </dxmvvm:EventToCommand.CommandParameter>
                                    </dxmvvm:EventToCommand>
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:ColorEdit>
                        </dx:DropDownButton>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Background"
                            Header="Background"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:DropDownButton Glyph="{dx:DXImage SvgImages/Dashboards/EditColors.svg}"
                                           GlyphHeight="15">
                            <dx:DropDownButton.Style>
                                <Style TargetType="dx:DropDownButton">
                                    <Setter Property="Background" Value="{Binding ElementName=BackgroundSelector, Path=Color, Converter={StaticResource ColorToBrushConverter}}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{Binding ElementName=BackgroundSelector, Path=Color, Converter={StaticResource ColorToBrushConverter}}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </dx:DropDownButton.Style>
                            <dxe:ColorEdit x:Name="BackgroundSelector"
                                           Grid.Column="0"
                                           ChipSize="Small"
                                           ColumnCount="8"
                                           DefaultColor="Transparent"
                                           ShowNoColorButton="False"
                                           Color="{Binding RowData, Converter={StaticResource SelectedColorExtractor}, ConverterParameter='BG'}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding View.DataContext.BackgroundChangedCommand}"
                                                           EventName="EditValueChanged">
                                        <dxmvvm:EventToCommand.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                                                <Binding Path="RowData.Row" />
                                                <Binding Path="Color"
                                                         RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                         AncestorType={x:Type dxe:ColorEdit}}" />
                                            </MultiBinding>
                                        </dxmvvm:EventToCommand.CommandParameter>
                                    </dxmvvm:EventToCommand>
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:ColorEdit>
                        </dx:DropDownButton>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

        </dxg:GridControl>
    </Grid>
</dx:ThemedWindow>
