<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.LoopDynamicIncrementConfigView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startupHelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Dynamic Increment Settings"
                 Width="500"
                 Height="200"
                 MaxWidth="400"
                 d:DataContext="{d:DesignInstance Type=ViewModels:LoopDynamicIncrementConfigViewModel}"
                 DataContext="{startupHelpers:DISource Type=ViewModels:LoopDynamicIncrementConfigViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">
    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="2">
            <Label Width="50"
                   Margin="5,0,0,0"
                   Content="Title" />

            <dxe:TextEdit Margin="5,0,0,0"
                          Text="{Binding Title}" />
        </DockPanel>

        <DockPanel Grid.Row="1"
                   Margin="2">
            <Label Margin="5,0,0,0"
                   Content="Max % of Market Width" />

            <dxe:SpinEdit Width="70"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          HorizontalContentAlignment="Right"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding MaxPercentOfMarketWidth, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          Increment=".01"
                          Mask="N2"
                          MaskUseAsDisplayFormat="True"
                          MaxValue="1"
                          MinValue="0.15"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />
        </DockPanel>

        <dxg:GridControl Grid.Row="2"
                         AllowCollectionView="False"
                         ItemsSource="{Binding DynamicIncrementConfigs}">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="True"
                               AllowGrouping="False"
                               AllowSorting="False"
                               AutoWidth="True"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="Edge"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.Edge, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="0.01"
                                      Mask="N2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="MinTick"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <dxe:CheckEdit Margin="3,0"
                                           HorizontalAlignment="Center"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           EditValue="{Binding RowData.Row.MinTickEnabled, UpdateSourceTrigger=PropertyChanged}" />

                            <dxe:SpinEdit HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          Background="Transparent"
                                          BorderThickness="1,0,0,0"
                                          EditValue="{Binding RowData.Row.MinTick, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment=".01"
                                          IsEnabled="{Binding RowData.Row.MinTickEnabled}"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </DockPanel>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Increment"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.Increment, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".01"
                                      Mask="N2"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Default"
                            Header="Use As Fallback"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:CheckEdit HorizontalAlignment="Center"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       EditValue="{Binding RowData.Row.Default, UpdateSourceTrigger=PropertyChanged}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Width="20"
                            FieldName="Remove"
                            Header=""
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton BorderBrush="Transparent"
                                         BorderThickness="0"
                                         Command="{Binding View.DataContext.RemoveDynamicIncrementItemCommand}"
                                         CommandParameter="{Binding RowData.Row}"
                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                         GlyphWidth="19" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>
        <StackPanel Grid.Row="3"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Margin="5,0"
                             Command="{Binding AddNewDynamicIncrementConfigCommand}"
                             Content="Add"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                             GlyphHeight="15" />

            <dx:SimpleButton Margin="5,0"
                             Click="CloseWindow"
                             Command="{Binding SaveDynamicIncrementConfigCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Outlook Inspired/Save.svg}"
                             GlyphHeight="15" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
