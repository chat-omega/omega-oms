                            <dxe:ToggleSwitch Grid.Row="3"
                                              Grid.Column="1"
                                              Margin="5,2,0,0"
                                              CheckedStateContent="Yes"
                                              ContentPlacement="Inside"
                                              IsChecked="{Binding SyntheticSpreadConfig.SeparateEquityLeg}"
                                              IsEnabled="{Binding SyntheticSpreadConfig.SeparateEquityLegEnabled}"
                                              IsThreeState="True"
                                              ToggleSwitchWidth="120"
                                              UncheckedStateContent="No"
                                              UndefinedStateContent="Default" />
