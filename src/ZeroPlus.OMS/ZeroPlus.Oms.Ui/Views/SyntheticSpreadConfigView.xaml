                                              Grid.Column="1"
                                              Margin="5,2,0,0"
                                              CheckedStateContent="Yes"
                                              ContentPlacement="Inside"
                                              IsChecked="{Binding SyntheticSpreadConfig.CancelOnHalt}"
                                              IsEnabled="{Binding SyntheticSpreadConfig.CancelOnHaltEnabled}"
                                              IsThreeState="True"
                                              ToggleSwitchWidth="120"
                                              UncheckedStateContent="No"
                                              UndefinedStateContent="Default" />

                            <dxe:CheckEdit Grid.Row="3"
                                           Grid.Column="0"
                                           Margin="5,2,0,0"
                                           Content="ATS Mode"
                                           EditValue="{Binding SyntheticSpreadConfig.AtsModeEnabled}" />

                            <dxe:ToggleSwitch Grid.Row="3"
                                              Grid.Column="1"
                                              Margin="5,2,0,0"
                                              CheckedStateContent="Yes"
                                              ContentPlacement="Inside"
                                              IsChecked="{Binding SyntheticSpreadConfig.AtsMode}"
                                              IsEnabled="{Binding SyntheticSpreadConfig.AtsModeEnabled}"
                                              IsThreeState="True"
                                              ToggleSwitchWidth="120"
                                              UncheckedStateContent="No"
                                              UndefinedStateContent="Default" />

                            <dxe:CheckEdit Grid.Row="4"
                                           Grid.Column="0"
                                           Margin="5,2,0,0"
                                           Content="Fee Optimal"
                                           EditValue="{Binding SyntheticSpreadConfig.SynthFeeOptimalEnabled}" />

                            <dxe:ToggleSwitch Grid.Row="4"
                                              Grid.Column="1"
                                              Margin="5,2,0,0"
                                              CheckedStateContent="Yes"
                                              ContentPlacement="Inside"
                                              IsChecked="{Binding SyntheticSpreadConfig.SynthFeeOptimal}"
                                              IsEnabled="{Binding SyntheticSpreadConfig.SynthFeeOptimalEnabled}"
                                              IsThreeState="True"
                                              ToggleSwitchWidth="120"
                                              UncheckedStateContent="No"
                                              UndefinedStateContent="Default" />

                            <dxe:CheckEdit Grid.Row="5"
                                           Grid.Column="0"
                                           Margin="5,2,0,0"
                                           Content="Take Only"
                                           EditValue="{Binding SyntheticSpreadConfig.TakeOnlyEnabled}" />

                            <dxe:ToggleSwitch Grid.Row="5"
                                              Grid.Column="1"
                                              Margin="5,2,0,0"
                                              CheckedStateContent="Yes"
                                              ContentPlacement="Inside"
                                              IsChecked="{Binding SyntheticSpreadConfig.TakeOnly}"
                                              IsEnabled="{Binding SyntheticSpreadConfig.TakeOnlyEnabled}"
                                              IsThreeState="True"
                                              ToggleSwitchWidth="120"
                                              UncheckedStateContent="No"
                                              UndefinedStateContent="Default" />
                        </Grid>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="0"
                                           Margin="5,2,0,0"
                                           Content="Passive Mode"
                                           EditValue="{Binding SyntheticSpreadConfig.PassiveModeEnabled}" />

                            <dxe:ComboBoxEdit Grid.Row="0"
                                              Grid.Column="1"
                                              Width="120"
                                              Margin="5,2,0,0"
                                              HorizontalAlignment="Left"
                                              EditValue="{Binding SyntheticSpreadConfig.PassiveMode, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding SyntheticSpreadConfig.PassiveModeEnabled}"
                                              IsSynchronizedWithCurrentItem="True"
                                              IsTextEditable="False"
                                              ItemsSource="{Binding Algorithms}" />

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="5,2,0,0"
                                           Content="Passive Cancel Delay (ms)"
                                           EditValue="{Binding SyntheticSpreadConfig.PassiveModeCancelDelayEnabled}" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="5,2,0,0"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding SyntheticSpreadConfig.PassiveModeCancelDelay, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:UInt32}"
                                          IsEnabled="{Binding SyntheticSpreadConfig.PassiveModeCancelDelayEnabled}"
                                          PreviewMouseUp="EditBox_PreviewMouseUp"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:CheckEdit Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="5,2,0,0"
                                           Content="Number of Tries"
                                           EditValue="{Binding SyntheticSpreadConfig.NumOfTriesEnabled}" />

                            <dxe:SpinEdit Grid.Row="2"
                                          Grid.Column="1"
                                          Margin="5,2,0,0"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding SyntheticSpreadConfig.NumOfTries, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:UInt32}"
                                          IsEnabled="{Binding SyntheticSpreadConfig.NumOfTriesEnabled}"
                                          PreviewMouseUp="EditBox_PreviewMouseUp"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:CheckEdit Grid.Row="3"
                                           Grid.Column="0"
                                           Margin="5,2,0,0"
                                           Content="Separate Equity Leg"
