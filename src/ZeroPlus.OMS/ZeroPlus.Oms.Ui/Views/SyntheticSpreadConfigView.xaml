<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.SyntheticSpreadConfigView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startupHelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Synthetic Spread Config"
                 Width="700"
                 Height="600"
                 d:DataContext="{d:DesignInstance Type=ViewModels:SyntheticSpreadConfigViewModel}"
                 DataContext="{startupHelpers:DISource Type=ViewModels:SyntheticSpreadConfigViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dx:ThemedWindow.Resources>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToButtonTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                5
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                6
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
    </dx:ThemedWindow.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,2">
            <Label Width="50"
                   Margin="5,0,0,0"
                   Content="Title" />

            <dxe:TextEdit Margin="5,0,0,0"
                          Text="{Binding Title}" />
        </DockPanel>
        <dx:DXTabControl Grid.Row="1">
            <dx:DXTabControl.View>
                <dx:TabControlScrollView HeaderOrientation="Horizontal"
                                         ShowHeaderMenu="False" />
            </dx:DXTabControl.View>
            <dx:DXTabItem Header="Scrape">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Height="200"
                          Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <dxg:GridControl Grid.Row="0"
                                         Margin="-1,-1,-1,0"
                                         AllowCollectionView="False"
                                         ItemsSource="{Binding ScrapeConfig.Exchanges}">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowDragDrop="True"
                                               AllowEditing="True"
                                               AllowGrouping="False"
                                               AllowSorting="False"
                                               AutoWidth="True"
                                               ShowDragDropHint="False"
                                               ShowGroupPanel="False"
                                               VerticalScrollbarVisibility="Auto">
                                    <dxg:TableView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowColumnChooserCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Column Chooser">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ClearColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Hide All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowAllColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Default Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </dxg:TableView.ContextMenu>
                                </dxg:TableView>
                            </dxg:GridControl.View>

                            <dxg:GridColumn FieldName="Name"
                                            Header="Exchanges"
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True" />

                            <dxg:GridColumn Width="20"
                                            FieldName="Remove"
                                            Header=""
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dx:SimpleButton Margin="-1"
                                                         Command="{Binding View.DataContext.RemoveScrapeExchangeCommand}"
                                                         CommandParameter="{Binding RowData.Row}"
                                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                         GlyphWidth="19" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl>

                        <dx:SimpleButton Grid.Row="1"
                                         Command="{Binding AddScrapeExchangeCommand}"
                                         Content="Add"
                                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                                         GlyphHeight="15" />
                    </Grid>
                    <Grid Grid.Row="0"
                          Grid.Column="1"
                          Height="200"
                          Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <dxg:GridControl Grid.Row="0"
                                         Margin="-1,-1,-1,0"
                                         AllowCollectionView="False"
                                         ItemsSource="{Binding ScrapeConfig.ExchangesTake}">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowDragDrop="True"
                                               AllowEditing="True"
                                               AllowGrouping="False"
                                               AllowSorting="False"
                                               AutoWidth="True"
                                               ShowDragDropHint="False"
                                               ShowGroupPanel="False"
                                               VerticalScrollbarVisibility="Auto">
                                    <dxg:TableView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowColumnChooserCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Column Chooser">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ClearColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Hide All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowAllColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Default Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </dxg:TableView.ContextMenu>
                                </dxg:TableView>
                            </dxg:GridControl.View>

                            <dxg:GridColumn FieldName="Name"
                                            Header="Exchanges Take"
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True" />

                            <dxg:GridColumn Width="20"
                                            FieldName="Remove"
                                            Header=""
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dx:SimpleButton Margin="-1"
                                                         Command="{Binding View.DataContext.RemoveScrapeExchangeTakeCommand}"
                                                         CommandParameter="{Binding RowData.Row}"
                                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                         GlyphWidth="19" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl>

                        <dx:SimpleButton Grid.Row="1"
                                         Command="{Binding AddScrapeExchangeTakeCommand}"
                                         Content="Add"
                                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                                         GlyphHeight="15" />
                    </Grid>
                    <Grid Grid.Row="1"
                          Grid.Column="0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <dxe:CheckEdit Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Make Take"
                                       EditValue="{Binding ScrapeConfig.MakeTakeEnabled}" />

                        <dxe:ComboBoxEdit Grid.Row="0"
                                          Grid.Column="1"
                                          Width="120"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          EditValue="{Binding ScrapeConfig.MakeTake, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding ScrapeConfig.MakeTakeEnabled}"
                                          IsSynchronizedWithCurrentItem="True"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding MakeTakeOptions}" />

                        <dxe:CheckEdit Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="EXT Hours"
                                       EditValue="{Binding ScrapeConfig.ExtTradingHoursEnabled}" />

                        <dxe:ToggleSwitch Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="5,2,0,0"
                                          CheckedStateContent="Yes"
                                          ContentPlacement="Inside"
                                          IsChecked="{Binding ScrapeConfig.ExtTradingHours}"
                                          IsEnabled="{Binding ScrapeConfig.ExtTradingHoursEnabled}"
                                          IsThreeState="True"
                                          ToggleSwitchWidth="120"
                                          UncheckedStateContent="No"
                                          UndefinedStateContent="Default" />

                        <dxe:CheckEdit Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Limit To Mkt Time"
                                       EditValue="{Binding ScrapeConfig.LimitToMarketTimeEnabled}" />

                        <dxe:TextEdit Grid.Row="2"
                                      Grid.Column="1"
                                      Margin="5,2,0,0"
                                      HorizontalContentAlignment="Center"
                                      EditValue="{Binding ScrapeConfig.LimitToMarketTime}"
                                      IsEnabled="{Binding ScrapeConfig.LimitToMarketTimeEnabled}"
                                      Mask="G"
                                      MaskType="DateTimeAdvancingCaret"
                                      MaskUseAsDisplayFormat="True" />

                        <dxe:CheckEdit Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Working Qty"
                                       EditValue="{Binding ScrapeConfig.WorkingQtyEnabled}" />

                        <StackPanel Grid.Row="4"
                                    Grid.Column="1"
                                    Margin="5,2,0,0"
                                    IsEnabled="{Binding ScrapeConfig.WorkingQtyEnabled}"
                                    Orientation="Horizontal">

                            <dxe:SpinEdit Width="55"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding ScrapeConfig.MinWorkingQty, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:UInt32}"
                                          PreviewMouseUp="EditBox_PreviewMouseUp"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <TextBlock Width="8"
                                       Margin="1,2"
                                       HorizontalAlignment="Center"
                                       Text="-"
                                       TextAlignment="Center" />

                            <dxe:SpinEdit Width="55"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding ScrapeConfig.WorkingQty, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:UInt32}"
                                          PreviewMouseUp="EditBox_PreviewMouseUp"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </StackPanel>

                    </Grid>
                    <Grid Grid.Row="1"
                          Grid.Column="1">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                    </Grid>
                </Grid>
            </dx:DXTabItem>
            <dx:DXTabItem Header="Seeker">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Height="200"
                          Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <dxg:GridControl Grid.Row="0"
                                         Margin="-1,-1,-1,0"
                                         AllowCollectionView="False"
                                         ItemsSource="{Binding SeekerConfig.Exchanges}">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowDragDrop="True"
                                               AllowEditing="True"
                                               AllowGrouping="False"
                                               AllowSorting="False"
                                               AutoWidth="True"
                                               ShowDragDropHint="False"
                                               ShowGroupPanel="False"
                                               VerticalScrollbarVisibility="Auto">
                                    <dxg:TableView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowColumnChooserCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Column Chooser">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ClearColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Hide All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowAllColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Default Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </dxg:TableView.ContextMenu>
                                </dxg:TableView>
                            </dxg:GridControl.View>

                            <dxg:GridColumn FieldName="Name"
                                            Header="Exchanges"
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True" />

                            <dxg:GridColumn Width="20"
                                            FieldName="Remove"
                                            Header=""
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dx:SimpleButton Margin="-1"
                                                         Command="{Binding View.DataContext.RemoveSeekerExchangeCommand}"
                                                         CommandParameter="{Binding RowData.Row}"
                                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                         GlyphWidth="19" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl>

                        <dx:SimpleButton Grid.Row="1"
                                         Command="{Binding AddSeekerExchangeCommand}"
                                         Content="Add"
                                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                                         GlyphHeight="15" />
                    </Grid>
                    <Grid Grid.Row="0"
                          Grid.Column="1"
                          Height="200"
                          Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <dxg:GridControl Grid.Row="0"
                                         Margin="-1,-1,-1,0"
                                         AllowCollectionView="False"
                                         ItemsSource="{Binding SeekerConfig.ExchangesTake}">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowDragDrop="True"
                                               AllowEditing="True"
                                               AllowGrouping="False"
                                               AllowSorting="False"
                                               AutoWidth="True"
                                               ShowDragDropHint="False"
                                               ShowGroupPanel="False"
                                               VerticalScrollbarVisibility="Auto">
                                    <dxg:TableView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowColumnChooserCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Column Chooser">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ClearColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Hide All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowAllColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Default Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </dxg:TableView.ContextMenu>
                                </dxg:TableView>
                            </dxg:GridControl.View>

                            <dxg:GridColumn FieldName="Name"
                                            Header="Exchanges Take"
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True" />

                            <dxg:GridColumn Width="20"
                                            FieldName="Remove"
                                            Header=""
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dx:SimpleButton Margin="-1"
                                                         Command="{Binding View.DataContext.RemoveSeekerExchangeTakeCommand}"
                                                         CommandParameter="{Binding RowData.Row}"
                                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                         GlyphWidth="19" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl>

                        <dx:SimpleButton Grid.Row="1"
                                         Command="{Binding AddSeekerExchangeTakeCommand}"
                                         Content="Add"
                                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                                         GlyphHeight="15" />
                    </Grid>
                    <Grid Grid.Row="1"
                          Grid.Column="0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <dxe:CheckEdit Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Make Take"
                                       EditValue="{Binding SeekerConfig.MakeTakeEnabled}" />

                        <dxe:ComboBoxEdit Grid.Row="0"
                                          Grid.Column="1"
                                          Width="120"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          EditValue="{Binding SeekerConfig.MakeTake, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding SeekerConfig.MakeTakeEnabled}"
                                          IsSynchronizedWithCurrentItem="True"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding MakeTakeOptions}" />


                        <dxe:CheckEdit Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Working Qty"
                                       EditValue="{Binding SeekerConfig.WorkingQtyEnabled}" />

                        <StackPanel Grid.Row="4"
                                    Grid.Column="1"
                                    Margin="5,2,0,0"
                                    IsEnabled="{Binding SeekerConfig.WorkingQtyEnabled}"
                                    Orientation="Horizontal">

                            <dxe:SpinEdit Width="55"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding SeekerConfig.MinWorkingQty, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:UInt32}"
                                          PreviewMouseUp="EditBox_PreviewMouseUp"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <TextBlock Width="8"
                                       Margin="1,2"
                                       HorizontalAlignment="Center"
                                       Text="-"
                                       TextAlignment="Center" />

                            <dxe:SpinEdit Width="55"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding SeekerConfig.WorkingQty, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:UInt32}"
                                          PreviewMouseUp="EditBox_PreviewMouseUp"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </StackPanel>

                    </Grid>
                    <Grid Grid.Row="1"
                          Grid.Column="1">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                    </Grid>
                </Grid>
            </dx:DXTabItem>
            <dx:DXTabItem Header="Synthetic Spread">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Height="200"
                          Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <dxg:GridControl Grid.Row="0"
                                         Margin="-1,-1,-1,0"
                                         AllowCollectionView="False"
                                         ItemsSource="{Binding SyntheticSpreadConfig.Exchanges}">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowDragDrop="True"
                                               AllowEditing="True"
                                               AllowGrouping="False"
                                               AllowSorting="False"
                                               AutoWidth="True"
                                               ShowDragDropHint="False"
                                               ShowGroupPanel="False"
                                               VerticalScrollbarVisibility="Auto">
                                    <dxg:TableView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowColumnChooserCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Column Chooser">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ClearColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Hide All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowAllColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Default Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </dxg:TableView.ContextMenu>
                                </dxg:TableView>
                            </dxg:GridControl.View>

                            <dxg:GridColumn FieldName="Name"
                                            Header="Exchanges"
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True" />

                            <dxg:GridColumn Width="20"
                                            FieldName="Remove"
                                            Header=""
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dx:SimpleButton Margin="-1"
                                                         Command="{Binding View.DataContext.RemoveExchangeCommand}"
                                                         CommandParameter="{Binding RowData.Row}"
                                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                         GlyphWidth="19" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl>

                        <dx:SimpleButton Grid.Row="1"
                                         Command="{Binding AddExchangeCommand}"
                                         Content="Add"
                                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                                         GlyphHeight="15" />
                    </Grid>
                    <Grid Grid.Row="0"
                          Grid.Column="1"
                          Height="200"
                          Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <dxg:GridControl Grid.Row="0"
                                         Margin="-1,-1,-1,0"
                                         AllowCollectionView="False"
                                         ItemsSource="{Binding SyntheticSpreadConfig.ExchangesTake}">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowDragDrop="True"
                                               AllowEditing="True"
                                               AllowGrouping="False"
                                               AllowSorting="False"
                                               AutoWidth="True"
                                               ShowDragDropHint="False"
                                               ShowGroupPanel="False"
                                               VerticalScrollbarVisibility="Auto">
                                    <dxg:TableView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowColumnChooserCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Column Chooser">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ClearColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Hide All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowAllColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Default Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </dxg:TableView.ContextMenu>
                                </dxg:TableView>
                            </dxg:GridControl.View>

                            <dxg:GridColumn FieldName="Name"
