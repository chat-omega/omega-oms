                            <dxg:GridColumn Width="20"
                                            FieldName="Remove"
                                            Header=""
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dx:SimpleButton Margin="-1"
                                                         Command="{Binding View.DataContext.RemoveExchangeTakeCommand}"
                                                         CommandParameter="{Binding RowData.Row}"
                                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                         GlyphWidth="19" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl>

                        <dx:SimpleButton Grid.Row="1"
                                         Command="{Binding AddExchangeTakeCommand}"
                                         Content="Add"
                                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                                         GlyphHeight="15" />
                    </Grid>
                    <Grid Grid.Row="1"
                          Grid.Column="0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <dxe:CheckEdit Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Make Take"
                                       EditValue="{Binding SyntheticSpreadConfig.MakeTakeEnabled}" />

                        <dxe:ComboBoxEdit Grid.Row="0"
                                          Grid.Column="1"
                                          Width="120"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          EditValue="{Binding SyntheticSpreadConfig.MakeTake, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding SyntheticSpreadConfig.MakeTakeEnabled}"
                                          IsSynchronizedWithCurrentItem="True"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding MakeTakeOptions}" />

                        <dxe:CheckEdit Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Price Discretion"
                                       EditValue="{Binding SyntheticSpreadConfig.SpreadPriceDiscretionEnabled}" />

                        <dxe:ToggleSwitch Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="5,2,0,0"
                                          CheckedStateContent="Yes"
                                          ContentPlacement="Inside"
                                          IsChecked="{Binding SyntheticSpreadConfig.SpreadPriceDiscretion}"
                                          IsEnabled="{Binding SyntheticSpreadConfig.SpreadPriceDiscretionEnabled}"
                                          IsThreeState="True"
                                          ToggleSwitchWidth="120"
                                          UncheckedStateContent="No"
                                          UndefinedStateContent="Default" />

                        <dxe:CheckEdit Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Min Quote Qty"
                                       EditValue="{Binding SyntheticSpreadConfig.MinQuoteQtyEnabled}"
                                       IsEnabled="False" />

                        <dxe:SpinEdit Grid.Row="2"
                                      Grid.Column="1"
                                      Margin="5,2,0,0"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      EditValue="{Binding SyntheticSpreadConfig.MinQuoteQty, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:UInt32}"
                                      IsEnabled="{Binding SyntheticSpreadConfig.MinQuoteQtyEnabled}"
                                      PreviewMouseUp="EditBox_PreviewMouseUp"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />

                        <dxe:CheckEdit Grid.Row="3"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Take Hidden"
                                       EditValue="{Binding SyntheticSpreadConfig.TakeHiddenEnabled}"
                                       IsEnabled="False" />

                        <dxe:ToggleSwitch Grid.Row="3"
                                          Grid.Column="1"
                                          Margin="5,2,0,0"
                                          CheckedStateContent="Yes"
                                          ContentPlacement="Inside"
                                          IsChecked="{Binding SyntheticSpreadConfig.TakeHidden}"
                                          IsEnabled="{Binding SyntheticSpreadConfig.TakeHiddenEnabled}"
                                          IsThreeState="True"
                                          ToggleSwitchWidth="120"
                                          UncheckedStateContent="No"
                                          UndefinedStateContent="Default" />

                    </Grid>
                    <Grid Grid.Row="1"
                          Grid.Column="1">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <dxe:CheckEdit Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Bad Ratio Timeout"
                                       EditValue="{Binding SyntheticSpreadConfig.BadRatioTimeoutEnabled}" />

                        <dxe:SpinEdit Grid.Row="0"
                                      Grid.Column="1"
                                      Margin="5,2,0,0"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      EditValue="{Binding SyntheticSpreadConfig.BadRatioTimeout, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".01"
                                      IsEnabled="{Binding SyntheticSpreadConfig.BadRatioTimeoutEnabled}"
                                      Mask="N2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="EditBox_PreviewMouseUp"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />

                        <dxe:CheckEdit Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Bad Ratio Price Discretion"
                                       EditValue="{Binding SyntheticSpreadConfig.BadRatioPriceDiscretionEnabled}" />

                        <dxe:SpinEdit Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="5,2,0,0"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      EditValue="{Binding SyntheticSpreadConfig.BadRatioPriceDiscretion, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".01"
                                      IsEnabled="{Binding SyntheticSpreadConfig.BadRatioPriceDiscretionEnabled}"
                                      Mask="N2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="EditBox_PreviewMouseUp"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />

                        <dxe:CheckEdit Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Bad Ratio Try Threshold"
                                       EditValue="{Binding SyntheticSpreadConfig.BadRatioTryThresholdEnabled}" />

                        <dxe:SpinEdit Grid.Row="2"
                                      Grid.Column="1"
                                      Margin="5,2,0,0"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      EditValue="{Binding SyntheticSpreadConfig.BadRatioTryThreshold, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:UInt32}"
                                      IsEnabled="{Binding SyntheticSpreadConfig.BadRatioTryThresholdEnabled}"
                                      PreviewMouseUp="EditBox_PreviewMouseUp"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />

                        <dxe:CheckEdit Grid.Row="3"
                                       Grid.Column="0"
                                       Margin="5,2,0,0"
                                       Content="Working Qty"
                                       EditValue="{Binding SyntheticSpreadConfig.WorkingQtyEnabled}" />

                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="5,2,0,0"
                                    IsEnabled="{Binding SyntheticSpreadConfig.WorkingQtyEnabled}"
                                    Orientation="Horizontal">
                            <dxe:SpinEdit Width="55"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding SyntheticSpreadConfig.MinWorkingQty, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:UInt32}"
                                          PreviewMouseUp="EditBox_PreviewMouseUp"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <TextBlock Width="8"
                                       Margin="1,2"
                                       HorizontalAlignment="Center"
                                       Text="-"
                                       TextAlignment="Center" />

                            <dxe:SpinEdit Width="55"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding SyntheticSpreadConfig.WorkingQty, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:UInt32}"
                                          PreviewMouseUp="EditBox_PreviewMouseUp"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </StackPanel>

                    </Grid>
                    <dx:SimpleButton Grid.Row="2"
                                     Grid.Column="0"
                                     Grid.ColumnSpan="2"
                                     Width="100"
                                     Height="10"
                                     Margin="0,3"
                                     Padding="0,-1,0,0"
                                     HorizontalAlignment="Center"
                                     ButtonKind="Toggle"
                                     Content="{Binding SyntheticSpreadConfig.ShowAdvancedConfigsPanel, Converter={StaticResource BooleanToButtonTextConverter}}"
                                     CornerRadius="3"
                                     FontFamily="Marlett"
                                     FontSize="10"
                                     IsChecked="{Binding SyntheticSpreadConfig.ShowAdvancedConfigsPanel}" />
                    <Grid Grid.Row="3"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          Visibility="{Binding SyntheticSpreadConfig.ShowAdvancedConfigsPanel, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="auto" />
