                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="0"
                                           Margin="5,2,0,0"
                                           Content="Legging Only"
                                           EditValue="{Binding SyntheticSpreadConfig.LeggingOnlyEnabled}" />

                            <dxe:ToggleSwitch Grid.Row="0"
                                              Grid.Column="1"
                                              Margin="5,2,0,0"
                                              CheckedStateContent="Yes"
                                              ContentPlacement="Inside"
                                              IsChecked="{Binding SyntheticSpreadConfig.LeggingOnly}"
                                              IsEnabled="{Binding SyntheticSpreadConfig.LeggingOnlyEnabled}"
                                              IsThreeState="True"
                                              ToggleSwitchWidth="120"
                                              UncheckedStateContent="No"
                                              UndefinedStateContent="Default" />

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="5,2,0,0"
                                           Content="EXT Hours"
                                           EditValue="{Binding SyntheticSpreadConfig.ExtTradingHoursEnabled}" />

                            <dxe:ToggleSwitch Grid.Row="1"
                                              Grid.Column="1"
                                              Margin="5,2,0,0"
                                              CheckedStateContent="Yes"
                                              ContentPlacement="Inside"
                                              IsChecked="{Binding SyntheticSpreadConfig.ExtTradingHours}"
                                              IsEnabled="{Binding SyntheticSpreadConfig.ExtTradingHoursEnabled}"
                                              IsThreeState="True"
                                              ToggleSwitchWidth="120"
                                              UncheckedStateContent="No"
                                              UndefinedStateContent="Default" />

