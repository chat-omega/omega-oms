<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.PnlReportView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="{Binding ModuleTitle}"
                 Width="500"
                 Height="250"
                 DataContext="{startuphelpers:DISource Type=ViewModels:PnlReportViewModel}"
                 WindowStartupLocation="CenterScreen">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:SaveFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Content="Date Range" />
        <StackPanel Grid.Row="1"
                    Grid.Column="2"
                    Margin="5,0,0,0"
                    Orientation="Horizontal">
            <dxe:TextEdit Width="190"
                          HorizontalContentAlignment="Center"
                          EditValue="{Binding StartDateTime}"
                          Mask="G"
                          MaskType="DateTimeAdvancingCaret"
                          MaskUseAsDisplayFormat="True" />

            <Label Margin="10,0"
                   VerticalAlignment="Center"
                   Content="-" />

            <dxe:TextEdit Width="190"
                          HorizontalContentAlignment="Center"
                          EditValue="{Binding EndDateTime}"
                          Mask="G"
                          MaskType="DateTimeAdvancingCaret"
                          MaskUseAsDisplayFormat="True" />

        </StackPanel>
        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="API Usernames" />

        <dxe:TextEdit Grid.Row="2"
                      Grid.Column="2"
                      Width="405"
                      Margin="5,5,0,0"
                      HorizontalAlignment="Left"
                      EditValue="{Binding ApiUsernames}" />

        <Label Grid.Row="3"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Tags" />

        <dxe:TextEdit Grid.Row="3"
                      Grid.Column="2"
                      Width="405"
                      Margin="5,5,0,0"
                      HorizontalAlignment="Left"
                      EditValue="{Binding Tags}" />

        <Label Grid.Row="4"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Symbols" />

        <dxe:TextEdit Grid.Row="4"
                      Grid.Column="2"
                      Width="405"
                      Margin="5,5,0,0"
                      HorizontalAlignment="Left"
                      EditValue="{Binding Symbols}" />

        <Label Grid.Row="5"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Underlyings" />

        <dxe:TextEdit Grid.Row="5"
                      Grid.Column="2"
                      Width="405"
                      Margin="5,5,0,0"
                      HorizontalAlignment="Left"
                      EditValue="{Binding Underlyings}" />

        <Label Grid.Row="6"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Report Format" />

        <dxe:ComboBoxEdit Grid.Row="6"
                          Grid.Column="2"
                          Width="405"
                          Margin="5,5,0,0"
                          HorizontalAlignment="Left"
                          HorizontalContentAlignment="Center"
                          EditValue="{Binding Format}"
                          IsTextEditable="False">
            <dxe:ComboBoxEditItem Content="HTML" />
            <dxe:ComboBoxEditItem Content="EXCEL"
                                  IsEnabled="False" />
        </dxe:ComboBoxEdit>

        <dx:SimpleButton Grid.Row="8"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         HorizontalAlignment="Center"
                         Command="{Binding RequestCommand}"
                         Content="Request" />
    </Grid>
</dx:ThemedWindow>
