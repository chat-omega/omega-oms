<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.ShareWithView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="{Binding ModuleTitle}"
                 Width="570"
                 Height="355"
                 DataContext="{startuphelpers:DISource Type=ViewModels:ShareWithViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
        <dxmvvm:DispatcherService />
    </dxmvvm:Interaction.Behaviors>

    <Window.Resources>
        <Style TargetType="dxg:GridCardHeaderControl">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #587C8D
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <dxg:GridControl Grid.Row="1"
                         Grid.Column="1"
                         AutoPopulateColumns="True"
                         ItemsSource="{Binding Users}">
            <dxg:GridControl.View>
                <dxg:CardView Margin="0"
                              Padding="0"
                              CardLayout="Rows"
                              ShowGroupPanel="False">
                    <dxg:CardView.CardTemplate>
                        <DataTemplate>
                            <dx:SimpleButton Width="80"
                                             Height="80"
                                             Margin="0"
                                             Padding="0"
                                             Background="{Binding Row.IsSelected, Converter={StaticResource BooleanToColorConverter}}"
                                             ButtonKind="Toggle"
                                             IsChecked="{Binding Row.IsSelected}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Row="0"
                                           Width="50"
                                           Height="50"
                                           Source="{dx:DXImage SvgImages/Icon Builder/Actions_User.svg}" />
                                    <TextBlock Grid.Row="1"
                                               Margin="0,5,0,0"
                                               HorizontalAlignment="Center"
                                               Text="{Binding Row.Username}" />

                                    <dx:DXImage Grid.Row="1"
                                                Width="15"
                                                Height="15"
                                                Margin="56,0,0,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Source="{dx:DXImage SvgImages/Icon Builder/Actions_CheckCircled.svg}"
                                                ToolTip="Online"
                                                Visibility="{Binding Row.IsOnline, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <dx:DXImage Grid.Row="1"
                                                Width="13"
                                                Height="13"
                                                Margin="56,0,0,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Source="{dx:DXImage SvgImages/Icon Builder/Security_WarningCircled1.svg}"
                                                ToolTip="Offline"
                                                Visibility="{Binding Row.IsOnline, Converter={StaticResource BooleanToVisibilityInverseConverter}}" />

                                </Grid>
                            </dx:SimpleButton>
                        </DataTemplate>
                    </dxg:CardView.CardTemplate>
                </dxg:CardView>
            </dxg:GridControl.View>
        </dxg:GridControl>

        <DockPanel Grid.Row="2"
                   Grid.Column="1"
                   Margin="0,5">
            <Label Content="Message:" />
            <dxe:TextEdit Margin="5,0,0,0"
                          EditValue="{Binding Message, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <StackPanel Grid.Row="3"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding ShareCommand}"
                             Content="Share"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}"
                             GlyphHeight="15"
                             IsDefault="True" />

            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
