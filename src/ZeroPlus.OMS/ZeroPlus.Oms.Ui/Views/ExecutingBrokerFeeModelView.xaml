<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.ExecutingBrokerFeeModelView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="{Binding Model.BrokerName, StringFormat='{}{0} Routes And Fees'}"
                 Width="510"
                 Height="250"
                 MinWidth="500"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:ExecutingBrokerFeeModelViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:ExecutingBrokerFeeModelViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal">
            <Label Content="Exec Fee" />
            <dxe:TextEdit Width="70"
                          Margin="4,0,0,0"
                          HorizontalContentAlignment="Right"
                          EditValue="{Binding Model.ExecutionFee}"
                          IsReadOnly="True"
                          Mask="N2"
                          MaskUseAsDisplayFormat="True" />
            <Label Margin="15,0,0,0"
                   Content="Algo Exec Fee" />
            <dxe:TextEdit Width="70"
                          Margin="4,0,0,0"
                          HorizontalContentAlignment="Right"
                          EditValue="{Binding Model.AlgoExecutionFee}"
                          IsReadOnly="True"
                          Mask="N2"
                          MaskUseAsDisplayFormat="True" />
            <Label Margin="15,0,0,0"
                   Content="Default Exchange Fee" />
            <dxe:TextEdit Width="70"
                          Margin="4,0,0,0"
                          HorizontalContentAlignment="Right"
                          EditValue="{Binding Model.DefaultExchangeFee}"
                          IsReadOnly="True"
                          Mask="N2"
                          MaskUseAsDisplayFormat="True" />
        </StackPanel>

        <dxg:GridControl Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,5,0,0"
                         AllowCollectionView="False"
                         ItemsSource="{Binding Model.RouteModels}">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="RoutesTable"
                               AllowDragDrop="False"
                               AllowEditing="False"
                               AllowGrouping="False"
                               AllowSorting="False"
                               AutoWidth="True"
                               ShowDragDropHint="False"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="Route"
                            Header="All Routes"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True" />
        </dxg:GridControl>

        <dxg:GridControl Grid.Row="2"
                         Grid.Column="2"
                         Margin="0,5,0,0"
                         AllowCollectionView="False"
                         ItemsSource="{Binding Model.AlgoRouteModels}">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="AlgoRoutesTable"
                               AllowDragDrop="False"
                               AllowEditing="False"
                               AllowGrouping="False"
                               AllowSorting="False"
                               AutoWidth="True"
                               ShowDragDropHint="False"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="Route"
                            Header="Algo Routes"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True" />
        </dxg:GridControl>
    </Grid>
</dx:ThemedWindow>
