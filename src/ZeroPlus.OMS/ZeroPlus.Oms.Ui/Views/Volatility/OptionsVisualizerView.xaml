<UserControl x:Class="ZeroPlus.Oms.Ui.Views.Volatility.OptionsVisualizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:ZeroPlus.Oms.Ui.Models.Volatility"
             xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
             xmlns:sys="clr-namespace:System.Windows.Media;assembly=PresentationCore"
             xmlns:vm="clr-namespace:ZeroPlus.Oms.Ui.ViewModels.Volatility"
             d:DataContext="{d:DesignInstance Type=vm:OptionsVisualizerViewModel}"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             mc:Ignorable="d">

    <UserControl.Resources>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helper:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,5" />
        </Style>
    </UserControl.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Controls Panel  -->
        <Border Grid.Column="0"
                Padding="15"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Title  -->
                    <RowDefinition Height="Auto" />
                    <!--  Global Params  -->
                    <RowDefinition Height="Auto" />
                    <!--  Time Slider  -->
                    <RowDefinition Height="*" />
                    <!--  Legs Grid  -->
                    <RowDefinition Height="Auto" />
                    <!--  Buttons  -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="0,0,0,20"
                           FontSize="16"
                           FontWeight="Bold"
                           Text="OPTIONS STRATEGY CONTROLS" />

                <!--  Global Parameters  -->
                <GroupBox Grid.Row="1"
                          Margin="0,0,0,15"
                          Padding="5"
                          Header="Global Market">
                    <StackPanel>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Text="Underlying" />
                            <TextBox Grid.Column="1"
                                     Width="80"
                                     CharacterCasing="Upper"
                                     IsReadOnly="True"
                                     Text="{Binding UnderlyingSymbol, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Reference Price" />
                            <TextBox Grid.Column="1"
                                     Width="60"
                                     Text="{Binding ReferencePrice, UpdateSourceTrigger=PropertyChanged}"
                                     TextAlignment="Right" />
                        </Grid>

                        <TextBlock Margin="0,10,0,0"
                                   Text="Implied Volatility (%)" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <Slider VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True"
                                    Maximum="1.0"
                                    Minimum="0.05"
                                    TickFrequency="0.01"
                                    TickPlacement="BottomRight"
                                    Value="{Binding ImpliedVolatility, Delay=100}" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Text="{Binding ImpliedVolatility, StringFormat=P1}"
                                       TextAlignment="Right" />
                        </Grid>

                        <TextBlock Margin="0,10,0,0"
                                   Text="Risk-Free Rate (%)" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <Slider VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True"
                                    Maximum="0.10"
                                    Minimum="0"
                                    TickFrequency="0.001"
                                    TickPlacement="BottomRight"
                                    Value="{Binding RiskFreeRate, Delay=100}" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Text="{Binding RiskFreeRate, StringFormat=P2}"
                                       TextAlignment="Right" />
                        </Grid>

                        <TextBlock Margin="0,10,0,0"
                                   Text="Borrow Rate (%)" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <Slider VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True"
                                    Maximum="0.10"
                                    Minimum="0"
                                    TickFrequency="0.001"
                                    TickPlacement="BottomRight"
                                    Value="{Binding BorrowRate, Delay=100}" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Text="{Binding BorrowRate, StringFormat=P2}"
                                       TextAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!--  Evaluation Time Slider  -->
                <GroupBox Grid.Row="2"
                          Margin="0,0,0,15"
                          Padding="5"
                          Header="Evaluation Time">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Date to Evaluate" />
                            <TextBlock Grid.Column="1"
                                       FontWeight="Bold"
                                       Text="{Binding EvaluationDate, StringFormat=d}" />
                        </Grid>
                        <dxe:TrackBarEdit Margin="0,5"
                                          LargeStep="7"
                                          Maximum="{Binding MaxEvaluationDateOADate}"
                                          Minimum="{Binding MinEvaluationDateOADate}"
                                          SmallStep="1"
                                          TickPlacement="None"
                                          Value="{Binding EvaluationDateOADate, Mode=TwoWay}" />
                    </StackPanel>
                </GroupBox>

                <!--  Legs Grid  -->
                <GroupBox Grid.Row="3"
                          Margin="0,0,0,15"
                          Padding="5"
                          Header="Strategy Legs">
                    <dxg:GridControl EnableSmartColumnsGeneration="True"
                                     ItemsSource="{Binding Legs}">
                        <dxg:GridControl.View>
                            <dxg:TableView AllowEditing="True"
                                           AutoWidth="True"
                                           EnableImmediatePosting="True"
                                           NewItemRowPosition="Bottom"
                                           ShowGroupPanel="False"
                                           ShowTotalSummary="False">
                                <dxg:TableView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowColumnChooserCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show Column Chooser">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ClearColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Hide All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowAllColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowDefaultColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show Default Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </dxg:TableView.ContextMenu>
                            </dxg:TableView>
                        </dxg:GridControl.View>

                        <dxg:GridColumn Width="25"
                                        AllowEditing="False"
                                        FieldName="IsValid"
                                        Header=""
                                        ReadOnly="True">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <Viewbox Width="16"
                                             Height="16"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding RowData.Row.IsValid, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}">
                                        <Path Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z"
                                              Fill="Orange"
                                              Stretch="Uniform"
                                              ToolTip="Option contract not found in exchange chain" />
                                    </Viewbox>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="Side"
                                        Header="Side">
                            <dxg:GridColumn.CellEditTemplate>
                                <DataTemplate>
                                    <dxe:ComboBoxEdit Name="PART_Editor"
                                                      IsTextEditable="False"
                                                      ItemsSource="{dxe:EnumItemsSource EnumType={x:Type models:PositionSide}}">
                                        <dxe:ComboBoxEdit.StyleSettings>
                                            <dxe:RadioComboBoxStyleSettings />
                                        </dxe:ComboBoxEdit.StyleSettings>
                                    </dxe:ComboBoxEdit>
                                </DataTemplate>
                            </dxg:GridColumn.CellEditTemplate>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="Type"
                                        Header="Type">
                            <dxg:GridColumn.CellEditTemplate>
                                <DataTemplate>
                                    <dxe:ComboBoxEdit Name="PART_Editor"
                                                      IsTextEditable="False"
                                                      ItemsSource="{dxe:EnumItemsSource EnumType={x:Type models:OptionType}}">
                                        <dxe:ComboBoxEdit.StyleSettings>
                                            <dxe:RadioComboBoxStyleSettings />
                                        </dxe:ComboBoxEdit.StyleSettings>
                                    </dxe:ComboBoxEdit>
                                </DataTemplate>
                            </dxg:GridColumn.CellEditTemplate>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="Strike"
                                        Header="Strike">
                            <dxg:GridColumn.CellEditTemplate>
                                <DataTemplate>
                                    <dxe:ComboBoxEdit Name="PART_Editor"
                                                      IsTextEditable="False"
                                                      ItemsSource="{Binding View.DataContext.StrikesList}" />
                                </DataTemplate>
                            </dxg:GridColumn.CellEditTemplate>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="ExpiryDate"
                                        Header="Expiry">
                            <dxg:GridColumn.CellEditTemplate>
                                <DataTemplate>
                                    <dxe:ComboBoxEdit Name="PART_Editor"
                                                      DisplayFormatString="d"
                                                      IsTextEditable="False"
                                                      ItemsSource="{Binding View.DataContext.ExpiriesList}" />
                                </DataTemplate>
                            </dxg:GridColumn.CellEditTemplate>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="Quantity"
                                        Header="Qty">
                            <dxg:GridColumn.EditSettings>
                                <dxe:SpinEditSettings IsFloatValue="False"
                                                      MaxValue="1000"
                                                      MinValue="1" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn Width="35"
                                        AllowFocus="False">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Padding="2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding View.DataContext.RemoveLegCommand}"
                                            CommandParameter="{Binding RowData.Row}"
                                            Content="X"
                                            FontWeight="Bold"
                                            Foreground="Red" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                </GroupBox>

                <!--  Buttons  -->
                <StackPanel Grid.Row="4">
                    <Button Margin="0,0,0,10"
                            Padding="10,5"
                            Command="{Binding AddLegCommand}"
                            Content="Add Leg (Default)" />
                    <Button Padding="10,5"
                            Command="{Binding ResetDefaultsCommand}"
                            Content="Reset to Defaults" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Charts Area  -->
        <Grid Grid.Column="1"
              Margin="10">
            <!--  Consolidated Chart Control  -->
            <dxc:ChartControl Background="Transparent"
                              BorderThickness="0"
                              CrosshairEnabled="True">
                <dxc:ChartControl.CrosshairOptions>
                    <dxc:CrosshairOptions ShowArgumentLine="True"
                                          ShowValueLine="True" />
                </dxc:ChartControl.CrosshairOptions>

                <dxc:XYDiagram2D>
                    <!--  Panes Definition  -->
                    <dxc:XYDiagram2D.Panes>
                        <dxc:Pane x:Name="DeltaPane" />
                        <dxc:Pane x:Name="GammaPane" />
                        <dxc:Pane x:Name="ThetaPane" />
                        <dxc:Pane x:Name="VegaPane" />
                    </dxc:XYDiagram2D.Panes>

                    <!--  Shared X-Axis  -->
                    <dxc:XYDiagram2D.AxisX>
                        <dxc:AxisX2D Visible="True">
                            <dxc:AxisX2D.WholeRange>
                                <dxc:Range SideMarginsValue="0" />
                            </dxc:AxisX2D.WholeRange>
                            <dxc:AxisX2D.Label>
                                <dxc:AxisLabel TextPattern="{}{V:N1}" />
                            </dxc:AxisX2D.Label>
                        </dxc:AxisX2D>
                    </dxc:XYDiagram2D.AxisX>

                    <!--  Primary Y-Axis (Payoff)  -->
                    <dxc:XYDiagram2D.AxisY>
                        <dxc:AxisY2D GridLinesMinorVisible="True">
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Payoff ($)" />
                            </dxc:AxisY2D.Title>
                            <dxc:AxisY2D.Label>
                                <dxc:AxisLabel TextPattern="{}{V:N0}" />
                            </dxc:AxisY2D.Label>
                            <dxc:AxisY2D.ConstantLinesInFront>
                                <dxc:ConstantLine Brush="White"
                                                  Value="0">
                                    <dxc:ConstantLine.LineStyle>
                                        <dxc:LineStyle Thickness="1" />
                                    </dxc:ConstantLine.LineStyle>
                                </dxc:ConstantLine>
                            </dxc:AxisY2D.ConstantLinesInFront>
                        </dxc:AxisY2D>
                    </dxc:XYDiagram2D.AxisY>

                    <!--  Secondary Y-Axes  -->
                    <dxc:XYDiagram2D.SecondaryAxesY>
                        <dxc:SecondaryAxisY2D x:Name="DeltaAxis"
                                              Alignment="Near"
                                              GridLinesMinorVisible="True">
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Delta (%)" />
                            </dxc:AxisY2D.Title>
                            <dxc:AxisY2D.Label>
                                <dxc:AxisLabel TextPattern="{}{V:G3}%" />
                            </dxc:AxisY2D.Label>
                            <dxc:AxisY2D.CustomLabels>
                                <dxc:CustomAxisLabel Content="{Binding MinDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.G3Pct}, StringFormat='Min: {0}'}"
                                                     Value="{Binding MinDelta}" />
                                <dxc:CustomAxisLabel Content="{Binding MaxDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.G3Pct}, StringFormat='Max: {0}'}"
                                                     Value="{Binding MaxDelta}" />
                            </dxc:AxisY2D.CustomLabels>
                        </dxc:SecondaryAxisY2D>

                        <dxc:SecondaryAxisY2D x:Name="GammaAxis"
                                              Alignment="Near"
                                              GridLinesMinorVisible="True">
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Gamma (%)" />
                            </dxc:AxisY2D.Title>
                            <dxc:AxisY2D.Label>
                                <dxc:AxisLabel TextPattern="{}{V:G3}%" />
                            </dxc:AxisY2D.Label>
                            <dxc:AxisY2D.CustomLabels>
                                <dxc:CustomAxisLabel Content="{Binding MinGamma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.G3Pct}, StringFormat='Min: {0}'}"
                                                     Value="{Binding MinGamma}" />
                                <dxc:CustomAxisLabel Content="{Binding MaxGamma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.G3Pct}, StringFormat='Max: {0}'}"
                                                     Value="{Binding MaxGamma}" />
                            </dxc:AxisY2D.CustomLabels>
                        </dxc:SecondaryAxisY2D>

                        <dxc:SecondaryAxisY2D x:Name="ThetaAxis"
                                              Alignment="Near"
                                              GridLinesMinorVisible="True">
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Theta (%)" />
                            </dxc:AxisY2D.Title>
                            <dxc:AxisY2D.Label>
                                <dxc:AxisLabel TextPattern="{}{V:G3}%" />
                            </dxc:AxisY2D.Label>
                            <dxc:AxisY2D.CustomLabels>
                                <dxc:CustomAxisLabel Content="{Binding MinTheta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.G3Pct}, StringFormat='Min: {0}'}"
                                                     Value="{Binding MinTheta}" />
                                <dxc:CustomAxisLabel Content="{Binding MaxTheta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.G3Pct}, StringFormat='Max: {0}'}"
                                                     Value="{Binding MaxTheta}" />
                            </dxc:AxisY2D.CustomLabels>
                        </dxc:SecondaryAxisY2D>

                        <dxc:SecondaryAxisY2D x:Name="VegaAxis"
                                              Alignment="Near"
                                              GridLinesMinorVisible="True">
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Vega (%)" />
                            </dxc:AxisY2D.Title>
                            <dxc:AxisY2D.Label>
                                <dxc:AxisLabel TextPattern="{}{V:G3}%" />
                            </dxc:AxisY2D.Label>
                            <dxc:AxisY2D.CustomLabels>
                                <dxc:CustomAxisLabel Content="{Binding MinVega, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.G3Pct}, StringFormat='Min: {0}'}"
                                                     Value="{Binding MinVega}" />
                                <dxc:CustomAxisLabel Content="{Binding MaxVega, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.G3Pct}, StringFormat='Max: {0}'}"
                                                     Value="{Binding MaxVega}" />
                            </dxc:AxisY2D.CustomLabels>
                        </dxc:SecondaryAxisY2D>
                    </dxc:XYDiagram2D.SecondaryAxesY>

                    <!--  Series Definitions  -->

                    <!--  Payoff (Main Pane)  -->
                    <dxc:AreaSeries2D ArgumentDataMember="Price"
                                      BorderBrush="Transparent"
                                      Brush="#4028A745"
                                      DataSource="{Binding ChartPoints}"
                                      DisplayName="Profit"
                                      ValueDataMember="PayoffProfit" />
                    <dxc:AreaSeries2D ArgumentDataMember="Price"
                                      BorderBrush="Transparent"
                                      Brush="#40DC3545"
                                      DataSource="{Binding ChartPoints}"
                                      DisplayName="Loss"
                                      ValueDataMember="PayoffLoss" />
                    <dxc:LineSeries2D ArgumentDataMember="Price"
                                      Brush="Gray"
                                      DataSource="{Binding ChartPoints}"
                                      DisplayName="Expiration"
                                      MarkerVisible="False"
                                      ValueDataMember="ExpiryPayoff">
                        <dxc:LineSeries2D.LineStyle>
                            <dxc:LineStyle DashStyle="{x:Static Member=sys:DashStyles.Dash}"
                                           Thickness="2" />
                        </dxc:LineSeries2D.LineStyle>
                    </dxc:LineSeries2D>
                    <dxc:LineSeries2D ArgumentDataMember="Price"
                                      Brush="#00A8FF"
                                      DataSource="{Binding ChartPoints}"
                                      DisplayName="Payoff"
                                      MarkerVisible="False"
                                      ValueDataMember="Payoff">
                        <dxc:LineSeries2D.LineStyle>
                            <dxc:LineStyle Thickness="3" />
                        </dxc:LineSeries2D.LineStyle>
                    </dxc:LineSeries2D>

                    <!--  Delta Pane  -->
                    <dxc:LineSeries2D ArgumentDataMember="Price"
                                      AxisY="{Binding ElementName=DeltaAxis}"
                                      Brush="#007BFF"
                                      DataSource="{Binding ChartPoints}"
                                      DisplayName="Delta"
                                      Pane="{Binding ElementName=DeltaPane}"
                                      ValueDataMember="Delta" />

                    <!--  Gamma Pane  -->
                    <dxc:LineSeries2D ArgumentDataMember="Price"
                                      AxisY="{Binding ElementName=GammaAxis}"
                                      Brush="#6F42C1"
                                      DataSource="{Binding ChartPoints}"
                                      DisplayName="Gamma"
                                      Pane="{Binding ElementName=GammaPane}"
                                      ValueDataMember="Gamma" />

                    <!--  Theta Pane  -->
                    <dxc:LineSeries2D ArgumentDataMember="Price"
                                      AxisY="{Binding ElementName=ThetaAxis}"
                                      Brush="#D97706"
                                      DataSource="{Binding ChartPoints}"
                                      DisplayName="Theta"
                                      Pane="{Binding ElementName=ThetaPane}"
                                      ValueDataMember="Theta" />

                    <!--  Vega Pane  -->
                    <dxc:LineSeries2D ArgumentDataMember="Price"
                                      AxisY="{Binding ElementName=VegaAxis}"
                                      Brush="#14B8A6"
                                      DataSource="{Binding ChartPoints}"
                                      DisplayName="Vega"
                                      Pane="{Binding ElementName=VegaPane}"
                                      ValueDataMember="Vega" />

                </dxc:XYDiagram2D>
            </dxc:ChartControl>

            <!--  Overlays  -->
            <StackPanel Margin="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontWeight="Bold"
                               Text="Max Profit:" />
                    <TextBlock FontWeight="Bold"
                               Text="{Binding MaxProfit}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontWeight="Bold"
                               Text="Max Loss:" />
                    <TextBlock FontWeight="Bold"
                               Text="{Binding MaxLoss}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
