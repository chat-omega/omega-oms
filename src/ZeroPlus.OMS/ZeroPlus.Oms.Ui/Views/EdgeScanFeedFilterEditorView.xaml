                              EditValue="{Binding MinFarExpirationFilter}"
                              Mask="d"
                              MaskType="DateTimeAdvancingCaret"
                              MaskUseAsDisplayFormat="True" />

                <Label Grid.Row="3"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Content="Far Max" />

                <dxe:TextEdit Grid.Row="3"
                              Grid.Column="1"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Center"
                              Background="Transparent"
                              EditValue="{Binding MaxFarExpirationFilter}"
                              Mask="d"
                              MaskType="DateTimeAdvancingCaret"
                              MaskUseAsDisplayFormat="True" />

                <Label Grid.Row="4"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Content="Blocked" />

                <dx:SimpleButton Grid.Row="4"
                                 Grid.Column="1"
                                 Margin="5,2,0,0"
                                 Background="Transparent"
                                 Command="{Binding DataContext.ShowBlockedExpirationsSelectorCommand, ElementName=FilterTabControl}"
                                 CommandParameter="{Binding}"
                                 Content="Configure"
                                 Glyph="{dx:DXImage 'SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Settings.svg'}"
                                 GlyphWidth="15" />
            </Grid>
        </dxlc:GroupBox>

        <dxlc:GroupBox Grid.Row="6"
                       Grid.Column="2"
                       Margin="5,5,0,0"
                       Padding="2">
            <dxlc:GroupBox.Header>
                <Grid Height="22">
                    <Label Padding="0"
                           VerticalAlignment="Center"
                           Content="Px Chain Deviation"
                           FontWeight="Bold"
                           Foreground="#AFAFB0"
                           IsHitTestVisible="False" />
                </Grid>
            </dxlc:GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Content="Max Lookback" />

                <dxe:SpinEdit Grid.Row="0"
                              Grid.Column="1"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="Transparent"
                              BorderThickness="0"
                              EditValue="{Binding PriceChainDeviationMaxLookBackTime, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment="1"
                              Mask="N0"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="1"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Content="Max UL Chg" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="1"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="Transparent"
                              BorderThickness="0"
                              EditValue="{Binding PriceChainDeviationMaxChangeInUnder, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment=".01"
                              Mask="N4"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="2"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Content="Min Deviation" />

                <dxe:SpinEdit Grid.Row="2"
                              Grid.Column="1"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="Transparent"
                              BorderThickness="0"
                              EditValue="{Binding PriceChainDeviationMinDeviation, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment=".01"
                              Mask="N2"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="3"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Content="Min Trade Width" />

                <dxe:SpinEdit Grid.Row="3"
                              Grid.Column="1"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="Transparent"
                              BorderThickness="0"
                              EditValue="{Binding PriceChainDeviationMinMarketWidthAtTrade, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment=".01"
                              Mask="N2"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="4"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Content="Max Violation Width" />

                <dxe:SpinEdit Grid.Row="4"
                              Grid.Column="1"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="Transparent"
                              BorderThickness="0"
                              EditValue="{Binding PriceChainDeviationMaxMarketWidthAtViolation, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment=".01"
                              Mask="N2"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

            </Grid>
        </dxlc:GroupBox>
    </Grid>
</UserControl>
