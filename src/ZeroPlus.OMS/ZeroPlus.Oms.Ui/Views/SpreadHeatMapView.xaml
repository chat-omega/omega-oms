                                                  Command="{Binding ClearColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Hide All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowAllColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowDefaultColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show Default Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </dxg:TableView.ContextMenu>
                                <dxg:TableView.RowCellMenuCustomizations>
                                    <dxb:BarButtonItem Command="{Binding View.DataContext.ClearSymbolsCommand}"
                                                       Content="Clear Symbols" />
                                </dxg:TableView.RowCellMenuCustomizations>
                            </dxg:TableView>
                        </dxg:GridControl.View>

                        <dxg:GridColumn Name="TopSymbolColumn"
                                        Width="200"
                                        FieldName="Symbol"
                                        HorizontalHeaderContentAlignment="Center"
                                        IsSmart="True" />

                        <dxg:GridColumn Width="70"
                                        Binding="{Binding Path=RowData.Row.Spread, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                        FieldName="Spread"
                                        Header="Value"
                                        HorizontalHeaderContentAlignment="Center"
                                        IsSmart="True" />

                    </dxg:GridControl>
                </Grid>

                <dxh:HeatmapControl x:Name="HeatmapControl"
                                    EnableAxisXNavigation="True"
                                    EnableAxisYNavigation="True"
                                    HighlightMode="Cell"
                                    MouseDoubleClick="HeatmapControl_MouseDoubleClick"
                                    SelectedItem="{Binding SelectedTallyCell}"
                                    SelectionMode="Single"
                                    ToolTipEnabled="True"
                                    Visibility="{Binding OrderTallyMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <dxh:HeatmapControl.DataAdapter>
                        <dxh:HeatmapMatrixAdapter Values="{Binding TallyValues}"
                                                  XArguments="{Binding XArguments}"
                                                  YArguments="{Binding YArguments}" />
                    </dxh:HeatmapControl.DataAdapter>
                    <dxh:HeatmapControl.ColorProvider>
                        <dxh:HeatmapRangeColorProvider LegendItemPattern="{}{V1:0}-{V2:0}"
                                                       Palette="{Binding HeatmapColorPalette}"
                                                       RangeStops="{Binding HeatmapRangeStops}">
                            <!--<dxh:HeatmapRangeColorProvider.Palette>
                                <dxc:CustomPalette>
                                    <dxc:CustomPalette.Colors>
                                        <Color>#ff0000</Color>
                                        <Color>#00ff00</Color>
                                    </dxc:CustomPalette.Colors>
                                </dxc:CustomPalette>
                            </dxh:HeatmapRangeColorProvider.Palette>-->
                        </dxh:HeatmapRangeColorProvider>
                    </dxh:HeatmapControl.ColorProvider>
                    <dxh:HeatmapControl.Legend>
                        <dxh:HeatmapLegend Margin="0,0,4,10">
                            <dxh:HeatmapLegend.Title>
                                <dxc:LegendTitle Content="Submissions" />
                            </dxh:HeatmapLegend.Title>
                        </dxh:HeatmapLegend>
                    </dxh:HeatmapControl.Legend>
                    <dxh:HeatmapControl.Label>
                        <dxh:HeatmapLabel Padding="2"
                                          Foreground="Black" />
                    </dxh:HeatmapControl.Label>
                    <dxh:HeatmapControl.AxisX>
                        <dxh:HeatmapAxis>
                            <dxh:HeatmapAxis.Title>
                                <dxc:AxisTitle Content="Strike" />
                            </dxh:HeatmapAxis.Title>
                        </dxh:HeatmapAxis>
                    </dxh:HeatmapControl.AxisX>
                    <dxh:HeatmapControl.AxisY>
                        <dxh:HeatmapAxis Reverse="True">
                            <dxh:HeatmapAxis.Title>
                                <dxc:AxisTitle Content="Expiration" />
                            </dxh:HeatmapAxis.Title>
                        </dxh:HeatmapAxis>
                    </dxh:HeatmapControl.AxisY>
                </dxh:HeatmapControl>

                <views:BusyIndicatorView HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />

            </Grid>
        </Grid>
    </Grid>
</dx:ThemedWindow>
