<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.EditHeatmapAlertView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Edit Heatmap Alert"
                 Width="300"
                 Height="200"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>

        <dxe:CheckEdit Grid.Row="1"
                       Grid.Column="1"
                       Margin="0,5,0,0"
                       Content="Threshold"
                       EditValue="{Binding Enabled}" />

        <dxe:SpinEdit Grid.Row="1"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="N2"
                      EditValue="{Binding Threshold, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="0.01"
                      IsEnabled="{Binding Enabled}"
                      Mask="N2"
                      MinValue="0"
                      PreviewMouseUp="SpinEdit_MouseUp"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <dxe:CheckEdit Grid.Row="2"
                       Grid.Column="1"
                       Margin="0,5,0,0"
                       Content="Audio"
                       EditValue="{Binding AudioEnabled}"
                       IsEnabled="{Binding Enabled}" />
        <DockPanel Grid.Row="2"
                   Grid.Column="2"
                   Margin="5,5,0,0"
                   IsEnabled="{Binding Enabled}">
            <dx:SimpleButton Width="22"
                             Command="{Binding TestSoundCommand}"
                             DockPanel.Dock="Right"
                             Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"
                             GlyphHeight="15"
                             GlyphWidth="15" />
            <dxe:ComboBoxEdit IsTextEditable="False"
                              ItemsSource="{Binding NotificationManager.SoundsList}"
                              SelectedItem="{Binding AudioSound, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <dxe:CheckEdit Grid.Row="3"
                       Grid.Column="1"
                       Margin="0,5,0,0"
                       Content="Notification"
                       EditValue="{Binding NotificationEnabled}"
                       IsEnabled="{Binding Enabled}" />

        <dx:SimpleButton Grid.Row="3"
                         Grid.Column="2"
                         Margin="5,5,0,0"
                         Command="{Binding ShareNotificationCommand}"
                         Content="Share Notification"
                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}"
                         GlyphHeight="15"
                         IsEnabled="{Binding Enabled}" />

        <dxe:CheckEdit Grid.Row="4"
                       Grid.Column="1"
                       Margin="0,5,0,0"
                       Content="Visual"
                       EditValue="{Binding VisualEnabled}"
                       IsEnabled="{Binding Enabled}" />

        <StackPanel Grid.Row="6"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Command="{Binding SaveCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Bell.svg}"
                             GlyphHeight="15"
                             IsDefault="True" />
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel"
                             IsCancel="True" />
        </StackPanel>

    </Grid>
</dx:ThemedWindow>
