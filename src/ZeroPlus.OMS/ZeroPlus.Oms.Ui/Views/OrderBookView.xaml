<UserControl x:Class="ZeroPlus.Oms.Ui.Views.OrderBookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:local="clr-namespace:ZeroPlus.Oms.Ui.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
             xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DataContext="{d:DesignInstance Type=ViewModels:OrderBookViewModel}"
             d:DesignHeight="450"
             d:DesignWidth="1500"
             DataContext="{startuphelpers:DISource Type=ViewModels:OrderBookViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />

        <Style x:Key="OrderBookGridColumnBase"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="Visible" Value="False" />
            <Setter Property="IsSmart" Value="True" />
            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="N2NumericColumn"
               BasedOn="{StaticResource OrderBookGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="N2"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="N6NumericColumn"
               BasedOn="{StaticResource OrderBookGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="N6"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="C2NumericColumn"
               BasedOn="{StaticResource OrderBookGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="C2"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                             Inverse="True" />
        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
        <helper:DoubleRangeToVisibilityConverter x:Key="DoubleRangeToVisibilityConverter"
                                                 Limit="0.0" />
        <helper:SignToBrushConverter x:Key="GiveUpToBrushConverter"
                                     NegativeBrush="#F1F1F1"
                                     PositiveBrush="#FFB115"
                                     ZeroBrush="#FFB115" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#6dc534"
                                     ZeroBrush="#6dc534" />
        <helper:SignToBrushConverter x:Key="CountdownToBrushConverter"
                                     Limit="3"
                                     NegativeBrush="#F05126"
                                     PositiveBrush="#171718"
                                     ZeroBrush="#F05126" />

        <Style x:Key="OrderStyle"
               TargetType="dxg:RowControl">
            <Style.Setters>
                <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Background'}" />
                <Setter Property="Foreground" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Foreground'}" />
                <Setter Property="Visibility" Value="{Binding Path=Row.Hide, Converter={StaticResource BooleanToVisibilityInverseConverter}}" />
            </Style.Setters>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='MouseOver'}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:EventToCommand Command="{Binding ViewLoadedCommand}"
                               EventName="Loaded" />
        <services:LoadCustomColumnService />
        <dxmvvm:SaveFileDialogService />
        <dxmvvm:WindowService />
        <dxmvvm:DispatcherService />
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition x:Name="GridSplitterRow"
                           Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
                <RowDefinition Height="5" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="1"
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">

                <StackPanel HorizontalAlignment="Center"
                            Orientation="Horizontal">

                    <Label Margin="5,0,0,0"
                           Content="Interval"
                           Visibility="{Binding CancelOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <dxe:SpinEdit Width="65"
                                  Margin="3,0,0,0"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding CancelIntervalSec, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  MinValue="1"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  Visibility="{Binding CancelOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Label Margin="5,0,0,0"
                           Content="Resting for"
                           Visibility="{Binding CancelOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <dxe:SpinEdit Width="65"
                                  Margin="3,0,0,0"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding CancelDeltaSec, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  Visibility="{Binding CancelOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Border Margin="5,0,0,0"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            Visibility="{Binding CancelOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Width="65"
                                   Padding="0,2,0,0"
                                   Background="{Binding CancelCountDown.TotalSeconds, Converter={StaticResource CountdownToBrushConverter}}"
                                   FontFamily="{StaticResource Technology}"
                                   FontSize="18"
                                   Text="{Binding CancelCountDown, Converter={StaticResource DoubleFormatter}}"
                                   TextAlignment="Center" />
                    </Border>

                </StackPanel>

                <dx:SplitButton Width="120"
                                Margin="5,0"
                                Padding="3,1,7,1"
                                Command="{Binding CancelAllCommand}"
                                Content="Cancel All">
                    <StackPanel Orientation="Vertical">
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Command="{Binding CancelAllMatrixOrdersCommand}"
                                         Content="Cancel ALL Matrix" />
                        <dx:SuperTipItemControlSeparator />
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Command="{Binding CancelAllSelectedCommand}"
                                         CommandParameter="{Binding Path=SelectedItems, ElementName=OpenOrderGrid}"
                                         Content="Cancel ALL Selected" />
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Command="{Binding CancelAllBuysCommand}"
                                         Content="Cancel ALL Buys" />
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Command="{Binding CancelAllSellsCommand}"
                                         Content="Cancel ALL Sells" />
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Content="Cancel ALL Sell Shorts"
                                         IsEnabled="False" />
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Content="Cancel ALL Stock"
                                         IsEnabled="False" />
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Content="Cancel ALL Calls"
                                         IsEnabled="False" />
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Content="Cancel ALL Puts"
                                         IsEnabled="False" />
                        <dx:SuperTipItemControlSeparator />
                        <dxe:ToggleSwitch Margin="1,1,0,2"
                                          VerticalAlignment="Center"
                                          AnimationMode="OnToggle"
                                          CheckedStateContent="Cxl Timer ON"
                                          ContentPlacement="Inside"
                                          IsChecked="{Binding CancelOnTimer}"
                                          ToggleSwitchWidth="135"
                                          UncheckedStateContent="Cxl Timer OFF" />
                    </StackPanel>
                </dx:SplitButton>

                <dx:DropDownButton Width="120"
                                   Margin="5,0"
                                   Padding="3,1,7,1"
                                   Content="Quick Settings">
                    <ItemsControl>
                        <StackPanel Orientation="Vertical">
                            <MenuItem Checked="AutoScrollChecked"
                                      Header="Auto Scroll"
                                      IsCheckable="True"
                                      IsChecked="{Binding AutoScroll}"
                                      Unchecked="AutoScrollUnchecked" />
                            <MenuItem Checked="ShowWorkingOrders"
                                      Header="Show Working Orders"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowWorkingOrders}"
                                      Unchecked="HideWorkingOrders" />
                            <dx:SuperTipItemControlSeparator />
                            <MenuItem Checked="ShowWorkingOrders"
                                      Click="ClearFiltersClick"
                                      Header="Clear Filters"
                                      Unchecked="HideWorkingOrders" />
                            <MenuItem Checked="ShowWorkingOrders"
                                      Click="ClearSortingClick"
                                      Header="Clear Sorting"
                                      Unchecked="HideWorkingOrders" />
                        </StackPanel>
                    </ItemsControl>
                </dx:DropDownButton>
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Grid.Column="3"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <controls:AdminConfigControl Margin="5,0"
                                             ConfigSelectionChanged="LoadConfig"
                                             ReloadConfigsSelected="ReloadConfigsSelected" />
                <dx:SimpleButton Width="20"
                                 VerticalAlignment="Top"
                                 dxb:BarManager.MenuShowMouseButton="LeftButton"
                                 Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}">
                    <dxb:BarManager.DXContextMenu>
                        <dxb:PopupControlContainer>
                            <ItemsControl>
                                <StackPanel>
                                    <MenuItem Height="25"
                                              Command="{Binding CloneCommand}"
                                              Header="Clone">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Click="ShareLayout"
                                              Header="Share Layout">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Click="SaveLayout"
                                              Header="Save Layout">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding BrowseLayoutsCommand}"
                                              Header="Browse Layout">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Click="LoadLayout"
                                              Header="Load Layout">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </StackPanel>
                            </ItemsControl>
                        </dxb:PopupControlContainer>
                    </dxb:BarManager.DXContextMenu>
                </dx:SimpleButton>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Visibility="{Binding ShowWorkingOrders, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Slider x:Name="OpenOrderGridScale"
                    Grid.Row="0"
                    Maximum="4"
                    Minimum="0.1"
                    Visibility="Hidden"
                    Value="1" />

            <dxg:GridControl x:Name="OpenOrderGrid"
                             Grid.Row="0"
                             dx:DXSerializer.StoreLayoutMode="All"
                             dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                             AutoGenerateColumns="AddNew"
                             AutoGeneratedColumns="Grid_ColumnsPopulated"
                             AutoGeneratingColumn="OnAutoGeneratingColumn"
                             CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                             EnableSmartColumnsGeneration="True"
                             ItemsSource="{Binding WorkingOrders}"
                             PreviewMouseWheel="OnZoomMouseWheel"
                             RestoreStateOnSourceChange="True"
                             SelectionMode="Row">
                <dxg:GridControl.LayoutTransform>
                    <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=OpenOrderGridScale, Path=Value}" ScaleY="{Binding ElementName=OpenOrderGridScale, Path=Value}" />
                </dxg:GridControl.LayoutTransform>
                <dxg:GridControl.Resources>
                    <Style BasedOn="{StaticResource OrderBookGridColumnBase}"
                           TargetType="dxg:GridColumn" />
                    <Style TargetType="{x:Type dxg:TableView}">
                        <Setter Property="AllowGrouping" Value="True" />
                        <Setter Property="ColumnHeaderTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextAlignment="Center"
                                               TextWrapping="{Binding ElementName=OpenOrderGrid, Path=View.DataContext.HeaderTextWrapping}" />
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </dxg:GridControl.Resources>
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:ReadOnlyDependencyPropertyBindingBehavior Binding="{Binding VisibleWorkingOrders, Mode=OneWayToSource}"
                                                                      Property="VisibleItems" />
                    <services:UiUpdateService />
                </dxmvvm:Interaction.Behaviors>
                <dxg:GridControl.View>
                    <dxg:TableView AllowDragDrop="True"
                                   AllowEditing="False"
                                   AutoWidth="True"
                                   CompleteRecordDragDrop="OnCompleteRecordDragDrop"
                                   EnableSelectedRowAppearance="True"
                                   IsDetailButtonVisibleBinding="{Binding Row.IsComplexOrder}"
                                   NavigationStyle="Row"
                                   RowDoubleClickCommand="{Binding RowDoubleClickCommand}"
                                   RowStyle="{StaticResource OrderStyle}"
                                   SearchColumns="Symbol;Description;SpreadId;Route;Username;UnderlyingSymbol;PermID"
                                   SearchPanelFindFilter="Contains"
                                   SearchPanelParseMode="Exact"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   StartRecordDrag="OnStartRecordDrag">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Height="25"
                                          Command="{Binding ShowColumnChooserCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Column Chooser">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ClearColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Hide All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowAllColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                        <dxg:TableView.RowCellMenuCustomizations>
                            <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInComplexOrderTicketCommand}"
                                               CommandParameter="{Binding Path=SelectedItem, ElementName=OpenOrderGrid}"
                                               Content="Open in Complex Order Ticket" />
                            <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInPositionAnalyzerCommand}"
                                               CommandParameter="{Binding Path=SelectedItem, ElementName=FilledOrderGrid}"
                                               Content="Open in Position Analyzer" />
                            <dxb:BarItemSeparator />
                            <dxb:BarButtonItem Command="{Binding View.DataContext.CancelOrderCommand}"
                                               CommandParameter="{Binding Path=SelectedItems, ElementName=OpenOrderGrid}"
                                               Content="Cancel Selected" />
                            <dxb:BarItemSeparator />
                            <dxb:BarButtonItem Command="{Binding View.DataContext.GetAuditTrailCommand}"
                                               CommandParameter="{Binding Path=SelectedItem, ElementName=OpenOrderGrid}"
                                               Content="Get Audit Trail" />
                            <dxb:BarButtonItem Command="{Binding View.DataContext.OpenOrderDetailsCommand}"
                                               CommandParameter="{Binding Path=SelectedItem, ElementName=OpenOrderGrid}"
                                               Content="Open Order Details" />
                        </dxg:TableView.RowCellMenuCustomizations>
                        <dxg:TableView.GroupValueTemplate>
                            <DataTemplate>
                                <TextBlock Margin="10,0,0,0"
                                           Text="{Binding Value}" />
                            </DataTemplate>
                        </dxg:TableView.GroupValueTemplate>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn Width="20"
                                MinWidth="20"
                                d:Visible="True"
                                AllowMoving="False"
                                AllowResizing="False"
                                FieldName="Expand"
                                Header="+"
                                IsSmart="False">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dx:SimpleButton Background="Transparent"
                                             BorderThickness="0"
                                             Command="{Binding View.DataContext.ShowLegDetailsCommand}"
                                             CommandParameter="{Binding Path=SelectedItem, ElementName=OpenOrderGrid}"
                                             Glyph="{dx:DXImage SvgImages/DiagramIcons/ExpandSubordinates.svg}"
                                             GlyphWidth="10"
                                             Visibility="{Binding RowData.Row.IsComplexOrder, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn d:Visible="True"
                                FieldName="AccountAcronym"
                                Header="Acc" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="Symbol"
                                Header="Sym" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="Description" />
                <dxg:GridColumn FieldName="Quantity"
                                Header="Qty" />
                <dxg:GridColumn FieldName="LastUpdateTime" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="LutTimeOnly"
                                Header="Update Time" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="CumulativeQuantity"
                                Header="Cum Qty" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="Price"
                                Header="Px" />
                <dxg:GridColumn FieldName="ClearingFirm" />
                <dxg:GridColumn FieldName="AveragePrice"
                                Header="Avg Px" />
                <dxg:GridColumn d:Visible="True"
                                Binding="{Binding Path=RowData.Row.TheoBid, Converter={StaticResource DoubleFormatter}}"
                                FieldName="TheoBid"
                                Header="Theo Bid" />
                <dxg:GridColumn d:Visible="True"
                                Binding="{Binding Path=RowData.Row.TheoAsk, Converter={StaticResource DoubleFormatter}}"
                                FieldName="TheoAsk"
                                Header="Theo Ask" />
                <dxg:GridColumn d:Visible="True"
                                Binding="{Binding Path=RowData.Row.TheoPercentBid, Converter={StaticResource DoubleFormatter}}"
                                FieldName="TheoPercentBid"
                                Header="Theo % Bid" />
                <dxg:GridColumn d:Visible="True"
                                Binding="{Binding Path=RowData.Row.FillTheoPercentBid, Converter={StaticResource DoubleFormatter}}"
                                FieldName="FillTheoPercentBid"
                                Header="Fill Theo % Bid" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="PermID"
                                Header="Perm Id" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="LeavesQuantity"
                                Header="Leaves Qty" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="PositionEffect"
                                Header="Pos Effect" />
                <dxg:GridColumn FieldName="LastExchange"
                                Header="Last Exch" />
                <dxg:GridColumn FieldName="Route" />
                <dxg:GridColumn FieldName="Side" />
                <dxg:GridColumn FieldName="Source" />
                <dxg:GridColumn FieldName="OrderStatus"
                                Header="Status" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="SubmitTime" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="Tag" />
                <dxg:GridColumn FieldName="UnderlyingSymbol"
                                Header="UA" />
                <dxg:GridColumn d:Visible="True"
                                FieldName="Username" />
                <dxg:GridColumn d:Visible="True"
                                Binding="{Binding Path=RowData.Row.Width, Converter={StaticResource DoubleFormatter}}"
                                FieldName="Width" />
                <dxg:GridColumn d:Visible="True"
                                Binding="{Binding Path=RowData.Row.UnderWidth, Converter={StaticResource DoubleFormatter}}"
                                FieldName="UnderWidth" />
                <dxg:GridColumn FieldName="Hide">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxe:CheckEdit HorizontalAlignment="Center"
                                           Background="Transparent"
                                           EditValue="{Binding RowData.Row.Hide}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="InitialEdge"
                                Header="Initial Edge">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,2,0"
                                       Padding="2"
                                       HorizontalAlignment="Right"
                                       FontWeight="DemiBold"
                                       Foreground="{Binding RowData.Row.InitialEdge, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding RowData.Row.InitialEdge, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.TheoToMid, Converter={StaticResource DoubleFormatter}}"
                                FieldName="TheoToMid" />
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaToMid, Converter={StaticResource DoubleFormatter}}"
                                FieldName="EmaToMid" />
                <dxg:GridColumn FieldName="OpenEdge"
                                Header="Open Edge">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,2,0"
                                       Padding="2"
                                       HorizontalAlignment="Right"
                                       FontWeight="DemiBold"
                                       Foreground="{Binding RowData.Row.OpenEdge, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding RowData.Row.OpenEdge, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="CloseEdge"
                                Header="Close Edge">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,2,0"
                                       Padding="2"
                                       HorizontalAlignment="Right"
                                       FontWeight="DemiBold"
                                       Foreground="{Binding RowData.Row.CloseEdge, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding RowData.Row.CloseEdge, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="IsCitadel">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,2,0"
                                       Padding="2"
                                       Text="{Binding RowData.Row.IsCitadel}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="IsFirstFill">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,2,0"
                                       Padding="2"
                                       Text="{Binding RowData.Row.IsFirstFill}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="FirstEdgeAcquired">
