                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <dx:SimpleButton MinWidth="20"
                                         Margin="0,0,5,0"
                                         Command="{Binding ElementName=QuickRoutesSource, Path=DataContext.LoadQuickRouteCommand}"
                                         CommandParameter="{Binding Item2}"
                                         Content="{Binding Item1}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <dx:DropDownButton Name="TrackerDropDown"
                               Grid.Row="9"
                               Grid.Column="5"
                               Height="23"
                               Margin="5,10,0,0"
                               VerticalAlignment="Bottom"
                               Command="{Binding CancelTrackerCommand}"
                               Content="{Binding Tracker.IsRunning, Converter={StaticResource TrackerRunningToTextConverter}}"
                               FontWeight="DemiBold"
                               Style="{StaticResource TriggerDropDownButtonStyle}">
                <ItemsControl>
                    <StackPanel Orientation="Vertical">
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Click="TrackerClick"
                                         Command="{Binding TrackMidToFillCommand}"
                                         Content="Track Mid (Cancel)" />
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Click="TrackerClick"
                                         Command="{Binding TrackMidToFillRestingCommand}"
                                         Content="Track Mid (Resting)" />
                    </StackPanel>
                </ItemsControl>
            </dx:DropDownButton>

            <ItemsControl Name="ContraQuickRoutesSource"
                          Grid.Row="9"
                          Grid.Column="6"
                          Grid.ColumnSpan="4"
                          Margin="0,10,0,0"
                          HorizontalAlignment="Right"
                          ItemsSource="{Binding QuickRoutes}"
                          Visibility="{Binding Path=IsChecked, ElementName=showQuickRoutesCheckBox, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel HorizontalAlignment="Left"
                                    Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <dx:SimpleButton MinWidth="20"
                                         Margin="5,0,0,0"
                                         Command="{Binding ElementName=QuickRoutesSource, Path=DataContext.LoadContraQuickRouteCommand}"
                                         CommandParameter="{Binding Item2}"
                                         Content="{Binding Item1}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        <dxlc:GroupBox Grid.Row="3"
                       Grid.Column="1"
                       Height="70"
                       Margin="0,3,0,0"
                       Padding="4,6"
                       VerticalAlignment="Bottom"
                       Header="Order Instructions"
                       Visibility="{Binding Path=IsChecked, ElementName=showOrderInstructionsPanelCheckBox, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Label Grid.Row="0"
                       Grid.Column="0"
                       Margin="1,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="ACCOUNT"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="1"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="TIF"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="2"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="TAG"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="3"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="LOCATE"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="4"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="DISPLAY #"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="5"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="GTH"
                       FontSize="8" />
                <dxe:ComboBoxEdit Grid.Row="1"
                                  Grid.Column="0"
                                  Width="145"
                                  Margin="0,0,0,0"
                                  HorizontalAlignment="Left"
                                  Background="#171718"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding AccountsList}"
                                  SelectedItem="{Binding Account}">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding AccountOrRouteChangedCommand}"
                                               EventName="EditValueChanged" />
                    </dxmvvm:Interaction.Behaviors>
                </dxe:ComboBoxEdit>
                <dxe:ComboBoxEdit Grid.Row="1"
                                  Grid.Column="1"
                                  Width="70"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  Background="#171718"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding TifsList}"
                                  SelectedItem="{Binding TimeInForce}" />
                <dxe:TextEdit Grid.Row="1"
                              Grid.Column="2"
                              Width="145"
                              Margin="5,0,0,0"
                              Background="#171718"
                              Text="{Binding Path=Tag}" />

                <DockPanel Grid.Row="1"
                           Grid.Column="3"
                           Width="145"
                           Margin="5,0,0,0"
                           Background="#171718">
                    <dxe:TextEdit Grid.Row="1"
                                  Grid.Column="4"
                                  Background="#171718" />
                </DockPanel>

                <DockPanel Grid.Row="1"
                           Grid.Column="4"
                           Width="70"
                           Margin="5,0,0,0"
                           Background="#171718">
                    <dxe:SpinEdit Background="#171718" />
                </DockPanel>

                <dxe:ToggleSwitch Grid.Row="1"
                                  Grid.Column="5"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  Background="#171718"
                                  CheckedStateContent="ON"
                                  ContentPlacement="Inside"
                                  IsChecked="{Binding IsGTH, UpdateSourceTrigger=PropertyChanged}"
                                  ToggleSwitchWidth="70"
                                  UncheckedStateContent="OFF" />
            </Grid>
        </dxlc:GroupBox>

        <Border Grid.Row="4"
                Grid.Column="1"
                Margin="0,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Padding="3,2"
                           Background="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                           Foreground="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                           Text="{Binding Status}" />

                <StackPanel Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Center"
                            Panel.ZIndex="100"
                            Orientation="Horizontal"
                            Visibility="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <dxe:ButtonEdit Grid.Row="0"
                                    Grid.Column="0"
                                    AllowDefaultButton="False"
                                    IsEnabled="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ShowBorder="False"
                                    ShowText="False">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:LoadingIndicatorButtonInfo />
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>
                    <dxe:ButtonEdit Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="-5,0,0,0"
                                    AllowDefaultButton="False"
                                    IsEnabled="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ShowBorder="False"
                                    ShowText="False">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:LoadingIndicatorButtonInfo />
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Padding="3,2,10,2"
                           Background="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                           Foreground="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                           Text="{Binding ContraStatus}"
                           TextAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</dx:ThemedWindow>
