                                   AllowGrouping="False"
                                   AllowSorting="False"
                                   AutoWidth="True"
                                   FadeSelectionOnLostFocus="False"
                                   RowStyle="{Binding ShowDepthBook, Converter={StaticResource TicketTypeToStyleConverter}}"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   ShowIndicator="True"
                                   ShowTotalSummary="True"
