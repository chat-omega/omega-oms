                           TargetType="dxg:RowControl">
                        <Style.Setters>
                            <Setter Property="Background" Value="{Binding Path=Row.Side, Converter={StaticResource SideToColorConverter}, ConverterParameter='BACKGROUND'}" />
                            <Setter Property="Foreground" Value="{Binding Path=Row.Side, Converter={StaticResource SideToColorConverter}, ConverterParameter='FOREGROUND'}" />
                        </Style.Setters>
                    </Style>

                    <Style x:Key="expirationCellStyle"
                           TargetType="dxg:LightweightCellEditor">
                        <Setter Property="Background" Value="{Binding RowData.Row.IsExpirationValid, Converter={StaticResource ValidityToColorConverter}}" />
                        <Style.Triggers>
                            <Trigger Property="IsFocusedCell" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="{Binding RowData.Row.IsExpirationValid, Converter={StaticResource ValidityToColorConverter}}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="strikeCellStyle"
                           TargetType="dxg:LightweightCellEditor">
                        <Setter Property="Background" Value="{Binding RowData.Row.IsStrikeValid, Converter={StaticResource ValidityToColorConverter}}" />
                        <Style.Triggers>
                            <Trigger Property="IsFocusedCell" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="{Binding RowData.Row.IsStrikeValid, Converter={StaticResource ValidityToColorConverter}}" />
                            </Trigger>
                        </Style.Triggers>
