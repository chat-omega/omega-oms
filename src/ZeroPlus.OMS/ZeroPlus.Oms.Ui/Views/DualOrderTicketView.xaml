<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.DualOrderTicketView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
                 xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Width="700"
                 Height="500"
                 MinWidth="300"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:ComplexOrderTicketViewModel}"
                 d:Width="1200"
                 DataContext="{startuphelpers:DISource Type=ViewModels:ComplexOrderTicketViewModel}"
                 FontSize="11"
                 KeyboardNavigation.DirectionalNavigation="Once"
                 MouseDown="TicketWindow_MouseDown"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <Window.Resources>
        <helper:BindingProxy x:Key="ProxyElement"
                             Data="{Binding}" />
        <helper:PutCallToTextConverter x:Key="PutCallToTextConverter" />
        <helper:PutCallToColorConverter x:Key="PutCallToColorConverter" />
        <helper:MultiBooleanToOrVisibilityConverter x:Key="MultiBooleanToOrVisibilityConverter" />
        <helper:MultiBooleanToAndVisibilityConverter x:Key="MultiBooleanToAndVisibilityConverter" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:MultiValueCloneConverter x:Key="MultiValueCloneConverter" />
        <helper:PriceToConnectorConverter x:Key="PriceToConnectorConverter" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:DepthSideToColorConverter x:Key="DepthSideToColorConverter" />
        <helper:CashPercentageToGlyphConverter x:Key="CashPercentageToGlyphConverter" />
        <helper:MultiBooleanToGridVisibilityConverter x:Key="MultiBooleanToGridVisibilityConverter" />
        <helper:RangeToBrushConverter x:Key="RangeToBrushConverter"
                                      AboveRangeBrush="#B73535"
                                      BelowRangeBrush="#0A8E51"
                                      InbetweenRangeBrush="#02F302"
                                      RangeCeil="0.50"
                                      RangeFloor="0.45" />
        <helper:RangeToBrushConverter x:Key="RangeToForegroundBrushConverter"
                                      AboveRangeBrush="#FFFFFF"
                                      BelowRangeBrush="#FFFFFF"
                                      InbetweenRangeBrush="#000000"
                                      RangeCeil="0.50"
                                      RangeFloor="0.45" />
        <dxmvvm:BooleanToObjectConverter x:Key="SignToHoverBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#C44E4E" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#2D9E65" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBackColorConverterRed">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F88F8F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="SignToPressedBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#772F2F" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#1D673F" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="SignToBackBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#B73535" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#0A8E51" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="DepthBookVisibilityToBuyStatusColumnConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                1
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                2
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TrackerRunningToTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Cancel
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Tracker
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:DoubleToVisibilityConverter x:Key="DoubleToVisibilityConverter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#FF0000"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#FFFFFF" />
        <helper:OrderToBackBrushConverter x:Key="SideToColorConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBorderColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #FF0000
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="ValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Transparent" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#FF0000" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="AdjTheoValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F1F1F1
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F3A202
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="IntValueToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F3A202
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F1F1F1
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TicketTypeToStyleConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <Style TargetType="dxg:RowControl">
                    <Style.Setters>
                        <Setter Property="Background" Value="Transparent" />
                    </Style.Setters>
                </Style>
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <Style TargetType="dxg:RowControl">
                    <Style.Setters>
                        <Setter Property="Background" Value="{Binding Path=Row.Side, Converter={StaticResource SideToColorConverter}, ConverterParameter='BACKGROUND'}" />
                        <Setter Property="Foreground" Value="{Binding Path=Row.Side, Converter={StaticResource SideToColorConverter}, ConverterParameter='FOREGROUND'}" />
                    </Style.Setters>
                </Style>
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>

        <Style x:Key="submitButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding IsSellOrder, Converter={StaticResource SignToHoverBrushConverter}}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{Binding IsSellOrder, Converter={StaticResource SignToPressedBrushConverter}}" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="{Binding IsSellOrder, Converter={StaticResource SignToBackBrushConverter}}" />
        </Style>

        <Style x:Key="submitBuyButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D9E65" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1D673F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#0A8E51" />
        </Style>

        <Style x:Key="submitSellButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C44E4E" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#772F2F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#B73535" />
        </Style>

        <Style x:Key="modifyButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A053CC" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#64337F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#8835B7" />
        </Style>

        <helper:LoopPricingModeToDisplayTextConverter x:Key="LoopPricingModeToDisplayTextConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <helper:SignToBrushConverter x:Key="CountdownToBrushConverter"
                                     Limit="3"
                                     NegativeBrush="#F05126"
                                     PositiveBrush="#171718"
                                     ZeroBrush="#F05126" />

        <dxmvvm:BooleanToObjectConverter x:Key="SignToForeBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#FF0000" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#02F302" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBorderColorConverterRed">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F88F8F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #3F3F46
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>

        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToButtonTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Stop
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Start
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>

        <dxmvvm:BooleanToObjectConverter x:Key="TheoValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #02F302
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F3A202
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>

        <Style x:Key="contraSubmitButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding IsContraSellOrder, Converter={StaticResource SignToHoverBrushConverter}}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{Binding IsContraSellOrder, Converter={StaticResource SignToPressedBrushConverter}}" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="{Binding IsContraSellOrder, Converter={StaticResource SignToBackBrushConverter}}" />
        </Style>

        <Style x:Key="closeButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#584ab4" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#64337F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#7160e8" />
        </Style>
    </Window.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
        <dxmvvm:DispatcherService />
        <dxmvvm:KeyToCommand Command="{Binding SearchUnderlyingCommand}"
                             KeyGesture="Enter" />
        <dxmvvm:KeyToCommand Command="{Binding IncrementPriceCommand}"
                             EventName="KeyDown"
                             KeyGesture="Up" />
        <dxmvvm:KeyToCommand Command="{Binding DecrementPriceCommand}"
                             EventName="KeyDown"
                             KeyGesture="Down" />
    </dxmvvm:Interaction.Behaviors>

    <dx:ThemedWindow.ToolbarItems>
        <StackPanel Margin="0,9,0,0"
                    Orientation="Horizontal">
            <TextBlock FontSize="12"
                       FontWeight="Bold"
                       Foreground="{Binding PutCall, Converter={StaticResource PutCallToColorConverter}}"
                       Text="{Binding PutCall, Converter={StaticResource PutCallToTextConverter}}"
                       TextAlignment="Right" />

            <TextBlock Margin="5,0,0,0"
                       FontSize="12"
                       Text="{Binding DualDescription}"
                       TextAlignment="Right" />
        </StackPanel>
    </dx:ThemedWindow.ToolbarItems>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

            <TextBlock Margin="15,2,0,1"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="DemiBold"
                       Text="Submit"
                       TextAlignment="Right" />

            <TextBlock Margin="4,2,0,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="Bold"
                       Text="{Binding SubmitLatency}"
                       TextAlignment="Right" />

            <TextBlock Margin="10,2,0,1"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="DemiBold"
                       Text="Status"
                       TextAlignment="Right" />

            <TextBlock Margin="4,2,0,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="Bold"
                       Text="{Binding PendingNewLatency}"
                       TextAlignment="Right" />

            <dxe:ToggleSwitch Margin="5,0,0,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              AnimationMode="Always"
                              Background="#FF0000"
                              CheckedStateContent="✓  Risk"
                              ContentPlacement="Inside"
                              Focusable="False"
                              FontWeight="Bold"
                              IsChecked="{Binding RiskCheckEnabled}"
                              ToggleSwitchWidth="65"
                              UncheckedStateContent="⚠ Risk" />

            <dx:SimpleButton Height="20"
                             Margin="5,0,0,0"
                             HorizontalAlignment="Right"
                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}">
                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupControlContainer>
                        <ItemsControl>
                            <StackPanel Margin="5">
                                <MenuItem Height="25"
                                          Command="{Binding CloneCommand}"
                                          Header="Clone">
                                    <MenuItem.CommandParameter>
                                        <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                                            <Binding Path="Width"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type Window}}" />
                                            <Binding Path="Height"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type Window}}" />
                                            <Binding Path="Left"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type Window}}" />
                                            <Binding Path="Top"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type Window}}" />
                                        </MultiBinding>
                                    </MenuItem.CommandParameter>
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="ShareLayout"
                                          Header="Share Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="SaveLayout"
                                          Header="Save Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding BrowseLayoutsCommand}"
                                          Header="Browse Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="LoadLayout"
                                          Header="Load Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <dx:SuperTipItemControlSeparator />
                                <MenuItem Height="25"
                                          Command="{Binding OpenInLiveChartCommand}"
                                          Header="Open in Theo Chart" />
                                <MenuItem Height="25"
                                          Command="{Binding ShowFeeCalculatorCommand}"
                                          Header="Show Fee Calculator" />
                                <MenuItem Name="showQuickRoutesCheckBox"
                                          Height="25"
                                          Checked="ShowQuickRoutesCheckBoxUpdated"
                                          Header="Show Quick Routes Panel"
                                          IsCheckable="True"
                                          IsChecked="{Binding ShowQuickRoutes}"
                                          Unchecked="ShowQuickRoutesCheckBoxUpdated" />
                                <MenuItem Name="showOrderInstructionsPanelCheckBox"
                                          Height="25"
                                          Checked="ShowOrderInstructionsPanelCheckBoxUpdated"
                                          Header="Show Order Instructions Panel"
                                          IsCheckable="True"
                                          Unchecked="ShowOrderInstructionsPanelCheckBoxUpdated" />
                            </StackPanel>
                        </ItemsControl>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>
        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <Grid PreviewMouseWheel="Grid_PreviewMouseWheel">
        <Grid.RowDefinitions>
            <RowDefinition Height="2" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="2" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="2" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="2" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        Margin="1,0,0,3"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <dxe:ButtonEdit Width="90"
                                Margin="0,0,2,0"
                                AllowDefaultButton="False"
                                Background="#171718"
                                CharacterCasing="Upper"
                                EditValue="{Binding Underlying, UpdateSourceTrigger=PropertyChanged}"
                                EditValuePostDelay="0"
                                SelectAllOnGotFocus="True"
                                SelectAllOnMouseUp="True"
                                TabIndex="1">
                    <dxe:ButtonEdit.Buttons>
                        <dxe:ButtonInfo Command="{Binding SearchUnderlyingCommand}"
                                        GlyphKind="Search"
                                        IsDefaultButton="True" />
                    </dxe:ButtonEdit.Buttons>
                </dxe:ButtonEdit>
                <Border Width="65"
                        Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1">
                    <DockPanel>
                        <Label Padding="3,0,2,0"
                               VerticalContentAlignment="Center"
                               Background="#171718"
                               Content="HEDGE"
                               FontSize="9" />
                        <TextBlock Padding="1,3,3,3"
                                   Background="#171718"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding HedgedStocks, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding HedgedStocks, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                   TextAlignment="Right" />
                    </DockPanel>
                </Border>
                <Border Width="65"
                        Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1">
                    <DockPanel>
                        <Label Padding="3,0,2,0"
                               VerticalContentAlignment="Center"
                               Background="#171718"
                               Content="REQ"
                               FontSize="9" />
                        <TextBlock Padding="1,3,3,3"
                                   Background="#171718"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding RequiredStocks, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RequiredStocks, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                   TextAlignment="Right" />
                    </DockPanel>
                </Border>
                <Border Width="75"
                        Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1">
                    <DockPanel>
                        <Label Padding="3,0,2,0"
                               VerticalContentAlignment="Center"
                               Content="U PnL"
                               FontSize="9" />
                        <TextBlock Padding="1,3,3,3"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding UnrealizedPnl, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding UnrealizedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                   TextAlignment="Right" />

                    </DockPanel>
                </Border>

                <Border Width="50"
                        Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1">
                    <DockPanel>
                        <Label Padding="3,0,2,0"
                               VerticalContentAlignment="Center"
                               Content="Pos"
                               FontSize="9" />
                        <TextBlock Padding="1,3,3,3"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding SingleOrderTicketPosition, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding SingleOrderTicketPosition, Converter={StaticResource DoubleFormatter}}"
                                   TextAlignment="Right" />

                    </DockPanel>
                </Border>

                <Border Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <dxe:CheckEdit Grid.Column="0"
                                       Width="60"
                                       Padding="3,0,2,0"
                                       VerticalContentAlignment="Center"
                                       Content="Stop Loss"
                                       EditValue="{Binding SingleOrderTicketStopLossEnabled, UpdateSourceTrigger=PropertyChanged}"
                                       FontSize="9" />

                        <Grid Grid.Column="1"
                              Visibility="{Binding SingleOrderTicketStopLossEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <dxe:CheckEdit Width="60"
                                           Padding="3,0,2,0"
                                           VerticalContentAlignment="Center"
                                           Content="Stop Loss"
                                           EditValue="{Binding SingleOrderTicketStopLossEnabled, UpdateSourceTrigger=PropertyChanged}"
                                           FontSize="9" />

                            <dx:SimpleButton Grid.Column="1"
                                             Width="20"
                                             Background="Transparent"
                                             BorderThickness="0.5,0"
                                             ButtonKind="Toggle"
                                             Glyph="{Binding SingleOrderTicketStopLossUsePercentage, Converter={StaticResource CashPercentageToGlyphConverter}}"
                                             GlyphHeight="15"
                                             GlyphWidth="15"
                                             IsChecked="{Binding SingleOrderTicketStopLossUsePercentage}"
                                             IsEnabled="{Binding SingleOrderTicketStopLossEnabled}" />

                            <dxe:SpinEdit Grid.Column="2"
                                          Width="65"
                                          HorizontalAlignment="Left"
                                          AllowSpinOnMouseWheel="True"
                                          BorderThickness="0.5,0"
                                          EditValue="{Binding SingleOrderTicketStopLoss}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment=".01"
