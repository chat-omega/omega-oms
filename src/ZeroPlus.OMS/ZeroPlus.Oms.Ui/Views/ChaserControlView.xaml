<UserControl x:Class="ZeroPlus.Oms.Ui.Views.ChaserControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:ChaserControlModel}"
             d:DesignHeight="450"
             d:DesignWidth="350"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Padding="5"
                BorderBrush="#3f3f46"
                BorderThickness="1">

            <Grid Margin="5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="0" />
                </Grid.ColumnDefinitions>
                <Label Grid.Row="1"
                       Grid.Column="1"
                       Width="75"
                       Margin="5,2,0,0"
                       Content="Spook Price" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="2"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding SpookPrice, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment=".01"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="1"
                       Grid.Column="3"
                       Width="90"
                       Margin="5,2,0,0"
                       Content="Chase Increment" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="4"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding ChaseIncrement, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment=".01"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="2"
                       Grid.Column="1"
                       Width="75"
                       Margin="5,2,0,0"
                       Content="Initial Delay" />

                <dxe:SpinEdit Grid.Row="2"
                              Grid.Column="2"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding InitialDelayMs, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="2"
                       Grid.Column="3"
                       Width="90"
                       Margin="5,2,0,0"
                       Content="Max Dup Retries" />

                <dxe:SpinEdit Grid.Row="2"
                              Grid.Column="4"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding MaxDuplicateRetries, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              MaxValue="10"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </Grid>
        </Border>

        <GroupBox Grid.Row="1"
                  Padding="0"
                  Header="Offset">
            <Grid Margin="5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="0" />
                </Grid.ColumnDefinitions>
                <Label Grid.Row="1"
                       Grid.Column="1"
                       Width="75"
                       Margin="5,2,0,0"
                       Content="Work Delay" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="2"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding OffsetWorkTtl, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="1"
                       Grid.Column="3"
                       Width="90"
                       Margin="5,2,0,0"
                       Content="Profit Ticks" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="4"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding OffsetProfitTicks, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              MaxValue="10000"
                              MinValue="-10000"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dxe:CheckEdit Grid.Row="2"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="5,2,0,0"
                               Content="If Payup Adj Theo"
                               EditValue="{Binding AdjTheoMode, UpdateSourceTrigger=PropertyChanged}" />

                <Label Grid.Row="2"
                       Grid.Column="3"
                       Width="90"
                       Margin="5,2,0,0"
                       Content="Adj Theo Px" />

                <dxe:SpinEdit Grid.Row="2"
                              Grid.Column="4"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding PayupAdjTheoPx, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment=".01"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="2"
                  Grid.Column="0"
                  Margin="0,0,0,0"
                  Padding="0"
                  Header="Chase">
            <StackPanel Margin="5,0"
                        Orientation="Horizontal">
                <Label Width="75"
                       Margin="5,2,0,0"
                       Content="Work Delay" />

                <dxe:SpinEdit Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding ChaseTtl, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>
        </GroupBox>
        <GroupBox Grid.Row="3"
                  Padding="0"
                  Header="Scratch">
            <StackPanel Margin="5,0"
                        Orientation="Horizontal">
                <Label Width="75"
                       Margin="5,2,0,0"
                       Content="Work Delay" />

                <dxe:SpinEdit Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding ScratchTtl, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>
        </GroupBox>
        <GroupBox Grid.Row="4"
                  Padding="0"
                  Header="Trade Out">
            <StackPanel>
                <StackPanel Margin="5,0"
                            Orientation="Horizontal">
                    <Label Width="75"
                           Margin="5,2,0,0"
                           Content="Trade Out TTL" />

                    <dxe:SpinEdit Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding TradeOutTtl, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  MinValue="0"
                                  PreviewMouseUp="SpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Width="90"
                           Margin="5,2,0,0"
                           Content="Trade Out Ticks" />

                    <dxe:SpinEdit Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding TradeOutTicks, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  MaxValue="100"
                                  MinValue="0"
                                  PreviewMouseUp="SpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />
                </StackPanel>
                <StackPanel Margin="5,0"
                            Orientation="Horizontal">

                    <dxe:CheckEdit Width="150"
                                   Margin="5,2,0,0"
                                   Content="SWEEP on NBBO Cross"
                                   EditValue="{Binding SweepOnTradeoutMode, UpdateSourceTrigger=PropertyChanged}" />

                    <Label Width="90"
                           Margin="5,2,0,0"
                           Content="SWEEP TTL" />

                    <dxe:SpinEdit Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding TradeOutSweepTTL, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  MaxValue="100"
                                  MinValue="0"
                                  PreviewMouseUp="SpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />
                </StackPanel>
            </StackPanel>
        </GroupBox>
    </Grid>

</UserControl>
