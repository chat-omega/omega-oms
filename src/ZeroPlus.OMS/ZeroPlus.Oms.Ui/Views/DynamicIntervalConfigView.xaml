<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.DynamicIntervalConfigView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Dynamic Interval - Editor"
                 Width="1200"
                 Height="500"
                 MinWidth="800"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:DynamicIntervalConfigViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:DynamicIntervalConfigViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="RowStyle"
               TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="#1D3C52" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="#1D3C52" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Label Margin="5,0,0,0"
                   Content="Title" />

            <dxe:TextEdit Grid.Column="1"
                          Margin="5,0,0,0"
                          Text="{Binding Model.Title}" />

            <dx:SimpleButton Grid.Column="2"
                             Width="120"
                             Margin="5,0,0,0"
                             Command="{Binding SaveCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Outlook Inspired/Save.svg}"
                             GlyphHeight="15" />

            <dx:SimpleButton Grid.Column="3"
                             Width="120"
                             Margin="5,0,0,0"
                             Command="{Binding SaveAndLoadCommand}"
                             Content="Save And Load"
                             Glyph="{dx:DXImage SvgImages/RichEdit/SelectTableRow.svg}"
                             GlyphHeight="15" />
        </Grid>

        <Grid Grid.Row="2"
              Grid.Column="1"
              Margin="5,2,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0"
                   Grid.Column="0"
                   Content="Default Interval" />

            <dxe:SpinEdit Grid.Row="0"
                          Grid.Column="1"
                          Width="70"
                          Margin="5,0,0,0"
                          HorizontalContentAlignment="Right"
                          AllowSpinOnMouseWheel="True"
                          BorderThickness="0"
                          EditValue="{Binding Model.DefaultInterval, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          Increment="1"
                          Mask="N2"
                          MaskUseAsDisplayFormat="True"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

            <Label Grid.Row="0"
                   Grid.Column="2"
                   Margin="5,0,0,0"
                   Content="Default Resubmit" />

            <dxe:SpinEdit Grid.Row="0"
                          Grid.Column="3"
                          Width="70"
                          Margin="5,0,0,0"
                          HorizontalContentAlignment="Right"
                          AllowSpinOnMouseWheel="True"
                          BorderThickness="0"
                          EditValue="{Binding Model.DefaultResubmit, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Int32}"
                          Increment="1"
                          Mask="N0"
                          MaskUseAsDisplayFormat="True"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />
        </Grid>

        <dxg:GridControl Name="IntervalGrid"
                         Grid.Row="3"
                         Grid.Column="1"
                         Margin="0,2,0,0"
                         dx:DXSerializer.StoreLayoutMode="All"
                         dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                         AutoGenerateColumns="None"
                         EnableSmartColumnsGeneration="True"
                         ItemsSource="{Binding Model.IntervalTable}"
                         SelectionMode="Row">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView Name="IntervalTable"
                               AllowDragDrop="True"
                               AutoWidth="True"
                               EditorShowMode="MouseUp"
                               EnableSelectedRowAppearance="True"
                               FadeSelectionOnLostFocus="False"
                               RowStyle="{StaticResource RowStyle}"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn Width="20"
                            MinWidth="20"
                            MaxWidth="20"
                            FieldName="Active"
                            Header=""
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Grid>
                            <dxe:CheckEdit HorizontalAlignment="Center"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           IsChecked="{Binding RowData.Row.Active}" />
                        </Grid>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="144"
                            MinWidth="144"
                            MaxWidth="144"
                            FieldName="DeltaRange"
                            Header="Delta Range"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <dxe:SpinEdit Grid.Column="0"
                                          Margin="0,-1,0,-1"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          Background="Transparent"
                                          BorderThickness="0,0,0.5,0"
                                          DisplayFormatString="N2"
                                          EditValue="{Binding RowData.Row.MinDelta, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          Mask="N2"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                            <dxe:SpinEdit Grid.Column="1"
                                          Margin="0,-1,0,-1"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          Background="Transparent"
                                          BorderThickness="0.5,0,0,0"
                                          DisplayFormatString="N2"
                                          EditValue="{Binding RowData.Row.MaxDelta, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          Mask="N2"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </Grid>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Width="72"
                            MinWidth="72"
                            MaxWidth="72"
                            FieldName="AttemptedEdge"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.AttemptedEdge, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="0.01"
                                      Mask="N3"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Width="72"
                            MinWidth="72"
                            MaxWidth="72"
                            FieldName="MinSize"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.MinSize, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Increment="1"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Width="72"
                            MinWidth="72"
                            MaxWidth="72"
                            FieldName="Interval"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.Interval, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="1"
                                      Mask="N2"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="72"
                            MinWidth="72"
                            MaxWidth="72"
                            FieldName="ResubmitCount"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.ResubmitCount, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Increment="1"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Width="92"
                            MinWidth="92"
                            MaxWidth="92"
                            AllowCellMerge="False"
                            FieldName="Route"
                            Header="Route"
                            IsSmart="True"
                            ReadOnly="False"
                            Visible="True">
                <dxg:GridColumn.CellEditTemplate>
                    <DataTemplate>
                        <dxe:TextEdit VerticalAlignment="Center"
                                      BorderBrush="#333337"
                                      BorderThickness="0"
                                      Text="{Binding RowData.Row.Route}" />
                    </DataTemplate>
                </dxg:GridColumn.CellEditTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Width="20"
                            MinWidth="20"
                            MaxWidth="20"
                            FieldName="DisableRounding"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Grid>
                            <dxe:CheckEdit HorizontalAlignment="Center"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           IsChecked="{Binding RowData.Row.DisableRounding}" />
                        </Grid>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="20"
                            MinWidth="20"
                            MaxWidth="20"
                            FieldName="Delete"
                            Header=""
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Padding="0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Command="{Binding View.DataContext.RemoveCommand}"
                                         CommandParameter="{Binding RowData.Row}"
                                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Delete.svg}"
                                         GlyphWidth="15" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>

        <StackPanel Grid.Row="4"
                    Grid.Column="1"
                    Margin="5,5,5,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">

            <dx:SimpleButton Width="150"
                             Margin="5,0"
                             Command="{Binding AddCommand}"
                             Content="Add" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>