                                            <MenuItem HorizontalContentAlignment="Center"
                                                      Command="{Binding View.DataContext.KillAllForInstanceCommand}"
                                                      CommandParameter="{Binding RowData.Row}"
                                                      Header="Kill All" />
                                        </ContextMenu>
                                    </dx:SimpleButton.ContextMenu>
                                </dx:SimpleButton>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="100"
                                    MinWidth="100"
                                    MaxWidth="100"
                                    AllowSorting="False"
                                    FieldName="RunInTestMode"
                                    FixedWidth="True"
                                    Header="Test Mode"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:ToggleSwitch Background="Transparent"
                                                  BorderThickness="0"
                                                  CheckedStateContent="On"
                                                  ContentPlacement="Inside"
                                                  IsChecked="{Binding RowData.Row.RunInTestMode}"
                                                  IsEnabled="{Binding RowData.Row.IsRunning, Converter={StaticResource BooleanNegationConverter}}"
                                                  ToggleSwitchWidth="100"
                                                  UncheckedStateContent="Off" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="20"
                                    AllowSorting="False"
                                    FieldName="Remove"
                                    FixedWidth="True"
                                    Header="Remove"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.HeaderTemplate>
                            <DataTemplate />
                        </dxg:GridColumn.HeaderTemplate>
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton Background="Transparent"
                                                 BorderThickness="0"
                                                 Command="{Binding View.DataContext.RemoveInstanceCommand}"
                                                 CommandParameter="{Binding RowData.Row}"
                                                 Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                 GlyphWidth="19" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>
                <dxg:GridControlBand>
                    <dxg:GridColumn FieldName="Message"
                                    Header="Message"
                                    Visible="True" />
                </dxg:GridControlBand>
            </dxg:GridControl.Bands>
        </dxg:GridControl>
    </Grid>
</view:ModuleWindow>
