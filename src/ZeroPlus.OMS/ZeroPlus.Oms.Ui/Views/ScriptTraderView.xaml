<view:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.ScriptTraderView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                   xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                   xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                   xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                   xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                   xmlns:sys="clr-namespace:System;assembly=mscorlib"
                   xmlns:view="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                   Title="{Binding ModuleTitle}"
                   Width="1200"
                   Height="1000"
                   MinWidth="400"
                   MinHeight="300"
                   d:DataContext="{d:DesignInstance Type=viewModels:ScriptTraderViewModel}"
                   DataContext="{startuphelpers:DISource Type=viewModels:ScriptTraderViewModel}"
                   WindowStartupLocation="CenterScreen"
                   mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <view:ModuleWindow.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:BooleanToGridColumnVisibilityConverter x:Key="BooleanToGridColumnVisibilityConverter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#f4241e"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#fefdff" />
        <helper:SignToBrushConverter x:Key="TitleSignToBrushConverter"
                                     NegativeBrush="#f4241e"
                                     PositiveBrush="#32ce4a"
                                     ZeroBrush="#fefdff" />
        <helper:SignToBrushConverter x:Key="CountdownToBrushConverter"
                                     Limit="3"
                                     NegativeBrush="#497427"
                                     PositiveBrush="#2d2d30"
                                     ZeroBrush="#497427" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToStatusColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Green" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="DarkRed" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TraderStateTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                RUNNING
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                STOPPED
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
    </view:ModuleWindow.Resources>

    <view:ModuleWindow.HeaderItems>
        <view:ModuleHeaderItems />
    </view:ModuleWindow.HeaderItems>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="5,2"
                BorderBrush="#3f3f46"
                BorderThickness=".75">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding SubscribeToQuotes, Converter={StaticResource BooleanToGridColumnVisibilityConverter}}" />
                    <ColumnDefinition Width="{Binding SubscribeToQuotes, Converter={StaticResource BooleanToGridColumnVisibilityConverter}}" />
                    <ColumnDefinition Width="{Binding SubscribeToQuotes, Converter={StaticResource BooleanToGridColumnVisibilityConverter}}" />
                    <ColumnDefinition Width="{Binding SubscribeToGreeks, Converter={StaticResource BooleanToGridColumnVisibilityConverter}}" />
                    <ColumnDefinition Width="{Binding SubscribeToGreeks, Converter={StaticResource BooleanToGridColumnVisibilityConverter}}" />
                    <ColumnDefinition Width="{Binding SubscribeToEma, Converter={StaticResource BooleanToGridColumnVisibilityConverter}}" />
                    <ColumnDefinition Width="{Binding SubscribeToMacd, Converter={StaticResource BooleanToGridColumnVisibilityConverter}}" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0"
                       Grid.Column="0"
                       HorizontalAlignment="Center"
                       Content="BID"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0"
                       Visibility="{Binding SubscribeToQuotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Label Grid.Row="0"
                       Grid.Column="1"
                       HorizontalAlignment="Center"
                       Content="MID"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0"
                       Visibility="{Binding SubscribeToQuotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Label Grid.Row="0"
                       Grid.Column="2"
                       HorizontalAlignment="Center"
                       Content="ASK"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0"
                       Visibility="{Binding SubscribeToQuotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Label Grid.Row="0"
                       Grid.Column="3"
                       HorizontalAlignment="Center"
                       Content="DELTA"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0"
                       Visibility="{Binding SubscribeToGreeks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Label Grid.Row="0"
                       Grid.Column="4"
                       HorizontalAlignment="Center"
                       Content="THEO"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0"
                       Visibility="{Binding SubscribeToGreeks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Label Grid.Row="0"
                       Grid.Column="5"
                       HorizontalAlignment="Center"
                       Content="EMA"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0"
                       Visibility="{Binding SubscribeToEma, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Label Grid.Row="0"
                       Grid.Column="6"
                       HorizontalAlignment="Center"
                       Content="MACD"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0"
                       Visibility="{Binding SubscribeToMacd, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Label Grid.Row="0"
                       Grid.Column="7"
                       HorizontalAlignment="Center"
                       Content="POS"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0" />
                <Label Grid.Row="0"
                       Grid.Column="8"
                       HorizontalAlignment="Center"
                       Content="WORKING"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0" />
                <Label Grid.Row="0"
                       Grid.Column="9"
                       HorizontalAlignment="Center"
                       Content="REAL PnL"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0" />
                <Label Grid.Row="0"
                       Grid.Column="10"
                       HorizontalAlignment="Center"
                       Content="UNREAL PnL"
                       FontWeight="DemiBold"
                       Foreground="#AFAFB0" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Text="{Binding Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                           Visibility="{Binding SubscribeToQuotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Text="{Binding Mid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                           Visibility="{Binding SubscribeToQuotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Text="{Binding Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                           Visibility="{Binding SubscribeToQuotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="3"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Text="{Binding Delta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Greek}}"
                           Visibility="{Binding SubscribeToGreeks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="4"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Text="{Binding Theo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                           Visibility="{Binding SubscribeToGreeks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="5"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Text="{Binding Ema, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                           Visibility="{Binding SubscribeToEma, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="6"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Text="{Binding Macd, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N6}}"
                           Visibility="{Binding SubscribeToMacd, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="7"
                              HorizontalAlignment="Center"
                              AllowSpinOnMouseWheel="True"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              BorderThickness="0"
                              DisplayFormatString="N0"
                              EditValue="{Binding Position}"
                              EditValueType="{x:Type sys:Int32}"
                              FontWeight="Bold"
                              Foreground="#00A8FF"
                              Increment="1"
                              IsReadOnly="{Binding IsRunning}"
                              Mask="N0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True"
                              ShowEditorButtons="False" />
                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="8"
                              HorizontalAlignment="Center"
                              AllowSpinOnMouseWheel="True"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              BorderThickness="0"
                              DisplayFormatString="N0"
                              EditValue="{Binding WorkingQty}"
                              EditValueType="{x:Type sys:Int32}"
                              FontWeight="Bold"
                              Foreground="{Binding WorkingQty, Converter={StaticResource SignToBrushConverter}}"
                              Increment="1"
                              IsReadOnly="{Binding IsRunning}"
                              Mask="N0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True"
                              ShowEditorButtons="False" />
                <TextBlock Grid.Row="1"
                           Grid.Column="9"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="{Binding RealPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                           Text="{Binding RealPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="10"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="{Binding UnrealPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                           Text="{Binding UnrealPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="1"
                Margin="0,5,0,0"
                Padding="5,2"
                BorderBrush="#3f3f46"
                BorderThickness=".75">
            <Grid Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <DockPanel>
                    <Label Content="Trade Type" />

                    <dxe:ComboBoxEdit Width="105"
                                      Margin="5,0,0,0"
                                      AllowDefaultButton="{Binding IsRunning, Converter={StaticResource BooleanNegationConverter}}"
                                      ApplyItemTemplateToSelectedItem="True"
                                      IsReadOnly="{Binding IsRunning}"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding ScriptTradeTypes}"
                                      PopupOpened="ReadonlyPopupOpened"
                                      SelectedItem="{Binding ScriptTradeType}"
                                      ShowEditorButtons="{Binding IsRunning, Converter={StaticResource BooleanNegationConverter}}">
                        <dxe:ComboBoxEdit.ItemTemplate>
                            <DataTemplate>
                                <Label Padding="0,1"
                                       HorizontalAlignment="Center"
                                       Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}" />
                            </DataTemplate>
                        </dxe:ComboBoxEdit.ItemTemplate>
                    </dxe:ComboBoxEdit>

                    <Label Margin="5,0,0,0"
                           Content="Symbol" />

                    <dxe:ButtonEdit Margin="5,0,0,0"
                                    AllowDefaultButton="False"
                                    CharacterCasing="Upper"
                                    EditValue="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                                    EditValuePostDelay="0"
                                    IsReadOnly="{Binding IsRunning}"
                                    SelectAllOnGotFocus="True"
                                    SelectAllOnMouseUp="True"
                                    TabIndex="1">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:KeyToCommand Command="{Binding LoadCommand}"
                                                 KeyGesture="Enter" />
                        </dxmvvm:Interaction.Behaviors>
                        <dxe:ButtonEdit.Buttons>
                            <dxe:ButtonInfo Command="{Binding LoadCommand}"
                                            GlyphKind="Search"
                                            IsDefaultButton="True" />
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>
                </DockPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Label Margin="5,0,0,0"
                           Content="Quantity" />

                    <dxe:SpinEdit Width="75"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding Qty, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsReadOnly="{Binding IsRunning}"
                                  Mask="N0"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  ShowEditorButtons="{Binding IsRunning, Converter={StaticResource BooleanNegationConverter}}" />

                    <dx:SimpleButton Width="75"
                                     Margin="5,0,0,0"
                                     Command="{Binding StartCommand}"
                                     Content="Start"
                                     Foreground="#7ac142"
                                     Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"
                                     GlyphHeight="16"
                                     IsEnabled="{Binding IsReady}" />

                    <dx:SimpleButton Width="75"
                                     Margin="5,0,0,0"
                                     Command="{Binding StopCommand}"
                                     Content="Stop"
                                     Foreground="#5680c0"
                                     Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Stop.svg}"
                                     GlyphHeight="16"
                                     IsEnabled="{Binding IsReady}" />

                    <dx:SimpleButton Width="75"
                                     Margin="5,0,0,0"
                                     Command="{Binding ClosePositionsCommand}"
                                     Content="Close Pos"
                                     IsEnabled="{Binding IsReady}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3"
              Grid.Column="1"
              Margin="0,5,0,0">
            <dx:DXTabControl>
                <dx:DXTabItem>
                    <dx:DXTabItem.Header>
                        <TextBlock Width="100"
                                   FontWeight="DemiBold"
                                   Text="Execution Control" />
                    </dx:DXTabItem.Header>
                    <dx:DXTabItem.GlyphTemplate>
                        <DataTemplate>
                            <Image Width="15"
                                   Height="15"
                                   Margin="0,0,5,0"
                                   Source="{dx:DXImage 'SvgImages/Scheduling/ViewSettings.svg'}" />
                        </DataTemplate>
                    </dx:DXTabItem.GlyphTemplate>
                    <Grid Margin="-12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="auto"
                                              MinWidth="215"
                                              MaxWidth="250" />
                            <ColumnDefinition Width="0" />
                        </Grid.ColumnDefinitions>

                        <dxlc:GroupBox Grid.Row="1"
                                       Grid.Column="1"
                                       Padding="0"
                                       BorderThickness="0">
                            <dxlc:GroupBox.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                Height="22"
                                                HorizontalAlignment="Left"
                                                Orientation="Horizontal">
                                        <dx:DXImage Grid.Column="0"
                                                    Height="15"
                                                    HorizontalAlignment="Right"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    Source="{dx:DXImage 'SvgImages/RichEdit/ShowAllFieldCodes.svg'}" />

                                        <Label Margin="5,0,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Content="Entry Script"
                                               Foreground="#AFAFB0"
                                               IsHitTestVisible="False" />

                                        <dx:SimpleButton Width="22"
                                                         Margin="5,0,0,0"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Command="{Binding ExpandScriptCommand}"
                                                         CommandParameter="{Binding EntryScript}"
                                                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Window.svg}"
                                                         GlyphHeight="17" />

                                        <Grid Margin="5,0">
                                            <dx:DXImage Grid.Row="1"
                                                        Grid.Column="10"
                                                        Height="15"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        RenderOptions.BitmapScalingMode="HighQuality"
                                                        Source="{dx:DXImage 'SvgImages/Icon Builder/Security_WarningCircled2.svg'}"
                                                        ToolTip="{Binding EntryScriptError}"
                                                        Visibility="{Binding EntryScriptReady, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                                                <dx:WpfSvgPalette.Palette>
                                                    <dx:WpfSvgPalette OverridesThemeColors="True">
                                                        <SolidColorBrush x:Key="Red"
                                                                         Color="Red" />
                                                    </dx:WpfSvgPalette>
                                                </dx:WpfSvgPalette.Palette>
                                            </dx:DXImage>

                                            <dx:DXImage Grid.Row="1"
                                                        Grid.Column="10"
                                                        Height="15"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        RenderOptions.BitmapScalingMode="HighQuality"
                                                        Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_CheckCircled.svg'}"
                                                        Visibility="{Binding EntryScriptReady, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding EntryScriptTriggerType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Timer'}">
                                        <dx:DXImage Grid.Column="0"
                                                    Height="15"
                                                    HorizontalAlignment="Right"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    Source="{dx:DXImage SvgImages/Outlook Inspired/NotStarted.svg}" />
                                        <Border Grid.Row="15"
                                                Grid.Column="1"
                                                Width="95"
                                                BorderBrush="#3F3F46"
                                                BorderThickness="1"
                                                CornerRadius="2">
                                            <TextBlock Padding="0,1"
                                                       Background="{Binding EntryScriptCountDown.TotalSeconds, Converter={StaticResource CountdownToBrushConverter}}"
                                                       FontFamily="{StaticResource Technology}"
                                                       FontSize="18"
                                                       Text="{Binding EntryScriptCountDown, StringFormat='{}{0:hh\\:mm\\:ss\\.fff}'}"
                                                       TextAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </dxlc:GroupBox.Header>

                            <avalonEdit:TextEditor Name="entryScriptEditor"
                                                   Document="{Binding EntryScript, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                   FontFamily="Consolas"
                                                   FontSize="10pt"
                                                   HorizontalScrollBarVisibility="Auto"
                                                   ShowLineNumbers="True"
                                                   SyntaxHighlighting="Python"
                                                   VerticalScrollBarVisibility="Auto" />
                        </dxlc:GroupBox>

                        <GridSplitter Grid.Row="1"
                                      Grid.RowSpan="5"
                                      Grid.Column="2"
                                      Width="1"
                                      Margin="0,14,0,0"
                                      HorizontalAlignment="Stretch"
                                      Background="#AFAFB0" />

                        <ScrollViewer Grid.Row="1"
                                      Grid.RowSpan="5"
                                      Grid.Column="3"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <dxlc:GroupBox Padding="0"
                                               BorderThickness="0">
                                    <dxlc:GroupBox.Header>
                                        <StackPanel Height="22"
                                                    HorizontalAlignment="Center"
                                                    Orientation="Horizontal">
                                            <dx:DXImage Grid.Column="0"
                                                        Height="15"
                                                        HorizontalAlignment="Right"
                                                        RenderOptions.BitmapScalingMode="HighQuality"
                                                        Source="{dx:DXImage 'SvgImages/Icon Builder/Weather_Lightning.svg'}" />

                                            <Label Width="70"
                                                   Margin="3,0,0,0"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   HorizontalContentAlignment="Center"
                                                   Content="Triggers"
                                                   FontWeight="DemiBold"
                                                   Foreground="#AFAFB0"
                                                   IsHitTestVisible="False" />
                                        </StackPanel>
                                    </dxlc:GroupBox.Header>

                                    <Grid Margin="0,0,0,2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="auto" />
                                        </Grid.ColumnDefinitions>

                                        <Label Grid.Row="0"
                                               Grid.Column="0"
                                               Width="90"
                                               Margin="5,2,0,0"
                                               Content="Entry Trigger" />

                                        <dxe:ComboBoxEdit Grid.Row="0"
                                                          Grid.Column="1"
                                                          Width="125"
                                                          Margin="5,2,0,0"
                                                          ApplyItemTemplateToSelectedItem="True"
                                                          IsTextEditable="False"
                                                          ItemsSource="{Binding ScriptTriggerTypes}"
                                                          SelectedItem="{Binding EntryScriptTriggerType}">
                                            <dxe:ComboBoxEdit.ItemTemplate>
                                                <DataTemplate>
                                                    <Label Padding="0,1"
                                                           HorizontalAlignment="Center"
                                                           Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}" />
                                                </DataTemplate>
                                            </dxe:ComboBoxEdit.ItemTemplate>
                                        </dxe:ComboBoxEdit>

                                        <Label Grid.Row="1"
                                               Grid.Column="0"
                                               Width="90"
                                               Margin="5,2,0,0"
                                               Content="Entry Timer"
                                               Visibility="{Binding EntryScriptTriggerType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Timer'}" />

                                        <dxe:SpinEdit Grid.Row="1"
                                                      Grid.Column="1"
                                                      Margin="5,2,0,0"
                                                      HorizontalContentAlignment="Right"
                                                      AllowSpinOnMouseWheel="True"
                                                      EditValue="{Binding EntryInterval, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                                      EditValueType="{x:Type sys:Int32}"
                                                      Increment="1"
                                                      Mask="N0"
                                                      MaskUseAsDisplayFormat="True"
                                                      MinValue="0"
                                                      PreviewMouseUp="SelectAll"
                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True"
                                                      Visibility="{Binding EntryScriptTriggerType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Timer'}" />

                                        <Label Grid.Row="2"
                                               Grid.Column="0"
                                               Width="90"
                                               Margin="5,2,0,0"
                                               Content="Exit Trigger" />

                                        <dxe:ComboBoxEdit Grid.Row="2"
                                                          Grid.Column="1"
                                                          Width="125"
                                                          Margin="5,2,0,0"
                                                          ApplyItemTemplateToSelectedItem="True"
                                                          IsTextEditable="False"
                                                          ItemsSource="{Binding ScriptTriggerTypes}"
                                                          SelectedItem="{Binding ExitScriptTriggerType}">
                                            <dxe:ComboBoxEdit.ItemTemplate>
                                                <DataTemplate>
