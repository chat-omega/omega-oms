                                                        RenderOptions.BitmapScalingMode="HighQuality"
                                                        Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_CheckCircled.svg'}"
                                                        Visibility="{Binding StopLossScriptReady, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding StopLossScriptTriggerType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Timer'}">
                                        <dx:DXImage Grid.Column="0"
                                                    Height="15"
                                                    HorizontalAlignment="Right"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    Source="{dx:DXImage SvgImages/Outlook Inspired/NotStarted.svg}" />
                                        <Border Grid.Row="15"
                                                Grid.Column="1"
                                                Width="95"
                                                BorderBrush="#3F3F46"
                                                BorderThickness="1"
                                                CornerRadius="2">
                                            <TextBlock Padding="0,1"
                                                       Background="{Binding StopLossScriptCountDown.TotalSeconds, Converter={StaticResource CountdownToBrushConverter}}"
                                                       FontFamily="{StaticResource Technology}"
                                                       FontSize="18"
                                                       Text="{Binding StopLossScriptCountDown, StringFormat='{}{0:hh\\:mm\\:ss\\.fff}'}"
                                                       TextAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </dxlc:GroupBox.Header>

                            <avalonEdit:TextEditor Name="stopLossScriptEditor"
                                                   Document="{Binding StopLossScript, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                   FontFamily="Consolas"
                                                   FontSize="10pt"
                                                   HorizontalScrollBarVisibility="Auto"
                                                   ShowLineNumbers="True"
                                                   SyntaxHighlighting="Python"
                                                   VerticalScrollBarVisibility="Auto" />
                        </dxlc:GroupBox>
                    </Grid>
                </dx:DXTabItem>
                <dx:DXTabItem>
                    <dx:DXTabItem.Header>
                        <TextBlock Width="100"
                                   FontWeight="DemiBold"
                                   Text="Order Book" />
                    </dx:DXTabItem.Header>
                    <dx:DXTabItem.GlyphTemplate>
                        <DataTemplate>
                            <Image Width="15"
                                   Height="15"
                                   Margin="0,0,5,0"
                                   Source="{dx:DXImage 'SvgImages/Dashboards/BandedRows.svg'}" />
                        </DataTemplate>
                    </dx:DXTabItem.GlyphTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="0" />
                        </Grid.ColumnDefinitions>

                        <dxg:GridControl x:Name="PairOrdersGrid"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         MinHeight="70"
                                         MaxHeight="5000"
                                         Margin="0,2,0,5"
                                         HorizontalAlignment="Center"
                                         AutoGenerateColumns="AddNew"
                                         CurrentItem="{Binding LastPairOrder}"
                                         ItemsSource="{Binding PairOrders}"
                                         Visibility="{Binding ScriptTradeType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='StockPair'}">
                            <dxg:GridControl.Resources>
                                <Style TargetType="dxg:GridColumn">
                                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                                    <Setter Property="Visible" Value="False" />
                                </Style>
                                <Style x:Key="OrderRowStyle"
                                       TargetType="dxg:RowControl">
                                    <Style.Setters>
                                        <Setter Property="FontWeight" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='FONTWEIGHT'}" />
                                        <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Background'}" />
                                        <Setter Property="Foreground" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Foreground'}" />
                                    </Style.Setters>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=IsSelected}"
                                                     Value="True">
                                            <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                                        </DataTrigger>
                                        <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                            <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='MouseOver'}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </dxg:GridControl.Resources>
                            <dxg:GridControl.View>
                                <dxg:TableView Name="PairOrdersTableView"
                                               AllowEditing="False"
                                               AllowGrouping="False"
                                               AutoWidth="True"
                                               FadeSelectionOnLostFocus="False"
                                               RowStyle="{StaticResource OrderRowStyle}"
                                               ShowGroupPanel="False"
                                               ShowIndicator="True"
                                               VerticalScrollbarVisibility="Auto">
                                    <dxg:TableView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowColumnChooserCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Column Chooser">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ClearColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Hide All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowAllColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Default Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </dxg:TableView.ContextMenu>
                                </dxg:TableView>
                            </dxg:GridControl.View>
                            <dxg:GridColumn FieldName="SubmitTime"
                                            ReadOnly="True"
                                            Visible="True">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                                          Mask="hh:mm:ss\\.ffff"
                                                          MaskType="DateTime"
                                                          MaskUseAsDisplayFormat="True" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="LastUpdateTime"
                                            Header="Last Time"
                                            ReadOnly="True"
                                            Visible="True">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                                          Mask="hh:mm:ss\\.ffff"
                                                          MaskType="DateTime"
                                                          MaskUseAsDisplayFormat="True" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="Side"
                                            Header="Side"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="Type"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="InitSide"
                                            Header="Init Side"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="Symbol"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.TriggerValue, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="TriggerValue"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.AvgFillPx, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="AvgFillPx"
                                            Header="Avg Px"
                                            ReadOnly="True"
                                            Visible="True">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.PxImprovement, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="PxImprovement"
                                            Header="Px Impr"
                                            ReadOnly="True"
                                            Visible="True">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="Bid"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Mid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="Mid"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="Ask"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.BidEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="BidEma"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.MidEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="MidEma"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.AskEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="AskEma"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.HighestBid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="HighestBid"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.LowestAsk, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                            FieldName="LowestAsk"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="Pnl"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Grid.Column="0"
                                                   Margin="-1"
                                                   Padding="3"
                                                   Background="Transparent"
                                                   Foreground="{Binding RowData.Row.Pnl, Converter={StaticResource SignToBrushConverter}}"
                                                   Text="{Binding RowData.Row.Pnl, Converter={StaticResource DoubleFormatter}}"
                                                   TextAlignment="Right" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="LastEdge"
                                            ReadOnly="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Grid.Column="0"
                                                   Margin="-1"
                                                   Padding="3"
                                                   Background="Transparent"
                                                   Foreground="{Binding RowData.Row.LastEdge, Converter={StaticResource SignToBrushConverter}}"
                                                   Text="{Binding RowData.Row.LastEdge, Converter={StaticResource DoubleFormatter}}"
                                                   TextAlignment="Right" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="TriggerMode"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="ClientOrderId"
                                            ReadOnly="True"
                                            Visible="False" />
                            <dxg:GridColumn FieldName="OrderId"
                                            ReadOnly="True"
                                            Visible="False" />
                            <dxg:GridColumn FieldName="Reason"
                                            ReadOnly="True"
                                            Visible="False" />
                            <dxg:GridColumn FieldName="Quantity"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="Filled"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="Leaves"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="OrderStatus"
                                            ReadOnly="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="Tag"
                                            ReadOnly="True"
                                            Visible="True" />

                            <dxg:GridColumn Width="72"
                                            MinWidth="72"
                                            MaxWidth="72"
                                            AllowSorting="False"
                                            FieldName="Cancel"
                                            Header="Cancel"
                                            IsSmart="False"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dx:SimpleButton BorderThickness="0"
                                                         Command="{Binding View.DataContext.CancelOrderCommand}"
                                                         CommandParameter="{Binding RowData.Row.OrderRequest}"
                                                         Content="Cancel"
                                                         Foreground="#FFFFFF" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>

                            <dxg:GridControl.DetailDescriptor>
                                <dxg:DataControlDetailDescriptor ItemsSourceBinding="{Binding Legs}">
                                    <dxg:DataControlDetailDescriptor.DataControl>
                                        <dxg:GridControl Name="DetailsGrid"
                                                         AutoGenerateColumns="AddNew"
                                                         EnableSmartColumnsGeneration="True"
                                                         SelectionMode="Row">
                                            <dxg:GridControl.Resources>
                                                <dxe:TextEditSettings x:Key="numeric"
                                                                      Mask="##0.00"
                                                                      MaskType="Numeric"
                                                                      MaskUseAsDisplayFormat="True" />
                                                <Style TargetType="dxg:GridColumn">
                                                    <Setter Property="Visible" Value="False" />
                                                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                                                </Style>
                                                <Style x:Key="LegRowStyle"
                                                       TargetType="dxg:RowControl">
                                                    <Style.Setters>
                                                        <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Background'}" />
                                                        <Setter Property="Foreground" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Foreground'}" />
                                                    </Style.Setters>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Path=IsSelected}"
                                                                     Value="True">
                                                            <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                                                        </DataTrigger>
                                                        <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                                            <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='MouseOver'}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </dxg:GridControl.Resources>

                                            <dxg:GridControl.View>
                                                <dxg:TableView AutoWidth="True"
                                                               FadeSelectionOnLostFocus="False"
                                                               RowStyle="{StaticResource LegRowStyle}"
                                                               ShowGroupPanel="False"
                                                               ShowIndicator="True"
                                                               VerticalScrollbarVisibility="Auto">
                                                    <dxg:TableView.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Height="25"
                                                                      Command="{Binding ShowColumnChooserCommand}"
                                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      Header="Show Column Chooser">
                                                                <MenuItem.Icon>
                                                                    <Image Width="15"
                                                                           Height="15"
                                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Height="25"
                                                                      Command="{Binding ClearColumnsCommand}"
                                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      Header="Hide All Columns">
                                                                <MenuItem.Icon>
                                                                    <Image Width="15"
                                                                           Height="15"
                                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Height="25"
                                                                      Command="{Binding ShowAllColumnsCommand}"
                                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      Header="Show All Columns">
                                                                <MenuItem.Icon>
                                                                    <Image Width="15"
                                                                           Height="15"
                                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Height="25"
                                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      Header="Show Default Columns">
                                                                <MenuItem.Icon>
                                                                    <Image Width="15"
                                                                           Height="15"
                                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </dxg:TableView.ContextMenu>
                                                </dxg:TableView>
                                            </dxg:GridControl.View>
                                            <dxg:GridColumn FieldName="LastUpdateTime"
                                                            Header="Time"
                                                            ReadOnly="True"
                                                            Visible="True">
                                                <dxg:GridColumn.EditSettings>
                                                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                                                          Mask="hh:mm:ss\\.ffff"
                                                                          MaskType="DateTime"
                                                                          MaskUseAsDisplayFormat="True" />
                                                </dxg:GridColumn.EditSettings>
                                            </dxg:GridColumn>
                                            <dxg:GridColumn FieldName="Side"
                                                            ReadOnly="True"
                                                            Visible="True" />
                                            <dxg:GridColumn FieldName="Symbol"
                                                            ReadOnly="True"
                                                            Visible="True" />
                                            <dxg:GridColumn FieldName="ClientOrderId"
                                                            ReadOnly="True"
                                                            Visible="True" />
                                            <dxg:GridColumn FieldName="OrderId"
                                                            ReadOnly="True"
                                                            Visible="True" />
                                            <dxg:GridColumn FieldName="Reason"
                                                            ReadOnly="True"
                                                            Visible="True" />
                                            <dxg:GridColumn FieldName="Quantity"
                                                            ReadOnly="True"
                                                            Visible="True" />
                                            <dxg:GridColumn FieldName="Filled"
                                                            ReadOnly="True"
                                                            Visible="True" />
                                            <dxg:GridColumn FieldName="Leaves"
                                                            ReadOnly="True"
                                                            Visible="True" />
                                            <dxg:GridColumn AllowCellMerge="False"
                                                            Binding="{Binding Path=RowData.Row.AvgPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                                            FieldName="AvgPrice"
                                                            IsSmart="True"
                                                            ReadOnly="True"
                                                            Visible="True">
                                                <dxg:GridColumn.EditSettings>
                                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                                </dxg:GridColumn.EditSettings>
                                            </dxg:GridColumn>
                                            <dxg:GridColumn FieldName="OrderStatus"
                                                            ReadOnly="True"
                                                            Visible="True" />
                                        </dxg:GridControl>
                                    </dxg:DataControlDetailDescriptor.DataControl>
                                </dxg:DataControlDetailDescriptor>
                            </dxg:GridControl.DetailDescriptor>
                        </dxg:GridControl>
                    </Grid>
                </dx:DXTabItem>
                <dx:DXTabItem>
                    <dx:DXTabItem.Header>
                        <TextBlock Width="100"
                                   FontWeight="DemiBold"
                                   Text="Console" />
                    </dx:DXTabItem.Header>
                    <dx:DXTabItem.GlyphTemplate>
                        <DataTemplate>
                            <Image Width="15"
                                   Height="15"
                                   Margin="0,0,5,0"
                                   Source="{dx:DXImage 'SvgImages/Icon Builder/Electronics_TV.svg'}" />
                        </DataTemplate>
                    </dx:DXTabItem.GlyphTemplate>
                    <Grid Margin="-5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <dx:SimpleButton Width="75"
                                             Command="{Binding ClearCommand}"
                                             Content="Clear"
                                             Glyph="{dx:DXImage SvgImages/Spreadsheet/ClearPivotTable.svg}"
                                             GlyphHeight="16" />
                            <dxe:CheckEdit x:Name="AutoScrollCheckEdit"
                                           Margin="5,0,0,0"
                                           Content="Auto Scroll" />
                        </StackPanel>
                        <TextBox x:Name="ConsoleTextEdit"
                                 Grid.Row="1"
                                 Margin="0,2,0,0"
                                 VerticalContentAlignment="Top"
                                 AcceptsReturn="True"
                                 FontFamily="Consolas"
                                 IsReadOnly="True"
                                 Text="{Binding ConsoleOutput, Mode=OneWay}"
                                 TextChanged="ConsoleTextEdit_TextChanged"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </dx:DXTabItem>
            </dx:DXTabControl>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Width="100"
                    Margin="5,0,5,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="{Binding IsRunning, Converter={StaticResource BooleanToStatusColorConverter}}"
                    BorderBrush="{Binding IsRunning, Converter={StaticResource BooleanToStatusColorConverter}}"
                    BorderThickness="0.7"
                    CornerRadius="2">
                <TextBlock Padding="5,2"
                           HorizontalAlignment="Center"
                           Background="{Binding IsRunning, Converter={StaticResource BooleanToStatusColorConverter}}"
                           FontWeight="Medium"
                           Foreground="White"
                           Text="{Binding IsRunning, Converter={StaticResource TraderStateTextConverter}}" />
            </Border>

        </Grid>

        <Grid Grid.Row="4"
              Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Height="22"
                       Padding="3,2"
                       Panel.ZIndex="1"
                       Background="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding Status}" />
            <TextBlock Grid.Column="1"
                       Height="22"
                       Padding="3,2"
                       Panel.ZIndex="1"
                       Background="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding ContraStatus}"
                       TextAlignment="Right" />
        </Grid>
    </Grid>
</view:ModuleWindow>
