<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.PermComboEditorView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Perm Combo Editor"
                 Width="700"
                 Height="500"
                 DataContext="{startuphelpers:DISource Type=ViewModels:PermComboEditorViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <dx:ThemedWindow.Resources>
        <helper:PermModeToSettingsStateConverter x:Key="PermModeToSettingsStateConverter" />
    </dx:ThemedWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Width="100"
               HorizontalContentAlignment="Center"
               Content="Title"
               FontWeight="Bold" />

        <dxe:ComboBoxEdit Grid.Row="1"
                          Grid.Column="2"
                          Margin="10,0,0,0"
                          EditValue="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding Titles}">

            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding ConfigLoadedCommand}"
                                       EventName="SelectedIndexChanged" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ComboBoxEdit>

        <dx:SimpleButton Grid.Row="1"
                         Grid.Column="3"
                         Width="120"
                         Margin="5,0,0,0"
                         Command="{Binding AddCommand}"
                         Content="Add Operation"
                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                         GlyphHeight="15"
                         IsDefault="True" />

        <ScrollViewer x:Name="Viewer"
                      Grid.Row="2"
                      Grid.Column="1"
                      Grid.ColumnSpan="4"
                      Margin="0,5,0,0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <ListBox Background="Transparent"
                     ItemsSource="{Binding Combinations}"
                     SelectedItem="{Binding SelectedCombination}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <RadioButton Margin="10,0,0,0"
                                         BorderBrush="#CCCCCC"
                                         GroupName="Properties">
                                <RadioButton.IsChecked>
                                    <Binding Mode="TwoWay"
                                             Path="IsSelected"
                                             RelativeSource="{RelativeSource AncestorType=ListBoxItem}" />
                                </RadioButton.IsChecked>
                            </RadioButton>

                            <DockPanel Grid.Column="1"
                                       Margin="5,0,0,0">
                                <Label Margin="3,0"
                                       Content="Mode - " />

                                <dxe:ComboBoxEdit Name="PermModeBox"
                                                  Grid.Column="5"
                                                  Margin="5,0,0,0"
                                                  BorderBrush="#171718"
                                                  EditValue="{Binding PermMode, UpdateSourceTrigger=PropertyChanged}"
                                                  IsTextEditable="False"
                                                  ItemsSource="{Binding PermModes}" />
                            </DockPanel>

                            <DockPanel Grid.Column="2"
                                       Width="120"
                                       Margin="5,0,0,0"
                                       HorizontalAlignment="Left"
                                       IsEnabled="{Binding ElementName=PermModeBox, Path=EditValue, Converter={StaticResource PermModeToSettingsStateConverter}}">
                                <Label Margin="3,0"
                                       Content="Strike - " />

                                <dxe:ComboBoxEdit Margin="5,0,0,0"
                                                  BorderBrush="#171718"
                                                  FontSize="11"
                                                  IsTextEditable="False"
                                                  ItemsSource="{Binding PermSides}"
                                                  SelectedItem="{Binding PermSide}" />
                            </DockPanel>

                            <DockPanel Grid.Column="3"
                                       Width="100"
                                       Margin="5,0,0,0"
                                       HorizontalAlignment="Left"
                                       IsEnabled="{Binding ElementName=PermModeBox, Path=EditValue, Converter={StaticResource PermModeToSettingsStateConverter}}">
                                <Label Margin="3,0"
                                       Content="Count - " />

                                <dxe:SpinEdit Grid.Column="1"
                                              AllowSpinOnMouseWheel="True"
                                              BorderBrush="#171718"
                                              EditValue="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Mask="d"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DockPanel>

                            <Grid Grid.Column="4"
                                  Margin="5,0,0,0"
                                  IsEnabled="{Binding ElementName=PermModeBox, Path=EditValue, Converter={StaticResource PermModeToSettingsStateConverter}}">
                                <dxe:CheckEdit Margin="5,0"
                                               Content="Maintain Base Strategy"
                                               EditValue="{Binding MaintainBaseStrategy, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <dx:SimpleButton Grid.Column="5"
                                             Width="20"
                                             Margin="5,0,0,0"
                                             VerticalAlignment="Center"
                                             Command="{Binding DataContext.RemoveCommand, ElementName=Viewer}"
                                             CommandParameter="{Binding}"
                                             Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                             GlyphWidth="20" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <StackPanel Grid.Row="3"
                    Grid.Column="1"
                    Grid.ColumnSpan="4"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Grid.Row="1"
                             Grid.Column="3"
                             Width="19"
                             Margin="0,0,5,0"
                             Background="Transparent"
                             Command="{Binding MoveRowDownCommand}"
                             Glyph="{dx:DXImage SvgImages/Arrows/MoveDown.svg}"
                             GlyphHeight="15" />

            <dx:SimpleButton Grid.Row="1"
                             Grid.Column="4"
                             Width="19"
                             Margin="5,0,0,0"
                             Background="Transparent"
                             Command="{Binding MoveRowUpCommand}"
                             Glyph="{dx:DXImage SvgImages/Arrows/MoveUp.svg}"
                             GlyphHeight="15" />
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Grid.Column="1"
                    Grid.ColumnSpan="4"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding SaveCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Save/Save.svg}"
                             GlyphHeight="15"
                             IsDefault="True" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
