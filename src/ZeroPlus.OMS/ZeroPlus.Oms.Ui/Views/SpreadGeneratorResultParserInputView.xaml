<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.SpreadGeneratorResultParserInputView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Parse Config"
                 Width="330"
                 Height="150"
                 DataContext="{startuphelpers:DISource Type=ViewModels:SpreadGeneratorResultParserInputViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Label Grid.Row="1"
               Grid.Column="2"
               HorizontalAlignment="Center"
               Content="Low" />

        <Label Grid.Row="1"
               Grid.Column="4"
               HorizontalAlignment="Center"
               Content="High" />

        <dxe:ComboBoxEdit Grid.Row="2"
                          Width="70"
                          Margin="5,2,0,0"
                          IsTextEditable="False"
                          ItemsSource="{Binding LegTypes}"
                          SelectedItem="{Binding LegType}" />

        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="3,2,0,0"
               Content="leg delta range" />

        <dxe:SpinEdit Grid.Row="2"
                      Grid.Column="2"
                      Width="70"
                      Margin="5,2,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding HighestLegDeltaMinValue, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment=".01"
                      Mask="N2"
                      MaskUseAsDisplayFormat="True"
                      MaxValue="1"
                      MinValue="0"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="2"
               Grid.Column="3"
               Margin="5,0,0,0"
               Content="-" />

        <dxe:SpinEdit Grid.Row="2"
                      Grid.Column="4"
                      Width="70"
                      Margin="5,2,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding HighestLegDeltaMaxValue, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment=".01"
                      Mask="N2"
                      MaskUseAsDisplayFormat="True"
                      MaxValue="1"
                      MinValue="{Binding HighestLegDeltaMinValue}"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="3"
               Grid.Column="0"
               Grid.ColumnSpan="2"
               Margin="5,2,0,0"
               Content="Retained percentage range" />

        <dxe:SpinEdit Grid.Row="3"
                      Grid.Column="2"
                      Width="70"
                      Margin="5,2,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding RetainedPercentageRangeMin, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment=".01"
                      Mask="N2"
                      MaskUseAsDisplayFormat="True"
                      MaxValue="1"
                      MinValue="0"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="3"
               Grid.Column="3"
               Margin="5,0,0,0"
               Content="-" />

        <dxe:SpinEdit Grid.Row="3"
                      Grid.Column="4"
                      Width="70"
                      Margin="5,2,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding RetainedPercentageRangeMax, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment=".01"
                      Mask="N2"
                      MaskUseAsDisplayFormat="True"
                      MaxValue="1"
                      MinValue="{Binding RetainedPercentageRangeMin}"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <StackPanel Grid.Row="6"
                    Grid.Column="0"
                    Grid.ColumnSpan="6"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="75"
                             Margin="5,0"
                             Command="{Binding ApplyCommand}"
                             Content="Apply" />
            <dx:SimpleButton Width="75"
                             Margin="5,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel"
                             IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
