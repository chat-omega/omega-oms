                               Content="Prog ID" />
                        <dxe:TextEdit Grid.Row="1"
                                      Grid.Column="1"
                                      Width="80"
                                      Margin="5,2,0,0"
                                      HorizontalAlignment="Left"
                                      EditValue="{Binding Config.TelemetryProgId, Mode=OneWay}"
                                      IsReadOnly="True" />

                        <Label Grid.Row="2"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               Content="Instance ID" />
                        <dxe:TextEdit Grid.Row="2"
                                      Grid.Column="1"
                                      Width="80"
                                      Margin="5,2,0,0"
                                      HorizontalAlignment="Left"
                                      EditValue="{Binding Config.TelemetryInstanceId, UpdateSourceTrigger=PropertyChanged}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding TelemetryConfigChangedCommand}"
                                                       EventName="EditValueChanged" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>
                        <Label Grid.Row="2"
                               Grid.Column="2"
                               Margin="5,2,0,0"
                               Content="{Binding AutoDetectedInstanceId, StringFormat='(auto-detected: {0})'}"
                               Foreground="Gray" />
                    </Grid>
                </ScrollViewer>
            </dx:DXTabItem>
        </dx:DXTabControl>

        <Label Grid.Row="1"
               Grid.Column="0"
               Content="{Binding Message}" />

    </Grid>
</dx:ThemedWindow>
