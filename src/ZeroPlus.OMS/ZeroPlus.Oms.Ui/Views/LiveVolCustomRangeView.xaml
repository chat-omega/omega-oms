<UserControl x:Class="ZeroPlus.Oms.Ui.Views.LiveVolCustomRangeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:LiveVolCustomRangeViewModel}"
             mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="180" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="Start date:" />
        <dxe:DateEdit Grid.Row="0"
                      Grid.Column="1"
                      Width="180"
                      Margin="0,0,0,12"
                      EditValue="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Margin="0,0,12,0"
                   VerticalAlignment="Center"
                   Text="End date:" />
        <dxe:DateEdit Grid.Row="1"
                      Grid.Column="1"
                      Width="180"
                      EditValue="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}" />
    </Grid>
</UserControl>
