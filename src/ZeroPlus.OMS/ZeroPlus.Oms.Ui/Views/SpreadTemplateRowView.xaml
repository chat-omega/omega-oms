<UserControl x:Class="ZeroPlus.Oms.Ui.Views.SpreadTemplateRowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:local="clr-namespace:ZeroPlus.Oms.Ui.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DataContext="{d:DesignInstance Type=ViewModels:SpreadTemplateRowViewModel}"
             d:DesignHeight="36"
             d:DesignWidth="900"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helper:TemplateExpirationToBackgroundConverter x:Key="TemplateExpirationToBackgroundConverter" />
    </UserControl.Resources>
    <Grid Margin="5,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              Grid.Column="0"
              Margin="0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <dx:SimpleButton Grid.Row="0"
                             VerticalAlignment="Bottom"
                             Background="Transparent"
                             BorderThickness="0"
                             Command="{Binding ParentViewModel.RowUpCommand}"
                             CommandParameter="{Binding}"
                             Glyph="{dx:DXImage SvgImages/Spreadsheet/FillUp.svg}"
                             GlyphHeight="15" />
            <dx:SimpleButton Grid.Row="1"
                             VerticalAlignment="Top"
                             Background="Transparent"
                             BorderThickness="0"
                             Command="{Binding ParentViewModel.RowDownCommand}"
                             CommandParameter="{Binding}"
                             Glyph="{dx:DXImage SvgImages/Spreadsheet/FillDown.svg}"
                             GlyphHeight="15" />
        </Grid>

        <Label Grid.Row="0"
               Grid.Column="1"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="STRATEGY"
               FontSize="8" />

        <Label Grid.Row="0"
               Grid.Column="2"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="SIDE"
               FontSize="8" />

        <Label Grid.Row="0"
               Grid.Column="3"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="LEG 1 DELTA"
               FontSize="8" />

        <Label Grid.Row="0"
               Grid.Column="4"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="LEG 2 DELTA"
               FontSize="8" />

        <Label Grid.Row="0"
               Grid.Column="5"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="LEG 3 DELTA"
               FontSize="8"
               IsEnabled="{Binding IsLeg3Visible}" />

        <Label Grid.Row="0"
               Grid.Column="6"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="LEG 4 DELTA"
               FontSize="8"
               IsEnabled="{Binding IsLeg4Visible}" />

        <Label Grid.Row="0"
               Grid.Column="7"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="LEG 1 EXPIRATION"
               FontSize="8" />

        <Label Grid.Row="0"
               Grid.Column="8"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="LEG 2 EXPIRATION"
               FontSize="8"
               IsEnabled="{Binding IsLeg2ExpirationVisible}" />

        <Label Grid.Row="0"
               Grid.Column="9"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="EDGE OVERRIDE"
               FontSize="8" />

        <Label Grid.Row="0"
               Grid.Column="12"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="DUPLICATE"
               FontSize="8" />

        <Label Grid.Row="0"
               Grid.Column="13"
               Margin="5,0,0,0"
               Padding="2,2,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Content="REMOVE"
               FontSize="8" />

        <dxe:ComboBoxEdit Grid.Row="1"
                          Grid.Column="1"
                          Width="150"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          Background="#171718"
                          FontSize="10"
                          IsTextEditable="False"
                          ItemsSource="{Binding Strategies}"
                          SelectedItem="{Binding Strategy}">
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding StrategyChangedCommand}"
                                       EventName="EditValueChanged" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ComboBoxEdit>

        <dxe:ComboBoxEdit Grid.Row="1"
                          Grid.Column="2"
                          Width="70"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          Background="#171718"
                          FontSize="10"
                          IsTextEditable="False"
                          ItemsSource="{Binding Sides}"
                          SelectedItem="{Binding Side}" />

        <dxe:SpinEdit Grid.Row="1"
                      Grid.Column="3"
                      Width="70"
                      Margin="5,0,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      Background="#171718"
                      DisplayFormatString="N2"
                      EditValue="{Binding Leg1Delta, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="0.01"
                      Mask="N2"
                      MaxValue="1"
                      MinValue="0"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <dxe:SpinEdit Grid.Row="1"
                      Grid.Column="4"
                      Width="70"
                      Margin="5,0,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      Background="#171718"
                      DisplayFormatString="N2"
                      EditValue="{Binding Leg2Delta, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="0.01"
                      Mask="N2"
                      MaxValue="1"
                      MinValue="0"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <dxe:SpinEdit Grid.Row="1"
                      Grid.Column="5"
                      Width="70"
                      Margin="5,0,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      Background="#171718"
                      DisplayFormatString="N2"
                      EditValue="{Binding Leg3Delta, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="0.01"
                      IsEnabled="{Binding IsLeg3Visible}"
                      Mask="N2"
                      MaxValue="1"
                      MinValue="0"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <dxe:SpinEdit Grid.Row="1"
                      Grid.Column="6"
                      Width="70"
                      Margin="5,0,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      Background="#171718"
                      DisplayFormatString="N2"
                      EditValue="{Binding Leg4Delta, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="0.01"
                      IsEnabled="{Binding IsLeg4Visible}"
                      Mask="N2"
                      MaxValue="1"
                      MinValue="0"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <dxe:ComboBoxEdit Grid.Row="1"
                          Grid.Column="7"
                          Width="100"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          Background="{Binding Leg1Expiration, Converter={StaticResource TemplateExpirationToBackgroundConverter}}"
                          DisplayFormatString="MMM dd yy"
                          DisplayMember="Expiration"
                          FontSize="10"
                          IsTextEditable="False"
                          ItemsSource="{Binding ParentViewModel.Expirations}"
                          SelectedItem="{Binding Leg1Expiration, UpdateSourceTrigger=PropertyChanged}">
            <dxe:ComboBoxEdit.ItemContainerStyle>
                <Style TargetType="dxe:ComboBoxEditItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </dxe:ComboBoxEdit.ItemContainerStyle>
            <dxe:ComboBoxEdit.ItemTemplate>
                <DataTemplate>
                    <Grid Width="100"
                          HorizontalAlignment="Stretch"
                          Background="{Binding Converter={StaticResource TemplateExpirationToBackgroundConverter}}">
                        <Label HorizontalAlignment="Left"
                               Content="{Binding Expiration}"
                               ContentStringFormat="MMM dd yy" />
                    </Grid>
                </DataTemplate>
            </dxe:ComboBoxEdit.ItemTemplate>
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding ExpirationChangedCommand}"
                                       EventName="EditValueChanged" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ComboBoxEdit>

        <dxe:ComboBoxEdit Grid.Row="1"
                          Grid.Column="8"
                          Width="100"
                          Margin="5,0,0,0"
                          HorizontalAlignment="Left"
                          Background="{Binding Leg2Expiration, Converter={StaticResource TemplateExpirationToBackgroundConverter}}"
                          DisplayFormatString="MMM dd yy"
                          DisplayMember="Expiration"
                          FontSize="10"
                          IsEnabled="{Binding IsLeg2ExpirationVisible}"
                          IsTextEditable="False"
                          ItemsSource="{Binding ParentViewModel.Expirations}"
                          SelectedItem="{Binding Leg2Expiration, UpdateSourceTrigger=PropertyChanged}">
            <dxe:ComboBoxEdit.ItemContainerStyle>
                <Style TargetType="dxe:ComboBoxEditItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </dxe:ComboBoxEdit.ItemContainerStyle>
            <dxe:ComboBoxEdit.ItemTemplate>
                <DataTemplate>
                    <Grid Width="100"
                          HorizontalAlignment="Stretch"
                          Background="{Binding Converter={StaticResource TemplateExpirationToBackgroundConverter}}">
                        <Label HorizontalAlignment="Left"
                               Content="{Binding Expiration}"
                               ContentStringFormat="MMM dd yy" />
                    </Grid>
                </DataTemplate>
            </dxe:ComboBoxEdit.ItemTemplate>
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding ExpirationChangedCommand}"
                                       EventName="EditValueChanged" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ComboBoxEdit>
        <Border Grid.Row="1"
                Grid.Column="9"
                Margin="5,0,0,0"
                BorderBrush="#3F3F46"
                BorderThickness="1">
            <StackPanel VerticalAlignment="Center"
                        Background="#171718"
                        Orientation="Horizontal">
                <dxe:CheckEdit Margin="5,0,0,0"
                               Padding="0"
                               VerticalAlignment="Center"
                               Background="#171718"
                               EditValue="{Binding EdgeOverrideEnabled, UpdateSourceTrigger=PropertyChanged}" />
                <dxe:SpinEdit Width="70"
                              Margin="5,0,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              Background="#171718"
                              BorderBrush="Transparent"
                              BorderThickness="0"
                              DisplayFormatString="N2"
                              EditValue="{Binding EdgeOverride, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment="0.01"
                              IsEnabled="{Binding EdgeOverrideEnabled}"
                              Mask="N2"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_Click"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>
        </Border>

        <dx:DXImage Grid.Row="1"
                    Grid.Column="10"
                    Height="15"
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="{dx:DXImage 'SvgImages/Icon Builder/Security_WarningCircled2.svg'}"
                    Visibility="{Binding IsValid, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
            <dx:WpfSvgPalette.Palette>
                <dx:WpfSvgPalette OverridesThemeColors="True">
                    <SolidColorBrush x:Key="Red"
                                     Color="Red" />
                </dx:WpfSvgPalette>
            </dx:WpfSvgPalette.Palette>
        </dx:DXImage>

        <dx:DXImage Grid.Row="1"
                    Grid.Column="10"
                    Height="15"
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_CheckCircled.svg'}"
                    Visibility="{Binding IsValid, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <dx:SimpleButton Grid.Row="1"
                         Grid.Column="12"
                         Width="45"
                         Margin="5,0,0,0"
                         Background="#171718"
                         Command="{Binding ParentViewModel.DuplicateTemplateCommand}"
                         CommandParameter="{Binding}"
                         Glyph="{dx:DXImage SvgImages/Dashboards/Duplicate.svg}"
                         GlyphHeight="15" />

        <dx:SimpleButton Grid.Row="1"
                         Grid.Column="13"
                         Width="45"
                         Margin="5,0,0,0"
                         Background="#171718"
                         Command="{Binding ParentViewModel.RemoveTemplateCommand}"
                         CommandParameter="{Binding}"
                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Remove.svg}"
                         GlyphHeight="15" />

    </Grid>
</UserControl>
