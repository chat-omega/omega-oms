<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.GammaScalpingModuleView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxgt="http://schemas.devexpress.com/winfx/2008/xaml/grid/themekeys"
                 xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:helpers="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="1500"
                 Height="960"
                 MinWidth="400"
                 MinHeight="300"
                 Padding="0"
                 d:DataContext="{d:DesignInstance Type=ViewModels:GammaScalpingModuleViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:GammaScalpingModuleViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <dx:ThemedWindow.Resources>
        <helper:MultiBooleanToAndConverter x:Key="MultiBooleanToAndConverter" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:DateTimeToDisplayTextConverter x:Key="DateTimeToDisplayTextConverter" />
        <helper:OrderTypeToLimitHandlingStateEnabledConverter x:Key="OrderTypeToLimitHandlingStateEnabledConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="AddToTopToGlyphConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <Image Width="20"
                       Height="20"
                       Source="{dx:DXImage SvgImages/Spreadsheet/FillUp.svg}" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <Image Width="20"
                       Height="20"
                       Source="{dx:DXImage SvgImages/Spreadsheet/FillDown.svg}" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#F0E7D8" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBorderColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #02F302
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F30005
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToButtonTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Stop
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Start
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToLabelTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Running
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Stopped
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                             Inverse="True" />
        <Style x:Key="PositionsRowStyle"
               TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="#1d3c52" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="#1d3c52" />
                </Trigger>
                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#39393A" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#3E596B" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TotalCurrencyStyle"
               TargetType="{x:Type dxg:TotalSummaryItemsControl}">
            <Setter Property="Foreground" Value="{Binding Converter={StaticResource SignToBrushConverter}}" />
        </Style>
        <dxmvvm:BooleanToObjectConverter x:Key="ValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Transparent" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#FF0000" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helpers:SideToColorConverter x:Key="SideToColorConverter" />
        <helpers:SideToColorConverter x:Key="SideToInverseColorConverter"
                                      Inverse="True" />
    </dx:ThemedWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <dxlc:GroupBox Grid.Row="0"
                           Width="200"
                           HorizontalAlignment="Left">
                <dxlc:GroupBox.Header>
                    <Label Padding="0"
                           HorizontalContentAlignment="Center"
                           Content="{Binding IsHedging, Converter={StaticResource BooleanToLabelTextConverter}}"
                           FontWeight="Bold"
                           Foreground="{Binding IsHedging, Converter={StaticResource BooleanToBorderColorConverter}}" />
                </dxlc:GroupBox.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Padding="2,2,0,0"
                           VerticalAlignment="Bottom"
                           Content="UNDERLYING"
                           FontSize="8" />

                    <dxe:ButtonEdit Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Margin="2,2,0,0"
                                    AllowDefaultButton="False"
                                    Background="#171718"
                                    CharacterCasing="Upper"
                                    EditValue="{Binding Underlying, UpdateSourceTrigger=PropertyChanged}"
                                    EditValuePostDelay="0"
                                    IsEnabled="{Binding UnderlyingLoaded, Converter={StaticResource BooleanNegationConverter}}"
                                    SelectAllOnGotFocus="True"
                                    SelectAllOnMouseUp="True"
                                    TabIndex="1">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:ButtonInfo Command="{Binding SearchUnderlyingCommand}"
                                            GlyphKind="Search"
                                            IsDefaultButton="True" />
                        </dxe:ButtonEdit.Buttons>
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:KeyToCommand Command="{Binding SearchUnderlyingCommand}"
                                                 KeyGesture="Enter" />
                        </dxmvvm:Interaction.Behaviors>
                    </dxe:ButtonEdit>

                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Padding="2,2,0,0"
                           VerticalAlignment="Bottom"
                           Content="HEDGE"
                           FontSize="8" />

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Padding="2,2,0,0"
                           VerticalAlignment="Bottom"
                           Content="MULTIPLIER"
                           FontSize="8" />

                    <dxe:TextEdit Grid.Row="3"
                                  Grid.Column="0"
                                  Margin="2,2,0,0"
                                  Background="#171718"
                                  CharacterCasing="Upper"
                                  EditValue="{Binding HedgeUnderlying, UpdateSourceTrigger=PropertyChanged}"
                                  EditValuePostDelay="0"
                                  IsEnabled="{Binding UnderlyingLoaded, Converter={StaticResource BooleanNegationConverter}}"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  TabIndex="1" />

                    <dxe:SpinEdit Grid.Row="3"
                                  Grid.Column="1"
                                  Margin="2,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  Background="#171718"
                                  DisplayFormatString="N0"
                                  EditValue="{Binding HedgeMultiplier, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  IsEnabled="{Binding UnderlyingLoaded, Converter={StaticResource BooleanNegationConverter}}"
                                  Mask="N0"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True">
                        <dxmvvm:Interaction.Behaviors>
                            <behavior:SpinEditFocusSelectionBehavior />
                        </dxmvvm:Interaction.Behaviors>
                    </dxe:SpinEdit>

                    <dx:SimpleButton Grid.Row="4"
                                     Grid.Column="0"
                                     Grid.ColumnSpan="2"
                                     Width="100"
                                     Height="22"
                                     Margin="2,5,0,0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Command="{Binding StartStopCommand}"
                                     Content="{Binding IsHedging, Converter={StaticResource BooleanToButtonTextConverter}}"
                                     FontSize="11"
                                     FontWeight="DemiBold"
                                     IsEnabled="{Binding UnderlyingLoaded}" />
                </Grid>
            </dxlc:GroupBox>

            <ScrollViewer Grid.Row="1"
                          Margin="0,0,5,0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <dxlc:GroupBox Grid.Row="2"
                                   Width="200"
                                   Margin="0,2,0,0"
                                   Padding="5,2,6,2"
                                   IsEnabled="{Binding UnderlyingLoaded}">
                        <dxlc:GroupBox.Header>
                            <Label Padding="0"
                                   HorizontalAlignment="Center"
                                   Content="Position"
                                   FontWeight="DemiBold"
                                   Foreground="#AFAFB0" />
                        </dxlc:GroupBox.Header>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="ROUTE"
                                   FontSize="8" />

                            <Label Grid.Row="0"
                                   Grid.Column="1"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="QTY"
                                   FontSize="8" />

                            <dxe:ComboBoxEdit Grid.Row="1"
                                              Grid.Column="0"
                                              Margin="2,2,0,0"
                                              Background="#171718"
                                              IsTextEditable="False"
                                              ItemsSource="{Binding OrderTicket.RoutesList}"
                                              SelectedItem="{Binding OrderTicket.Route}" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="2,2,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          Background="#171718"
                                          DisplayFormatString="N0"
                                          EditValue="{Binding OrderTicket.Qty, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Mask="N0"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding OrderTicket.UpdateQtyCommand}"
                                                           EventName="EditValueChanged" />
                                    <behavior:SpinEditFocusSelectionBehavior />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="CANCEL DELAY"
                                   FontSize="8" />

                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="EDGE TYPE"
                                   FontSize="8" />

                            <Border Grid.Row="3"
                                    Grid.Column="0"
                                    Margin="2,2,0,0"
                                    Background="#171718"
                                    BorderBrush="#3F3F46"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <dxe:SpinEdit Grid.Column="0"
                                                  Margin="0,0,0,0"
                                                  HorizontalContentAlignment="Left"
                                                  AllowSpinOnMouseWheel="True"
                                                  Background="#171718"
                                                  EditValue="{Binding OrderTicket.AutoCancelIntervalMin, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Int32}"
                                                  MinValue="0"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True"
                                                  ShowBorder="False"
                                                  ShowEditorButtons="False" />
                                    <TextBlock Grid.Column="1"
                                               Width="4"
                                               Height="18"
                                               Foreground="White"
                                               Text="-"
                                               TextAlignment="Center" />
                                    <dxe:SpinEdit Grid.Column="2"
                                                  Margin="0,0,0,0"
                                                  HorizontalContentAlignment="Right"
                                                  AllowSpinOnMouseWheel="True"
                                                  Background="#171718"
                                                  EditValue="{Binding OrderTicket.AutoCancelIntervalMax, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Int32}"
                                                  MinValue="{Binding OrderTicket.AutoCancelIntervalMin}"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True"
                                                  ShowBorder="False"
                                                  ShowEditorButtons="False" />
                                </Grid>
                            </Border>

                            <dxe:ComboBoxEdit Grid.Row="3"
                                              Grid.Column="1"
                                              Margin="2,2,0,0"
                                              Background="#171718"
                                              IsTextEditable="False"
                                              ItemsSource="{Binding PositionEntryTypes}"
                                              SelectedItem="{Binding OrderTicket.ScalpPricingType}" />

                            <Label Grid.Row="4"
                                   Grid.Column="0"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="PnL TARGET"
                                   FontSize="8" />

                            <Label Grid.Row="4"
                                   Grid.Column="1"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="EDGE"
                                   FontSize="8" />

                            <dxe:SpinEdit Grid.Row="5"
                                          Grid.Column="0"
                                          Margin="2,2,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          Background="#171718"
                                          DisplayFormatString="N0"
                                          EditValue="{Binding OrderTicket.ScalpPnlTarget, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <behavior:SpinEditFocusSelectionBehavior />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <dxe:SpinEdit Grid.Row="5"
                                          Grid.Column="1"
                                          Margin="2,2,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          Background="#171718"
                                          DisplayFormatString="N0"
                                          EditValue="{Binding OrderTicket.ScalpEdge, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <behavior:SpinEditFocusSelectionBehavior />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <Label Grid.Row="6"
                                   Grid.Column="0"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="CANCEL TRIGGER - MID"
                                   FontSize="8" />

                            <Label Grid.Row="6"
                                   Grid.Column="1"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="CANCEL TRIGGER - UL"
                                   FontSize="8" />

                            <dxe:SpinEdit Grid.Row="7"
                                          Grid.Column="0"
                                          Margin="2,2,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          Background="#171718"
                                          DisplayFormatString="N0"
                                          EditValue="{Binding OrderTicket.ScalpCancelWithMidEdge, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <behavior:SpinEditFocusSelectionBehavior />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <dxe:SpinEdit Grid.Row="7"
                                          Grid.Column="1"
                                          Margin="2,2,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          Background="#171718"
                                          DisplayFormatString="N0"
                                          EditValue="{Binding OrderTicket.ScalpCancelWithUnderEdge, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <behavior:SpinEditFocusSelectionBehavior />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <dx:SimpleButton Grid.Row="8"
                                             Grid.Column="0"
                                             Height="22"
                                             Margin="2,2,0,0"
                                             VerticalAlignment="Center"
                                             Command="{Binding OrderTicket.AddLegCommand}"
                                             Content="Add Leg"
                                             FontSize="11" />

                            <dx:SimpleButton Grid.Row="8"
                                             Grid.Column="1"
                                             Height="22"
                                             Margin="2,2,0,0"
                                             VerticalAlignment="Center"
                                             Command="{Binding OrderTicket.CancelAnyCommand}"
                                             Content="Cancel"
                                             FontSize="11" />

                            <dx:SimpleButton Grid.Row="9"
                                             Grid.Column="0"
                                             Height="22"
                                             Margin="2,2,0,0"
                                             VerticalAlignment="Center"
                                             Command="{Binding SubmitAsyncCommand}"
                                             Content="Enter"
                                             FontSize="11"
                                             FontWeight="DemiBold" />

                            <dx:SimpleButton Grid.Row="9"
                                             Grid.Column="1"
                                             Height="22"
                                             Margin="2,2,0,0"
                                             VerticalAlignment="Center"
                                             Command="{Binding SubmitContraAsyncCommand}"
                                             Content="Exit"
                                             FontSize="11"
                                             FontWeight="DemiBold" />
                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Row="3"
                                   Width="200"
                                   Margin="0,2,0,0"
                                   Padding="5,2,6,2"
                                   IsEnabled="{Binding UnderlyingLoaded}">
                        <dxlc:GroupBox.Header>
                            <Label Padding="0"
                                   HorizontalAlignment="Center"
                                   Content="Hedge Order"
                                   FontWeight="DemiBold"
                                   Foreground="#AFAFB0" />
                        </dxlc:GroupBox.Header>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="ACCOUNT"
                                   FontSize="8" />

                            <Label Grid.Row="0"
                                   Grid.Column="1"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="ROUTE"
                                   FontSize="8" />

                            <dxe:ComboBoxEdit Grid.Row="1"
                                              Grid.Column="0"
                                              Margin="2,2,0,0"
                                              Background="#171718"
                                              IsTextEditable="False"
                                              ItemsSource="{Binding Accounts}"
                                              SelectedItem="{Binding Account}" />

                            <dxe:ComboBoxEdit Grid.Row="1"
                                              Grid.Column="2"
                                              Margin="2,2,0,0"
                                              Background="#171718"
                                              IsTextEditable="False"
                                              ItemsSource="{Binding RoutesList}"
                                              SelectedItem="{Binding UnderlyingPositionModel.Route}" />

                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="ORDER TYPE"
                                   FontSize="8" />

                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="LIMIT TYPE"
                                   FontSize="8" />

                            <dxe:ComboBoxEdit Grid.Row="3"
                                              Grid.Column="0"
                                              Margin="2,2,0,0"
                                              VerticalAlignment="Bottom"
                                              Background="#171718"
                                              IsTextEditable="False"
                                              ItemsSource="{Binding OrderTypes}"
                                              SelectedItem="{Binding OrderType}" />

                            <dxe:ComboBoxEdit Grid.Row="3"
                                              Grid.Column="1"
                                              Margin="2,2,0,0"
                                              VerticalAlignment="Bottom"
                                              ApplyItemTemplateToSelectedItem="True"
                                              Background="#171718"
                                              IsEnabled="{Binding OrderType, Converter={StaticResource OrderTypeToLimitHandlingStateEnabledConverter}}"
                                              IsTextEditable="False"
                                              ItemsSource="{Binding LimitHandlingOptions}"
                                              SelectedItem="{Binding LimitHandling}">
                                <dxe:ComboBoxEdit.ItemTemplate>
                                    <DataTemplate>
                                        <Label Padding="0"
                                               Content="{Binding Converter={StaticResource EnumToDisplayTextConverter}}" />
                                    </DataTemplate>
                                </dxe:ComboBoxEdit.ItemTemplate>
                            </dxe:ComboBoxEdit>

                            <Label Grid.Row="4"
                                   Grid.Column="0"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="INIT LIMIT EXT"
                                   FontSize="8" />

                            <Label Grid.Row="4"
                                   Grid.Column="1"
                                   Padding="2,2,0,0"
                                   VerticalAlignment="Bottom"
                                   Content="LIMIT EXT"
                                   FontSize="8" />

                            <dxe:SpinEdit Grid.Row="5"
                                          Grid.Column="0"
