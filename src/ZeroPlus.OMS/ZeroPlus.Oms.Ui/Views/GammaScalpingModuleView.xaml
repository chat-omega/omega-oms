                                       Content="Clear Sorting" />
                            </dx:SimpleButton>
                            <dx:SimpleButton Command="{Binding AddColumnCommand}"
                                             Glyph="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}"
                                             GlyphHeight="15">
                                <Label Width="90"
                                       HorizontalContentAlignment="Center"
                                       Content="Add Column" />
                            </dx:SimpleButton>
                        </StackPanel>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
