                            <DataTrigger Binding="{Binding Path=IsSelected}"
                                         Value="True">
                                <Setter Property="Background" Value="#1d3c52" />
                            </DataTrigger>
                            <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                <Setter Property="Background" Value="#1d3c52" />
                            </Trigger>
                            <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#39393A" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Path=Row.IsCurrent}"
                                         Value="True">
                                <Setter Property="Background" Value="#8a7750" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
