<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.ParseSpreadsConfigView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Parse Spreads"
                 Width="750"
                 Height="500"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">
    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Label Margin="15,0,0,0"
                   Content="Front Month %" />

            <dxe:SpinEdit Width="75"
                          Height="24"
                          Margin="5,0,0,0"
                          VerticalAlignment="Center"
                          AllowSpinOnMouseWheel="True"
                          Background="Transparent"
                          BorderThickness="0"
                          DisplayFormatString="N2"
                          EditValue="{Binding ParserFrontMonthPercent, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          Increment=".05"
                          Mask="N2"
                          MaxValue="1"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding ParserFrontMonthPercentChangedCommand}"
                                           EventName="EditValueChanged" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:SpinEdit>

            <Label Margin="15,0,0,0"
                   Content="Back Month %" />

            <dxe:SpinEdit Width="75"
                          Height="24"
                          Margin="5,0,0,0"
                          VerticalAlignment="Center"
                          AllowSpinOnMouseWheel="True"
                          Background="Transparent"
                          BorderThickness="0"
                          DisplayFormatString="N2"
                          EditValue="{Binding ParserBackMonthPercent, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          Increment=".05"
                          Mask="N2"
                          MaxValue="1"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding ParserBackMonthPercentChangedCommand}"
                                           EventName="EditValueChanged" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:SpinEdit>

            <Label Margin="15,0,0,0"
                   Content="Min Count" />

            <dxe:SpinEdit Width="75"
                          Height="24"
                          Margin="5,0,0,0"
                          VerticalAlignment="Center"
                          AllowSpinOnMouseWheel="True"
                          Background="Transparent"
                          BorderThickness="0"
                          DisplayFormatString="N0"
                          EditValue="{Binding ParserMinCount, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Int32}"
                          Mask="N0"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding ParserMinCountChangedCommand}"
                                           EventName="EditValueChanged" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:SpinEdit>

            <Label Margin="15,0,0,0"
                   Content="Total Count" />

            <dxe:SpinEdit Width="75"
                          Height="24"
                          Margin="5,0,0,0"
                          VerticalAlignment="Center"
                          AllowSpinOnMouseWheel="True"
                          Background="Transparent"
                          BorderThickness="0"
                          DisplayFormatString="N0"
                          EditValue="{Binding ParserGroupTotalCount, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Int32}"
                          Mask="N0"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding ParserGroupTotalCountChangedCommand}"
                                           EventName="EditValueChanged" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:SpinEdit>
        </StackPanel>

        <dxg:GridControl Name="ResultsGrid"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,2,0,0"
                         AutoGenerateColumns="AddNew"
                         ItemsSource="{Binding LatestSpreadGeneratorResults}"
                         Visibility="Visible">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False"
                               AutoWidth="True"
                               NavigationStyle="Row"
                               ShowGroupPanel="False"
                               ShowTotalSummary="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.RowCellMenuCustomizations>
                        <dxb:BarButtonItem Command="{Binding View.DataContext.ShowParseConfigCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=ResultsGrid}"
                                           Content="Filter By Highest Leg Delta Threshold" />
                    </dxg:TableView.RowCellMenuCustomizations>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                </Style>
            </dxg:GridControl.Resources>

            <dxg:GridColumn FieldName="Underlying"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn FieldName="Strategy"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn FieldName="Type"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn AllowCellMerge="False"
                            FieldName="FrontMonthExpirationsPercent"
                            Header="Front Month %"
                            IsSmart="True"
                            ReadOnly="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Height="24"
                                      VerticalAlignment="Center"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      DisplayFormatString="N2"
                                      EditValue="{Binding RowData.Row.FrontMonthExpirationsPercent, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".01"
                                      Mask="N2"
                                      MaxValue="1"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding View.DataContext.ExpirationPercentChangedCommand}"
                                                       CommandParameter="{Binding RowData.Row}"
                                                       EventName="EditValueChanged" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:SpinEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn AllowCellMerge="False"
                            FieldName="BackMonthExpirationsPercent"
                            Header="Back Month %"
                            IsSmart="True"
                            ReadOnly="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Height="24"
                                      VerticalAlignment="Center"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      DisplayFormatString="N2"
                                      EditValue="{Binding RowData.Row.BackMonthExpirationsPercent, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".01"
                                      Mask="N2"
                                      MaxValue="1"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding View.DataContext.ExpirationPercentChangedCommand}"
                                                       CommandParameter="{Binding RowData.Row}"
                                                       EventName="EditValueChanged" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:SpinEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn AllowCellMerge="False"
                            FieldName="MinCount"
                            Header="Min Count"
                            IsSmart="True"
                            ReadOnly="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Height="24"
                                      VerticalAlignment="Center"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      DisplayFormatString="N0"
                                      EditValue="{Binding RowData.Row.MinCount}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Mask="N0"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding View.DataContext.ExpirationPercentChangedCommand}"
                                                       CommandParameter="{Binding RowData.Row}"
                                                       EventName="EditValueChanged" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:SpinEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn AllowCellMerge="False"
                            FieldName="TotalCount"
                            IsSmart="True"
                            ReadOnly="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Height="24"
                                      VerticalAlignment="Center"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      DisplayFormatString="N0"
                                      EditValue="{Binding RowData.Row.TotalCount}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Mask="N0"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding View.DataContext.ExpirationPercentChangedCommand}"
                                                       CommandParameter="{Binding RowData.Row}"
                                                       EventName="EditValueChanged" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:SpinEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridControl.DetailDescriptor>
                <dxg:DataControlDetailDescriptor ItemsSourceBinding="{Binding Expirations}">
                    <dxg:DataControlDetailDescriptor.DataControl>
                        <dxg:GridControl AutoGenerateColumns="AddNew"
                                         EnableSmartColumnsGeneration="True"
                                         SelectionMode="Row">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowEditing="False"
                                               AutoWidth="True"
                                               NavigationStyle="Row"
                                               ShowGroupPanel="False"
                                               ShowIndicator="True"
                                               VerticalScrollbarVisibility="Auto">
                                    <dxg:TableView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowColumnChooserCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Column Chooser">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ClearColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Hide All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowAllColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Default Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </dxg:TableView.ContextMenu>
                                </dxg:TableView>
                            </dxg:GridControl.View>

                            <dxg:GridControl.Resources>
                                <Style TargetType="dxg:GridColumn">
                                    <Setter Property="Visible" Value="False" />
                                </Style>
                            </dxg:GridControl.Resources>

                            <dxg:GridColumn FieldName="Expiration"
                                            IsSmart="True"
                                            Visible="True" />

                            <dxg:GridColumn FieldName="Count"
                                            IsSmart="True"
                                            Visible="True" />

                            <dxg:GridColumn FieldName="Target"
                                            IsSmart="True"
                                            Visible="True" />

                            <dxg:GridColumn AllowCellMerge="False"
                                            FieldName="Percent"
                                            IsSmart="True"
                                            ReadOnly="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:SpinEdit Height="24"
                                                      VerticalAlignment="Center"
                                                      AllowSpinOnMouseWheel="True"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      DisplayFormatString="N2"
                                                      EditValue="{Binding RowData.Row.Percent, UpdateSourceTrigger=PropertyChanged}"
                                                      EditValueType="{x:Type sys:Double}"
                                                      Increment=".01"
                                                      Mask="N2"
                                                      MaxValue="1"
                                                      MinValue="0"
                                                      PreviewMouseUp="SelectAll"
                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl>
                    </dxg:DataControlDetailDescriptor.DataControl>
                </dxg:DataControlDetailDescriptor>
            </dxg:GridControl.DetailDescriptor>
        </dxg:GridControl>

        <dxe:ProgressBarEdit Grid.Row="3"
                             Grid.Column="1"
                             Height="24"
                             Margin="155,0"
                             VerticalAlignment="Bottom"
                             ContentDisplayMode="Content"
                             Visibility="{Binding ShowProgressBar, Converter={StaticResource BooleanToVisibilityConverter}}">
            <dxe:ProgressBarEdit.StyleSettings>
                <dxe:ProgressBarMarqueeStyleSettings />
            </dxe:ProgressBarEdit.StyleSettings>
        </dxe:ProgressBarEdit>

        <StackPanel Grid.Row="3"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Command="{Binding RunParserCommand}"
                             Content="Parse"
                             IsDefault="True" />
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Command="{Binding CancelParserCommand}"
                             Content="Cancel"
                             IsCancel="True" />
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Grid.Column="1"
                   Margin="5,2,5,0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="{Binding ProgressStatus}" />

    </Grid>
</dx:ThemedWindow>
