<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.ReleaseNotesView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mdxam="clr-namespace:MdXaml;assembly=MdXaml"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="{Binding ModuleTitle}"
                 Width="700"
                 Height="400"
                 d:DataContext="{d:DesignInstance Type=ViewModels:ReleaseNotesViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:ReleaseNotesViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="15" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="15" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="0" />
        </Grid.ColumnDefinitions>

        <Image Grid.Row="1"
               Grid.RowSpan="3"
               Grid.Column="1"
               Width="50"
               Margin="160,0,0,0"
               HorizontalAlignment="Left"
               Source="/Images/open_box.png" />

        <TextBlock Grid.Row="1"
                   Grid.Column="1"
                   HorizontalAlignment="Center"
                   FontFamily="{StaticResource AgencyFB}"
                   FontSize="30"
                   Foreground="#1D673F"
                   Text="OMS" />
        <StackPanel Grid.Row="2"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock FontFamily="{StaticResource ZPLufga}"
                       FontSize="15"
                       Foreground="#1D673F"
                       Text="{Binding Version}" />
            <TextBlock Margin="5,0,0,0"
                       FontFamily="{StaticResource ZPLufga}"
                       FontSize="14"
                       Foreground="#C0C0C0"
                       Text="Update Available!" />
        </StackPanel>
        <TextBlock Grid.Row="3"
                   Grid.Column="1"
                   HorizontalAlignment="Center"
                   FontFamily="{StaticResource ZPLufga}"
                   FontSize="14"
                   Foreground="#C0C0C0"
                   Text="What's New?" />

        <mdxam:MarkdownScrollViewer Grid.Row="4"
                                    Grid.Column="1"
                                    Margin="0,5,0,5"
                                    Foreground="#C0C0C0"
                                    HorizontalScrollBarVisibility="Auto"
                                    Markdown="{Binding ReleaseNotes}"
                                    VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="6"
                    Grid.Column="1"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="120"
                             Margin="3,0"
                             Command="{Binding RestartNowCommand}"
                             Content="Restart Now"
                             FontFamily="{StaticResource ZPLufga}"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Reload.svg}"
                             GlyphHeight="15"
                             IsDefault="True" />
            <dx:SimpleButton Width="120"
                             Margin="3,0"
                             Command="{Binding RestartLaterCommand}"
                             Content="Restart Later"
                             FontFamily="{StaticResource ZPLufga}"
                             Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Cancel.svg}"
                             GlyphHeight="15" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
