<views:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.EodRiskView"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                    xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                    xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                    Title="{Binding ModuleTitle}"
                    Width="1200"
                    Height="800"
                    MinWidth="400"
                    MinHeight="300"
                    d:DataContext="{d:DesignInstance Type=ViewModels:EodRiskViewModel}"
                    DataContext="{startuphelpers:DISource Type=ViewModels:EodRiskViewModel}"
                    WindowStartupLocation="CenterScreen"
                    mc:Ignorable="d">

    <Window.Resources>
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#F0E7D8" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:ExDividendToColorConverter x:Key="ExDividendToColorConverter" />
    </Window.Resources>

    <dx:ThemedWindow.HeaderItems>
        <views:ModuleHeaderItems />
    </dx:ThemedWindow.HeaderItems>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Margin="0,2"
                    VerticalAlignment="Center"
                    BorderBrush="#3F3F46"
                    BorderThickness="1">
                <DockPanel>
                    <Label Width="100"
                           Padding="5,0,2,0"
                           VerticalContentAlignment="Center"
                           Background="#171718"
                           Content="TOTAL NOTIONAL"
                           FontSize="9" />
                    <TextBlock Padding="1,3,3,3"
                               Background="#171718"
                               FontSize="15"
                               FontWeight="DemiBold"
                               Foreground="{Binding PortfolioManagerModel.TotalOpenNotional, Converter={StaticResource SignToBrushConverter}}"
                               Text="{Binding PortfolioManagerModel.TotalOpenNotional, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C0}}"
                               TextAlignment="Right" />
                </DockPanel>
            </Border>
            <Border Grid.Column="1"
                    Margin="5,2"
                    VerticalAlignment="Center"
                    BorderBrush="#3F3F46"
                    BorderThickness="1">
                <DockPanel>
                    <Label Width="100"
                           Padding="5,0,2,0"
                           VerticalContentAlignment="Center"
                           Background="#171718"
                           Content="HIGHEST NOTIONAL"
                           FontSize="9" />
                    <TextBlock Padding="1,3,3,3"
                               Background="#171718"
                               FontSize="15"
                               FontWeight="DemiBold"
                               Foreground="{Binding PortfolioManagerModel.HighestOpenNotional, Converter={StaticResource SignToBrushConverter}}"
                               Text="{Binding PortfolioManagerModel.HighestOpenNotional, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C0}}"
                               TextAlignment="Right" />
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <dxlc:GroupBox Grid.RowSpan="3"
                           Padding="0"
                           Header="Position Effect Tracker">
                <dxg:GridControl Name="RiskGrid"
                                 AllowLiveDataShaping="True"
                                 AutoGenerateColumns="AddNew"
                                 CustomColumnDisplayText="RiskGrid_CustomColumnDisplayText"
                                 ItemsSource="{Binding PortfolioManagerModel.SpreadRiskModels}"
                                 Visibility="Visible">
                    <dxg:GridControl.Resources>
                        <Style TargetType="dxg:GridColumn">
                            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                            <Setter Property="Visible" Value="False" />
                        </Style>
                        <Style x:Key="RowStyle"
                               TargetType="dxg:RowControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=IsSelected}"
                                             Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </DataTrigger>
                                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </Trigger>
                                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#39393A" />
                                </Trigger>
                                <DataTrigger Binding="{Binding Path=Row.Action}"
                                             Value="True">
                                    <Setter Property="Opacity" Value=".4" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style x:Key="ExDivCellStyle"
                               TargetType="dxg:LightweightCellEditor">
                            <Setter Property="Background" Value="{Binding RowData.Row.ExDividend, Converter={StaticResource ExDividendToColorConverter}}" />
                            <Style.Triggers>
                                <Trigger Property="IsFocusedCell" Value="True">
                                    <Setter Property="Background" Value="{Binding RowData.Row.ExDividend, Converter={StaticResource ExDividendToColorConverter}}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridControl.Resources>
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AutoWidth="True"
                                       NavigationStyle="Row"
                                       RowStyle="{StaticResource RowStyle}"
                                       ShowGridMenu="TableView_ShowGridMenu"
                                       ShowGroupPanel="False"
                                       ShowIndicator="True"
                                       ShowTotalSummary="False"
                                       VerticalScrollbarVisibility="Auto">
                            <dxg:TableView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowColumnChooserCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Column Chooser">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ClearColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Hide All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowAllColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowDefaultColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Default Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridColumn Width="50"
                                    MaxWidth="50"
                                    FieldName="Action"
                                    Header="Flat"
                                    IsSmart="True"
                                    SortIndex="0"
                                    Visible="True" />

                    <dxg:GridColumn FieldName="SpreadDescription"
                                    IsSmart="True"
                                    Visible="True" />

                    <dxg:GridColumn FieldName="Tags"
                                    IsSmart="True"
                                    Visible="True" />

                    <dxg:GridColumn FieldName="TotalOpen"
                                    IsSmart="True"
                                    Visible="True" />

                    <dxg:GridColumn FieldName="TotalClose"
                                    IsSmart="True"
                                    Visible="True" />

                    <dxg:GridColumn FieldName="LastTradeTime"
                                    IsSmart="True"
                                    SortIndex="2"
                                    SortOrder="Descending"
                                    Visible="True" />

                    <dxg:GridColumn CellStyle="{StaticResource ExDivCellStyle}"
                                    FieldName="ExDividend"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True"
                                    SortIndex="1"
                                    SortOrder="Descending"
                                    Visible="True">

                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="{Binding RowData.Row.ExDividend, StringFormat='{}{0:MMM dd yy}'}"
                                           TextAlignment="Center" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>

                    </dxg:GridColumn>
                </dxg:GridControl>
            </dxlc:GroupBox>
            <GridSplitter Grid.Row="0"
                          Grid.RowSpan="5"
                          Grid.Column="1"
                          Width="2"
                          HorizontalAlignment="Stretch" />
            <dxlc:GroupBox Grid.Row="0"
                           Grid.Column="2"
                           Padding="0"
                           Header="Self Trade Detection">
                <dxg:GridControl Name="SelfTradeGrid"
                                 AllowLiveDataShaping="True"
                                 AutoGenerateColumns="AddNew"
                                 CustomColumnDisplayText="RiskGrid_CustomColumnDisplayText"
                                 ItemsSource="{Binding PortfolioManagerModel.IdentifiedSelfTrades}"
                                 Visibility="Visible">
                    <dxg:GridControl.Resources>
                        <Style TargetType="dxg:GridColumn">
                            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                            <Setter Property="Visible" Value="False" />
                        </Style>
                        <Style x:Key="RowStyle"
                               TargetType="dxg:RowControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=IsSelected}"
                                             Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </DataTrigger>
                                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </Trigger>
                                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#39393A" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridControl.Resources>
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AutoWidth="True"
                                       NavigationStyle="Row"
                                       RowStyle="{StaticResource RowStyle}"
                                       ShowGridMenu="TableView_ShowGridMenu"
                                       ShowGroupPanel="False"
                                       ShowIndicator="True"
                                       ShowTotalSummary="False"
                                       VerticalScrollbarVisibility="Auto">
                            <dxg:TableView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowColumnChooserCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Column Chooser">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ClearColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Hide All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowAllColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowDefaultColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Default Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridColumn FieldName="Time"
                                    IsSmart="True"
                                    Visible="True" />

                    <dxg:GridColumn FieldName="Symbol"
                                    IsSmart="True"
                                    Visible="True" />

                    <dxg:GridColumn FieldName="Qty"
                                    IsSmart="True"
                                    Visible="True" />

                </dxg:GridControl>
            </dxlc:GroupBox>

            <GridSplitter Grid.Row="1"
                          Grid.Column="2"
                          Height="2"
                          HorizontalAlignment="Stretch" />

            <dxlc:GroupBox Grid.Row="2"
                           Grid.RowSpan="3"
                           Grid.Column="2"
                           Padding="0"
                           Header="Open Notional">
                <dxg:GridControl Name="OpenNotionalGrid"
                                 AllowLiveDataShaping="True"
                                 AutoGenerateColumns="AddNew"
                                 CustomColumnDisplayText="RiskGrid_CustomColumnDisplayText"
                                 ItemsSource="{Binding PortfolioManagerModel.OpenNotionalModels}"
                                 Visibility="Visible">
                    <dxg:GridControl.Resources>
                        <Style TargetType="dxg:GridColumn">
                            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                            <Setter Property="Visible" Value="False" />
                        </Style>
                        <Style x:Key="RowStyle"
                               TargetType="dxg:RowControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=IsSelected}"
                                             Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </DataTrigger>
                                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </Trigger>
                                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#39393A" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridControl.Resources>
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AutoWidth="True"
                                       NavigationStyle="Row"
                                       RowStyle="{StaticResource RowStyle}"
                                       ShowGridMenu="TableView_ShowGridMenu"
                                       ShowGroupPanel="False"
                                       ShowIndicator="True"
                                       ShowTotalSummary="False"
                                       VerticalScrollbarVisibility="Auto">
                            <dxg:TableView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowColumnChooserCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Column Chooser">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ClearColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Hide All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowAllColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowDefaultColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Default Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridColumn FieldName="Name"
                                    Header="Symbol"
                                    IsSmart="True"
                                    Visible="True" />

                    <dxg:GridColumn FieldName="OpenNotional"
                                    IsSmart="True"
                                    SortIndex="0"
                                    SortOrder="Descending"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Name="PART_Editor"
                                              HorizontalContentAlignment="Right"
                                              DisplayFormatString="C0"
                                              Foreground="{Binding RowData.Row.OpenNotional, Converter={StaticResource SignToBrushConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </dxlc:GroupBox>

            <GridSplitter Grid.Row="3"
                          Grid.Column="0"
                          Height="2"
                          HorizontalAlignment="Stretch" />

            <dxlc:GroupBox Grid.Row="4"
                           Grid.Column="0"
                           Padding="0"
                           Header="Open Positions">
                <dxg:GridControl Name="OpenPositionsGrid"
                                 AllowLiveDataShaping="True"
                                 AutoGenerateColumns="AddNew"
                                 CustomColumnDisplayText="RiskGrid_CustomColumnDisplayText"
                                 ItemsSource="{Binding PortfolioManagerModel.OpenPositions}"
                                 Visibility="Visible">
                    <dxg:GridControl.Resources>
                        <Style TargetType="dxg:GridColumn">
                            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                            <Setter Property="Visible" Value="False" />
                        </Style>
                        <Style x:Key="RowStyle"
                               TargetType="dxg:RowControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=IsSelected}"
                                             Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </DataTrigger>
                                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </Trigger>
                                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#39393A" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridControl.Resources>
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AutoWidth="True"
                                       NavigationStyle="Row"
                                       RowStyle="{StaticResource RowStyle}"
                                       ShowGridMenu="TableView_ShowGridMenu"
                                       ShowGroupPanel="False"
                                       ShowIndicator="True"
                                       ShowTotalSummary="False"
                                       VerticalScrollbarVisibility="Auto">
                            <dxg:TableView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowColumnChooserCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Column Chooser">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ClearColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Hide All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowAllColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowDefaultColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Default Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridColumn FieldName="Name"
                                    Header="Description"
                                    IsSmart="True"
                                    Visible="True" />

                    <dxg:GridColumn FieldName="NetDelta"
                                    IsSmart="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Name="PART_Editor"
                                              HorizontalContentAlignment="Right"
                                              DisplayFormatString="N4"
                                              Foreground="{Binding RowData.Row.NetDelta, Converter={StaticResource SignToBrushConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </dxlc:GroupBox>
            <StackPanel Grid.Row="5"
                        Grid.Column="0"
                        Height="22"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <TextBlock Margin="5,3,0,0"
                           Text="Total:" />
                <TextBlock Margin="3,3,3,0"
                           Text="{Binding PortfolioManagerModel.SpreadRiskModels.Count}" />
            </StackPanel>

            <StackPanel Grid.Row="5"
                        Grid.Column="2"
                        Height="22"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <TextBlock Margin="5,3,0,0"
                           Text="Total:" />
                <TextBlock Margin="3,3,3,0"
                           Text="{Binding PortfolioManagerModel.OpenNotionalModels.Count}" />
            </StackPanel>
        </Grid>
    </Grid>
</views:ModuleWindow>
