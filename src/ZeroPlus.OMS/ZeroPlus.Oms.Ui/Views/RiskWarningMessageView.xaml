<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.RiskWarningMessageView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 Title="{Binding Title}"
                 Width="400"
                 Height="180"
                 d:DataContext="{d:DesignInstance Type=viewModels:RiskWarningMessageViewModel}"
                 DataContext="{startuphelpers:DISource Type=viewModels:RiskWarningMessageViewModel}"
                 ResizeMode="NoResize"
                 Topmost="True"
                 WindowStartupLocation="CenterOwner"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Image Grid.Row="1"
               Grid.Column="1"
               Width="50"
               Height="50"
               Margin="10"
               VerticalAlignment="Top"
               Source="{dx:DXImage 'SvgImages/XAF/State_Validation_Warning.svg'}" />

        <TextBlock Grid.Row="1"
                   Grid.Column="2"
                   Margin="5,10"
                   Text="{Binding Message}"
                   TextWrapping="WrapWithOverflow" />

        <StackPanel Grid.Row="2"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="75"
                             Margin="3,0"
                             Command="{Binding SendCommand}"
                             Content="Proceed" />
            <dx:SimpleButton Width="75"
                             Margin="3,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel"
                             IsDefault="True" />
            <dx:SimpleButton Width="75"
                             Margin="3,0"
                             Command="{Binding CancelAllCommand}"
                             Content="Cancel All"
                             IsCancel="True"
                             Visibility="{Binding ShowCancelAll, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
