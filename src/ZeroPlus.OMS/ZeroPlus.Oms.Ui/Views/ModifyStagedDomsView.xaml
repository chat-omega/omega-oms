                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding TimeToEdgeSettingModel2.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           Content="If days to Exp is more than" />

                    <dxe:SpinEdit Grid.Row="2"
                                  Grid.Column="1"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding TimeToEdgeSettingModel3.Spacing}"
                                  EditValueType="{x:Type sys:Int32}"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="2"
                           Grid.Column="2"
                           Margin="5,5,0,0"
                           Content="widen by" />

                    <dxe:SpinEdit Grid.Row="2"
                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding TimeToEdgeSettingModel3.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           Content="If days to Exp is more than" />

                    <dxe:SpinEdit Grid.Row="3"
                                  Grid.Column="1"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding TimeToEdgeSettingModel4.Spacing}"
                                  EditValueType="{x:Type sys:Int32}"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="3"
                           Grid.Column="2"
                           Margin="5,5,0,0"
                           Content="widen by" />

                    <dxe:SpinEdit Grid.Row="3"
                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding TimeToEdgeSettingModel4.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           Content="If days to Exp is more than" />

                    <dxe:SpinEdit Grid.Row="4"
                                  Grid.Column="1"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding TimeToEdgeSettingModel5.Spacing}"
                                  EditValueType="{x:Type sys:Int32}"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="4"
                           Grid.Column="2"
                           Margin="5,5,0,0"
                           Content="widen by" />

                    <dxe:SpinEdit Grid.Row="4"
                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding TimeToEdgeSettingModel5.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           Content="If days to Exp is more than" />

                    <dxe:SpinEdit Grid.Row="5"
                                  Grid.Column="1"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding TimeToEdgeSettingModel6.Spacing}"
                                  EditValueType="{x:Type sys:Int32}"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="5"
                           Grid.Column="2"
                           Margin="5,5,0,0"
                           Content="widen by" />

                    <dxe:SpinEdit Grid.Row="5"
                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding TimeToEdgeSettingModel6.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="6"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           Content="If days to Exp is more than" />

                    <dxe:SpinEdit Grid.Row="6"
                                  Grid.Column="1"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding TimeToEdgeSettingModel7.Spacing}"
                                  EditValueType="{x:Type sys:Int32}"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="6"
                           Grid.Column="2"
                           Margin="5,5,0,0"
                           Content="widen by" />

                    <dxe:SpinEdit Grid.Row="6"
                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding TimeToEdgeSettingModel7.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                </Grid>
            </dx:DXTabItem>

            <dx:DXTabItem Header="Delta Edge">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           Content="If either leg delta is greater than" />

                    <dxe:SpinEdit Grid.Row="0"
                                  Grid.Column="1"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding LegDeltaToEdgeSettingModel1.Delta}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="0"
                           Grid.Column="2"
                           Margin="5,5,0,0"
                           Content="widen by" />

                    <dxe:SpinEdit Grid.Row="0"
                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding LegDeltaToEdgeSettingModel1.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           Content="If either leg delta is greater than" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="1"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding LegDeltaToEdgeSettingModel2.Delta}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="1"
                           Grid.Column="2"
                           Margin="5,5,0,0"
                           Content="widen by" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding LegDeltaToEdgeSettingModel2.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           Content="If either leg delta is greater than" />

                    <dxe:SpinEdit Grid.Row="2"
                                  Grid.Column="1"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding LegDeltaToEdgeSettingModel3.Delta}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
