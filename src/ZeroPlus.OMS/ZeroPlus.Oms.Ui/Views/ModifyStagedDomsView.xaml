                           Content="widen by" />

                    <dxe:SpinEdit Grid.Row="0"
                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding TimeToEdgeSettingModel1.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
