        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Command="{Binding ModifyCommand}"
                             Content="Modify"
                             IsDefault="True" />
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel"
                             IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
