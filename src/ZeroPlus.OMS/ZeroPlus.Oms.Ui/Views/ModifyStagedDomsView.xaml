                                  Grid.Column="1"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding SpreadDeltaToEdgeSettingModel.Delta}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
