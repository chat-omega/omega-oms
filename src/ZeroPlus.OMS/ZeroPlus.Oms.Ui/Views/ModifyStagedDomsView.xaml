                                  Grid.Column="3"
                                  Width="60"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding LegDeltaToEdgeSettingModel3.EdgeChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.05"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="PriceSpinEdit_MouseUp"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           Content="If spread delta is greater than"
                           FontWeight="Bold" />

