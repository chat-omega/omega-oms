<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.PositionAlertConfigurationView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Alert Configuration"
                 Width="400"
                 Height="220"
                 d:DataContext="{d:DesignInstance Type=ViewModels:PositionAlertConfigurationViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:PositionAlertConfigurationViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

            <dxe:ToggleSwitch HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              AnimationMode="Always"
                              Background="#f26543"
                              CheckedStateContent="✅ Enabled"
                              ContentPlacement="Inside"
                              Focusable="False"
                              FontWeight="Bold"
                              IsChecked="{Binding PortfolioManagerModel.OmsCore.Config.AlertEnabled}"
                              ToggleSwitchWidth="105"
                              UncheckedStateContent="⚠ Disabled" />

        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <Grid IsEnabled="{Binding PortfolioManagerModel.OmsCore.Config.AlertEnabled}">
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Margin="0,2,0,0"
               Content="Min Qty" />

        <dxe:SpinEdit Grid.Row="1"
                      Grid.Column="2"
                      Width="120"
                      Margin="5,2,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="d"
                      EditValue="{Binding PortfolioManagerModel.OmsCore.Config.AlertMinQty, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Int32}"
                      Mask="d"
                      MinValue="1"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="0,2,0,0"
               Content="Threshold" />

        <dxe:SpinEdit Grid.Row="2"
                      Grid.Column="2"
                      Width="120"
                      Margin="5,2,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="d"
                      EditValue="{Binding PortfolioManagerModel.OmsCore.Config.AlertThreshold, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Int32}"
                      Mask="d"
                      MinValue="1"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="3"
               Grid.Column="1"
               Margin="0,2,0,0"
               Content="Snooze" />

        <dxe:SpinEdit Grid.Row="3"
                      Grid.Column="2"
                      Width="120"
                      Margin="5,2,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="d"
                      EditValue="{Binding PortfolioManagerModel.OmsCore.Config.SnoozeThreshold, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Int32}"
                      Mask="d"
                      MinValue="1"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <dxe:CheckEdit Grid.Row="4"
                       Grid.Column="1"
                       Margin="0,2,0,0"
                       Content="Audio"
                       EditValue="{Binding PortfolioManagerModel.OmsCore.Config.AudioAlertEnabled}" />

        <DockPanel Grid.Row="4"
                   Grid.Column="2"
                   Margin="5,2,0,0"
                   IsEnabled="{Binding PortfolioManagerModel.OmsCore.Config.AudioAlertEnabled}">
            <dx:SimpleButton Width="22"
                             BorderThickness="0,1,1,1"
                             Command="{Binding TestSoundCommand}"
                             CommandParameter="{Binding PortfolioManagerModel.OmsCore.Config.AudioAlertSound}"
                             DockPanel.Dock="Right"
                             Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"
                             GlyphHeight="15"
                             GlyphWidth="15" />
            <dxe:ComboBoxEdit IsTextEditable="False"
                              ItemsSource="{Binding NotificationManager.SoundsList}"
                              SelectedItem="{Binding PortfolioManagerModel.OmsCore.Config.AudioAlertSound, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <dxe:CheckEdit Grid.Row="5"
                       Grid.Column="1"
                       Margin="0,2,0,0"
                       Content="Voice"
                       EditValue="{Binding PortfolioManagerModel.OmsCore.Config.TtsAlertEnabled}" />

        <dxe:CheckEdit Grid.Row="6"
                       Grid.Column="1"
                       Margin="0,2,0,0"
                       Content="Visual"
                       EditValue="{Binding PortfolioManagerModel.OmsCore.Config.VisualAlertEnabled}" />
    </Grid>
</dx:ThemedWindow>
