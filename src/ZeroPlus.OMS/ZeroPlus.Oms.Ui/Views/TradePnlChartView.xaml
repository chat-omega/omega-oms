<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.TradePnlChartView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 Title="{Binding ModuleTitle}"
                 Width="1200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=viewModels:TradePnlChartViewModel}"
                 DataContext="{startuphelpers:DISource Type=viewModels:TradePnlChartViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">
    <Window.Resources>
        <dxc:LineStyle x:Key="LineStyle"
                       Thickness="3" />
        <dxc:LineStyle x:Key="PermLineStyle"
                       Thickness="1" />
        <dxc:LineStyle x:Key="PriceLineStyle"
                       Thickness="2" />
        <dx:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <helper:ChartConstantLineModeToColorConverter x:Key="ChartConstantLineModeToColorConverter" />
        <helper:ChartConstantLineModeToAlignmentConverter x:Key="ChartConstantLineModeToAlignmentConverter" />
        <helper:ChartFieldToDisplayTextConverter x:Key="ChartFieldToDisplayTextConverter" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:HeatmapColorConverter x:Key="HeatmapColorConverter" />
        <DataTemplate x:Key="expirationTemplate">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="{Binding Value, StringFormat='{}{0}'}"
                       TextAlignment="Center" />
        </DataTemplate>
    </Window.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:DispatcherService />
        <dxmvvm:KeyToCommand Command="{Binding SearchCommand}"
                             KeyGesture="Enter" />
    </dxmvvm:Interaction.Behaviors>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Padding="3"
                   Background="#171718"
                   Content="Symbol - " />

            <dxe:TextEdit Grid.Column="1"
                          Background="#171718"
                          BorderBrush="#171718"
                          CharacterCasing="Upper"
                          EditValue="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                          EditValuePostDelay="0"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True"
                          TabIndex="1" />

            <DockPanel Grid.Column="2"
                       Width="90"
                       Margin="5,0,0,0"
                       HorizontalAlignment="Left"
                       Background="#171718">
                <Label Margin="3,0"
                       Content="Side - " />
                <dxe:ComboBoxEdit Background="#171718"
                                  BorderBrush="#171718"
                                  BorderThickness="0"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding Sides}"
                                  SelectedItem="{Binding Side}">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding SearchCommand}"
                                               EventName="EditValueChanged" />
                    </dxmvvm:Interaction.Behaviors>
                </dxe:ComboBoxEdit>
            </DockPanel>

            <DockPanel Grid.Column="3"
                       Width="100"
                       Margin="5,0,0,0"
                       HorizontalAlignment="Left"
                       Background="#171718"
                       LastChildFill="True">
                <Label Margin="3,0"
                       Content="Qty - "
                       DockPanel.Dock="Left" />
                <dxe:SpinEdit AllowSpinOnMouseWheel="True"
                              Background="#171718"
                              BorderBrush="#171718"
                              EditValue="{Binding Qty, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Mask="D"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </DockPanel>

            <DockPanel Grid.Column="4"
                       Width="140"
                       Margin="5,0,0,0"
                       HorizontalAlignment="Left"
                       Background="#171718"
                       LastChildFill="True">
                <Label Margin="3,0"
                       Content="Price - "
                       DockPanel.Dock="Left" />
                <dxe:SpinEdit AllowSpinOnMouseWheel="True"
                              Background="#171718"
                              BorderBrush="#171718"
                              EditValue="{Binding BasePrice, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Mask="N2"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </DockPanel>

            <DockPanel Grid.Column="5"
                       Width="120"
                       Margin="5,0,0,0"
                       HorizontalAlignment="Left"
                       Background="#171718"
                       LastChildFill="True">
                <Label Margin="3,0"
                       Content="Hedge - "
                       DockPanel.Dock="Left" />

                <dxe:ToggleSwitch Grid.Row="15"
                                  Grid.Column="1"
                                  HorizontalAlignment="Right"
                                  Background="#171718"
                                  CheckedStateContent="ON"
                                  ContentPlacement="Inside"
                                  IsChecked="{Binding HedgeEnabled}"
                                  ToggleSwitchHeight="24"
                                  ToggleSwitchWidth="67"
                                  UncheckedStateContent="OFF" />
            </DockPanel>

            <dx:SimpleButton Grid.Column="6"
                             Width="120"
                             Margin="5,0,0,0"
                             HorizontalAlignment="Left"
                             Background="#171718"
                             Command="{Binding SearchCommand}"
                             Content="Refresh"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Refresh.svg}"
                             GlyphHeight="15"
                             IsDefault="True" />

        </Grid>

        <dxc:ChartControl Name="ChartControl"
                          Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,2,0,0">
            <dxc:ChartControl.Legend>
                <dxc:Legend HorizontalPosition="Right" />
            </dxc:ChartControl.Legend>
            <dxc:ChartControl.Diagram>
                <dxc:XYDiagram2D Name="ChartDiagram"
                                 EnableAxisXNavigation="True"
                                 EnableAxisYNavigation="True">
                    <dxc:XYDiagram2D.AxisX>
                        <dxc:AxisX2D Name="axisX"
                                     ConstantLineInFrontItemsSource="{Binding ZpTradePoints}">

                            <dxc:AxisX2D.ConstantLineInFrontItemTemplate>
                                <DataTemplate>
                                    <dxc:ConstantLine Brush="{Binding LineMode, Converter={StaticResource ChartConstantLineModeToColorConverter}}"
                                                      Value="{Binding Value}">
                                        <dxc:ConstantLine.Title>
                                            <dxc:ConstantLineTitle Alignment="{Binding LineMode, Converter={StaticResource ChartConstantLineModeToAlignmentConverter}}"
                                                                   Content="{Binding Title}"
                                                                   Foreground="{Binding LineMode, Converter={StaticResource ChartConstantLineModeToColorConverter}}" />
                                        </dxc:ConstantLine.Title>
                                    </dxc:ConstantLine>
                                </DataTemplate>
                            </dxc:AxisX2D.ConstantLineInFrontItemTemplate>

                            <dxc:AxisX2D.DateTimeScaleOptions>
                                <dxc:ManualDateTimeScaleOptions AggregateFunction="None"
                                                                AutoGrid="False"
                                                                GridAlignment="Minute"
                                                                MeasureUnit="Minute"
                                                                WorkTimeOnly="True"
                                                                WorkdaysOnly="True">
                                    <dxc:ManualDateTimeScaleOptions.WorkdaysOptions>
                                        <dxc:WorkdaysOptions Workdays="Monday,Tuesday,Wednesday,Thursday,Friday" />
                                    </dxc:ManualDateTimeScaleOptions.WorkdaysOptions>
                                    <dxc:ManualDateTimeScaleOptions.WorkTimeRules>
                                        <dxc:WorkTimeRule>
                                            <dxc:WorkTimeRule.WorkIntervals>
                                                <dxc:TimeInterval EndHour="15"
                                                                  EndMinute="15"
                                                                  EndSecond="00"
                                                                  StartHour="08"
                                                                  StartMinute="30"
                                                                  StartSecond="00" />
                                            </dxc:WorkTimeRule.WorkIntervals>
                                        </dxc:WorkTimeRule>
                                    </dxc:ManualDateTimeScaleOptions.WorkTimeRules>
                                </dxc:ManualDateTimeScaleOptions>
                            </dxc:AxisX2D.DateTimeScaleOptions>
                            <dxc:AxisX2D.Label>
                                <dxc:AxisLabel TextPattern="{}{A:dd hh:mm:ss}" />
                            </dxc:AxisX2D.Label>
                        </dxc:AxisX2D>
                    </dxc:XYDiagram2D.AxisX>
                    <dxc:XYDiagram2D.NavigationOptions>
                        <dxc:NavigationOptions UseKeyboard="True"
                                               UseMouse="True"
                                               UseScrollBars="True"
                                               UseTouchDevice="True" />
                    </dxc:XYDiagram2D.NavigationOptions>
                    <dxc:XYDiagram2D.Series>
                        <dxc:LineSeries2D AggregateFunction="{Binding AggregateFunction}"
                                          ArgumentDataMember="Timestamp"
                                          Brush="#008d00"
                                          CrosshairLabelPattern="{}{S} {V:c2}"
                                          DataSource="{Binding ChartDataPoints}"
                                          DisplayName="Bid PnL"
                                          LineStyle="{StaticResource PriceLineStyle}"
                                          MarkerSize="3"
                                          ValueDataMember="BidIv" />
                        <dxc:LineSeries2D AggregateFunction="{Binding AggregateFunction}"
                                          ArgumentDataMember="Timestamp"
                                          Brush="#f24a4a"
                                          CrosshairLabelPattern="{}{S} {V:c2}"
                                          DataSource="{Binding ChartDataPoints}"
                                          DisplayName="Ask PnL"
                                          LineStyle="{StaticResource PriceLineStyle}"
                                          MarkerSize="3"
                                          ValueDataMember="AskIv" />
                    </dxc:XYDiagram2D.Series>
                </dxc:XYDiagram2D>
            </dxc:ChartControl.Diagram>
        </dxc:ChartControl>
    </Grid>
</dx:ThemedWindow>
