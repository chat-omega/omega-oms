                             VerticalAlignment="Top"
                             VerticalContentAlignment="Center"
                             BorderThickness="1.5"
                             Command="{Binding EmergencyStopCommand}"
                             Content="EMERGENCY STOP"
                             FontSize="10"
                             FontWeight="Bold"
                             IsTabStop="False">
                <dx:SimpleButton.Style>
                    <Style TargetType="dx:SimpleButton">
                        <Setter Property="Background" Value="#d72813" />
                        <Setter Property="BorderBrush" Value="#ffbf18" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D70000" />
                                <Setter Property="BorderBrush" Value="#ffbf18" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="#d72813" />
                                <Setter Property="BorderBrush" Value="#ffbf18" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#d72813" />
                                <Setter Property="BorderBrush" Value="#ffbf18" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </dx:SimpleButton.Style>
            </dx:SimpleButton>

