<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.SaveView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="Save"
                 Width="300"
                 Height="180"
                 DataContext="{startuphelpers:DISource Type=ViewModels:SaveViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
        <dxmvvm:DispatcherService />
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Content="Title" />

        <dxe:ComboBoxEdit Grid.Row="1"
                          Grid.Column="2"
                          Margin="5,0,0,0"
                          EditValue="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding Titles}">
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding LoadTitlesCommand}"
                                       EventName="EditValueChanged" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ComboBoxEdit>

        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Group"
               Visibility="{Binding ShowGroup, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <dxe:ComboBoxEdit Grid.Row="2"
                          Grid.Column="2"
                          Margin="5,5,0,0"
                          EditValue="{Binding SelectedGroup, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding Groups}"
                          Visibility="{Binding ShowGroup, Converter={StaticResource BooleanToVisibilityConverter}}">
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding LoadTitlesCommand}"
                                       EventName="EditValueChanged" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ComboBoxEdit>
        <Grid Grid.Row="3"
              Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <dxe:CheckEdit Grid.Column="0"
                           Margin="5,5,0,0"
                           Content="Set as default"
                           EditValue="{Binding SetAsDefault}"
                           Visibility="{Binding ShowDefault, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <dxe:CheckEdit Grid.Column="1"
                           Margin="5,5,0,0"
                           Content="Save Location"
                           EditValue="{Binding SaveLocation}"
                           IsEnabled="{Binding SetAsDefault}"
                           Visibility="{Binding ShowLocation, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <dxe:CheckEdit Grid.Row="1"
                           Grid.Column="0"
                           Margin="5,5,0,0"
                           Content="Add To Favorites"
                           EditValue="{Binding AddToFavorites}"
                           Visibility="{Binding ShowDefault, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Grid>
        <StackPanel Grid.Row="5"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding SaveCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Save/Save.svg}"
                             GlyphHeight="15"
                             IsDefault="True" />

            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
