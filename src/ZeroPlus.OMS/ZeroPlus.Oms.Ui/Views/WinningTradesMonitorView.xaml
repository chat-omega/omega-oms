<views:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.WinningTradesMonitorView"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                    xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                    xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                    xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                    Width="1500"
                    Height="800"
                    MinWidth="400"
                    MinHeight="300"
                    d:DataContext="{d:DesignInstance Type=ViewModels:WinningTradesMonitorViewModel}"
                    DataContext="{startuphelpers:DISource Type=ViewModels:WinningTradesMonitorViewModel}"
                    WindowStartupLocation="CenterScreen"
                    mc:Ignorable="d">

    <views:ModuleWindow.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#6dc534"
                                     ZeroBrush="#6dc534" />
    </views:ModuleWindow.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <views:ModuleWindow.HeaderItems>
        <dx:SimpleButton Margin="2"
                         Padding="0"
                         ButtonKind="Toggle"
                         Glyph="{dx:DXImage 'SvgImages/PDF Viewer/EnableScrolling.svg'}"
                         GlyphHeight="20"
                         IsChecked="{Binding AutoScroll}"
                         ToolTip="Auto Scroll" />
        <views:ModuleHeaderItems />
    </views:ModuleWindow.HeaderItems>

    <Grid>
        <dxg:GridControl x:Name="TradesGridControl"
                         MinHeight="70"
                         MaxHeight="5000"
                         AutoGenerateColumns="None"
                         CurrentItem="{Binding LastWinningTrade}"
                         EnableSmartColumnsGeneration="False"
                         ItemsSource="{Binding TransactionConsumer.WinningTrades}">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                    <Setter Property="Visible" Value="True" />
                    <Setter Property="IsSmart" Value="True" />
                    <Setter Property="EditSettings">
                        <Setter.Value>
                            <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                        </Setter.Value>
                    </Setter>
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView Name="TradesTable"
                               AllowDragDrop="True"
                               AllowEditing="False"
                               AutoWidth="True"
                               BandSeparatorWidth="1"
                               EnableSelectedRowAppearance="True"
                               GroupSummaryDisplayMode="AlignByColumns"
                               NavigationStyle="Cell"
                               RowStyle="{StaticResource RowStyle}"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.RowCellMenuCustomizations>
                        <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInOrderTicketCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=TradesGridControl}"
                                           Content="Open in Order Ticket" />
                    </dxg:TableView.RowCellMenuCustomizations>
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridColumn FieldName="Underlying">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Traders">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Symbol"
                            Visible="False">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="SpreadId">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Margin="2,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#F3A202"
                                   Text="{Binding RowData.Row.SpreadId}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="LastTradeTime">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Padding="4,3,3,3"
                                   Foreground="#F1F1F1"
                                   Text="{Binding Path=RowData.Row.LastEdgeTradeTime, StringFormat='{}{0:hh:mm:ss.fff}'}"
                                   TextAlignment="Left" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.HighestEdge, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="HighestEdge" />
            <dxg:GridColumn FieldName="BuyEdgeToTheo">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,0,2,0"
                                   Padding="2"
                                   HorizontalAlignment="Right"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding RowData.Row.BuyEdgeToTheo, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.BuyEdgeToTheo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="SellEdgeToTheo">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,0,2,0"
                                   Padding="2"
                                   HorizontalAlignment="Right"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding RowData.Row.SellEdgeToTheo, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.SellEdgeToTheo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.BuyPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="BuyPrice" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.SellPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="SellPrice" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.BuyUnderPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="BuyUnderPrice" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.SellUnderPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="SellUnderPrice" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.AdjBuyPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="AdjBuyPrice" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.AdjSellPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="AdjSellPrice" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.LastTradeDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="LastTradeDelta" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.LastTradeUnder, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="LastTradeUnder" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.UnderlyingChange, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="UnderlyingChange" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.UnderlyingMid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="UnderlyingMid" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.MinutesSinceEdgeTrade, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                            FieldName="MinutesSinceEdgeTrade"
                            Header="Mins - Edge Trade" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.MinutesSinceLastTrade, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                            FieldName="MinutesSinceEdgeTrade"
                            Header="Mins - Last Trade"
                            Visible="False" />
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.MinutesSinceLastHardSideAttempt, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                            FieldName="MinutesSinceLastHardSideAttempt"
                            Header="Mins - Hard Side Attempt"
                            Visible="False" />
            <dxg:GridColumn FieldName="HardSideKey"
                            Visible="False">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="HardSide">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="LastTradeSide">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn Width="150"
                            AllowSorting="False"
                            FieldName="Load"
                            FixedWidth="True"
                            Header="Load">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Background="Transparent"
                                         BorderThickness="0"
                                         Command="{Binding View.DataContext.LoadInBasketTraderCommand}"
                                         CommandParameter="{Binding RowData.Row}"
                                         Content="Load in Basket"
                                         Glyph="{dx:DXImage SvgImages/RichEdit/RichEditBookmark.svg}"
                                         GlyphHeight="16" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>
    </Grid>
</views:ModuleWindow>
