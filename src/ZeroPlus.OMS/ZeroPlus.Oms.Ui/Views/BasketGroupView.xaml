<view:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.BasketGroupView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                   xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                   xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                   xmlns:view="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                   Title="{Binding ModuleTitle}"
                   Width="1200"
                   Height="700"
                   MinWidth="600"
                   MinHeight="350"
                   d:DataContext="{d:DesignInstance Type=viewModels:BasketGroupViewModel}"
                   DataContext="{startuphelpers:DISource Type=viewModels:BasketGroupViewModel}"
                   WindowStartupLocation="CenterScreen"
                   mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:OpenFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <view:ModuleWindow.HeaderItems>
        <view:ModuleHeaderItems ShowNameEditor="True" />
    </view:ModuleWindow.HeaderItems>

    <view:ModuleWindow.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SignToBrushConverter x:Key="TitleSignToBrushConverter"
                                     NegativeBrush="#FF0000"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#10e411" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToStateColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#c6c6c6" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#F30005" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToFillColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#9fffb2" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="Transparent" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
    </view:ModuleWindow.Resources>

    <dx:DXTabControl x:Name="TabControl"
                     Padding="0"
                     AllowDrop="True"
                     DragOver="OnBasketGroupDragOver"
                     ItemsSource="{Binding Baskets}"
                     SelectedItem="{Binding SelectedBasket}"
                     TabContentCacheMode="CacheAllTabs">
        <dx:DXTabControl.ItemHeaderTemplate>
            <DataTemplate>
                <Grid dxb:BarManager.MenuShowMouseButton="RightButton">
                    <dxb:BarManager.DXContextMenu>
                        <dxb:PopupControlContainer>
                            <ItemsControl>
                                <MenuItem Height="25"
                                          Command="{Binding DataContext.CloneBasketCommand, ElementName=TabControl}"
                                          CommandParameter="{Binding}"
                                          Header="Duplicate">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ItemsControl>
                        </dxb:PopupControlContainer>
                    </dxb:BarManager.DXContextMenu>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Canvas Grid.Column="0"
                            Width="10"
                            Height="10">
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="{Binding SubmitAllRunning, Converter={StaticResource BooleanToFillColorConverter}}"
                                 Stroke="{Binding SubmitAllRunning, Converter={StaticResource BooleanToStateColorConverter}}" />
                    </Canvas>

                    <TextBlock Grid.Column="1"
                               Margin="5,0,0,0"
                               FontWeight="DemiBold"
                               Text="{Binding ModuleTitle}" />

                    <dx:DXImage Grid.Column="2"
                                Height="15"
                                Margin="5,0,0,0"
                                HorizontalAlignment="Right"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="{dx:DXImage 'SvgImages/Business Objects/BO_Notifications.svg'}"
                                Visibility="{Binding ShowMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <dx:SimpleButton Grid.Column="3"
                                     Width="15"
                                     Height="15"
                                     Margin="5,0,0,0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     BorderThickness="0"
                                     Command="{Binding DataContext.DetachCommand, ElementName=TabControl}"
                                     CommandParameter="{Binding}"
                                     Glyph="{dx:DXImage 'SvgImages/XAF/Context_Menu_Show_In_Popup.svg'}"
                                     GlyphHeight="15"
                                     GlyphWidth="15"
                                     ToolTip="Detach Basket" />
                </Grid>
            </DataTemplate>
        </dx:DXTabControl.ItemHeaderTemplate>
        <dx:DXTabControl.ControlBoxRightTemplate>
            <DataTemplate>
                <StackPanel Margin="0,0,10,0"
                            Orientation="Horizontal" />
            </DataTemplate>
        </dx:DXTabControl.ControlBoxRightTemplate>
        <dx:DXTabControl.ItemTemplate>
            <DataTemplate>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="2"
                          VerticalAlignment="Center">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal">
                            <TextBlock Margin="15,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="NET-Δ"
                                       TextAlignment="Right"
                                       ToolTip="Net Delta" />

                            <TextBlock Margin="2,0,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding NetDelta, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding NetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                       TextAlignment="Right" />

                            <TextBlock Margin="5,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="HEDGE-Δ"
                                       TextAlignment="Right"
                                       ToolTip="Hedge Net Delta" />

                            <TextBlock Margin="2,0,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding HedgeNetDelta, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding HedgeNetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                       TextAlignment="Right" />

                            <TextBlock Margin="5,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="TOTAL-Δ"
                                       TextAlignment="Right"
                                       ToolTip="Total Delta" />

                            <TextBlock Margin="2,0,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding TotalNetDelta, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding TotalNetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                       TextAlignment="Right" />

                            <TextBlock Margin="15,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="U-"
                                       TextAlignment="Right"
                                       ToolTip="Unrealized PnL" />

                            <Image Width="15"
                                   Height="15"
                                   Margin="0,2.3,0,0"
                                   VerticalAlignment="Center"
                                   Source="{dx:DXImage 'SvgImages/Icon Builder/Business_DollarCircled.svg'}"
                                   ToolTip="Unrealized PnL" />

                            <TextBlock Margin="2,0,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding UnrealizedPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding UnrealizedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                       TextAlignment="Right" />

                            <TextBlock Margin="5,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="R-"
                                       TextAlignment="Right"
                                       ToolTip="Realized PnL" />

                            <Image Width="15"
                                   Height="15"
                                   Margin="0,2.3,0,0"
                                   VerticalAlignment="Center"
                                   Source="{dx:DXImage 'SvgImages/Icon Builder/Business_DollarCircled.svg'}"
                                   ToolTip="Realized PnL" />

                            <TextBlock Margin="2,1,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding AdjustedPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding AdjustedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                       TextAlignment="Right" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal">
                            <dxe:ToggleSwitch Margin="10,0"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              AnimationMode="Always"
                                              Background="#FF0000"
                                              CheckedStateContent="✅ Risk Check"
                                              ContentPlacement="Inside"
                                              Focusable="False"
                                              FontWeight="Bold"
                                              IsChecked="{Binding BasketSettings.RiskCheckEnabled}"
                                              ToggleSwitchWidth="105"
                                              UncheckedStateContent="⚠ Risk Check" />

                            <dxe:ToggleSwitch Margin="10,0"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              AnimationMode="Always"
                                              Background="#FF0000"
                                              CheckedStateContent="✅ Active Uncheck"
                                              ContentPlacement="Inside"
                                              Focusable="False"
                                              FontWeight="Bold"
                                              IsChecked="{Binding BasketSettings.ActiveUncheckEnabled}"
                                              ToggleSwitchWidth="130"
                                              UncheckedStateContent="⚠ Active Uncheck" />

                            <Image Width="20"
                                   Height="20"
                                   Margin="5,2,0,1"
                                   Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_Clock.svg'}"
                                   ToolTip="Up-Time" />
                            <TextBlock Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="{Binding UpTime}"
                                       TextAlignment="Right"
                                       ToolTip="Up-Time" />
                        </StackPanel>
                    </Grid>
                    <view:BasketTraderContentView x:Name="BasketTraderContentView"
                                                  Grid.Row="1"
                                                  Loaded="BasketTraderTabLoaded" />
                </Grid>
            </DataTemplate>
        </dx:DXTabControl.ItemTemplate>
    </dx:DXTabControl>
</view:ModuleWindow>
