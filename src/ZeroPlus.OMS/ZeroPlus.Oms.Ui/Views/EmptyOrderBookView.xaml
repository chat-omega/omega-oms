<dx:ThemedWindow x:Name="window"
                 x:Class="ZeroPlus.Oms.Ui.Views.EmptyOrderBookView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="{Binding ModuleTitle}"
                 Width="1200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:EmptyOrderBookViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:EmptyOrderBookViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:LoadCustomColumnService />
        <services:OmsMessageBoxService />
        <services:GetItemsByVisualOrderService />
        <dxmvvm:WindowService />
        <dxmvvm:DispatcherService />
        <dxmvvm:OpenFileDialogService />
        <dxmvvm:SaveFileDialogService />
        <dxmvvm:EventToCommand Command="{Binding ClosingCommand}"
                               EventName="Closing"
                               SourceName="window" />
    </dxmvvm:Interaction.Behaviors>

    <Window.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:DoubleRangeToVisibilityConverter x:Key="DoubleRangeToVisibilityConverter"
                                                 Limit="0.0" />
        <helper:SignToBrushConverter x:Key="GiveUpToBrushConverter"
                                     NegativeBrush="#F1F1F1"
                                     PositiveBrush="#FFB115"
                                     ZeroBrush="#FFB115" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#6dc534"
                                     ZeroBrush="#6dc534" />
        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
        <Style x:Key="OrderStyle"
               TargetType="dxg:RowControl">
            <Style.Setters>
                <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Background'}" />
                <Setter Property="Foreground" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Foreground'}" />
            </Style.Setters>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='MouseOver'}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

            <dx:DropDownButton Width="115"
                               Margin="2"
                               Padding="3,1,7,1"
                               HorizontalAlignment="Right"
                               Content="Settings"
                               Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Settings.svg}"
                               GlyphHeight="15">
                <ItemsControl>
                    <StackPanel Orientation="Vertical">
                        <MenuItem Click="ClearFiltersClick"
                                  Header="Clear Filters" />
                        <MenuItem Click="ClearSortingClick"
                                  Header="Clear Sorting" />
                        <dx:SuperTipItemControlSeparator />
                        <MenuItem Header="Delta Adjust Fills"
                                  IsCheckable="True"
                                  IsChecked="{Binding EnableDeltaAdjusting}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding CheckForSubscriptionCommand}"
                                                       EventName="Checked" />
                                <dxmvvm:EventToCommand Command="{Binding CheckForSubscriptionCommand}"
                                                       EventName="Unchecked" />
                            </dxmvvm:Interaction.Behaviors>
                        </MenuItem>
                        <MenuItem Command="{Binding RequestSymbolEdgeMapCommand}"
                                  Header="Request Adj Edge Map" />
                    </StackPanel>
                </ItemsControl>
            </dx:DropDownButton>

            <dx:SimpleButton Width="23"
                             Margin="2"
                             HorizontalAlignment="Right"
                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                             GlyphHeight="17">
                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupControlContainer>
                        <ItemsControl>
                            <StackPanel>
                                <MenuItem Height="25"
                                          Command="{Binding CloneCommand}"
                                          Header="Clone">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="ShareLayout"
                                          Header="Share Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="SaveLayout"
                                          Header="Save Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding BrowseLayoutsCommand}"
                                          Header="Browse Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="LoadLayout"
                                          Header="Load Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </StackPanel>
                        </ItemsControl>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>
        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <dx:SplitButton Grid.Row="0"
                                Grid.Column="0"
                                Width="110"
                                Height="23"
                                HorizontalAlignment="Right"
                                Command="{Binding SaveOrderBookCommand}"
                                Content="Save"
                                Glyph="{dx:DXImage SvgImages/Save/Save.svg}"
                                GlyphHeight="15"
                                PopupAutoWidth="True">
                    <StackPanel Orientation="Vertical">
                        <dx:SimpleButton HorizontalContentAlignment="Left"
                                         Command="{Binding SaveAsOrderBookCommand}"
                                         Content="Save As"
                                         Glyph="{dx:DXImage SvgImages/Save/Save.svg}"
                                         GlyphHeight="15" />
                        <dxe:CheckEdit Content="Auto Save"
                                       EditValue="{Binding AutoSave}"
                                       IsEnabled="{Binding Loaded}" />
                    </StackPanel>
                </dx:SplitButton>

                <dx:SimpleButton Grid.Row="0"
                                 Grid.Column="1"
                                 Width="90"
                                 Height="23"
                                 Margin="5,0,0,0"
                                 HorizontalAlignment="Right"
                                 Command="{Binding LoadOrderBookCommand}"
                                 Content="Load File"
                                 Glyph="{dx:DXImage SvgImages/Outlook Inspired/Open.svg}"
                                 GlyphHeight="15" />

                <dx:SimpleButton Grid.Row="0"
                                 Grid.Column="2"
                                 Height="23"
                                 Margin="5,0,0,0"
                                 HorizontalContentAlignment="Left"
                                 Command="{Binding LoadOrderBookFromArchiveCommand}"
                                 Content="Load Archive"
                                 Glyph="{dx:DXImage SvgImages/Outlook Inspired/Open.svg}"
                                 GlyphHeight="15" />

                <dx:SimpleButton Grid.Row="0"
                                 Grid.Column="3"
                                 Height="23"
                                 Margin="5,0,0,0"
                                 HorizontalContentAlignment="Left"
                                 Command="{Binding ExportCommand}"
                                 Content="Export"
                                 Glyph="{dx:DXImage SvgImages/Export/ExportToXLSX.svg}"
                                 GlyphHeight="15" />

                <dx:SimpleButton Grid.Row="0"
                                 Grid.Column="4"
                                 Width="80"
                                 Height="23"
                                 Margin="5,0,0,0"
                                 Command="{Binding CleanCommand}"
                                 Content="Clean"
                                 Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Clear.svg}"
                                 GlyphHeight="15" />

                <dx:SimpleButton Grid.Row="0"
                                 Grid.Column="5"
                                 Width="90"
                                 Height="23"
                                 Margin="5,0,0,0"
                                 Command="{Binding RemoveSelectedCommand}"
                                 CommandParameter="{Binding Path=SelectedItems, ElementName=CustomOrderGrid}"
                                 Content="Remove"
                                 Glyph="{dx:DXImage SvgImages/Snap/RemoveGroupHeader.svg}" />
            </Grid>
            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <dx:SimpleButton Grid.Row="0"
                                 Grid.Column="5"
                                 Height="23"
                                 Margin="5,0,0,0"
                                 Command="{Binding AddToTodaysOrderbookCommand}"
                                 Content="Add to Today's Orderbook"
                                 Glyph="{dx:DXImage 'Images/Chart/AddChartPane_16x16.png'}"
                                 Visibility="{Binding PortfolioAdjustmentModuleGranted, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
            <Grid Grid.Row="0"
                  Grid.Column="1"
                  Visibility="{Binding ShowFilters, Converter={dx:BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <dx:SimpleButton Name="ALL"
                                 Grid.Column="1"
                                 Width="60"
                                 Margin="1"
                                 Padding="0,3"
                                 ButtonKind="Toggle"
                                 Click="FilterToggleClick"
                                 Command="{Binding ChangeFilterCommand}"
                                 CommandParameter="ALL"
                                 Content="ALL"
                                 FontSize="10"
                                 Visibility="{Binding ShowAllTransactionsTabs, Converter={dx:BooleanToVisibilityConverter}}" />
                <dx:SimpleButton Name="UNIQUE_ORDERS"
                                 Grid.Column="2"
                                 Width="60"
                                 Margin="1"
                                 Padding="0,3"
                                 ButtonKind="Toggle"
                                 Click="FilterToggleClick"
                                 Command="{Binding ChangeFilterCommand}"
                                 CommandParameter="UNIQUE_ORDERS"
                                 Content="UNIQUE"
                                 FontSize="10"
                                 Visibility="{Binding ShowAllTransactionsTabs, Converter={dx:BooleanToVisibilityConverter}}" />
                <dx:SimpleButton Name="FILLED"
                                 Grid.Column="3"
                                 Width="60"
                                 Margin="1"
                                 Padding="0,3"
                                 ButtonKind="Toggle"
                                 Click="FilterToggleClick"
                                 Command="{Binding ChangeFilterCommand}"
                                 CommandParameter="FILLED"
                                 Content="FILLED"
                                 FontSize="10" />
                <dx:SimpleButton Name="UNIQUE"
                                 Grid.Column="4"
                                 Width="75"
                                 Margin="1"
                                 Padding="0,3"
                                 ButtonKind="Toggle"
                                 Click="FilterToggleClick"
                                 Command="{Binding ChangeFilterCommand}"
                                 CommandParameter="UNIQUE"
                                 Content="UNIQUE FILLS"
                                 FontSize="10" />
            </Grid>
        </Grid>

        <Slider x:Name="CustomOrderGridScale"
                Grid.Row="2"
                Maximum="4"
                Minimum="0.1"
                Visibility="Hidden"
                Value="1" />

        <dxg:GridControl Name="CustomOrderGrid"
                         Grid.Row="2"
                         dx:DXSerializer.StoreLayoutMode="All"
                         dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                         AutoGenerateColumns="AddNew"
                         AutoGeneratedColumns="Grid_ColumnsPopulated"
                         CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                         CustomUnboundColumnDataCommand="{Binding CustomUnboundColumnDataCommand}"
                         EnableSmartColumnsGeneration="True"
                         ItemsSource="{Binding Orders}"
                         PreviewMouseWheel="OnZoomMouseWheel"
                         SelectionMode="Row">
            <dxg:GridControl.LayoutTransform>
                <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=CustomOrderGridScale, Path=Value}" ScaleY="{Binding ElementName=CustomOrderGridScale, Path=Value}" />
            </dxg:GridControl.LayoutTransform>
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
            </dxg:GridControl.Resources>
            <dxmvvm:Interaction.Behaviors>
                <services:UiUpdateService />
            </dxmvvm:Interaction.Behaviors>
            <dxg:GridControl.View>
                <dxg:TableView Name="CustomOrderTable"
                               AllowDragDrop="True"
                               AllowEditing="False"
                               AutoWidth="True"
                               CompleteRecordDragDrop="OnCompleteRecordDragDrop"
                               DragRecordOver="TableView_DragRecordOver"
                               DropRecord="TableView_DropRecord"
                               EditorShowMode="MouseUp"
                               EnableSelectedRowAppearance="True"
                               IsDetailButtonVisibleBinding="{Binding Row.ShowDetailsButton}"
                               RowDoubleClickCommand="{Binding RowDoubleClickCommand}"
                               RowStyle="{StaticResource OrderStyle}"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               StartRecordDrag="OnStartRecordDrag">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.RowCellMenuCustomizations>
                        <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInComplexOrderTicketCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=CustomOrderGrid}"
                                           Content="Open in Complex Order Ticket" />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.RemoveOrderCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=CustomOrderGrid}"
                                           Content="Remove" />
                        <dxb:BarItemSeparator />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.GetAuditTrailCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=CustomOrderGrid}"
                                           Content="Get Audit Trail" />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.OpenOrderDetailsCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=CustomOrderGrid}"
                                           Content="Open Order Details" />
                    </dxg:TableView.RowCellMenuCustomizations>
                    <dxg:TableView.GroupValueTemplate>
                        <DataTemplate>
                            <TextBlock Margin="10,0,0,0"
                                       Text="{Binding Value}" />
                        </DataTemplate>
                    </dxg:TableView.GroupValueTemplate>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridControl.DetailDescriptor>
                <dxg:TabViewDetailDescriptor>
                    <dxg:TabViewDetailDescriptor.DetailDescriptors>
                        <dxg:DataControlDetailDescriptor ItemsSourceBinding="{Binding Legs}">
                            <dxg:DataControlDetailDescriptor.DataControl>
                                <dxg:GridControl dx:DXSerializer.StoreLayoutMode="All"
                                                 dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                                                 AutoGenerateColumns="AddNew"
                                                 CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                                                 EnableSmartColumnsGeneration="True"
                                                 SelectionMode="Row">
                                    <dxg:GridControl.Resources>
                                        <Style TargetType="dxg:GridColumn">
                                            <Setter Property="Visible" Value="True" />
                                            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                                        </Style>
                                    </dxg:GridControl.Resources>
                                    <dxg:GridControl.View>
                                        <dxg:TableView DetailHeaderContent="Legs"
                                                       ShowGroupPanel="False">
                                            <dxg:TableView.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Height="25"
                                                              Command="{Binding ShowColumnChooserCommand}"
                                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Header="Show Column Chooser">
                                                        <MenuItem.Icon>
                                                            <Image Width="15"
                                                                   Height="15"
                                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Height="25"
                                                              Command="{Binding ClearColumnsCommand}"
                                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Header="Hide All Columns">
                                                        <MenuItem.Icon>
                                                            <Image Width="15"
                                                                   Height="15"
                                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Height="25"
                                                              Command="{Binding ShowAllColumnsCommand}"
                                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Header="Show All Columns">
                                                        <MenuItem.Icon>
                                                            <Image Width="15"
                                                                   Height="15"
                                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Height="25"
                                                              Command="{Binding ShowDefaultColumnsCommand}"
                                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Header="Show Default Columns">
                                                        <MenuItem.Icon>
                                                            <Image Width="15"
                                                                   Height="15"
                                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </dxg:TableView.ContextMenu>
                                        </dxg:TableView>
                                    </dxg:GridControl.View>
                                </dxg:GridControl>
                            </dxg:DataControlDetailDescriptor.DataControl>
                        </dxg:DataControlDetailDescriptor>

                        <dxg:DataControlDetailDescriptor ItemsSourceBinding="{Binding ContrapartyReportModel}">
                            <dxg:DataControlDetailDescriptor.DataControl>
                                <dxg:GridControl dx:DXSerializer.StoreLayoutMode="All"
                                                 dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                                                 AutoGenerateColumns="AddNew"
                                                 CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                                                 EnableSmartColumnsGeneration="True"
                                                 SelectionMode="Row">
                                    <dxg:GridControl.Resources>
                                        <Style TargetType="dxg:GridColumn">
                                            <Setter Property="Visible" Value="True" />
                                            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                                        </Style>
                                    </dxg:GridControl.Resources>
                                    <dxg:GridControl.View>
                                        <dxg:TableView DetailHeaderContent="Contraparty Report"
                                                       ShowGroupPanel="False">
                                            <dxg:TableView.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Height="25"
                                                              Command="{Binding ShowColumnChooserCommand}"
                                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Header="Show Column Chooser">
                                                        <MenuItem.Icon>
                                                            <Image Width="15"
                                                                   Height="15"
                                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Height="25"
                                                              Command="{Binding ClearColumnsCommand}"
                                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Header="Hide All Columns">
                                                        <MenuItem.Icon>
                                                            <Image Width="15"
                                                                   Height="15"
                                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Height="25"
                                                              Command="{Binding ShowAllColumnsCommand}"
                                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Header="Show All Columns">
                                                        <MenuItem.Icon>
                                                            <Image Width="15"
                                                                   Height="15"
                                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Height="25"
                                                              Command="{Binding ShowDefaultColumnsCommand}"
                                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Header="Show Default Columns">
                                                        <MenuItem.Icon>
                                                            <Image Width="15"
                                                                   Height="15"
                                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </dxg:TableView.ContextMenu>
                                        </dxg:TableView>
                                    </dxg:GridControl.View>
                                </dxg:GridControl>
                            </dxg:DataControlDetailDescriptor.DataControl>
                        </dxg:DataControlDetailDescriptor>
                    </dxg:TabViewDetailDescriptor.DetailDescriptors>
                </dxg:TabViewDetailDescriptor>
            </dxg:GridControl.DetailDescriptor>

            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem DisplayFormat="{}{0:N0}"
                                     FieldName="TotalContracts"
                                     ShowInColumn="TotalContracts"
                                     SummaryType="Sum" />
            </dxg:GridControl.TotalSummary>

            <dxg:GridControl.GroupSummary>
                <dxg:GridSummaryItem DisplayFormat="{}{0:+#0;-#0;-}"
                                     FieldName="Position"
                                     ShowInColumn="Position"
                                     SummaryType="Max" />
                <dxg:GridSummaryItem DisplayFormat="{}{0:C2}"
                                     FieldName="RealizedPnL"
                                     ShowInColumn="RealizedPnL"
                                     SummaryType="Max" />
                <dxg:GridSummaryItem DisplayFormat="{}{0:C2}"
                                     FieldName="AdjustedPnl"
                                     ShowInColumn="AdjustedPnl"
                                     SummaryType="Max" />
            </dxg:GridControl.GroupSummary>

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaIv, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Raw}}"
                            FieldName="VolaIv" />
            <dxg:GridColumn FieldName="AddToTodaysOrderbook">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:CheckEdit HorizontalAlignment="Center"
                                       EditValue="{Binding RowData.Row.AddToTodaysOrderbook}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="HasContraPartyReport" />
            <dxg:GridColumn FieldName="Symbol"
                            Header="Sym"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn FieldName="Description"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn FieldName="SpreadId"
                            Header="Spread Description"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn FieldName="SpreadType"
                            Header="Spread Type"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn FieldName="OrderStatus"
                            Header="Status"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn FieldName="FilledQty"
                            Header="Filled #"
