<dx:ThemedWindow x:Name="window"
                 x:Class="ZeroPlus.Oms.Ui.Views.AddColumnView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="Add Column"
                 Width="300"
                 Height="170"
                 DataContext="{startuphelpers:DISource Type=ViewModels:AddColumnViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Margin="5,0"
               Content="Header" />
        <dxe:TextEdit x:Name="HeaderTextEdit"
                      Grid.Row="1"
                      Grid.Column="2"
                      EditValue="{Binding ColumnTemplate.Header}" />
        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="5,5,0,0"
               Content="Type" />

        <dxe:ComboBoxEdit Grid.Row="2"
                          Grid.Column="2"
                          Margin="0,5,0,0"
                          EditValue="{Binding ColumnTemplate.Type}"
                          IsTextEditable="False">
            <dxe:ComboBoxEditItem Content="Integer" />
            <dxe:ComboBoxEditItem Content="Decimal" />
            <dxe:ComboBoxEditItem Content="DateTime" />
            <dxe:ComboBoxEditItem Content="String" />
            <dxe:ComboBoxEditItem Content="Boolean" />
        </dxe:ComboBoxEdit>

        <dxe:CheckEdit Grid.Row="3"
                       Grid.Column="2"
                       Content="Allow Editing"
                       EditValue="{Binding ColumnTemplate.AllowEditing}" />

        <dxe:CheckEdit Grid.Row="4"
                       Grid.Column="2"
                       Content="With Expression Evaluator"
                       EditValue="{Binding ColumnTemplate.AllowEquationEvaluator}" />

        <StackPanel Grid.Row="6"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="60"
                             Margin="5"
                             Command="{Binding AddColumnCommand}"
                             Content="Save"
                             IsDefault="True" />
            <dx:SimpleButton Width="60"
                             Margin="5"
                             Click="SimpleButton_Click"
                             Content="Cancel"
                             IsCancel="True" />
        </StackPanel>

    </Grid>
</dx:ThemedWindow>
