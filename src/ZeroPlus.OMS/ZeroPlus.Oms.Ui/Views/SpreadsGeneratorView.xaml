<view:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.SpreadsGeneratorView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                   xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                   xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                   xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                   xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                   xmlns:sys="clr-namespace:System;assembly=mscorlib"
                   xmlns:view="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                   Title="{Binding ModuleTitle}"
                   Width="1800"
                   Height="700"
                   MinWidth="520"
                   MinHeight="300"
                   d:DataContext="{d:DesignInstance Type=viewModels:SpreadsGeneratorViewModel}"
                   d:Height="1200"
                   d:Width="auto"
                   DataContext="{startuphelpers:DISource Type=viewModels:SpreadsGeneratorViewModel}"
                   mc:Ignorable="d">

    <dx:ThemedWindow.HeaderItems>
        <view:ModuleHeaderItems />
    </dx:ThemedWindow.HeaderItems>

    <dx:ThemedWindow.Resources>
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:MultiBooleanToOrConverter x:Key="MultiBooleanToOrConverter" />
        <helper:MultiBooleanToVisibilityInverseConverter x:Key="MultiBooleanToVisibilityInverseConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="CanExportToContentConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Export to File
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Preset Export
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
    </dx:ThemedWindow.Resources>

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:SaveFileDialogService />
        <dxmvvm:DispatcherService />
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition x:Name="GridSplitterCol"
                              Width="*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="1"
              Grid.Column="1"
              Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0"
                          Padding="0,2"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <dxlc:GroupBox Grid.Column="0"
                                   Width="119"
                                   Margin="0,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Label Padding="0"
                                       HorizontalAlignment="Center"
                                       Content="Runner"
                                       Foreground="#AFAFB0" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <dxe:ComboBoxEdit Width="90"
                                          Margin="0,5,0,0"
                                          VerticalAlignment="Top"
                                          ApplyItemTemplateToSelectedItem="True"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding RunnerOptions}"
                                          SelectedItem="{Binding RunnerOption}">
                            <dxe:ComboBoxEdit.ItemTemplate>
                                <DataTemplate>
                                    <Label Padding="0,0.5"
                                           HorizontalAlignment="Center"
                                           Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}"
                                           FontSize="11" />
                                </DataTemplate>
                            </dxe:ComboBoxEdit.ItemTemplate>
                        </dxe:ComboBoxEdit>

                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Column="1"
                                   Width="119"
                                   Margin="5,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Label Padding="0"
                                       HorizontalAlignment="Center"
                                       Content="Type"
                                       Foreground="#AFAFB0" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Vertical">
                            <dxe:CheckEdit Height="22"
                                           Content="Calls"
                                           EditValue="{Binding CallsEnabled}" />
                            <dxe:CheckEdit Height="22"
                                           Margin="0,2,0,0"
                                           Content="Puts"
                                           EditValue="{Binding PutsEnabled}" />
                        </StackPanel>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Column="2"
                                   Width="90"
                                   Margin="5,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Label Padding="0"
                                       HorizontalAlignment="Center"
                                       Content="Strike Type"
                                       Foreground="#AFAFB0" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <StackPanel Margin="2,0,0,0"
                                    HorizontalAlignment="Left"
                                    Orientation="Vertical">
                            <dxe:CheckEdit Height="22"
                                           Content="Whole"
                                           EditValue="{Binding WholeStrikes}" />
                            <dxe:CheckEdit Height="22"
                                           Margin="0,2,0,0"
                                           Content="Decimal"
                                           EditValue="{Binding DecimalStrikes}" />
                        </StackPanel>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Column="3"
                                   Margin="5,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Label Padding="0"
                                       HorizontalAlignment="Center"
                                       Content="Strike Range"
                                       Foreground="#AFAFB0" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid Margin="2,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="0"
                                           Width="50"
                                           Height="22"
                                           Content="Min"
                                           EditValue="{Binding MinStrikeEnabled}" />

                            <dxe:SpinEdit Grid.Row="0"
                                          Grid.Column="1"
                                          Width="75"
                                          Height="22"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding MinStrike, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          IsEnabled="{Binding MinStrikeEnabled}"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="0"
                                           Width="50"
                                           Height="22"
                                           Margin="0,2,0,0"
                                           Content="Max"
                                           EditValue="{Binding MaxStrikeEnabled}" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="1"
                                          Width="75"
                                          Height="22"
                                          Margin="0,2,0,0"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding MaxStrike, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          IsEnabled="{Binding MaxStrikeEnabled}"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Column="4"
                                   Margin="5,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Label Padding="0"
                                       HorizontalAlignment="Center"
                                       Content="Strike Occurrence"
                                       Foreground="#AFAFB0" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid Margin="2,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="0"
                                           Width="50"
                                           Height="22"
                                           Content="Min"
                                           EditValue="{Binding MinStrikeOccurrenceEnabled}" />

                            <dxe:SpinEdit Grid.Row="0"
                                          Grid.Column="1"
                                          Width="75"
                                          Height="22"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          DisplayFormatString="N0"
                                          EditValue="{Binding MinStrikeOccurrence, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          IsEnabled="{Binding MinStrikeOccurrenceEnabled}"
                                          Mask="N0"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="0"
                                           Width="50"
                                           Height="22"
                                           Margin="0,2,0,0"
                                           Content="Max"
                                           EditValue="{Binding MaxStrikeOccurrenceEnabled}" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="1"
                                          Width="75"
                                          Height="22"
                                          Margin="0,2,0,0"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          DisplayFormatString="N0"
                                          EditValue="{Binding MaxStrikeOccurrence, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          IsEnabled="{Binding MaxStrikeOccurrenceEnabled}"
                                          Mask="N0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Column="5"
                                   Margin="5,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Label Padding="0"
                                       HorizontalAlignment="Center"
                                       Content="Strike Distance"
                                       Foreground="#AFAFB0" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid Margin="2,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="0"
                                           Height="22"
                                           Margin="0,2,0,0"
                                           Content="Distance From Last %"
                                           EditValue="{Binding StrikeDistanceFromLastPercentEnabled}" />

                            <dxe:SpinEdit Grid.Row="0"
                                          Grid.Column="1"
                                          Height="22"
                                          Margin="5,2,0,0"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding StrikeDistanceFromLastPercent, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          IsEnabled="{Binding StrikeDistanceFromLastPercentEnabled}"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          MaxValue="1"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="0"
                                           Height="22"
                                           Margin="0,2,0,0"
                                           Content="Top and Bottom Strikes"
                                           EditValue="{Binding StrikeIncludeFromTopAndBottomEnabled}" />

                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Orientation="Horizontal">
                                <dxe:SpinEdit Width="45"
                                              Height="22"
                                              Margin="5,2,0,0"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              EditValue="{Binding StrikeIncludeFromTopAndBottomCount, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              IsEnabled="{Binding StrikeIncludeFromTopAndBottomEnabled}"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />

                                <dxe:ToggleSwitch Margin="2,2,0,0"
                                                  HorizontalAlignment="Left"
                                                  CheckedStateContent="Include"
                                                  ContentPlacement="Inside"
                                                  IsChecked="{Binding StrikeIncludeAsAdditionFromTopAndBottom}"
                                                  IsEnabled="{Binding StrikeIncludeFromTopAndBottomEnabled}"
                                                  ToggleSwitchWidth="60"
                                                  UncheckedStateContent="Only" />
                            </StackPanel>

                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Column="6"
                                   Margin="5,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Label Padding="0"
                                       HorizontalAlignment="Center"
                                       Content="Expiration Range"
                                       Foreground="#AFAFB0" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid Margin="2,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0"
                                        Grid.Column="0"
                                        Width="50"
                                        Orientation="Horizontal">
                                <dxe:CheckEdit Height="22"
                                               EditValue="{Binding MinExpEnabled}" />
                                <Label Margin="3,0,0,0"
                                       Content="Min" />
                            </StackPanel>
                            <dx:DropDownButton Grid.Row="0"
                                               Grid.Column="1"
                                               Width="35"
                                               BorderThickness="1,1,0.5,1"
                                               PopupHeight="200"
                                               PopupWidth="105">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <dxe:CheckEdit Margin="10,0,-10,0"
                                                       HorizontalAlignment="Left"
                                                       Content="     Select All"
                                                       FlowDirection="RightToLeft"
                                                       IsChecked="True">
                                            <dxmvvm:Interaction.Behaviors>
                                                <dxmvvm:EventToCommand Command="{Binding ElementName=SpreadGeneratorTab, Path=DataContext.CheckAllExpirationCommand}"
                                                                       EventName="Checked" />
                                                <dxmvvm:EventToCommand Command="{Binding ElementName=SpreadGeneratorTab, Path=DataContext.UncheckAllExpirationCommand}"
                                                                       EventName="Unchecked" />
                                            </dxmvvm:Interaction.Behaviors>
                                        </dxe:CheckEdit>
                                        <ItemsControl Grid.Row="1"
                                                      ItemsSource="{Binding ExpirationsList}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel>
                                                        <dxe:CheckEdit Margin="3,0"
                                                                       HorizontalAlignment="Left"
                                                                       DockPanel.Dock="Right"
                                                                       IsChecked="{Binding IsChecked}" />
                                                        <dx:SimpleButton Width="80"
                                                                         Margin="0,0,-4,0"
                                                                         HorizontalAlignment="Left"
                                                                         HorizontalContentAlignment="Left"
                                                                         Background="Transparent"
                                                                         BorderThickness="0"
                                                                         Command="{Binding MinExpirationChangedCommand}"
                                                                         Content="{Binding Date}"
                                                                         ContentStringFormat="MMM dd yy" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </ScrollViewer>
                            </dx:DropDownButton>

                            <dxe:DateEdit Grid.Row="0"
                                          Grid.Column="2"
                                          Width="90"
                                          HorizontalAlignment="Left"
                                          BorderThickness="0.5,1,1,1"
                                          EditValue="{Binding MinExp}"
                                          IsEnabled="{Binding MinExpEnabled}" />

                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="3"
                                           Height="22"
                                           Margin="5,0,0,0"
                                           HorizontalAlignment="Left"
                                           Content="DTE Range"
                                           EditValue="{Binding DteRangeEnabled}" />

                            <StackPanel Grid.Row="0"
                                        Grid.Column="4"
                                        Margin="0,2,0,0"
                                        IsEnabled="{Binding DteRangeEnabled}"
                                        Orientation="Horizontal">

                                <dxe:SpinEdit Width="55"
                                              Height="22"
                                              Margin="5,0,0,0"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              DisplayFormatString="N0"
                                              EditValue="{Binding MinDteRange, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Mask="N0"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True"
                                              ShowEditorButtons="False" />

                                <dxe:SpinEdit Width="55"
                                              Height="22"
                                              Margin="2,0,0,0"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              DisplayFormatString="N0"
                                              EditValue="{Binding MaxDteRange, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Mask="N0"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True"
                                              ShowEditorButtons="False" />

                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="0"
                                        Width="50"
                                        Margin="0,2,0,0"
                                        Orientation="Horizontal">
                                <dxe:CheckEdit Height="22"
                                               EditValue="{Binding MaxExpEnabled}" />
                                <Label Margin="3,0,0,0"
                                       Content="Max" />
                            </StackPanel>

                            <dx:DropDownButton Grid.Row="1"
                                               Grid.Column="1"
                                               Width="35"
                                               Margin="0,2,0,0"
                                               BorderThickness="1,1,0.5,1"
                                               PopupHeight="200"
                                               PopupWidth="105">

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <dxe:CheckEdit Margin="10,0,-10,0"
                                                       HorizontalAlignment="Left"
                                                       Content="     Select All"
                                                       FlowDirection="RightToLeft"
                                                       IsChecked="True">
                                            <dxmvvm:Interaction.Behaviors>
                                                <dxmvvm:EventToCommand Command="{Binding ElementName=SpreadGeneratorTab, Path=DataContext.CheckAllExpirationCommand}"
                                                                       EventName="Checked" />
                                                <dxmvvm:EventToCommand Command="{Binding ElementName=SpreadGeneratorTab, Path=DataContext.UncheckAllExpirationCommand}"
                                                                       EventName="Unchecked" />
                                            </dxmvvm:Interaction.Behaviors>
                                        </dxe:CheckEdit>
                                        <ItemsControl Grid.Row="1"
                                                      ItemsSource="{Binding ExpirationsList}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel>
                                                        <dxe:CheckEdit Margin="3,0"
                                                                       HorizontalAlignment="Left"
                                                                       DockPanel.Dock="Right"
                                                                       IsChecked="{Binding IsChecked}" />
                                                        <dx:SimpleButton Width="80"
                                                                         Margin="0,0,-4,0"
                                                                         HorizontalAlignment="Left"
                                                                         HorizontalContentAlignment="Left"
                                                                         Background="Transparent"
                                                                         BorderThickness="0"
                                                                         Command="{Binding MaxExpirationChangedCommand}"
                                                                         Content="{Binding Date}"
                                                                         ContentStringFormat="MMM dd yy" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </ScrollViewer>
                            </dx:DropDownButton>

                            <dxe:DateEdit Grid.Row="1"
                                          Grid.Column="2"
                                          Width="90"
                                          Margin="0,2,0,0"
                                          HorizontalAlignment="Left"
                                          BorderThickness="0.5,1,1,1"
                                          EditValue="{Binding MaxExp}"
                                          IsEnabled="{Binding MaxExpEnabled}" />

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="3"
                                           Grid.ColumnSpan="2"
                                           Height="22"
                                           Margin="5,0,0,0"
                                           Content="Apply DTE to Exp-Spacing map"
                                           EditValue="{Binding ApplyDteToExpSpacingMap}" />

                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Column="7"
                                   Margin="5,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Label Padding="0"
                                       HorizontalAlignment="Center"
                                       Content="Expiration Type"
                                       Foreground="#AFAFB0" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="0"
                                           Height="22"
                                           Content="Regulars"
                                           EditValue="{Binding Regulars}" />
                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="1"
                                           Height="22"
                                           Margin="5,0,0,0"
                                           Content="Non Regulars"
                                           EditValue="{Binding NonRegulars}" />
                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="0"
                                           Height="22"
                                           Margin="0,2,0,0"
                                           Content="Quarterlies"
                                           EditValue="{Binding Quarterlies}" />
                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Column="8"
                                   Margin="5,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Label Padding="0"
                                       HorizontalAlignment="Center"
                                       Content="Firm Spread Filter"
                                       Foreground="#AFAFB0" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="0"
                                           Height="22"
                                           Margin="5,2,0,0"
                                           Content="Fresh Spreads"
                                           EditValue="{Binding FreshSpreads}" />
                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="0"
                                           Height="22"
                                           Margin="5,0,0,0"
                                           Content="Attempted Spreads"
                                           EditValue="{Binding AttemptedSpreads}" />
                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Column="9"
                                   Margin="5,0,0,0"
                                   Padding="2">
                        <dxlc:GroupBox.IsEnabled>
