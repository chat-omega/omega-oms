                                                       Foreground="#F30005" />

                                        <dxe:SpinEdit Grid.Row="0"
                                                      Grid.Column="1"
                                                      Width="70"
                                                      Margin="3,0,0,0"
                                                      HorizontalContentAlignment="Right"
                                                      AllowSpinOnMouseWheel="True"
                                                      EditValue="{Binding TwoThreeOneSpreadsSettings.SpreadEmaToMidRangeFloor, UpdateSourceTrigger=PropertyChanged}"
                                                      EditValueType="{x:Type sys:Double}"
                                                      Increment="0.01"
                                                      IsEnabled="{Binding TwoThreeOneSpreadsSettings.SpreadEmaToMidRangeEnabled}"
                                                      Mask="N2"
                                                      MaskUseAsDisplayFormat="True"
                                                      PreviewMouseUp="SelectAll"
                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True" />

                                        <Label Grid.Row="0"
                                               Grid.Column="2"
                                               Margin="3,0,0,0"
                                               Content="-"
                                               IsEnabled="{Binding TwoThreeOneSpreadsSettings.SpreadEmaToMidRangeEnabled}" />

                                        <dxe:SpinEdit Grid.Row="0"
                                                      Grid.Column="3"
                                                      Width="70"
                                                      Margin="3,0,0,0"
                                                      HorizontalContentAlignment="Right"
                                                      AllowSpinOnMouseWheel="True"
                                                      EditValue="{Binding TwoThreeOneSpreadsSettings.SpreadEmaToMidRangeCeil, UpdateSourceTrigger=PropertyChanged}"
                                                      EditValueType="{x:Type sys:Double}"
                                                      Increment="0.01"
                                                      IsEnabled="{Binding TwoThreeOneSpreadsSettings.SpreadEmaToMidRangeEnabled}"
                                                      Mask="N2"
                                                      MaskUseAsDisplayFormat="True"
                                                      MinValue="{Binding TwoThreeOneSpreadsSettings.SpreadEmaToMidRangeFloor}"
                                                      PreviewMouseUp="SelectAll"
                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True" />

                                        <dxe:CheckEdit Grid.Row="1"
                                                       Grid.Column="0"
                                                       Width="55"
                                                       Margin="0,2,0,0"
                                                       Content="Theo"
                                                       EditValue="{Binding TwoThreeOneSpreadsSettings.SpreadTheoToMidRangeEnabled}"
                                                       Foreground="#F30005" />

                                        <dxe:SpinEdit Grid.Row="1"
                                                      Grid.Column="1"
                                                      Width="70"
                                                      Margin="3,2,0,0"
                                                      HorizontalContentAlignment="Right"
                                                      AllowSpinOnMouseWheel="True"
                                                      EditValue="{Binding TwoThreeOneSpreadsSettings.SpreadTheoToMidRangeFloor, UpdateSourceTrigger=PropertyChanged}"
                                                      EditValueType="{x:Type sys:Double}"
                                                      Increment="0.01"
                                                      IsEnabled="{Binding TwoThreeOneSpreadsSettings.SpreadTheoToMidRangeEnabled}"
                                                      Mask="N2"
                                                      MaskUseAsDisplayFormat="True"
                                                      PreviewMouseUp="SelectAll"
                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True" />

                                        <Label Grid.Row="1"
                                               Grid.Column="2"
                                               Margin="3,0,0,0"
                                               Content="-"
                                               IsEnabled="{Binding TwoThreeOneSpreadsSettings.SpreadTheoToMidRangeEnabled}" />

                                        <dxe:SpinEdit Grid.Row="1"
                                                      Grid.Column="3"
                                                      Width="70"
                                                      Margin="3,2,0,0"
                                                      HorizontalContentAlignment="Right"
                                                      AllowSpinOnMouseWheel="True"
                                                      EditValue="{Binding TwoThreeOneSpreadsSettings.SpreadTheoToMidRangeCeil, UpdateSourceTrigger=PropertyChanged}"
                                                      EditValueType="{x:Type sys:Double}"
                                                      Increment="0.01"
                                                      IsEnabled="{Binding TwoThreeOneSpreadsSettings.SpreadTheoToMidRangeEnabled}"
                                                      Mask="N2"
                                                      MaskUseAsDisplayFormat="True"
                                                      MinValue="{Binding TwoThreeOneSpreadsSettings.SpreadTheoToMidRangeFloor}"
                                                      PreviewMouseUp="SelectAll"
                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True" />
                                    </Grid>
                                </dxlc:GroupBox>

                            </StackPanel>

                            <Grid Grid.Row="0"
                                  Grid.Column="2"
                                  Margin="10,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0"
                                           Margin="0,2">
                                    <Label Width="70"
                                           Margin="5,0"
                                           Content="Call Sample" />
                                    <dxe:TextEdit Margin="0.5"
                                                  EditValue="{Binding TwoThreeOneCallSpreadSample}"
                                                  IsReadOnly="True" />
                                </DockPanel>
                                <DockPanel Grid.Row="1"
                                           Margin="0,2">
                                    <Label Width="70"
                                           Margin="5,0"
                                           Content="Put Sample" />
                                    <dxe:TextEdit Margin="0.5"
                                                  EditValue="{Binding TwoThreeOnePutSpreadSample}"
                                                  IsReadOnly="True" />
                                </DockPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </dx:DXTabItem>

                <dx:DXTabItem Padding="2.5,2"
                              BorderThickness="1">
                    <dx:DXTabItem.Header>
                        <StackPanel Width="110"
                                    Orientation="Horizontal">
                            <dxe:CheckEdit EditValue="{Binding ConfigChainEnabled}" />
                            <Label Margin="5,0,0,0"
                                   Content="Config Chain"
                                   Foreground="#AFAFB0" />
                        </StackPanel>
                    </dx:DXTabItem.Header>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <dx:SimpleButton Grid.Row="0"
                                             Width="120"
                                             Command="{Binding AddConfigToChainCommand}"
                                             Content="Add Config"
                                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                                             GlyphHeight="15" />
                            <ItemsControl Grid.Row="1"
                                          Margin="0,5,0,0"
                                          ItemsSource="{Binding ConfigChains}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="auto" />
                                            </Grid.ColumnDefinitions>
                                            <dxe:ComboBoxEdit Grid.Column="0"
                                                              Margin="0,0,0,0"
                                                              Background="#171718"
                                                              DisplayMember="Title"
                                                              FontSize="10"
                                                              IsTextEditable="False"
                                                              ItemsSource="{Binding Configs}"
                                                              SelectedItem="{Binding Config}">
                                                <dxe:ComboBoxEdit.ItemContainerStyle>
                                                    <Style TargetType="dxe:ComboBoxEditItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    </Style>
                                                </dxe:ComboBoxEdit.ItemContainerStyle>
                                                <dxe:ComboBoxEdit.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid HorizontalAlignment="Stretch">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Label Grid.Column="0"
                                                                   HorizontalAlignment="Left"
                                                                   Content="{Binding Username}" />
                                                            <Label Grid.Column="1"
                                                                   Width="500"
                                                                   HorizontalAlignment="Left"
                                                                   Content="{Binding Title}" />
                                                            <Label Grid.Column="2"
                                                                   HorizontalAlignment="Right"
                                                                   Content="{Binding SaveTime}"
                                                                   ContentStringFormat="dd-yy hh:mm:ss" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </dxe:ComboBoxEdit.ItemTemplate>
                                            </dxe:ComboBoxEdit>

                                            <dx:SimpleButton Grid.Column="1"
                                                             Width="45"
                                                             Margin="5,0,0,0"
                                                             Background="#171718"
                                                             Command="{Binding ParentViewModel.RemoveConfigFromChainCommand}"
                                                             CommandParameter="{Binding}"
                                                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Remove.svg}"
                                                             GlyphHeight="15" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </dx:DXTabItem>
            </dx:DXTabControl>

            <dxg:GridControl Name="UnderlyingsGrid"
                             Grid.Row="1"
                             Grid.RowSpan="2"
                             Grid.Column="0"
                             ItemsSource="{Binding OptionChains}"
                             SelectionMode="Row">
                <dxg:GridControl.View>
                    <dxg:TableView AllowColumnFiltering="False"
                                   AllowEditing="False"
                                   AllowGrouping="False"
                                   AllowSorting="True"
                                   AutoWidth="True"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   ShowIndicator="True"
                                   ShowTotalSummary="False"
                                   VerticalScrollbarVisibility="Auto">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Height="25"
                                          Command="{Binding ShowColumnChooserCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Column Chooser">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ClearColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Hide All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowAllColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowDefaultColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Default Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                        <dxg:TableView.RowCellMenuCustomizations>
                            <dxb:BarButtonItem Command="{Binding View.DataContext.ClearSymbolsCommand}"
                                               Content="Clear Symbols" />
                        </dxg:TableView.RowCellMenuCustomizations>
                    </dxg:TableView>
                </dxg:GridControl.View>

                <dxg:GridColumn Width="90"
                                FieldName="Symbol"
                                HorizontalHeaderContentAlignment="Center"
                                IsSmart="True" />

                <dxg:GridColumn Width="50"
                                FieldName="Count"
                                HorizontalHeaderContentAlignment="Center"
                                IsSmart="True"
                                Visible="False" />

                <dxg:GridColumn Width="20"
                                MinWidth="20"
                                AllowMoving="False"
                                AllowResizing="False"
                                FieldName="Remove"
                                Header="-"
                                HorizontalHeaderContentAlignment="Center"
                                IsSmart="False">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dx:SimpleButton Command="{Binding View.DataContext.RemoveOptionChainCommand}"
                                             CommandParameter="{Binding Path=SelectedItem, ElementName=UnderlyingsGrid}"
                                             Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                             GlyphWidth="19" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
            </dxg:GridControl>
        </Grid>

        <Grid Grid.Row="3"
              Grid.Column="1"
              Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Margin="0,4"
                        Orientation="Horizontal">
                <dx:SplitButton Width="145"
                                VerticalAlignment="Bottom"
                                Command="{Binding OpenInBasketTraderCommand}"
                                Content="Open in Basket"
                                IsEnabled="{Binding CanExport}"
                                PopupAutoWidth="True">
                    <dxb:PopupMenu Name="OpenInBasketSubButton" />
                </dx:SplitButton>
                <dx:SplitButton Width="140"
                                Height="24"
                                Margin="5,0,0,0"
                                VerticalAlignment="Bottom"
                                Command="{Binding SaveToFileCommand}"
                                Content="{Binding CanExport, Converter={StaticResource CanExportToContentConverter}}"
                                PopupAutoWidth="True">
                    <StackPanel Orientation="Vertical">
                        <dx:SimpleButton VerticalAlignment="Bottom"
                                         Command="{Binding ParseSpreadsCommand}"
                                         Content="Parse List"
                                         IsEnabled="{Binding CanExport}" />
                        <dx:SimpleButton VerticalAlignment="Bottom"
                                         Command="{Binding OpenInQuotesAndGreeksBoardCommand}"
                                         Content="Open in Quotes &amp; Greeks"
                                         IsEnabled="{Binding CanExport}" />
                    </StackPanel>
                </dx:SplitButton>
            </StackPanel>

            <dxe:ProgressBarEdit Grid.Column="1"
                                 Height="24"
                                 Margin="5,4"
                                 VerticalAlignment="Bottom"
                                 ContentDisplayMode="Content"
                                 Visibility="{Binding ShowProgressBar, Converter={StaticResource BooleanToVisibilityConverter}}">
                <dxe:ProgressBarEdit.StyleSettings>
                    <dxe:ProgressBarMarqueeStyleSettings />
                </dxe:ProgressBarEdit.StyleSettings>
            </dxe:ProgressBarEdit>

            <TextBlock Grid.Column="1"
                       Margin="0,0,0,8"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       PreviewMouseDown="ExportText_PreviewMouseDown"
                       PreviewMouseMove="ExportText_PreviewMouseMove"
                       PreviewMouseUp="ExportText_PreviewMouseUp"
                       Text="{Binding ProgressStatus}" />

            <StackPanel Grid.Column="2"
                        Margin="0,4"
                        Orientation="Horizontal">
                <dx:SimpleButton Width="70"
                                 VerticalAlignment="Bottom"
                                 Command="{Binding GenerateSpreadsCommand}"
                                 Content="Generate"
                                 IsEnabled="{Binding AllowGenerating}" />

                <dx:SimpleButton Width="70"
                                 Margin="5,0,0,0"
                                 VerticalAlignment="Bottom"
                                 Command="{Binding CancelCommand}"
                                 Content="Cancel"
                                 IsEnabled="{Binding Generating}" />
            </StackPanel>
        </Grid>
    </Grid>
</view:ModuleWindow>
