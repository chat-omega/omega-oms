<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.FeesEstimateView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:Models="clr-namespace:ZeroPlus.Oms.Ui.Models"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 Title="Fees Estimate"
                 Width="300"
                 Height="150"
                 d:DataContext="{d:DesignInstance Type=Models:OrderTicket}"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Margin="5,0"
               Content="Exchange" />

        <dxe:TextEdit Grid.Row="1"
                      Grid.Column="2"
                      Margin="0,2,0,0"
                      EditValue="{Binding LastExchange}" />

        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="5,0"
               Content="Fees" />

        <dxe:TextEdit Grid.Row="2"
                      Grid.Column="2"
                      Margin="0,2,0,0"
                      EditValue="{Binding FeesEstimate}"
                      IsReadOnly="True" />
        <StackPanel Grid.Row="4"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="70"
                             Margin="2,0"
                             Command="{Binding UpdateFeesEstimateCommand}"
                             Content="Refresh" />
            <dx:SimpleButton Width="70"
                             Margin="2,0"
                             Click="CloseButton_Click"
                             Content="Close" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
