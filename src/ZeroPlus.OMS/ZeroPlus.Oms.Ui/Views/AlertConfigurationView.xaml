<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.AlertConfigurationView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Width="480"
                 Height="220"
                 DataContext="{startuphelpers:DISource Type=ViewModels:AlertConfigurationViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <Window.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
    </Window.Resources>

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <dx:DXTabControl>
            <dx:DXTabItem Width="100"
                          Padding="10,2"
                          Header="Total Subs">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="10" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="10" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="10" />
                    </Grid.RowDefinitions>

                    <dxe:CheckEdit Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Threshold"
                                   EditValue="{Binding PortfolioManager.TotalSubmissionsAlertConfig.Enabled}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="2"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="d"
                                  EditValue="{Binding PortfolioManager.TotalSubmissionsAlertConfig.Threshold, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  IsEnabled="{Binding PortfolioManager.TotalSubmissionsAlertConfig.Enabled}"
                                  Mask="d"
                                  MinValue="0"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="1"
                           Grid.Column="3"
                           Margin="5,5,0,0"
                           VerticalAlignment="Bottom"
                           Content="Snooze"
                           IsEnabled="{Binding PortfolioManager.TotalSubmissionsAlertConfig.Enabled}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="4"
                                  Width="100"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="d"
                                  EditValue="{Binding PortfolioManager.TotalSubmissionsAlertConfig.SnoozeInterval, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  IsEnabled="{Binding PortfolioManager.TotalSubmissionsAlertConfig.Enabled}"
                                  Mask="d"
                                  MinValue="0"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:CheckEdit Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Audio"
                                   EditValue="{Binding PortfolioManager.TotalSubmissionsAlertConfig.AudioEnabled}"
                                   IsEnabled="{Binding PortfolioManager.TotalSubmissionsAlertConfig.Enabled}" />
                    <DockPanel Grid.Row="2"
                               Grid.Column="2"
                               Grid.ColumnSpan="3"
                               Margin="5,5,0,0"
                               IsEnabled="{Binding PortfolioManager.TotalSubmissionsAlertConfig.Enabled}">
                        <dx:SimpleButton Width="22"
                                         Command="{Binding TestSoundCommand}"
                                         CommandParameter="{Binding PortfolioManager.TotalSubmissionsAlertConfig.AudioSound}"
                                         DockPanel.Dock="Right"
                                         Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"
                                         GlyphHeight="15"
                                         GlyphWidth="15" />
                        <dxe:ComboBoxEdit IsTextEditable="False"
                                          ItemsSource="{Binding NotificationManager.SoundsList}"
                                          SelectedItem="{Binding PortfolioManager.TotalSubmissionsAlertConfig.AudioSound, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <dxe:CheckEdit Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Dialog"
                                   EditValue="{Binding PortfolioManager.TotalSubmissionsAlertConfig.VisualEnabled}"
                                   IsEnabled="{Binding PortfolioManager.TotalSubmissionsAlertConfig.Enabled}" />

                    <dxe:CheckEdit Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Notification"
                                   EditValue="{Binding PortfolioManager.TotalSubmissionsAlertConfig.NotificationEnabled}"
                                   IsEnabled="{Binding PortfolioManager.TotalSubmissionsAlertConfig.Enabled}" />

                </Grid>
            </dx:DXTabItem>
            <dx:DXTabItem Width="100"
                          Padding="10,2"
                          Header="Unique Subs">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="10" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="10" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="10" />
                    </Grid.RowDefinitions>

                    <dxe:CheckEdit Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Threshold"
                                   EditValue="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.Enabled}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="2"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="d"
                                  EditValue="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.Threshold, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  IsEnabled="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.Enabled}"
                                  Mask="N2"
                                  MinValue="0"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="1"
                           Grid.Column="3"
                           Margin="5,5,0,0"
                           VerticalAlignment="Bottom"
                           Content="Snooze"
                           IsEnabled="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.Enabled}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="4"
                                  Width="100"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="d"
                                  EditValue="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.SnoozeInterval, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  IsEnabled="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.Enabled}"
                                  Mask="d"
                                  MinValue="0"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:CheckEdit Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Audio"
                                   EditValue="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.AudioEnabled}"
                                   IsEnabled="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.Enabled}" />
                    <DockPanel Grid.Row="2"
                               Grid.Column="2"
                               Grid.ColumnSpan="3"
                               Margin="5,5,0,0"
                               IsEnabled="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.Enabled}">
                        <dx:SimpleButton Width="22"
                                         Command="{Binding TestSoundCommand}"
                                         CommandParameter="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.AudioSound}"
                                         DockPanel.Dock="Right"
                                         Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"
                                         GlyphHeight="15"
                                         GlyphWidth="15" />
                        <dxe:ComboBoxEdit IsTextEditable="False"
                                          ItemsSource="{Binding NotificationManager.SoundsList}"
                                          SelectedItem="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.AudioSound, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <dxe:CheckEdit Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Dialog"
                                   EditValue="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.VisualEnabled}"
                                   IsEnabled="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.Enabled}" />

                    <dxe:CheckEdit Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Notification"
                                   EditValue="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.NotificationEnabled}"
                                   IsEnabled="{Binding PortfolioManager.UniqueSubmissionsAlertConfig.Enabled}" />

                </Grid>
            </dx:DXTabItem>
            <dx:DXTabItem Width="100"
                          Padding="10,2"
                          Header="Total Contracts">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="10" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="10" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="10" />
                    </Grid.RowDefinitions>

                    <dxe:CheckEdit Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Threshold"
                                   EditValue="{Binding PortfolioManager.TotalContractsAlertConfig.Enabled}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="2"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="d"
                                  EditValue="{Binding PortfolioManager.TotalContractsAlertConfig.Threshold, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  IsEnabled="{Binding PortfolioManager.TotalContractsAlertConfig.Enabled}"
                                  Mask="N2"
                                  MinValue="0"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="1"
                           Grid.Column="3"
                           Margin="5,5,0,0"
                           VerticalAlignment="Bottom"
                           Content="Snooze"
                           IsEnabled="{Binding PortfolioManager.TotalContractsAlertConfig.Enabled}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="4"
                                  Width="100"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="d"
                                  EditValue="{Binding PortfolioManager.TotalContractsAlertConfig.SnoozeInterval, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  IsEnabled="{Binding PortfolioManager.TotalContractsAlertConfig.Enabled}"
                                  Mask="d"
                                  MinValue="0"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:CheckEdit Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Audio"
                                   EditValue="{Binding PortfolioManager.TotalContractsAlertConfig.AudioEnabled}"
                                   IsEnabled="{Binding PortfolioManager.TotalContractsAlertConfig.Enabled}" />
                    <DockPanel Grid.Row="2"
                               Grid.Column="2"
                               Grid.ColumnSpan="3"
                               Margin="5,5,0,0"
                               IsEnabled="{Binding PortfolioManager.TotalContractsAlertConfig.Enabled}">
                        <dx:SimpleButton Width="22"
                                         Command="{Binding TestSoundCommand}"
                                         CommandParameter="{Binding PortfolioManager.TotalContractsAlertConfig.AudioSound}"
                                         DockPanel.Dock="Right"
                                         Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"
                                         GlyphHeight="15"
                                         GlyphWidth="15" />
                        <dxe:ComboBoxEdit IsTextEditable="False"
                                          ItemsSource="{Binding NotificationManager.SoundsList}"
                                          SelectedItem="{Binding PortfolioManager.TotalContractsAlertConfig.AudioSound, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <dxe:CheckEdit Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Dialog"
                                   EditValue="{Binding PortfolioManager.TotalContractsAlertConfig.VisualEnabled}"
                                   IsEnabled="{Binding PortfolioManager.TotalContractsAlertConfig.Enabled}" />

                    <dxe:CheckEdit Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Notification"
                                   EditValue="{Binding PortfolioManager.TotalContractsAlertConfig.NotificationEnabled}"
                                   IsEnabled="{Binding PortfolioManager.TotalContractsAlertConfig.Enabled}" />

                </Grid>
            </dx:DXTabItem>
            <dx:DXTabItem Width="100"
                          Padding="2,0"
                          Header="Unique Contracts">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="10" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="10" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="10" />
                    </Grid.RowDefinitions>

                    <dxe:CheckEdit Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Threshold"
                                   EditValue="{Binding PortfolioManager.UniqueContractsAlertConfig.Enabled}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="2"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="d"
                                  EditValue="{Binding PortfolioManager.UniqueContractsAlertConfig.Threshold, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  IsEnabled="{Binding PortfolioManager.UniqueContractsAlertConfig.Enabled}"
                                  Mask="N2"
                                  MinValue="0"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="1"
                           Grid.Column="3"
                           Margin="5,5,0,0"
                           VerticalAlignment="Bottom"
                           Content="Snooze"
                           IsEnabled="{Binding PortfolioManager.UniqueContractsAlertConfig.Enabled}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="4"
                                  Width="100"
                                  Margin="5,5,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="d"
                                  EditValue="{Binding PortfolioManager.UniqueContractsAlertConfig.SnoozeInterval, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  IsEnabled="{Binding PortfolioManager.UniqueContractsAlertConfig.Enabled}"
                                  Mask="d"
                                  MinValue="0"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:CheckEdit Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Audio"
                                   EditValue="{Binding PortfolioManager.UniqueContractsAlertConfig.AudioEnabled}"
                                   IsEnabled="{Binding PortfolioManager.UniqueContractsAlertConfig.Enabled}" />
                    <DockPanel Grid.Row="2"
                               Grid.Column="2"
                               Grid.ColumnSpan="3"
                               Margin="5,5,0,0"
                               IsEnabled="{Binding PortfolioManager.UniqueContractsAlertConfig.Enabled}">
                        <dx:SimpleButton Width="22"
                                         Command="{Binding TestSoundCommand}"
                                         CommandParameter="{Binding PortfolioManager.UniqueContractsAlertConfig.AudioSound}"
                                         DockPanel.Dock="Right"
                                         Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"
                                         GlyphHeight="15"
                                         GlyphWidth="15" />
                        <dxe:ComboBoxEdit IsTextEditable="False"
                                          ItemsSource="{Binding NotificationManager.SoundsList}"
                                          SelectedItem="{Binding PortfolioManager.UniqueContractsAlertConfig.AudioSound, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <dxe:CheckEdit Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Dialog"
                                   EditValue="{Binding PortfolioManager.UniqueContractsAlertConfig.VisualEnabled}"
                                   IsEnabled="{Binding PortfolioManager.UniqueContractsAlertConfig.Enabled}" />

                    <dxe:CheckEdit Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,5,0,0"
                                   Content="Notification"
                                   EditValue="{Binding PortfolioManager.UniqueContractsAlertConfig.NotificationEnabled}"
                                   IsEnabled="{Binding PortfolioManager.UniqueContractsAlertConfig.Enabled}" />

                </Grid>
            </dx:DXTabItem>
        </dx:DXTabControl>

        <StackPanel Grid.Row="1"
                    Margin="0,5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Command="{Binding SaveCommand}"
                             Content="Close"
                             IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
