<UserControl x:Class="ZeroPlus.Oms.Ui.Views.ConfigBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:ConfigBrowserViewModel}"
             d:DesignHeight="300"
             d:DesignWidth="300"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <dxe:ToggleSwitch Grid.Row="1"
                          Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          CheckedStateContent="All"
                          ContentPlacement="Inside"
                          IsChecked="{Binding ShowAllConfigs, UpdateSourceTrigger=PropertyChanged}"
                          ToggleSwitchWidth="80"
                          UncheckedStateContent="User">
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding ViewChangedCommand}"
                                       EventName="Checked" />
                <dxmvvm:EventToCommand Command="{Binding ViewChangedCommand}"
                                       EventName="Unchecked" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ToggleSwitch>

        <dx:SimpleButton Grid.Row="1"
                         Grid.Column="2"
                         Margin="0,5"
                         Command="{Binding RefreshCommand}"
                         Content="Refresh"
                         DockPanel.Dock="Right"
                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Refresh.svg}"
                         GlyphHeight="15" />

        <dxg:TreeListControl Name="ConfigsTable"
                             Grid.Row="2"
                             Grid.Column="1"
                             Grid.ColumnSpan="2"
                             AutoGenerateColumns="AddNew"
                             ItemsSource="{Binding Configs}"
                             SelectedItems="{Binding SelectedConfig}"
                             SelectionMode="Row">
            <dxg:TreeListColumn Width="270"
                                MinWidth="270"
                                FieldName="Title"
                                Header="Name"
                                IsSmart="True"
                                SortIndex="0" />
            <dxg:TreeListColumn Width="150"
                                MinWidth="150"
                                MaxWidth="150"
                                FieldName="Username"
                                Header="Contributors"
                                IsSmart="True" />
            <dxg:TreeListColumn Width="150"
                                MinWidth="150"
                                MaxWidth="150"
                                FieldName="SaveTime"
                                Header="Time"
                                IsSmart="True"
                                SortIndex="1"
                                SortOrder="Descending" />
            <dxg:TreeListControl.View>
                <dxg:TreeListView AllowEditing="False"
                                  AutoExpandAllNodes="{Binding ShowAllConfigs, Converter={StaticResource BooleanNegationConverter}}"
                                  AutoWidth="True"
                                  BestFitMode="AllRows"
                                  BestFitModeOnSourceChange="AllRows"
                                  ChildNodesPath="Configs"
                                  RowDoubleClickCommand="{Binding ConfigRowDoubleClickCommand}"
                                  TreeDerivationMode="ChildNodesSelector"
                                  VerticalScrollbarVisibility="Auto">
                    <dxg:TreeListView.RowCellMenuCustomizations>
                        <dxb:BarButtonItem Command="{Binding View.DataContext.LoadCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=ConfigsTable}"
                                           Content="Load" />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.EditConfigCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=ConfigsTable}"
                                           Content="Edit" />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.DeleteConfigCommand}"
                                           CommandParameter="{Binding Path=SelectedItems, ElementName=ConfigsTable}"
                                           Content="Delete" />
                    </dxg:TreeListView.RowCellMenuCustomizations>
                </dxg:TreeListView>
            </dxg:TreeListControl.View>
        </dxg:TreeListControl>

        <StackPanel Grid.Row="3"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="0,5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding LoadCommand}"
                             Content="Load"
                             Glyph="{dx:DXImage SvgImages/Dashboards/ImageLoad.svg}"
                             GlyphHeight="15" />
        </StackPanel>
    </Grid>
</UserControl>
