<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.ExportSpreadsToFileView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                 Title="Export Spreads To File"
                 Width="300"
                 Height="200"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Content="Export Format" />

        <dxe:ComboBoxEdit Grid.Row="1"
                          Grid.Column="2"
                          Margin="2,0,0,0"
                          AllowUpdateTwoWayBoundPropertiesOnSynchronization="False"
                          IsTextEditable="False"
                          ItemsSource="{Binding SupportedFormats}"
                          SelectedItem="{Binding ExportFormat, UpdateSourceTrigger=PropertyChanged}" />

        <dxe:CheckEdit Grid.Row="2"
                       Grid.Column="1"
                       Margin="0,5,0,0"
                       Content="Randomize"
                       EditValue="{Binding RandomizeExport}" />

        <dxe:CheckEdit x:Name="GeneratePermsCheckBox"
                       Grid.Row="3"
                       Grid.Column="1"
                       Margin="0,5,0,0"
                       Content="Generate Perms"
                       EditValue="{Binding GeneratePerms}"
                       Visibility="Collapsed" />

        <dxe:SpinEdit x:Name="GeneratePermsSpinEdit"
                      Grid.Row="3"
                      Grid.Column="2"
                      Width="60"
                      Margin="5,5,0,0"
                      HorizontalAlignment="Left"
                      HorizontalContentAlignment="Right"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding GeneratePermsCount}"
                      EditValueType="{x:Type sys:Int32}"
                      Increment="1"
                      IsEnabled="{Binding GeneratePerms}"
                      MinValue="0"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True"
                      Visibility="Collapsed" />

        <dxe:CheckEdit Grid.Row="4"
                       Grid.Column="1"
                       Grid.ColumnSpan="2"
                       Margin="0,5,0,0"
                       Content="Create separate file file per underlying"
                       EditValue="{Binding CrateSeparateExportForUnderlyings}" />

        <StackPanel Grid.Row="6"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Click="Cancel_Click"
                             Command="{Binding WriteToFileCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/XAF/Action_Export_ToXls.svg}"
                             GlyphHeight="15"
                             IsDefault="True" />
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Click="Cancel_Click"
                             Content="Cancel"
                             IsCancel="True" />
        </StackPanel>

    </Grid>
</dx:ThemedWindow>
