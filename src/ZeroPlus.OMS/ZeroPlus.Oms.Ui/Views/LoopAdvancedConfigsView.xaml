                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Row="30"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="4"
                                   Margin="0,5,0,0"
                                   Padding="0"
                                   VerticalAlignment="Top"
                                   IsEnabled="{Binding BasketSettings.AutomationConfig.LoopingEnabled}">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>

                                <dx:DXImage Grid.Column="0"
                                            Height="15"
                                            HorizontalAlignment="Right"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{dx:DXImage 'SvgImages/Icon Builder/Travel_Mountains.svg'}" />

                                <Label Grid.Column="1"
                                       Margin="2,0"
                                       Padding="0"
                                       VerticalAlignment="Center"
                                       Content="Iceberg Closer"
                                       Foreground="#AFAFB0"
                                       IsHitTestVisible="False" />

                                <dxe:ToggleSwitch Grid.Column="2"
                                                  Margin="10,0,5,0"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  AnimationMode="Always"
                                                  CheckedStateContent="On"
                                                  ContentPlacement="Inside"
                                                  FontSize="11"
                                                  IsChecked="{Binding BasketSettings.AutomationConfig.IcebergCloserEnabled}"
                                                  ToggleSwitchHeight="16"
                                                  ToggleSwitchWidth="50"
                                                  UncheckedStateContent="Off" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid IsEnabled="{Binding BasketSettings.AutomationConfig.IcebergCloserEnabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="85" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="5" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="5" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Display Size" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding BasketSettings.AutomationConfig.IcebergDisplaySize, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Increment="1"
                                          Mask="N0"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Total/Min Size" />

                            <dxe:SpinEdit Grid.Row="2"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding BasketSettings.AutomationConfig.IcebergTotalSize, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Increment="1"
                                          Mask="N0"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <Label Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Max Resubmit" />

                            <dxe:SpinEdit Grid.Row="3"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding BasketSettings.AutomationConfig.IcebergMaxResubmit, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Increment="1"
                                          Mask="N0"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </Grid>
                    </dxlc:GroupBox>
                </Grid>
            </ScrollViewer>
        </dx:DXTabItem>
        <dx:DXTabItem Header="Auto-Close">
            <GroupBox VerticalAlignment="Top"
                      Header="3-way Close">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="5" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="5" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="5" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Max perms" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding BasketSettings.AutomationConfig.ThreeWayCloseMaxPerms, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding BasketSettings.AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Vertical closer max resubmit" />

                    <dxe:SpinEdit Grid.Row="2"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding BasketSettings.AutomationConfig.ThreeWayVerticalResubmit, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding BasketSettings.AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="3"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Max strike spacing" />

                    <dxe:SpinEdit Grid.Row="3"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding BasketSettings.AutomationConfig.ThreeWayCloseMaxSpacing, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding BasketSettings.AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:CheckEdit Grid.Row="4"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="5,2,0,0"
                                   HorizontalAlignment="Left"
                                   Content="Attempt regular close as part of 3-way"
                                   EditValue="{Binding BasketSettings.AutomationConfig.AttemptRegularCloseIn3Way}"
                                   IsEnabled="{Binding BasketSettings.AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}" />

                    <dxe:CheckEdit Grid.Row="5"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="3"
                                   Margin="5,2,0,0"
                                   HorizontalAlignment="Left"
                                   Content="Use matching HW theos to price verticals"
                                   EditValue="{Binding BasketSettings.AutomationConfig.UseMatchingHwTheosForPricing3WayVerticals}"
                                   IsEnabled="{Binding BasketSettings.AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}" />

                </Grid>
            </GroupBox>
        </dx:DXTabItem>
    </dx:DXTabControl>
</dx:ThemedWindow>
