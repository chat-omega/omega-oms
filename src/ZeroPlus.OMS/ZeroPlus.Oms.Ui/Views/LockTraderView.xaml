<views:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.LockTraderView"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                    xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                    xmlns:enums="clr-namespace:ZeroPlus.Oms.Ui.Enums"
                    xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                    xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                    Title="{Binding ModuleTitle}"
                    Width="1200"
                    Height="800"
                    MinWidth="400"
                    MinHeight="300"
                    d:DataContext="{d:DesignInstance Type=ViewModels:LockTraderViewModel}"
                    d:Height="750"
                    d:Width="auto"
                    DataContext="{startuphelpers:DISource Type=ViewModels:LockTraderViewModel}"
                    WindowStartupLocation="CenterScreen"
                    mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:LoadCustomColumnService />
        <services:GetItemsByVisualOrderService />
        <services:OmsMessageBoxService />
        <dxmvvm:WindowService />
        <dxmvvm:DispatcherService />
        <dxmvvm:OpenFileDialogService />
        <dxmvvm:SaveFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <Window.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:NullToCheckGlyphConverter x:Key="NullToCheckGlyphConverter" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:EnumToDisplayTextConverter x:Key="EnumToDisplayTextConverter" />
        <helper:TheoModelToDisplayTextConverter x:Key="TheoModelToDisplayTextConverter" />
        <helper:SizeUpTypeToVisibilityConverter x:Key="SizeUpTypeToVisibilityConverter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#B73535"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#10e411" />
        <helper:SignToBrushConverter x:Key="TitleSignToBrushConverter"
                                     NegativeBrush="#FF0000"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#10e411" />
        <helper:SignToBrushConverter x:Key="SignToDarkBrushConverter"
                                     NegativeBrush="#FF2100"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#F1F1F1" />

        <helper:OrderToBackBrushConverter x:Key="SideToColorConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToGlyphConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                15
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                0
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToColorConverterRed">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F88F8F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #2D2D30
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                             Inverse="True" />
    </Window.Resources>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Margin="5,2,0,0"
                             Padding="2"
                             ButtonKind="Toggle"
                             Command="{Binding ToggleTheoLockCommand}"
                             CommandParameter="LockTheos"
                             Content="Lock Theos"
                             CornerRadius="1"
                             FontSize="12"
                             IsChecked="{Binding BasketSettings.LockTheos}"
                             Style="{StaticResource SubscriptionButtonStyle}"
                             Visibility="{Binding OmsCore.Config.ShowLockTheosShortcutInBasketHeader, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Image Width="20"
                   Height="20"
                   Margin="15,0,0,0"
                   Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_Clock.svg'}"
                   ToolTip="Up-Time" />
            <TextBlock Padding="3,3,5,3"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Text="{Binding UpTime}"
                       TextAlignment="Right"
                       ToolTip="Up-Time" />

            <Image Width="20"
                   Height="20"
                   Margin="5,0,0,0"
                   Source="{dx:DXImage 'SvgImages/Icon Builder/Business_DollarCircled.svg'}"
                   ToolTip="PnL" />
            <TextBlock Padding="3,3,5,3"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="{Binding AdjustedPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                       Text="{Binding AdjustedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                       TextAlignment="Right" />

            <views:ModuleHeaderItems />
        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="3" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3" />
            <ColumnDefinition x:Name="GridSplitterCol"
                              Width="*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    Margin="5"
                    Orientation="Horizontal">

            <dxlc:GroupBox Name="BasketSettingsSubModule"
                           Margin="5,0,0,0"
                           Padding="10,5">
                <dxlc:GroupBox.Header>
                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <dxe:TextEdit x:Name="NameEdit"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                      IsHitTestVisible="False"
                                      KeyDown="NameKeyDown"
                                      MouseDoubleClick="ToggleEdit"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />

                        <dx:SimpleButton x:Name="NameEditButton"
                                         Grid.Column="2"
                                         Width="25"
                                         HorizontalAlignment="Right"
                                         ButtonKind="Toggle"
                                         Checked="EditName"
                                         Glyph="{dx:DXImage SvgImages/Dashboards/RenameQuery.svg}"
                                         GlyphHeight="15"
                                         ToolTip="Edit Instance Title"
                                         Unchecked="SetName" />

                        <dx:SimpleButton x:Name="SetTitleButton"
                                         Grid.Column="3"
                                         Width="25"
                                         HorizontalAlignment="Right"
                                         Command="{Binding SetInstanceTitleToWindowCommand}"
                                         Glyph="{dx:DXImage SvgImages/XAF/Action_ResetViewSettings.svg}"
                                         GlyphHeight="15"
                                         ToolTip="Set As Basket Title" />
                    </Grid>
                </dxlc:GroupBox.Header>

                <Grid Margin="0,5,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <dx:SplitButton Grid.Row="0"
                                    Grid.Column="0"
                                    Width="110"
                                    Height="23"
                                    Padding="9,3,3,3"
                                    HorizontalAlignment="Right"
                                    Command="{Binding SaveConfigOnServerCommand}"
                                    Content="Save"
                                    Glyph="{dx:DXImage SvgImages/Save/Save.svg}"
                                    PopupAutoWidth="True">
                        <ItemsControl>
                            <StackPanel Orientation="Vertical">
                                <MenuItem Command="{Binding SaveCommand}"
                                          Header="Save Locally" />
                                <MenuItem Command="{Binding SaveAsCommand}"
                                          Header="Save As" />
                                <Separator />
                                <MenuItem Header="Auto Save"
                                          IsCheckable="True"
                                          IsChecked="{Binding AutoSave}"
                                          IsEnabled="{Binding Loaded}" />
                            </StackPanel>
                        </ItemsControl>
                    </dx:SplitButton>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Width="145"
                                Margin="5,0,0,0"
                                Orientation="Horizontal">
                        <dx:SimpleButton Width="50"
                                         Padding="2,2,0,0"
                                         HorizontalContentAlignment="Stretch"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ButtonKind="Toggle"
                                         IsChecked="{Binding InstanceModeLocked}">
                            <DockPanel HorizontalAlignment="Left">
                                <Label Width="34"
                                       Padding="0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Content="Mode" />
                                <dx:DXImage Width="16"
                                            Height="16"
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{dx:DXImage SvgImages/Icon Builder/Security_Lock.svg}"
                                            Visibility="{Binding InstanceModeLocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </DockPanel>
                        </dx:SimpleButton>

                        <dxe:ComboBoxEdit Width="90"
                                          Margin="5,0,0,0"
                                          Panel.ZIndex="1"
                                          ApplyItemTemplateToSelectedItem="True"
                                          EditValue="{Binding InstanceMode, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding InstanceModeLocked, Converter={StaticResource BooleanNegationConverter}}"
                                          IsSynchronizedWithCurrentItem="True"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding InstanceModes}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding ApplyInstanceModeChangesCommand}"
                                                       EventName="EditValueChanged" />
                            </dxmvvm:Interaction.Behaviors>
                            <dxe:ComboBoxEdit.ItemTemplate>
                                <DataTemplate>
                                    <Label Padding="0,0.5"
                                           HorizontalAlignment="Center"
                                           HorizontalContentAlignment="Center"
                                           Content="{Binding Converter={StaticResource EnumToDisplayTextConverter}}" />
                                </DataTemplate>
                            </dxe:ComboBoxEdit.ItemTemplate>
                        </dxe:ComboBoxEdit>
                    </StackPanel>

                    <dx:DropDownButton Grid.Row="1"
                                       Grid.Column="0"
                                       Width="110"
                                       Margin="0,5,0,0"
                                       Padding="3,1,7,1"
                                       HorizontalAlignment="Right"
                                       Content="Load"
                                       Glyph="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}"
                                       GlyphHeight="15">
                        <ItemsControl>
                            <StackPanel Orientation="Vertical">
                                <MenuItem Command="{Binding BrowseConfigsCommand}"
                                          Header="Load Saved" />
                                <MenuItem Command="{Binding LoadCommand}"
                                          Header="Load File" />
                            </StackPanel>
                        </ItemsControl>
                    </dx:DropDownButton>

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Width="145"
                                Margin="5,0,0,0"
                                Orientation="Horizontal">
                        <dx:SimpleButton Width="50"
                                         Padding="2,2,0,0"
                                         HorizontalContentAlignment="Stretch"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ButtonKind="Toggle"
                                         Command="{Binding BrokerLockedCommand}">
                            <DockPanel HorizontalAlignment="Left">
                                <Label Width="34"
                                       Padding="0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Content="Broker" />
                                <dx:DXImage Width="16"
                                            Height="16"
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{dx:DXImage SvgImages/Icon Builder/Security_Lock.svg}"
                                            Visibility="{Binding BrokerLocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </DockPanel>
                        </dx:SimpleButton>

                        <dxe:ComboBoxEdit Width="90"
                                          Margin="5,3,0,0"
                                          EditValue="{Binding BrokerOverride, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding BrokerLocked, Converter={StaticResource BooleanNegationConverter}}"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding OmsCore.Config.AvailableBrokers}"
                                          NullText="Use global">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding BrokerChangedCommand}"
                                                       EventName="EditValueChanged" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:ComboBoxEdit>
                    </StackPanel>

                    <dx:DropDownButton Grid.Row="2"
                                       Grid.Column="0"
                                       Width="110"
                                       Margin="5,5,0,0"
                                       Padding="3,1,7,1"
                                       HorizontalAlignment="Left"
                                       Content="Settings"
                                       Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Settings.svg}"
                                       GlyphHeight="15">
                        <ItemsControl>
                            <StackPanel Orientation="Vertical">
                                <MenuItem Command="{Binding HideCommand}"
                                          Header="Send To Manager" />
                                <Separator />
                                <MenuItem Click="ClearFiltersClick"
                                          Header="Clear Filters" />
                                <MenuItem Click="ClearSortingClick"
                                          Header="Clear Sorting" />
                                <Separator />
                                <MenuItem Command="{Binding ExportBasketSettingsCommand}"
                                          Header="Export Settings" />
                                <MenuItem Command="{Binding ImportBasketSettingsCommand}"
                                          Header="Import Settings" />
                                <Separator />
                                <MenuItem Header="Reset Volume Change"
                                          IsCheckable="True"
                                          IsChecked="{Binding ResetVolumeChange}" />
                            </StackPanel>
                        </ItemsControl>
                    </dx:DropDownButton>

                    <dx:SplitButton Grid.Row="2"
                                    Grid.Column="1"
                                    Width="145"
                                    Margin="5,5,0,0"
                                    Padding="5,3,3,3"
                                    HorizontalAlignment="Right"
                                    Command="{Binding ClearCommand}"
                                    Content="Remove"
                                    Glyph="{dx:DXImage SvgImages/Snap/RemoveGroupHeader.svg}"
                                    GlyphHeight="15"
                                    PopupAutoWidth="True">
                        <ItemsControl>
                            <StackPanel Orientation="Vertical">
                                <MenuItem Header="Remove on Interval"
                                          IsCheckable="True"
                                          IsChecked="{Binding RemoveAllOnInterval}" />
                            </StackPanel>
                        </ItemsControl>
                    </dx:SplitButton>

                </Grid>
            </dxlc:GroupBox>
            <dxlc:GroupBox Width="225"
                           Margin="5,0,0,0">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding LockSettingsCommand}"
                                           EventName="MouseLeave" />
                </dxmvvm:Interaction.Behaviors>

                <dxlc:GroupBox.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <Label Padding="0"
                               Content="Lock Settings"
                               FontWeight="Bold"
                               Foreground="#AFAFB0" />

                        <dxe:ToggleSwitch Name="LockSettingsMasterLockSwitch"
                                          Grid.Column="1"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          AnimationMode="Always"
                                          CheckedStateContent="Locked"
                                          ContentPlacement="Inside"
                                          FontSize="11"
                                          IsChecked="{Binding LockSettingsLocked}"
                                          ToggleSwitchHeight="16"
                                          ToggleSwitchWidth="70"
                                          UncheckedStateContent="Unlocked" />
                    </Grid>
                </dxlc:GroupBox.Header>

                <Grid IsEnabled="{Binding LockSettingsLocked, Converter={dx:BoolInverseConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <dx:SimpleButton Name="LockTraderPriceLock"
                                     Grid.Row="0"
                                     Grid.Column="0"
                                     Padding="0,2,0,0"
                                     HorizontalContentAlignment="Left"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ButtonKind="Toggle"
                                     IsChecked="{Binding LockTraderModifyPriceQtyModel.UpdatePrice, UpdateSourceTrigger=PropertyChanged}">
                        <DockPanel HorizontalAlignment="Left">
                            <Label Width="25"
                                   Margin="1,0,0,0"
                                   Padding="0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Content="Price" />
                            <dx:DXImage Height="14"
                                        Margin="3,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="{dx:DXImage SvgImages/Icon Builder/Security_Lock.svg}"
                                        Visibility="{Binding LockTraderModifyPriceQtyModel.UpdatePrice, Converter={StaticResource BooleanToVisibilityInverseConverter}}" />
                        </DockPanel>
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding UpdatePriceLimitsCommand}"
                                                   EventName="Checked" />
                            <dxmvvm:EventToCommand Command="{Binding UpdatePriceLimitsCommand}"
                                                   EventName="Unchecked" />
                        </dxmvvm:Interaction.Behaviors>
                    </dx:SimpleButton>

                    <dxe:SpinEdit Grid.Row="0"
                                  Grid.Column="1"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N2"
                                  EditValue="{Binding LockTraderModifyPriceQtyModel.Price, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  IsEnabled="{Binding LockTraderModifyPriceQtyModel.UpdatePrice}"
                                  Mask="N2"
                                  MaxValue="{Binding LockTraderPriceMax}"
                                  MinValue="{Binding LockTraderPriceMin}"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dx:SimpleButton Name="LockTraderQtyLock"
                                     Grid.Row="1"
                                     Grid.Column="0"
                                     Padding="0,2,0,0"
                                     HorizontalContentAlignment="Left"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ButtonKind="Toggle"
                                     IsChecked="{Binding LockTraderModifyPriceQtyModel.UpdateQty}">
                        <DockPanel HorizontalAlignment="Left">
                            <Label Width="25"
                                   Margin="1,0,0,0"
                                   Padding="0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Content="Qty" />
                            <dx:DXImage Height="14"
                                        Margin="3,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="{dx:DXImage SvgImages/Icon Builder/Security_Lock.svg}"
                                        Visibility="{Binding LockTraderModifyPriceQtyModel.UpdateQty, Converter={StaticResource BooleanToVisibilityInverseConverter}}" />
                        </DockPanel>
                    </dx:SimpleButton>

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="1"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N0"
                                  EditValue="{Binding LockTraderModifyPriceQtyModel.Qty, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  IsEnabled="{Binding LockTraderModifyPriceQtyModel.UpdateQty}"
                                  Mask="N0"
                                  MaxValue="{Binding OmsCore.Config.LockTraderQtyMax}"
                                  MinValue="{Binding OmsCore.Config.LockTraderQtyMin}"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dx:SimpleButton Grid.Row="2"
                                     Grid.Column="0"
                                     Grid.ColumnSpan="4"
                                     Margin="0,3,0,0"
                                     HorizontalAlignment="Center"
                                     Command="{Binding LockTraderModifyPriceQtyModel.ModifyQtyPxCommand}"
                                     Content="Modify"
                                     IsDefault="True" />
                </Grid>
            </dxlc:GroupBox>

            <dxlc:GroupBox Width="225"
                           Margin="5,0,0,0">
                <dxlc:GroupBox.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0"
                               Padding="0"
                               Content="Perm Settings"
                               FontWeight="Bold"
                               Foreground="#AFAFB0" />

                        <dxe:ToggleSwitch Name="permNewToggleSwitch"
                                          Grid.Column="1"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          AnimationMode="Always"
                                          CheckedStateContent="Self"
                                          ContentPlacement="Inside"
                                          FontSize="11"
                                          IsChecked="{Binding PermSelf}"
                                          ToggleSwitchHeight="16"
                                          UncheckedStateContent="New" />
                    </Grid>

                </dxlc:GroupBox.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,3,0,0"
                                Orientation="Horizontal">
                        <Label HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Content="Count"
                               IsEnabled="{Binding Path=IsChecked, ElementName=permNewToggleSwitch, Converter={StaticResource InverseBooleanConverter}}" />

                        <dxe:SpinEdit Width="50"
                                      Margin="3,0,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      EditValue="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Int32}"
                                      IsEnabled="{Binding Path=IsChecked, ElementName=permNewToggleSwitch, Converter={StaticResource InverseBooleanConverter}}"
                                      Mask="d"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </StackPanel>

                    <dx:SimpleButton Grid.Row="0"
                                     Grid.Column="2"
                                     Width="50"
                                     Height="22"
                                     Margin="5,3,0,0"
                                     Padding="0,1"
                                     Command="{Binding ExpirationUpCommand}"
                                     CommandParameter="{Binding Path=SelectedItem, ElementName=LockTraderGrid}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Exp" />
                            <TextBlock Margin="0,2,0,0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Marlett"
                                       Text="5" />
                        </StackPanel>
                    </dx:SimpleButton>

                    <dx:SimpleButton Grid.Row="0"
                                     Grid.Column="3"
                                     Width="50"
                                     Height="22"
                                     Margin="5,3,0,0"
                                     Padding="0,1"
                                     Command="{Binding StrikeUpCommand}"
                                     CommandParameter="{Binding Path=SelectedItem, ElementName=LockTraderGrid}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Strike" />
                            <TextBlock Margin="0,2,0,0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Marlett"
                                       Text="5" />
                        </StackPanel>
                    </dx:SimpleButton>

                    <dxe:CheckEdit Grid.Row="1"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Content="No Invalids"
                                   EditValue="{Binding AvoidInvalid}"
                                   IsEnabled="{Binding Path=IsChecked, ElementName=permNewToggleSwitch, Converter={StaticResource InverseBooleanConverter}}" />

                    <dx:SimpleButton Grid.Row="1"
                                     Grid.Column="2"
                                     Width="50"
                                     Height="22"
                                     Margin="5,3,0,0"
                                     Padding="0,1"
                                     Command="{Binding ExpirationDownCommand}"
                                     CommandParameter="{Binding Path=SelectedItem, ElementName=LockTraderGrid}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Exp" />
                            <TextBlock Margin="0,2,0,0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Marlett"
                                       Text="6" />
                        </StackPanel>
                    </dx:SimpleButton>

                    <dx:SimpleButton Grid.Row="1"
                                     Grid.Column="3"
                                     Width="50"
                                     Height="22"
                                     Margin="5,3,0,0"
