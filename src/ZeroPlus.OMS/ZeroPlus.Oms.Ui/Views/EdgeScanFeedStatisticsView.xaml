<views:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.EdgeScanFeedStatisticsView"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                    xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                    xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                    Width="1500"
                    Height="800"
                    MinWidth="400"
                    MinHeight="300"
                    d:DataContext="{d:DesignInstance Type=ViewModels:EdgeScanFeedStatisticsViewModel}"
                    DataContext="{startuphelpers:DISource Type=ViewModels:EdgeScanFeedStatisticsViewModel}"
                    WindowStartupLocation="CenterScreen"
                    mc:Ignorable="d">

    <views:ModuleWindow.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
    </views:ModuleWindow.Resources>

    <dx:ThemedWindow.HeaderItems>
        <views:ModuleHeaderItems />
    </dx:ThemedWindow.HeaderItems>

    <dx:DXTabControl Padding="0">
        <dx:DXTabItem>
            <dx:DXTabItem.Header>
                <TextBlock FontWeight="DemiBold"
                           Text="Summary" />
            </dx:DXTabItem.Header>
            <dx:DXTabItem.GlyphTemplate>
                <DataTemplate>
                    <Image Width="15"
                           Height="15"
                           Margin="0,0,5,0"
                           Source="{dx:DXImage 'SvgImages/Spreadsheet/Table.svg'}" />
                </DataTemplate>
            </dx:DXTabItem.GlyphTemplate>
            <dxg:GridControl x:Name="StatsGrid"
                             MinHeight="70"
                             MaxHeight="5000"
                             AllowLiveDataShaping="True"
                             AutoGenerateColumns="None"
                             EnableSmartColumnsGeneration="False"
                             ItemsSource="{Binding TransactionConsumer.EdgeScanFeedStatsSummary}">
                <dxg:GridControl.Resources>
                    <Style TargetType="dxg:GridColumn">
                        <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                        <Setter Property="Visible" Value="True" />
                        <Setter Property="IsSmart" Value="True" />
                    </Style>
                </dxg:GridControl.Resources>
                <dxg:GridControl.View>
                    <dxg:TableView Name="StatsTable"
                                   AllowDragDrop="True"
                                   AllowEditing="False"
                                   AutoWidth="True"
                                   BandSeparatorWidth="1"
                                   EnableSelectedRowAppearance="True"
                                   GroupSummaryDisplayMode="AlignByColumns"
                                   NavigationStyle="Cell"
                                   RowStyle="{StaticResource RowStyle}"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   ShowIndicator="True"
                                   ShowTotalSummary="False"
                                   VerticalScrollbarVisibility="Auto">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Height="25"
                                          Command="{Binding ShowColumnChooserCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Column Chooser">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ClearColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Hide All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowAllColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowDefaultColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Default Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn FieldName="State">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="DemiBold"
                                       Foreground="#a37009"
                                       Text="{Binding RowData.Row.State}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>

                <dxg:GridColumn FieldName="User">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="DemiBold"
                                       Foreground="#a37009"
                                       Text="{Binding RowData.Row.User}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="ScannerConfig">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="DemiBold"
                                       Foreground="#a37009"
                                       Text="{Binding RowData.Row.ScannerConfig}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="BasketConfig">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="DemiBold"
                                       Foreground="#a37009"
                                       Text="{Binding RowData.Row.BasketConfig}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="TotalAttempts">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,3,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Text="{Binding RowData.Row.TotalAttempts, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="TotalSubs">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,3,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Text="{Binding RowData.Row.TotalSubs, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Submissions">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,3,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Text="{Binding RowData.Row.Submissions, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Received">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,3,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Text="{Binding RowData.Row.Received, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="StartTime"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                              Mask="hh:mm:ss"
                                              MaskType="DateTime"
                                              MaskUseAsDisplayFormat="True" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Timestamp"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                              Mask="hh:mm:ss"
                                              MaskType="DateTime"
                                              MaskUseAsDisplayFormat="True" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridControl.DetailDescriptor>
                    <dxg:DataControlDetailDescriptor ItemsSourceBinding="{Binding Self}">
                        <dxg:DataControlDetailDescriptor.DataControl>
                            <dxg:GridControl x:Name="DetailsGrid"
                                             AllowLiveDataShaping="True"
                                             AutoGenerateColumns="None"
                                             EnableSmartColumnsGeneration="False">
                                <dxg:GridControl.Resources>
                                    <Style TargetType="dxg:GridColumn">
                                        <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                                        <Setter Property="Visible" Value="True" />
                                        <Setter Property="IsSmart" Value="True" />
                                    </Style>
                                </dxg:GridControl.Resources>
                                <dxg:GridControl.View>
                                    <dxg:TableView Name="DetailsTable"
                                                   AllowDragDrop="True"
                                                   AllowEditing="False"
                                                   AutoWidth="True"
                                                   BandSeparatorWidth="1"
                                                   EnableSelectedRowAppearance="True"
                                                   GroupSummaryDisplayMode="AlignByColumns"
                                                   NavigationStyle="Cell"
                                                   RowStyle="{StaticResource RowStyle}"
                                                   ShowGridMenu="TableView_ShowGridMenu"
                                                   ShowGroupPanel="False"
                                                   ShowIndicator="True"
                                                   ShowTotalSummary="False"
                                                   VerticalScrollbarVisibility="Auto">
                                        <dxg:TableView.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Height="25"
                                                          Command="{Binding ShowColumnChooserCommand}"
                                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Header="Show Column Chooser">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Command="{Binding ClearColumnsCommand}"
                                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Header="Hide All Columns">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Command="{Binding ShowAllColumnsCommand}"
                                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Header="Show All Columns">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Command="{Binding ShowDefaultColumnsCommand}"
                                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Header="Show Default Columns">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </dxg:TableView.ContextMenu>
                                    </dxg:TableView>
                                </dxg:GridControl.View>
                                <dxg:GridColumn FieldName="Win/Lose Trade Ratio">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="DemiBold"
                                                       Text="{Binding RowData.Row.WinLoseRatio, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                                <dxg:GridColumn FieldName="Winning Trades Count">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="DemiBold"
                                                       Text="{Binding RowData.Row.WinningTradesCount, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                                <dxg:GridColumn FieldName="Losing Trades Count">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="DemiBold"
                                                       Text="{Binding RowData.Row.LosingTradesCount, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                                <dxg:GridColumn FieldName="HighestPnlName" />
                                <dxg:GridColumn FieldName="LowestPnlName" />
                            </dxg:GridControl>
                        </dxg:DataControlDetailDescriptor.DataControl>
                    </dxg:DataControlDetailDescriptor>
                </dxg:GridControl.DetailDescriptor>
            </dxg:GridControl>
        </dx:DXTabItem>
        <dx:DXTabItem>
            <dx:DXTabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               FontWeight="DemiBold"
                               Text="Submission X Time" />
                    <dx:SimpleButton Grid.Column="1"
                                     Margin="4,0,0,0"
                                     BorderThickness="0"
                                     Command="{Binding RefreshChartCommand}"
                                     Glyph="{dx:DXImage 'SvgImages/XAF/Action_Reload.svg'}"
                                     GlyphWidth="16" />
                </Grid>
            </dx:DXTabItem.Header>
            <dx:DXTabItem.GlyphTemplate>
                <DataTemplate>
                    <Image Width="15"
                           Height="15"
                           Margin="0,0,5,0"
                           Source="{dx:DXImage 'SvgImages/Chart/ChartType_LineStacked100.svg'}" />
                </DataTemplate>
            </dx:DXTabItem.GlyphTemplate>

            <dxc:ChartControl Name="Chart">
                <dxc:ChartControl.Legend>
                    <dxc:Legend MarkerMode="CheckBox" />
                </dxc:ChartControl.Legend>
                <dxc:ChartControl.Diagram>
                    <dxc:XYDiagram2D Name="PnlDiagram"
                                     DependentAxesYRange="True"
                                     EnableAxisXNavigation="True"
                                     EnableAxisYNavigation="True"
                                     SeriesItemsSource="{Binding TransactionConsumer.EdgeScanFeedStatChartValues}">
                        <dxc:XYDiagram2D.AxisX>
                            <dxc:AxisX2D>
                                <dxc:AxisX2D.DateTimeScaleOptions>
                                    <dxc:ContinuousDateTimeScaleOptions />
                                </dxc:AxisX2D.DateTimeScaleOptions>
                            </dxc:AxisX2D>
                        </dxc:XYDiagram2D.AxisX>
                        <dxc:XYDiagram2D.AxisY>
                            <dxc:AxisY2D>
                                <dxc:AxisY2D.WholeRange>
                                    <dxc:Range dxc:AxisY2D.AlwaysShowZeroLevel="False" />
                                </dxc:AxisY2D.WholeRange>
                            </dxc:AxisY2D>
                        </dxc:XYDiagram2D.AxisY>
                        <dxc:XYDiagram2D.NavigationOptions>
                            <dxc:NavigationOptions UseKeyboard="True"
                                                   UseMouse="True"
                                                   UseScrollBars="True"
                                                   UseTouchDevice="True" />
                        </dxc:XYDiagram2D.NavigationOptions>
                        <dxc:XYDiagram2D.SeriesItemTemplate>
                            <DataTemplate>
                                <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                                  DataSource="{Binding ChartValues}"
                                                  DisplayName="{Binding Title}"
                                                  MarkerSize="3"
                                                  ValueDataMember="Value">
                                    <dxc:LineSeries2D.LastPoint>
                                        <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                            <dxc:SidePoint.Label>
                                                <dxc:SeriesLabel TextPattern="{}{V:N0}" />
                                            </dxc:SidePoint.Label>
                                        </dxc:SidePoint>
                                    </dxc:LineSeries2D.LastPoint>
                                </dxc:LineSeries2D>
                            </DataTemplate>
                        </dxc:XYDiagram2D.SeriesItemTemplate>
                    </dxc:XYDiagram2D>
                </dxc:ChartControl.Diagram>
            </dxc:ChartControl>

        </dx:DXTabItem>
    </dx:DXTabControl>
</views:ModuleWindow>
