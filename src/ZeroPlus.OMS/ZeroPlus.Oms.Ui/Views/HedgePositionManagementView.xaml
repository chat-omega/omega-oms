<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.HedgePositionManagementView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helpers="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 Title="{Binding UnderlyingPositionModel.Symbol, StringFormat='{}{0} - Position Manager'}"
                 Width="345"
                 Height="205"
                 d:DataContext="{d:DesignInstance Type=viewModels:HedgePositionManagementViewModel}"
                 DataContext="{startuphelpers:DISource Type=viewModels:HedgePositionManagementViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">
    <dx:ThemedWindow.Resources>
        <helpers:DoubleFormatter x:Key="DoubleFormatter" />
        <helpers:SignToBrushConverter x:Key="SignToBrushConverter"
                                      NegativeBrush="#B73535"
                                      PositiveBrush="#10e411"
                                      ZeroBrush="#10e411" />
    </dx:ThemedWindow.Resources>
    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Margin="5,2,0,0"
               Content="Symbol" />

        <dxe:ComboBoxEdit Grid.Row="1"
                          Grid.Column="2"
                          Grid.ColumnSpan="3"
                          Margin="5,2,0,0"
                          DisplayMember="Symbol"
                          EditValue="{Binding SelectedPosition, UpdateSourceTrigger=PropertyChanged}"
                          IsTextEditable="False"
                          ItemsSource="{Binding UnderlyingPositionModel.Positions}">
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding SelectedPositionChangedCommand}"
                                       EventName="EditValueChanged" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ComboBoxEdit>

        <Label Grid.Row="2"
               Grid.Column="1"
               Width="70"
               Margin="5,2,0,0"
               Content="Net Qty" />

        <dxe:SpinEdit Grid.Row="2"
                      Grid.Column="2"
                      Width="80"
                      Margin="5,2,0,0"
                      HorizontalAlignment="Left"
                      DisplayFormatString="+#0;-#0;-"
                      EditValue="{Binding SelectedPosition.NetQty, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Int32}"
                      Foreground="{Binding SelectedPosition.NetQty, Converter={StaticResource SignToBrushConverter}}"
                      IsReadOnly="False"
                      ShowEditorButtons="True" />

        <Label Grid.Row="2"
               Grid.Column="3"
               Width="70"
               Margin="5,2,0,0"
               Content="Avg Px" />

        <dxe:SpinEdit Grid.Row="2"
                      Grid.Column="4"
                      Width="80"
                      Margin="5,2,0,0"
                      HorizontalAlignment="Left"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding SelectedPosition.Position.OpenPositionAveragePrice, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Foreground="{Binding SelectedPosition.Position.OpenPositionAveragePrice, Converter={StaticResource SignToBrushConverter}}"
                      Increment=".01"
                      Mask="C2"
                      MaskUseAsDisplayFormat="True"
                      PreviewMouseUp="SpinEdit_MouseUp"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <StackPanel Grid.Row="7"
                    Grid.Column="0"
                    Grid.ColumnSpan="7"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="3,0"
                             Command="{Binding AddCommand}"
                             Content="Add"
                             IsCancel="True" />
            <dx:SimpleButton Width="80"
                             Margin="3,0"
                             Command="{Binding SaveCommand}"
                             Content="Save"
                             IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
