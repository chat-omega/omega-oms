<UserControl x:Class="ZeroPlus.Oms.Ui.Views.DominatorConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DataContext="{d:DesignInstance Type=ViewModels:DominatorConfigurationViewModel}"
             d:DesignHeight="600"
             d:DesignWidth="1200"
             mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <UserControl.Resources>
        <Style x:Key="labelStyle"
               TargetType="Label">
            <Setter Property="Margin" Value="5,2,0,0" />
        </Style>
        <Style x:Key="RowStyle"
               TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="#1D3C52" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="#1D3C52" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Row="1"
                       Grid.Column="1"
                       Grid.ColumnSpan="2"
                       Margin="3">
                <Label Margin="2,0,0,0"
                       Content="Title"
                       FontWeight="DemiBold" />

                <dxe:TextEdit x:Name="TitleEdit"
                              Margin="5,0,0,0"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              BorderThickness="0"
                              EditValue="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                              IsHitTestVisible="True"
                              KeyDown="TitleKeyDown"
                              MouseDoubleClick="ToggleEdit"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </DockPanel>

            <DockPanel Grid.Row="1"
                       Grid.Column="3"
                       Margin="3">
                <Label Content="Last Updated"
                       FontWeight="DemiBold" />

                <dxe:TextEdit Margin="5,0,0,0"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              EditValue="{Binding LastUpdateTime, UpdateSourceTrigger=PropertyChanged}"
                              IsReadOnly="True"
                              Mask="MM/dd hh:mm:ss"
                              MaskType="DateTimeAdvancingCaret"
                              MaskUseAsDisplayFormat="True" />
            </DockPanel>

            <dxe:SearchControl Grid.Row="1"
                               Grid.Column="4"
                               Margin="3"
                               FilterByColumnsMode="Custom"
                               FilterCondition="Contains" />
        </Grid>
        <dx:DXTabControl Grid.Row="2"
                         Grid.Column="1"
                         Grid.ColumnSpan="4">
            <dx:DXTabItem Name="GeneralTab">
                <dx:DXTabItem.Header>
                    <TextBlock FontWeight="DemiBold"
                               Text="General" />
                </dx:DXTabItem.Header>
                <dx:DXTabItem.GlyphTemplate>
                    <DataTemplate>
                        <Image Width="15"
                               Height="15"
                               Margin="0,0,5,0"
                               Source="{dx:DXImage 'SvgImages/Layout/TableLayout.svg'}" />
                    </DataTemplate>
                </dx:DXTabItem.GlyphTemplate>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="0" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="0" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Content="Security Type"
                           Style="{StaticResource labelStyle}" />

                    <dxe:ComboBoxEdit Grid.Row="1"
                                      Grid.Column="2"
                                      Margin="5,2,0,0"
                                      ApplyItemTemplateToSelectedItem="True"
                                      EditValue="{Binding SecurityType, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding SecurityTypes}">
                        <dxe:ComboBoxEdit.ItemTemplate>
                            <DataTemplate>
                                <Label Padding="0,0.5"
                                       HorizontalAlignment="Center"
                                       Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}"
                                       FontSize="11" />
                            </DataTemplate>
                        </dxe:ComboBoxEdit.ItemTemplate>
                    </dxe:ComboBoxEdit>

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Content="Initial Fish Qty"
                           Style="{StaticResource labelStyle}" />

                    <dxe:SpinEdit Grid.Row="2"
                                  Grid.Column="2"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding InitialFishQty}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="3"
                           Grid.Column="1"
                           Content="Restart When Done"
                           Style="{StaticResource labelStyle}" />

                    <dxe:ToggleSwitch Grid.Row="3"
                                      Grid.Column="2"
                                      Margin="5,2,0,0"
                                      HorizontalAlignment="Left"
                                      Background="#f4241e"
                                      CheckedStateContent="Enabled"
                                      ContentPlacement="Inside"
                                      IsChecked="{Binding RestartWhenDone}"
                                      ToggleSwitchWidth="145"
                                      UncheckedStateContent="Disabled" />

                    <Label Grid.Row="4"
                           Grid.Column="1"
                           Content="Edge Expansion Per Delta"
                           Style="{StaticResource labelStyle}" />

                    <dxe:SpinEdit Grid.Row="4"
                                  Grid.Column="2"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding EdgeExpansionPerDelta}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment=".01"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="5"
                           Grid.Column="1"
                           Content="Min Edge Per Contract"
                           Style="{StaticResource labelStyle}" />

                    <dxe:SpinEdit Grid.Row="5"
                                  Grid.Column="2"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding MinEdgePerContract}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment=".01"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="6"
                           Grid.Column="1"
                           Content="Max Spread Delta"
                           Style="{StaticResource labelStyle}" />

                    <dxe:SpinEdit Grid.Row="6"
                                  Grid.Column="2"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding MaxSpreadDelta}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment=".01"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="7"
                           Grid.Column="1"
                           Content="DTE Range"
                           Style="{StaticResource labelStyle}" />

                    <Grid Grid.Row="7"
                          Grid.Column="2"
                          Margin="5,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <dxe:SpinEdit Grid.Column="0"
                                      Margin="0,0,3,0"
                                      AllowSpinOnMouseWheel="True"
                                      EditValue="{Binding MinDte}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Increment="1"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />

                        <dxe:SpinEdit Grid.Column="2"
                                      Margin="3,0,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      EditValue="{Binding MaxDte}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Increment="1"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </Grid>

                    <Label Grid.Row="8"
                           Grid.Column="1"
                           Content="Allow If Day Traded"
                           Style="{StaticResource labelStyle}" />

                    <dxe:ToggleSwitch Grid.Row="8"
                                      Grid.Column="2"
                                      Margin="5,2,0,0"
                                      HorizontalAlignment="Left"
                                      Background="#f4241e"
                                      CheckedStateContent="Enabled"
                                      ContentPlacement="Inside"
                                      IsChecked="{Binding AllowIfDayTraded}"
                                      ToggleSwitchWidth="145"
                                      UncheckedStateContent="Disabled" />

                    <Label Grid.Row="9"
                           Grid.Column="1"
                           Content="Use Best Quote for Bid %"
                           Style="{StaticResource labelStyle}" />

                    <dxe:ToggleSwitch Grid.Row="9"
                                      Grid.Column="2"
                                      Margin="5,2,0,0"
                                      HorizontalAlignment="Left"
                                      Background="#f4241e"
                                      CheckedStateContent="Enabled"
                                      ContentPlacement="Inside"
                                      IsChecked="{Binding UseBestQuoteForBid}"
                                      ToggleSwitchWidth="145"
                                      UncheckedStateContent="Disabled" />
                </Grid>
            </dx:DXTabItem>
            <dx:DXTabItem Name="DTEEdgeTab">
                <dx:DXTabItem.Header>
                    <TextBlock FontWeight="DemiBold"
                               Text="DTE Edge Expansion" />
                </dx:DXTabItem.Header>
                <dx:DXTabItem.GlyphTemplate>
                    <DataTemplate>
                        <Image Width="15"
                               Height="15"
                               Margin="0,0,5,0"
                               Source="{dx:DXImage 'SvgImages/Layout/TableLayout.svg'}" />
                    </DataTemplate>
                </dx:DXTabItem.GlyphTemplate>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <dxg:GridControl Name="DteEdgeMultiplierGrid"
                                     Grid.Row="0"
                                     MaxHeight="1500"
                                     Margin="0,2,0,0"
                                     dx:DXSerializer.StoreLayoutMode="All"
                                     dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                                     AutoGenerateColumns="None"
                                     EnableSmartColumnsGeneration="True"
                                     ItemsSource="{Binding DteEdgeMultiplierTable}"
                                     SelectionMode="Row">
                        <dxg:GridControl.Resources>
                            <Style TargetType="dxg:GridColumn">
                                <Setter Property="Visible" Value="False" />
                                <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                            </Style>
                        </dxg:GridControl.Resources>
                        <dxg:GridControl.View>
                            <dxg:TableView Name="DteMultiplierTable"
                                           AllowDragDrop="True"
                                           AutoWidth="True"
                                           EditorShowMode="MouseUp"
                                           EnableSelectedRowAppearance="True"
                                           FadeSelectionOnLostFocus="False"
                                           RowStyle="{StaticResource RowStyle}"
                                           ShowGroupPanel="False"
                                           ShowIndicator="True"
                                           VerticalScrollbarVisibility="Auto">
                                <dxg:TableView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowColumnChooserCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show Column Chooser">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ClearColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Hide All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowAllColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowDefaultColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show Default Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </dxg:TableView.ContextMenu>
                            </dxg:TableView>
                        </dxg:GridControl.View>

                        <dxg:GridColumn MinWidth="72"
                                        FieldName="Dte"
                                        Header="DTE"
                                        IsSmart="False"
                                        Visible="True">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dxe:SpinEdit Margin="-1"
                                                  HorizontalContentAlignment="Right"
                                                  AllowSpinOnMouseWheel="True"
                                                  BorderThickness="0"
                                                  EditValue="{Binding RowData.Row.Dte, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Int32}"
                                                  Increment="1"
                                                  Mask="N0"
                                                  MaskUseAsDisplayFormat="True"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>

                        <dxg:GridColumn MinWidth="72"
                                        FieldName="Multiplier"
                                        Header="Multiplier"
                                        IsSmart="False"
                                        Visible="True">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dxe:SpinEdit Margin="-1"
                                                  HorizontalContentAlignment="Right"
                                                  AllowSpinOnMouseWheel="True"
                                                  BorderThickness="0"
                                                  EditValue="{Binding RowData.Row.Multiplier, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Double}"
                                                  Increment="0.01"
                                                  Mask="N2"
                                                  MaskUseAsDisplayFormat="True"
                                                  MinValue="0.05"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>

                        <dxg:GridColumn Width="20"
                                        MinWidth="16"
                                        MaxWidth="24"
                                        FieldName="Delete"
                                        Header=""
                                        IsSmart="False"
                                        Visible="True">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dx:SimpleButton Padding="0"
                                                     BorderThickness="0"
                                                     Command="{DXCommand '@e(DteEdgeMultiplierGrid).DataContext.DteEdgeMultiplierTable.Remove(@p.RowData.Row)'}"
                                                     Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Delete.svg}"
                                                     GlyphWidth="15" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <dx:SimpleButton Width="80"
                                         Margin="3,5,3,1"
                                         Command="{DXCommand 'AddDTEEdgeExpansion()'}"
                                         Content="Add"
                                         IsDefault="True" />
                    </StackPanel>
                </Grid>
            </dx:DXTabItem>
            <dx:DXTabItem Name="UnderEdgeTab">
                <dx:DXTabItem.Header>
                    <TextBlock FontWeight="DemiBold"
                               Text="Under Multiplier" />
                </dx:DXTabItem.Header>
                <dx:DXTabItem.GlyphTemplate>
                    <DataTemplate>
                        <Image Width="15"
                               Height="15"
                               Margin="0,0,5,0"
                               Source="{dx:DXImage 'SvgImages/Layout/TableLayout.svg'}" />
                    </DataTemplate>
                </dx:DXTabItem.GlyphTemplate>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <dxg:GridControl Name="UnderMultiplierGrid"
                                     Grid.Row="0"
                                     MaxHeight="1500"
                                     Margin="0,2,0,0"
                                     dx:DXSerializer.StoreLayoutMode="All"
                                     dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                                     AutoGenerateColumns="None"
                                     EnableSmartColumnsGeneration="True"
                                     ItemsSource="{Binding UnderMultiplierTable}"
                                     SelectionMode="Row">
                        <dxg:GridControl.Resources>
                            <Style TargetType="dxg:GridColumn">
                                <Setter Property="Visible" Value="False" />
                                <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                            </Style>
                        </dxg:GridControl.Resources>
                        <dxg:GridControl.View>
                            <dxg:TableView Name="UnderMultiplierTable"
                                           AllowDragDrop="True"
                                           AutoWidth="True"
                                           EditorShowMode="MouseUp"
                                           EnableSelectedRowAppearance="True"
                                           FadeSelectionOnLostFocus="False"
                                           RowStyle="{StaticResource RowStyle}"
                                           ShowGroupPanel="False"
                                           ShowIndicator="True"
                                           VerticalScrollbarVisibility="Auto">
                                <dxg:TableView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowColumnChooserCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show Column Chooser">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ClearColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Hide All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowAllColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowDefaultColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show Default Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </dxg:TableView.ContextMenu>
                            </dxg:TableView>
                        </dxg:GridControl.View>

                        <dxg:GridColumn MinWidth="72"
                                        FieldName="Under"
                                        Header="Under"
                                        IsSmart="False"
                                        Visible="True">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dxe:TextEdit VerticalAlignment="Center"
                                                  BorderBrush="#333337"
                                                  BorderThickness="0"
                                                  CharacterCasing="Upper"
                                                  Text="{Binding RowData.Row.Under}" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>

                        <dxg:GridColumn MinWidth="72"
                                        FieldName="Multiplier"
                                        Header="Multiplier"
                                        IsSmart="False"
                                        Visible="True">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dxe:SpinEdit Margin="-1"
                                                  HorizontalContentAlignment="Right"
                                                  AllowSpinOnMouseWheel="True"
                                                  BorderThickness="0"
                                                  EditValue="{Binding RowData.Row.Multiplier, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Double}"
                                                  Increment="0.01"
                                                  Mask="N2"
                                                  MaskUseAsDisplayFormat="True"
                                                  MinValue="0.05"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>

                        <dxg:GridColumn Width="20"
                                        MinWidth="16"
                                        MaxWidth="24"
                                        FieldName="Delete"
                                        Header=""
                                        IsSmart="False"
                                        Visible="True">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dx:SimpleButton Padding="0"
                                                     BorderThickness="0"
                                                     Command="{DXCommand '@e(UnderMultiplierGrid).DataContext.UnderMultiplierTable.Remove(@p.RowData.Row)'}"
                                                     Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Delete.svg}"
                                                     GlyphWidth="15" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <dx:SimpleButton Width="80"
                                         Margin="3,5,3,1"
                                         Command="{DXCommand 'AddUnderlyingEdgeExpansion()'}"
                                         Content="Add"
                                         IsDefault="True" />
                    </StackPanel>
                </Grid>
            </dx:DXTabItem>
            <dx:DXTabItem Name="SpreadTypeEdge">
                <dx:DXTabItem.Header>
                    <TextBlock FontWeight="DemiBold"
                               Text="Spread Type Multiplier" />
                </dx:DXTabItem.Header>
                <dx:DXTabItem.GlyphTemplate>
                    <DataTemplate>
                        <Image Width="15"
                               Height="15"
                               Margin="0,0,5,0"
                               Source="{dx:DXImage 'SvgImages/Layout/TableLayout.svg'}" />
                    </DataTemplate>
                </dx:DXTabItem.GlyphTemplate>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <dxg:GridControl Name="SpreadTypeMultiplierGrid"
                                     Grid.Row="0"
                                     MaxHeight="1500"
                                     Margin="0,2,0,0"
                                     dx:DXSerializer.StoreLayoutMode="All"
                                     dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                                     AutoGenerateColumns="None"
                                     EnableSmartColumnsGeneration="True"
