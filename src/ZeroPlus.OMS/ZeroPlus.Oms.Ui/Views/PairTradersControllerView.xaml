<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.PairTradersControllerView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxgt="http://schemas.devexpress.com/winfx/2008/xaml/grid/themekeys"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="1800"
                 Height="700"
                 MinWidth="400"
                 MinHeight="300"
                 Padding="0"
                 d:DataContext="{d:DesignInstance Type=ViewModels:PairTradersControllerViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:PairTradersControllerViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:LoadCustomColumnService />
        <services:OmsMessageBoxService />
        <dxmvvm:DispatcherService />
    </dxmvvm:Interaction.Behaviors>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <dx:DropDownButton Grid.Row="0"
                               Grid.Column="12"
                               Width="115"
                               Margin="2"
                               Padding="3,1,7,1"
                               HorizontalAlignment="Right"
                               Content="Settings"
                               Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Settings.svg}"
                               GlyphHeight="15">
                <ItemsControl>
                    <StackPanel Orientation="Vertical">
                        <dx:SuperTipItemControlSeparator />
                        <MenuItem Click="ClearSortingClick"
                                  Header="Clear Sorting" />
                    </StackPanel>
                </ItemsControl>
            </dx:DropDownButton>

            <dx:SimpleButton Width="23"
                             Margin="2"
                             HorizontalAlignment="Right"
                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                             GlyphHeight="17">

                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupControlContainer>
                        <ItemsControl>
                            <StackPanel>
                                <MenuItem Height="25"
                                          Click="CloneClick"
                                          Header="Clone">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="ShareLayout"
                                          Header="Share Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="SaveLayout"
                                          Header="Save Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="BrowseLayout"
                                          Header="Browse Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="LoadLayout"
                                          Header="Load Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </StackPanel>
                        </ItemsControl>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>

        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <dx:ThemedWindow.Resources>
        <helper:TriggerMethodToDisplayTextConverter x:Key="TriggerMethodToDisplayTextConverter" />
        <helper:TriggerMethodToMinTriggerValueConverter x:Key="TriggerMethodToRatioEnabledConverter" />
        <helper:TriggerMethodToMinTriggerValueConverter x:Key="TriggerMethodToSpreadEnabledConverter"
                                                        Inverse="True" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToStateColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#039C23" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#D11C1C" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:SignToBrushConverter x:Key="TitleSignToBrushConverter"
                                     NegativeBrush="#FF0000"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#10e411" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#02F302" />
        <Style x:Key="submitBuyButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D9E65" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1D673F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Margin" Value="-1" />
            <Setter Property="Background" Value="#0A8E51" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style x:Key="submitSellButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C44E4E" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#772F2F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Margin" Value="-1" />
            <Setter Property="Background" Value="#B73535" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="AddToTopToGlyphConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <Image Width="20"
                       Height="20"
                       Source="{dx:DXImage SvgImages/Spreadsheet/FillUp.svg}" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <Image Width="20"
                       Height="20"
                       Source="{dx:DXImage SvgImages/Spreadsheet/FillDown.svg}" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="FeedStateTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                SUBSCRIBED
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                DOWN
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TraderStateTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                AUTO TRADER RUNNING
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                AUTO TRADER STOPPED
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TraderStateButtonTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Stop Trader
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Start Trader
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToStatusColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Green" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="DarkRed" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                             Inverse="True" />
        <helper:SignToBrushConverter x:Key="CountdownToBrushConverter"
                                     Limit="3"
                                     NegativeBrush="#F05126"
                                     PositiveBrush="#F1F1F1"
                                     ZeroBrush="#F05126" />
        <Style x:Key="PositionsRowStyle"
               TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="#1d3c52" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="#1d3c52" />
                </Trigger>
                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#39393A" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#3E596B" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </dx:ThemedWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="5,5,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="auto"
                                  MinWidth="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="auto"
                                  MinWidth="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="auto"
                                  MinWidth="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="auto"
                                  MinWidth="50" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   HorizontalAlignment="Center"
                   Content="Total Qty"
                   FontWeight="DemiBold"
                   Foreground="#AFAFB0" />

            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Text="{Binding TotalQty}" />

            <Label Grid.Column="2"
                   HorizontalAlignment="Center"
                   Content="Running"
                   FontWeight="DemiBold"
                   Foreground="#AFAFB0" />

            <TextBlock Grid.Column="3"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Text="{Binding TotalRunning}" />

            <Label Grid.Column="4"
                   HorizontalAlignment="Center"
                   Content="R.PnL"
                   FontWeight="DemiBold"
                   Foreground="#AFAFB0" />

            <TextBlock Grid.Column="5"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="{Binding RealPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                       Text="{Binding RealPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />

            <Label Grid.Column="6"
                   HorizontalAlignment="Center"
                   Content="U.PnL"
                   FontWeight="DemiBold"
                   Foreground="#AFAFB0" />

            <TextBlock Grid.Column="7"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="{Binding UnrealPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                       Text="{Binding UnrealPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />

            <dx:SimpleButton Grid.Row="0"
                             Grid.Column="9"
                             Command="{Binding AddCommand}"
                             Content="Add Pair Trader"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                             GlyphHeight="13"
                             GlyphWidth="13" />
        </Grid>

        <Slider x:Name="ModelsMainGridScale"
                Grid.Row="1"
                Maximum="4"
                Minimum="0.1"
                Visibility="Hidden"
                Value="1" />

        <dxg:GridControl x:Name="ModelsMainGrid"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,3,0,0"
                         dx:DXSerializer.StoreLayoutMode="All"
                         dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                         AutoGenerateColumns="AddNew"
                         AutoGeneratedColumns="Grid_ColumnsPopulated"
                         CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                         EnableSmartColumnsGeneration="True"
                         ItemsSource="{Binding ManagerModel.PairTraderModels}"
                         PreviewMouseWheel="OnZoomMouseWheel"
                         RestoreStateOnSourceChange="True"
                         SelectionMode="Row">
            <dxg:GridControl.LayoutTransform>
                <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=ModelsMainGridScale, Path=Value}" ScaleY="{Binding ElementName=ModelsMainGridScale, Path=Value}" />
            </dxg:GridControl.LayoutTransform>
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
                <Style TargetType="dxg:GridControlBand">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
                <ControlTemplate x:Key="{dxgt:GridColumnHeaderThemeKey ResourceKey=ColumnFilterTemplate}"
                                 TargetType="{x:Type ToggleButton}" />
            </dxg:GridControl.Resources>
            <dxmvvm:Interaction.Behaviors>
                <services:UiUpdateService />
            </dxmvvm:Interaction.Behaviors>
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False"
                               AutoWidth="True"
                               EnableSelectedRowAppearance="True"
                               GroupSummaryDisplayMode="AlignByColumns"
                               NavigationStyle="Row"
                               RowStyle="{StaticResource PositionsRowStyle}"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.RowCellMenuCustomizations>
                        <dxb:BarButtonItem Command="{Binding View.DataContext.ActivateWindowCommand}"
                                           CommandParameter="{Binding ElementName=ModelsMainGrid, Path=SelectedItem}"
                                           Content="Activate Window" />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.HideWindowCommand}"
                                           CommandParameter="{Binding ElementName=ModelsMainGrid, Path=SelectedItem}"
                                           Content="Hide Window" />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.CloseWindowCommand}"
                                           CommandParameter="{Binding ElementName=ModelsMainGrid, Path=SelectedItem}"
                                           Content="Close Window" />
                    </dxg:TableView.RowCellMenuCustomizations>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="SpreadQty"
                            Header="Pair Qty"
                            IsSmart="True"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               Content="{Binding RowData.Row.SpreadQty, Converter={StaticResource DoubleFormatter}}"
                               FontWeight="DemiBold" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Width="400"
                            FieldName="Symbol"
                            Header="Pair Symbol"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               Background="#333337"
                               Content="{Binding RowData.Row.Symbol}"
                               FontWeight="DemiBold" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Bid"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               Background="#111111"
                               Content="{Binding RowData.Row.Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               FontWeight="DemiBold" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Mid"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               Background="#111111"
                               Content="{Binding RowData.Row.Mid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               FontWeight="DemiBold" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Ask"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               Background="#111111"
                               Content="{Binding RowData.Row.Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               FontWeight="DemiBold" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Ema"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               Background="#111111"
                               Content="{Binding RowData.Row.Ema, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               FontWeight="DemiBold" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="LcdPosition"
                            Header="Pos"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               HorizontalContentAlignment="Center"
                               Background="#333337"
                               Content="{Binding RowData.Row.LcdPosition, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               FontWeight="Bold"
                               Foreground="#00A8FF" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="LastPnl"
                            Header="Last PnL"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               HorizontalContentAlignment="Center"
                               Background="#333337"
                               Content="{Binding RowData.Row.LastPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               FontWeight="DemiBold"
                               Foreground="{Binding RowData.Row.LastPnl, Converter={StaticResource TitleSignToBrushConverter}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="AdjPnl"
                            Header="Adj PnL"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               HorizontalContentAlignment="Center"
                               Background="#333337"
                               Content="{Binding RowData.Row.AdjPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               FontWeight="DemiBold"
                               Foreground="{Binding RowData.Row.AdjPnl, Converter={StaticResource TitleSignToBrushConverter}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="UnrealPnl"
                            Header="U. PnL"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               HorizontalContentAlignment="Center"
                               Background="#333337"
                               Content="{Binding RowData.Row.UnrealPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               FontWeight="DemiBold"
                               Foreground="{Binding RowData.Row.UnrealPnl, Converter={StaticResource TitleSignToBrushConverter}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="NetPnl"
                            Header="Net PnL"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Label Padding="3"
                               HorizontalContentAlignment="Center"
                               Background="#333337"
                               Content="{Binding RowData.Row.NetPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               FontWeight="DemiBold"
                               Foreground="{Binding RowData.Row.NetPnl, Converter={StaticResource TitleSignToBrushConverter}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="BuyInitialSide"
                            Header="Buy Init Side"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:ComboBoxEdit Margin="-1"
                                          BorderThickness="0"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding RowData.Row.InitSides}"
                                          SelectedItem="{Binding RowData.Row.BuyInitialSide}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="SellInitialSide"
                            Header="Sell Init Side"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:ComboBoxEdit Margin="-1"
                                          BorderThickness="0"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding RowData.Row.InitSides}"
                                          SelectedItem="{Binding RowData.Row.SellInitialSide}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="BuyExecutionStyle"
                            Header="Buy Style"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:ComboBoxEdit Margin="-1"
                                          BorderThickness="0"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding RowData.Row.ExecutionStyles}"
                                          SelectedItem="{Binding RowData.Row.BuyExecutionStyle}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="SellExecutionStyle"
                            Header="Sell Style"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:ComboBoxEdit Margin="-1"
                                          BorderThickness="0"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding RowData.Row.ExecutionStyles}"
                                          SelectedItem="{Binding RowData.Row.SellExecutionStyle}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="TriggerMethod"
                            Header="Trigger Method"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:ComboBoxEdit Margin="-1"
                                          BorderThickness="0"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding RowData.Row.TriggerMethods}"
                                          SelectedItem="{Binding RowData.Row.TriggerMethod}">
                            <dxe:ComboBoxEdit.ItemTemplate>
                                <DataTemplate>
                                    <Label Padding="0,0.5"
                                           HorizontalAlignment="Center"
                                           Content="{Binding Converter={StaticResource TriggerMethodToDisplayTextConverter}}"
                                           FontSize="11" />
                                </DataTemplate>
                            </dxe:ComboBoxEdit.ItemTemplate>
                        </dxe:ComboBoxEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="TriggerValue"
                            Header="Buy Trigger Value"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.TriggerValue, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".0001"
                                      IsEnabled="{Binding RowData.Row.TriggerMethod, Converter={StaticResource TriggerMethodToRatioEnabledConverter}}"
                                      Mask="N4"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue=".0001"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="SellTriggerValue"
                            Header="Sell Trigger Value"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.SellTriggerValue, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".0001"
                                      IsEnabled="{Binding RowData.Row.TriggerMethod, Converter={StaticResource TriggerMethodToRatioEnabledConverter}}"
                                      Mask="N4"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue=".0001"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="SpreadTriggerValue"
                            Header="Spread Buy Trigger Value"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.SpreadTriggerValue, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".0001"
                                      IsEnabled="{Binding RowData.Row.TriggerMethod, Converter={StaticResource TriggerMethodToSpreadEnabledConverter}}"
                                      Mask="N4"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="SpreadSellTriggerValue"
                            Header="Spread Sell Trigger Value"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.SpreadSellTriggerValue, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".0001"
                                      IsEnabled="{Binding RowData.Row.TriggerMethod, Converter={StaticResource TriggerMethodToSpreadEnabledConverter}}"
                                      Mask="N4"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="SendBuy"
                            Header="-"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Grid.Column="0"
                                         Command="{Binding RowData.Row.SendBuyOrderCommand}"
                                         Content="Buy Pair"
                                         GlyphHeight="13"
                                         Style="{StaticResource submitBuyButtonStyle}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="SendSell"
                            Header="-"
                            IsSmart="False"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Grid.Column="0"
                                         Command="{Binding RowData.Row.SendSellOrderCommand}"
                                         Content="Sell Pair"
                                         GlyphHeight="13"
                                         Style="{StaticResource submitSellButtonStyle}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="CancelAll"
                            Header="-"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Margin="-1"
                                         BorderThickness="0"
                                         Command="{Binding RowData.Row.CancelAllCommand}"
                                         Content="Cancel All" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Load"
                            Header="-"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Margin="-1"
                                         BorderThickness="0"
                                         Command="{Binding RowData.Row.LoadCommand}"
                                         Content="Load" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="Stop"
                            Header="-"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Margin="-1"
                                         BorderThickness="0"
                                         Command="{Binding RowData.Row.StopCommand}"
                                         Content="Stop" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

        </dxg:GridControl>
    </Grid>
</dx:ThemedWindow>
