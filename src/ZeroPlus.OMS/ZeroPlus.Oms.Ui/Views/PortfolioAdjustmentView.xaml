<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.PortfolioAdjustmentView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Portfolio Adjustment"
                 Width="1200"
                 Height="800"
                 d:DataContext="{d:DesignInstance Type=ViewModels:PortfolioAdjustmentViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:PortfolioAdjustmentViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <dx:ThemedWindow.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#F0E7D8" />
    </dx:ThemedWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1"
              Grid.Column="1"
              Margin="0,2,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Margin="5,0,0,0"
                   Content="Target Date" />

            <dxe:TextEdit Grid.Column="1"
                          Width="120"
                          Margin="5,0,0,0"
                          HorizontalContentAlignment="Center"
                          EditValue="{Binding TargetDate, UpdateSourceTrigger=PropertyChanged}"
                          Mask="MMM-dd-yy"
                          MaskType="DateTimeAdvancingCaret"
                          MaskUseAsDisplayFormat="True" />

            <dx:SimpleButton Grid.Column="2"
                             Width="90"
                             Margin="5,0,0,0"
                             Command="{Binding LoadCommand}"
                             Content="Load"
                             Glyph="{dx:DXImage SvgImages/Dashboards/UpdateDataExtract.svg}"
                             GlyphHeight="15" />

            <dx:SimpleButton Grid.Column="3"
                             Width="90"
                             Margin="5,0,0,0"
                             Command="{Binding ClearCommand}"
                             Content="Clear"
                             Glyph="{dx:DXImage SvgImages/Snap/ClearTableStyle.svg}"
                             GlyphHeight="15"
                             IsEnabled="{Binding IsLoaded}" />

            <dx:SimpleButton Grid.Column="4"
                             Width="90"
                             Margin="5,0,0,0"
                             Command="{Binding UpdateCommand}"
                             Content="Update"
                             Glyph="{dx:DXImage SvgImages/Dashboards/EditDataSource.svg}"
                             GlyphHeight="15"
                             IsDefault="True"
                             IsEnabled="{Binding IsLoaded}" />
        </Grid>

        <dxg:GridControl Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,2,0,0"
                         AutoGenerateColumns="AddNew"
                         ItemsSource="{Binding Portfolios}"
                         Visibility="Visible">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                    <Setter Property="Visible" Value="False" />
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False"
                               AutoWidth="True"
                               NavigationStyle="Row"
                               SearchPanelClearOnClose="True"
                               SearchPanelNullText="Search"
                               SearchPanelPosition="OverGroupPanel"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowSearchPanelMode="Always"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="Name"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn FieldName="PortfolioType"
                            IsSmart="True"
                            Visible="True" />
            <dxg:GridColumn AllowEditing="True"
                            FieldName="TotalSubmissions"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      DisplayFormatString="#0;#0;-"
                                      EditValue="{Binding RowData.Row.TotalSubmissions, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn AllowEditing="True"
                            FieldName="TotalFills"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      DisplayFormatString="#0;#0;-"
                                      EditValue="{Binding RowData.Row.TotalFills, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="FillRate"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings DisplayFormat="p2" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="OrderFillRate"
                            Header="Ord Fill Rate"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings DisplayFormat="p2" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="IbOrderFillRate"
                            Header="IB Fill Rate"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings DisplayFormat="p2" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="NetQty"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <dxe:SpinEdit Grid.Column="0"
                                          Margin="-1"
                                          AllowSpinOnMouseWheel="True"
                                          Background="Transparent"
                                          BorderThickness="0,0,0,0"
                                          DisplayFormatString="+#0;-#0;-"
                                          EditValue="{Binding RowData.Row.ShortQty, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Foreground="{Binding RowData.Row.ShortQty, Converter={StaticResource SignToBrushConverter}}"
                                          Mask="N0"
                                          MaskUseAsDisplayFormat="True"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                            <dxe:SpinEdit Grid.Column="1"
                                          Margin="-1"
                                          AllowSpinOnMouseWheel="True"
                                          Background="Transparent"
                                          BorderThickness="0,0,0,0"
                                          DisplayFormatString="+#0;-#0;-"
                                          EditValue="{Binding RowData.Row.LongQty, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Foreground="{Binding RowData.Row.LongQty, Converter={StaticResource SignToBrushConverter}}"
                                          Mask="N0"
                                          MaskUseAsDisplayFormat="True"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </Grid>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="AdjustedPnl"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Grid.Column="2"
                                      Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.AdjustedPnl, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Double}"
                                      Foreground="{Binding RowData.Row.AdjustedPnl, Converter={StaticResource SignToBrushConverter}}"
                                      Mask="C2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="RealizedPnl"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Grid.Column="2"
                                      Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.RealizedPnl, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Double}"
                                      Foreground="{Binding RowData.Row.RealizedPnl, Converter={StaticResource SignToBrushConverter}}"
                                      Mask="C2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="UnrealizedPnl"
                            IsSmart="True"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Grid.Column="2"
                                      Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.UnrealizedPnl, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Double}"
                                      Foreground="{Binding RowData.Row.UnrealizedPnl, Converter={StaticResource SignToBrushConverter}}"
                                      Mask="C2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="LowestRealizedPnl"
                            Header="Low Real PnL"
                            IsSmart="True"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Grid.Column="2"
                                      Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.LowestRealizedPnl, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Double}"
                                      Foreground="{Binding RowData.Row.LowestRealizedPnl, Converter={StaticResource SignToBrushConverter}}"
                                      Mask="C2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="HighestRealizedPnl"
                            Header="High Real PnL"
                            IsSmart="True"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Grid.Column="2"
                                      Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.HighestRealizedPnl, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Double}"
                                      Foreground="{Binding RowData.Row.HighestRealizedPnl, Converter={StaticResource SignToBrushConverter}}"
                                      Mask="C2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="LowestAdjustedPnl"
                            Header="Low Adj PnL"
                            IsSmart="True"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Grid.Column="2"
                                      Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.LowestAdjustedPnl, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Double}"
                                      Foreground="{Binding RowData.Row.LowestAdjustedPnl, Converter={StaticResource SignToBrushConverter}}"
                                      Mask="C2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="HighestAdjustedPnl"
                            Header="High Adj PnL"
                            IsSmart="True"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Grid.Column="2"
                                      Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.HighestAdjustedPnl, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Double}"
                                      Foreground="{Binding RowData.Row.HighestAdjustedPnl, Converter={StaticResource SignToBrushConverter}}"
                                      Mask="C2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="TotalOutOfMarketOrders"
                            Header="Out Of Mkt"
                            IsSmart="True"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      DisplayFormatString="#0;#0;-"
                                      EditValue="{Binding RowData.Row.TotalOutOfMarketOrders, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="TotalOutOfMarketFills"
                            Header="Out Of Mkt Fill"
                            IsSmart="True"
                            Visible="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit Margin="-1"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      DisplayFormatString="#0;#0;-"
                                      EditValue="{Binding RowData.Row.TotalOutOfMarketFills, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>
    </Grid>
</dx:ThemedWindow>
