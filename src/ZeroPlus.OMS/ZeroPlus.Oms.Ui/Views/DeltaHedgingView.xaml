<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.DeltaHedgingView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxgt="http://schemas.devexpress.com/winfx/2008/xaml/grid/themekeys"
                 xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="1200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 Padding="0"
                 d:DataContext="{d:DesignInstance Type=ViewModels:DeltaHedgingViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:DeltaHedgingViewModel}"
                 Topmost="{Binding PortfolioManagerModel.IsHedging}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:LoadCustomColumnService />
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <Window.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:DateTimeToDisplayTextConverter x:Key="DateTimeToDisplayTextConverter" />
        <helper:OrderTypeToLimitHandlingStateEnabledConverter x:Key="OrderTypeToLimitHandlingStateEnabledConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="AddToTopToGlyphConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <Image Width="20"
                       Height="20"
                       Source="{dx:DXImage SvgImages/Spreadsheet/FillUp.svg}" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <Image Width="20"
                       Height="20"
                       Source="{dx:DXImage SvgImages/Spreadsheet/FillDown.svg}" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#F0E7D8" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBorderColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #01c001
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToButtonTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Stop
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Start
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                             Inverse="True" />
        <Style x:Key="PositionsRowStyle"
               TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="#1d3c52" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="#1d3c52" />
                </Trigger>
                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#39393A" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#3E596B" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TotalCurrencyStyle"
               TargetType="{x:Type dxg:TotalSummaryItemsControl}">
            <Setter Property="Foreground" Value="{Binding Converter={StaticResource SignToBrushConverter}}" />
        </Style>
    </Window.Resources>
    <Border Grid.Row="1"
            Grid.Column="1"
            BorderBrush="{Binding PortfolioManagerModel.IsHedging, Converter={StaticResource BooleanToBorderColorConverter}}"
            BorderThickness="5,0,5,5">
        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Grid.Column="1"
                  Margin="5,2,0,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="13"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <dx:SimpleButton Margin="5,0,0,0"
                                     HorizontalAlignment="Right"
                                     dxb:BarManager.MenuShowMouseButton="LeftButton"
                                     Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                                     GlyphHeight="20">
                        <dxb:BarManager.DXContextMenu>
                            <dxb:PopupControlContainer>
                                <ItemsControl>
                                    <StackPanel>
                                        <MenuItem Height="25"
                                                  Command="{Binding CloneCommand}"
                                                  Header="Clone">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Click="ShareLayout"
                                                  Header="Share Layout">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Click="SaveLayout"
                                                  Header="Save Layout">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding BrowseLayoutsCommand}"
                                                  Header="Browse Layout">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Click="LoadLayout"
                                                  Header="Load Layout">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <dx:SuperTipItemControlSeparator />
                                    </StackPanel>
                                </ItemsControl>
                            </dxb:PopupControlContainer>
                        </dxb:BarManager.DXContextMenu>
                    </dx:SimpleButton>
                </StackPanel>

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,0,0"
                       Content="Account:" />
                <dxe:ComboBoxEdit Grid.Row="0"
                                  Grid.Column="1"
                                  Width="100"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  Background="#171718"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding PortfolioManagerModel.Accounts}"
                                  SelectedItem="{Binding PortfolioManagerModel.Account}" />

                <Label Grid.Row="0"
                       Grid.Column="2"
                       Margin="5,0,0,0"
                       Content="Trader:" />
                <dxe:ComboBoxEdit Grid.Row="0"
                                  Grid.Column="3"
                                  Width="100"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  Background="#171718"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding PortfolioManagerModel.Users}"
                                  SelectedItem="{Binding PortfolioManagerModel.SelectedUser}" />

                <Label Grid.Row="0"
                       Grid.Column="5"
                       Width="65"
                       Margin="5,0,0,0"
                       VerticalAlignment="Bottom"
                       Content="Order Type:" />

                <dxe:ComboBoxEdit Grid.Row="0"
                                  Grid.Column="6"
                                  Width="100"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Bottom"
                                  Background="#171718"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding OrderTypes}"
                                  SelectedItem="{Binding PortfolioManagerModel.OrderType}" />

                <Label Grid.Row="0"
                       Grid.Column="7"
                       Width="80"
                       Margin="5,0,0,0"
                       VerticalAlignment="Bottom"
                       Content="Limit Handling:" />

                <dxe:ComboBoxEdit Grid.Row="0"
                                  Grid.Column="8"
                                  Width="100"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Bottom"
                                  ApplyItemTemplateToSelectedItem="True"
                                  Background="#171718"
                                  IsEnabled="{Binding PortfolioManagerModel.OrderType, Converter={StaticResource OrderTypeToLimitHandlingStateEnabledConverter}}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding LimitHandlingOptions}"
                                  SelectedItem="{Binding PortfolioManagerModel.LimitHandling}">
                    <dxe:ComboBoxEdit.ItemTemplate>
                        <DataTemplate>
                            <Label Padding="0,0.5"
                                   Content="{Binding Converter={StaticResource EnumToDisplayTextConverter}}" />
                        </DataTemplate>
                    </dxe:ComboBoxEdit.ItemTemplate>
                </dxe:ComboBoxEdit>

                <dxe:CheckEdit Grid.Row="0"
                               Grid.Column="9"
                               Margin="5,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               Content="Round Deltas"
                               EditValue="{Binding PortfolioManagerModel.RoundDeltaForHedge}" />

                <dx:SimpleButton Grid.Row="0"
                                 Grid.Column="10"
                                 Width="100"
                                 Height="22"
                                 Margin="5,0,0,0"
                                 Padding="0"
                                 VerticalAlignment="Bottom"
                                 VerticalContentAlignment="Center"
                                 Command="{Binding StartStopCommand}"
                                 Content="{Binding PortfolioManagerModel.IsHedging, Converter={StaticResource BooleanToButtonTextConverter}}" />

                <dx:DropDownButton Grid.Row="0"
                                   Grid.Column="12"
                                   Width="115"
                                   Margin="5,0,0,0"
                                   Padding="3,1,7,1"
                                   HorizontalAlignment="Right"
                                   Content="Settings"
                                   Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Settings.svg}"
                                   GlyphHeight="15">
                    <StackPanel Orientation="Vertical">
                        <dx:SimpleButton Click="ClearFiltersClick"
                                         Content="Clear Filters" />
                        <dx:SimpleButton Click="ClearSortingClick"
                                         Content="Clear Sorting" />
                        <dx:SimpleButton Command="{Binding AddColumnCommand}"
                                         Content="Add Column"
                                         Glyph="{dx:DXImage SvgImages/Outlook Inspired/AddColumn.svg}"
                                         GlyphHeight="15" />

                    </StackPanel>
                </dx:DropDownButton>
            </Grid>

            <Slider x:Name="DeltaHedgingGridScale"
                    Grid.Row="1"
                    Maximum="4"
                    Minimum="0.1"
                    Visibility="Hidden"
                    Value="1" />

            <dxg:GridControl x:Name="DeltaHedgingGrid"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,3,0,0"
                             dx:DXSerializer.StoreLayoutMode="All"
                             dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                             AutoGenerateColumns="AddNew"
                             AutoGeneratedColumns="Grid_ColumnsPopulated"
                             CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                             EnableSmartColumnsGeneration="True"
                             ItemsSource="{Binding PortfolioManagerModel.UserPositions}"
                             PreviewMouseWheel="OnZoomMouseWheel"
                             RestoreStateOnSourceChange="True"
                             SelectionMode="Row">
                <dxg:GridControl.LayoutTransform>
                    <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=DeltaHedgingGridScale, Path=Value}" ScaleY="{Binding ElementName=DeltaHedgingGridScale, Path=Value}" />
                </dxg:GridControl.LayoutTransform>
                <dxg:GridControl.Resources>
                    <Style TargetType="dxg:GridColumn">
                        <Setter Property="Visible" Value="False" />
                        <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                    </Style>
                    <ControlTemplate x:Key="{dxgt:GridColumnHeaderThemeKey ResourceKey=ColumnFilterTemplate}"
                                     TargetType="{x:Type ToggleButton}" />
                </dxg:GridControl.Resources>
                <dxmvvm:Interaction.Behaviors>
                    <services:UiUpdateService />
                </dxmvvm:Interaction.Behaviors>
                <dxg:GridControl.View>
                    <dxg:TableView AllowEditing="False"
                                   AutoWidth="True"
                                   EnableSelectedRowAppearance="True"
                                   GroupSummaryDisplayMode="AlignByColumns"
                                   NavigationStyle="Row"
                                   RowStyle="{StaticResource PositionsRowStyle}"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   ShowTotalSummary="False"
                                   VerticalScrollbarVisibility="Auto">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="{Binding AddCommand}"
                                          Header="Add Underlying" />
                                <MenuItem Command="{Binding ActivateAllCommand}"
                                          Header="Check All" />
                                <MenuItem Command="{Binding DeactivateAllCommand}"
                                          Header="Uncheck All" />
                                <MenuItem Height="25"
                                          Command="{Binding ShowColumnChooserCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Column Chooser">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ClearColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Hide All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowAllColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowDefaultColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Default Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                        <dxg:TableView.RowCellMenuCustomizations>
                            <dxb:BarButtonItem Command="{Binding View.DataContext.AddCommand}"
                                               Content="Add Underlying" />
                            <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInPositionManagerCommand}"
                                               CommandParameter="{Binding Path=SelectedItem, ElementName=DeltaHedgingGrid}"
                                               Content="Open in Position Manager" />
                            <dxb:BarItemSeparator />
                            <dxb:BarButtonItem Command="{Binding View.DataContext.ActivateAllCommand}"
                                               Content="Check All" />
                            <dxb:BarButtonItem Command="{Binding View.DataContext.DeactivateAllCommand}"
                                               Content="Uncheck All" />
                        </dxg:TableView.RowCellMenuCustomizations>
                        <dxg:TableView.TotalSummaryContentStyle>
                            <Style TargetType="dx:DataContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                            </Style>
                        </dxg:TableView.TotalSummaryContentStyle>
                        <dxg:TableView.TotalSummaryItemTemplate>
                            <DataTemplate>
                                <TextBlock Padding="2"
                                           Foreground="{Binding Column.TotalSummaryText, Converter={StaticResource SignToBrushConverter}}"
                                           Text="{Binding Column.TotalSummaryText, StringFormat='{}{0:C0}'}" />
                            </DataTemplate>
                        </dxg:TableView.TotalSummaryItemTemplate>
                        <dxg:TableView.GroupColumnSummaryItemTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Right"
                                           Foreground="{Binding Value, Converter={StaticResource SignToBrushConverter}}"
                                           Text="{Binding Value}" />
                            </DataTemplate>
                        </dxg:TableView.GroupColumnSummaryItemTemplate>
                        <dxg:TableView.GroupValueTemplate>
                            <DataTemplate>
                                <TextBlock Margin="10,0,0,0"
                                           Text="{Binding Value}" />
                            </DataTemplate>
                        </dxg:TableView.GroupValueTemplate>
                    </dxg:TableView>
                </dxg:GridControl.View>

                <dxg:GridColumn Width="50"
                                FieldName="Active"
                                FilterPopupMode="Disabled"
                                IsSmart="True"
                                Visible="True">
                    <dxg:GridColumn.HeaderTemplate>
                        <DataTemplate>
                            <dxe:CheckEdit HorizontalAlignment="Center"
                                           Background="Transparent"
                                           BorderBrush="#CCCCCC">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding ElementName=DeltaHedgingGrid, Path=DataContext.ActivateAllCommand}"
                                                           EventName="Checked" />
                                    <dxmvvm:EventToCommand Command="{Binding ElementName=DeltaHedgingGrid, Path=DataContext.DeactivateAllCommand}"
                                                           EventName="Unchecked" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:CheckEdit>
                        </DataTemplate>
                    </dxg:GridColumn.HeaderTemplate>
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxe:CheckEdit HorizontalAlignment="Center"
                                           Background="Transparent"
                                           BorderBrush="#CCCCCC"
                                           EditValue="{Binding RowData.Row.Active}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Symbol"
                                Header="Underlying"
                                IsSmart="True"
                                Visible="True" />
                <dxg:GridColumn FieldName="Last"
                                IsSmart="True"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{Binding RowData.Row.NetChange, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding RowData.Row.Last, Converter={StaticResource DoubleFormatter}}"
                                       TextAlignment="Right" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="NetChange"
                                IsSmart="True"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{Binding RowData.Row.NetChange, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding RowData.Row.NetChange, Converter={StaticResource DoubleFormatter}}"
                                       TextAlignment="Right" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="NetPosition"
                                IsSmart="True"
                                Visible="True" />
                <dxg:GridColumn FieldName="NetDelta"
                                IsSmart="True"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{Binding RowData.Row.NetDelta, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding RowData.Row.NetDelta, Converter={StaticResource DoubleFormatter}}"
                                       TextAlignment="Right" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="HedgeQty"
                                Header="Hedge #"
                                IsSmart="True"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxe:TextEdit Name="PART_Editor"
                                          HorizontalContentAlignment="Right"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          Foreground="{Binding RowData.Row.HedgeQty, Converter={StaticResource SignToBrushConverter}}"
                                          IsReadOnly="True" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn AllowCellMerge="False"
                                FieldName="OrderStatus"
                                Header="Order Status"
                                IsSmart="True"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,2,0"
                                       Padding="2,4,0,0"
                                       VerticalAlignment="Center"
                                       Background="{Binding RowData.Row.StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                                       Foreground="{Binding RowData.Row.StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                                       Text="{Binding RowData.Row.Status}"
                                       TextAlignment="Center" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="FilledQty"
                                Header="Filled #"
                                IsSmart="True"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxe:TextEdit Name="PART_Editor"
                                          HorizontalContentAlignment="Right"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          DisplayFormatString="#0;-#0;-"
                                          Foreground="{Binding RowData.Row.FilledQty, Converter={StaticResource SignToBrushConverter}}"
                                          IsReadOnly="True" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="WorkingQty"
                                Header="Working #"
                                IsSmart="True"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxe:TextEdit Name="PART_Editor"
                                          HorizontalContentAlignment="Right"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          DisplayFormatString="#0;-#0;-"
                                          Foreground="{Binding RowData.Row.WorkingQty, Converter={StaticResource SignToBrushConverter}}"
                                          IsReadOnly="True" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn AllowCellMerge="False"
                                FieldName="Percent"
                                IsSmart="True"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxe:SpinEdit VerticalAlignment="Center"
                                          AllowSpinOnMouseWheel="True"
                                          AllowUpdateTwoWayBoundPropertiesOnSynchronization="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          EditValue="{Binding RowData.Row.HedgePercent, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment=".01"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          MaxValue="1"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn AllowCellMerge="False"
                                FieldName="Route"
                                Header="Route"
                                IsSmart="True"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <controls:RoutePicker VerticalAlignment="Center"
                                                  AllowUpdateTwoWayBoundPropertiesOnSynchronization="False"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  DmaRoutesList="{Binding View.DataContext.PortfolioManagerModel.DmaRoutesList}"
                                                  ItemsSource="{Binding View.DataContext.PortfolioManagerModel.RoutesList}"
                                                  SelectedItem="{Binding RowData.Row.Route}"
                                                  SorRoutesList="{Binding View.DataContext.PortfolioManagerModel.SorRoutesList}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn AllowSorting="False"
                                FieldName="CancelOrder"
                                IsSmart="False"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dx:SimpleButton BorderThickness="0"
                                             Command="{Binding RowData.Row.CancelAsyncCommand}"
                                             Content="Cancel"
                                             Foreground="#FFFFFF"
                                             IsEnabled="{Binding RowData.Row.IsCancelEnabled}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>

                <dxg:GridColumn AllowSorting="False"
                                FieldName="SendOrder"
                                IsSmart="False"
                                Visible="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dx:SimpleButton BorderThickness="0"
                                             Command="{Binding RowData.Row.SubmitAsyncCommand}"
                                             Content="Send"
                                             Foreground="#02F302"
                                             IsEnabled="{Binding RowData.Row.IsSubmitEnabled}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>

                <dxg:GridControl.DetailDescriptor>
                    <dxg:DataControlDetailDescriptor ItemsSourceBinding="{Binding Positions}">
                        <dxg:DataControlDetailDescriptor.DataControl>
                            <dxg:GridControl Name="DetailsGrid"
                                             AutoGenerateColumns="None"
                                             CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                                             EnableSmartColumnsGeneration="True"
                                             SelectionMode="Row">
                                <dxg:GridControl.Resources>
                                    <dxe:TextEditSettings x:Key="numeric"
                                                          Mask="##0.00"
                                                          MaskType="Numeric"
                                                          MaskUseAsDisplayFormat="True" />
                                    <Style TargetType="dxg:GridColumn">
                                        <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                                    </Style>
                                </dxg:GridControl.Resources>

                                <dxg:GridControl.View>
                                    <dxg:TableView AutoWidth="True"
                                                   FadeSelectionOnLostFocus="False"
                                                   RowStyle="{StaticResource PositionsRowStyle}"
                                                   ShowGroupPanel="False"
                                                   ShowIndicator="True"
                                                   VerticalScrollbarVisibility="Auto">
                                        <dxg:TableView.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Height="25"
                                                          Command="{Binding ShowColumnChooserCommand}"
                                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Header="Show Column Chooser">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Command="{Binding ClearColumnsCommand}"
                                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Header="Hide All Columns">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Command="{Binding ShowAllColumnsCommand}"
                                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Header="Show All Columns">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Command="{Binding ShowDefaultColumnsCommand}"
                                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Header="Show Default Columns">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </dxg:TableView.ContextMenu>
                                        <dxg:TableView.RowCellMenuCustomizations>
                                            <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInPositionManagerCommand}"
                                                               CommandParameter="{Binding Path=SelectedItem, ElementName=DetailsGrid}"
                                                               Content="Open in Position Manager" />
                                            <dxb:BarButtonItem Command="{Binding View.DataContext.DeletePositionCommand}"
                                                               CommandParameter="{Binding Path=SelectedItem, ElementName=DetailsGrid}"
                                                               Content="Delete Position" />
                                            <dxb:BarItemSeparator />
                                            <dxb:BarButtonItem Command="{Binding View.DataContext.ActivateAllCommand}"
                                                               Content="Check All" />
                                            <dxb:BarButtonItem Command="{Binding View.DataContext.DeactivateAllCommand}"
                                                               Content="Uncheck All" />
                                        </dxg:TableView.RowCellMenuCustomizations>
                                    </dxg:TableView>
                                </dxg:GridControl.View>

                                <dxg:GridColumn Width="50"
                                                FieldName="Active"
                                                Header=""
                                                IsSmart="True"
                                                Visible="True">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <dxe:CheckEdit HorizontalAlignment="Center"
                                                           Background="Transparent"
                                                           BorderBrush="#CCCCCC"
                                                           EditValue="{Binding RowData.Row.Active}" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>

                                <dxg:GridColumn Binding="{Binding Position.Name}"
                                                FieldName="Symbol"
                                                IsSmart="True"
                                                Visible="True" />

                                <dxg:GridColumn Binding="{Binding Position.ActualQty}"
                                                FieldName="Qty"
                                                IsSmart="True"
                                                Visible="True">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{Binding RowData.Row.Position.ActualQty, Converter={StaticResource SignToBrushConverter}}"
                                                       Text="{Binding RowData.Row.Position.ActualQty, Converter={StaticResource DoubleFormatter}}"
                                                       TextAlignment="Right" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>

                                <dxg:GridColumn FieldName="Delta"
                                                IsSmart="True"
                                                Visible="True">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{Binding RowData.Row.Delta, Converter={StaticResource SignToBrushConverter}}"
                                                       Text="{Binding RowData.Row.Delta, Converter={StaticResource DoubleFormatter}}"
                                                       TextAlignment="Right" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>

                                <dxg:GridColumn FieldName="NetDelta"
                                                IsSmart="True"
                                                Visible="True">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{Binding RowData.Row.NetDelta, Converter={StaticResource SignToBrushConverter}}"
                                                       Text="{Binding RowData.Row.NetDelta, Converter={StaticResource DoubleFormatter}}"
                                                       TextAlignment="Right" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>

                                <dxg:GridColumn FieldName="PostExDelta"
                                                Header="Post-Ex Delta"
                                                IsSmart="True"
                                                Visible="True">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{Binding RowData.Row.PostExDelta, Converter={StaticResource SignToBrushConverter}}"
                                                       Text="{Binding RowData.Row.PostExDelta, Converter={StaticResource DoubleFormatter}}"
                                                       TextAlignment="Right" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>

                                <dxg:GridColumn Binding="{Binding Position.OpenPositionAveragePrice}"
                                                FieldName="PriceAvg"
                                                IsSmart="True"
                                                Visible="True" />

                                <dxg:GridColumn Binding="{Binding Position.RealizedPnl}"
                                                FieldName="Pnl"
                                                Header="PnL"
                                                IsSmart="True"
                                                Visible="True">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{Binding RowData.Row.Position.RealizedPnl, Converter={StaticResource SignToBrushConverter}}"
                                                       Text="{Binding RowData.Row.Position.RealizedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                                       TextAlignment="Right" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl>
                        </dxg:DataControlDetailDescriptor.DataControl>
                    </dxg:DataControlDetailDescriptor>
                </dxg:GridControl.DetailDescriptor>

                <dxg:GridControl.GroupSummary />
            </dxg:GridControl>
        </Grid>
    </Border>
</dx:ThemedWindow>
