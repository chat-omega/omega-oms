<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.LoadDomListView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 Title="Load Dom List"
                 Width="1200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 WindowStartupLocation="CenterScreen">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
        <dxmvvm:DispatcherService />
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <dxg:GridControl Grid.Row="2"
                         Grid.Column="1"
                         AutoGenerateColumns="AddNew"
                         CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                         ItemsSource="{Binding Lists}"
                         SelectedItem="{Binding SelectedList}"
                         SelectionMode="Row">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                    <Setter Property="Visible" Value="False" />
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False"
                               AutoWidth="True"
                               NavigationStyle="Row"
                               ShowGroupPanel="False"
                               ShowTotalSummary="True">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="Product"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn FieldName="ProductPrice"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn FieldName="Type"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn FieldName="Creator"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn FieldName="Count"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn FieldName="DateMade"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn FieldName="AdditionalSpecs"
                            IsSmart="True"
                            Visible="True" />

            <dxg:GridColumn FieldName="FileName"
                            IsSmart="True"
                            Visible="True" />

        </dxg:GridControl>

        <dx:WaitIndicator Grid.Row="2"
                          Grid.Column="1"
                          Content="Loading"
                          DeferedVisibility="{Binding IsBusy}"
                          IsTabStop="False" />

        <StackPanel Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding LoadCommand}"
                             Content="Load"
                             Glyph="{dx:DXImage SvgImages/Dashboards/ImageLoad.svg}"
                             GlyphHeight="15"
                             IsDefault="True" />

            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel" />
        </StackPanel>

    </Grid>
</dx:ThemedWindow>
