<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.LoopSizeupView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Dynamic Sizeup Config - Editor"
                 Width="1200"
                 Height="500"
                 MinWidth="600"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:LoopSizeupViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:LoopSizeupViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dx:ThemedWindow.Resources>
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
    </dx:ThemedWindow.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0"
                   Margin="5,0,0,0"
                   Content="Title" />

            <dxe:TextEdit Grid.Column="1"
                          Margin="5,0,0,0"
                          Text="{Binding Model.Title}" />

            <dx:SimpleButton Grid.Column="2"
                             Width="115"
                             Margin="5,0,0,0"
                             Command="{Binding SaveCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Outlook Inspired/Save.svg}"
                             GlyphHeight="15" />

            <dx:SimpleButton Grid.Column="3"
                             Width="120"
                             Margin="5,0,0,0"
                             Command="{Binding SaveAndLoadCommand}"
                             Content="Save And Load"
                             Glyph="{dx:DXImage SvgImages/RichEdit/SelectTableRow.svg}"
                             GlyphHeight="15" />
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="5">
            <dxe:CheckEdit Content="Match filled size after Partial Fill"
                           EditValue="{Binding Model.MatchFilledSizeAfterPartialFill}" />
        </StackPanel>

        <dxg:GridControl Grid.Row="2"
                         Margin="0,2,0,0"
                         AllowCollectionView="False"
                         ItemsSource="{Binding Model.SizeUpConfigs}">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="True" />
                    <Setter Property="IsSmart" Value="True" />
                    <Setter Property="ReadOnly" Value="False" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
                <Style TargetType="dxg:GridControlBand">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="True"
                               AllowGrouping="False"
                               AutoWidth="True"
                               BandSeparatorWidth="1"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridControl.Bands>
                <dxg:GridControlBand>

                    <dxg:GridColumn Width="20"
                                    MinWidth="20"
                                    MaxWidth="20"
                                    FieldName="Enabled"
                                    Header=""
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:CheckEdit HorizontalAlignment="Center"
                                               Background="Transparent"
                                               EditValue="{Binding RowData.Row.Enabled}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="Edge"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.Edge, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N3"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="Size"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.Size, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="D0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="AdditionalEdgePerContract"
                                    Header="+ Per Contract"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.AdditionalEdgePerContract, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N3"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="MaxAbsDelta"
                                    Header="Max Delta"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.MaxAbsDelta, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N2"
                                              MaskUseAsDisplayFormat="True"
                                              MaxValue="1"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="MaxUnderWidth"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.MaxUnderWidth, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N2"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="MinIncrement"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <dxe:CheckEdit Margin="2,0"
                                                   HorizontalAlignment="Center"
                                                   Background="Transparent"
                                                   EditValue="{Binding RowData.Row.MinIncrementEnabled}" />
                                    <dxe:SpinEdit HorizontalContentAlignment="Right"
                                                  AllowSpinOnMouseWheel="True"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"
                                                  BorderThickness="0"
                                                  EditValue="{Binding RowData.Row.MinIncrement, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Double}"
                                                  Increment="0.01"
                                                  IsEnabled="{Binding RowData.Row.MinIncrementEnabled}"
                                                  Mask="N2"
                                                  MaskUseAsDisplayFormat="True"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True" />
                                </DockPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="MinEdgeToEma"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <dxe:CheckEdit Margin="2,0"
                                                   HorizontalAlignment="Center"
                                                   Background="Transparent"
                                                   EditValue="{Binding RowData.Row.MinEdgeToEmaEnabled}" />
                                    <dxe:SpinEdit HorizontalContentAlignment="Right"
                                                  AllowSpinOnMouseWheel="True"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"
                                                  BorderThickness="0"
                                                  EditValue="{Binding RowData.Row.MinEdgeToEma, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Double}"
                                                  Increment="0.01"
                                                  IsEnabled="{Binding RowData.Row.MinEdgeToEmaEnabled}"
                                                  Mask="N2"
                                                  MaskUseAsDisplayFormat="True"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True" />
                                </DockPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="MaxEmaBidPercent"
                                    Header="Max Ema-Bid %"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <dxe:CheckEdit Margin="2,0"
                                                   HorizontalAlignment="Center"
                                                   Background="Transparent"
                                                   EditValue="{Binding RowData.Row.MaxEmaBidPercentEnabled}" />
                                    <dxe:SpinEdit HorizontalContentAlignment="Right"
                                                  AllowSpinOnMouseWheel="True"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"
                                                  BorderThickness="0"
                                                  EditValue="{Binding RowData.Row.MaxEmaBidPercent, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Double}"
                                                  Increment="0.01"
                                                  IsEnabled="{Binding RowData.Row.MaxEmaBidPercentEnabled}"
                                                  Mask="N2"
                                                  MaskUseAsDisplayFormat="True"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True" />
                                </DockPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="MinEmaWidthPercentEdgeToTheoCheckEnabled"
                                    Header="Width % E2T"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True"
                                    ToolTip="Ema Width %, Edge To Theo">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <dxe:CheckEdit Margin="2,0"
                                                   HorizontalAlignment="Center"
                                                   Background="Transparent"
                                                   EditValue="{Binding RowData.Row.MinEmaWidthPercentEdgeToTheoCheckEnabled}" />
                                    <dxe:SpinEdit HorizontalContentAlignment="Right"
                                                  AllowSpinOnMouseWheel="True"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"
                                                  BorderThickness="0"
                                                  EditValue="{Binding RowData.Row.MinEmaWidthPercentEdgeToTheoCheckEdge, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Double}"
                                                  Increment="0.01"
                                                  IsEnabled="{Binding RowData.Row.MinEmaWidthPercentEdgeToTheoCheckEnabled}"
                                                  Mask="N2"
                                                  MaskUseAsDisplayFormat="True"
                                                  MinValue="0"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True" />
                                </DockPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="ResubmitSizeOption"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:ComboBoxEdit Margin="-1"
                                                  ApplyItemTemplateToSelectedItem="True"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  EditValue="{Binding RowData.Row.ResubmitSizeOption}"
                                                  IsTextEditable="False"
                                                  ItemsSource="{Binding View.DataContext.ResubmitSizeOptions}">
                                    <dxe:ComboBoxEdit.ItemTemplate>
                                        <DataTemplate>
                                            <Label Padding="0,1"
                                                   HorizontalAlignment="Center"
                                                   Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}" />
                                        </DataTemplate>
                                    </dxe:ComboBoxEdit.ItemTemplate>
                                </dxe:ComboBoxEdit>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header="Size Scale">
                    <dxg:GridColumn FieldName="SizeScaleEnabled"
                                    Header="Enabled"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:CheckEdit Margin="2,0"
                                               HorizontalAlignment="Center"
                                               Background="Transparent"
                                               EditValue="{Binding RowData.Row.SizeScaleEnabled}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="SizeScaleUnderMin"
                                    Header="Under Min"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.SizeScaleUnderMin, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="1"
                                              IsEnabled="{Binding RowData.Row.SizeScaleEnabled}"
                                              Mask="N2"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="SizeScaleUnderMax"
                                    Header="Under Max"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.SizeScaleUnderMax, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="1"
                                              IsEnabled="{Binding RowData.Row.SizeScaleEnabled}"
                                              Mask="N2"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="SizeScaleFactor"
                                    Header="Scale Factor"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.SizeScaleFactor, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="1"
                                              IsEnabled="{Binding RowData.Row.SizeScaleEnabled}"
                                              Mask="N2"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="SizeScaleMax"
                                    Header="Max Size"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.SizeScaleMax, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              IsEnabled="{Binding RowData.Row.SizeScaleEnabled}"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MaxValue="150"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                </dxg:GridControlBand>

                <dxg:GridControlBand Header="Unhedgeable Equities">
                    <dxg:GridColumn FieldName="UnhedgeableEquityCheckEnabled"
                                    Header="Enabled"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:CheckEdit Margin="2,0"
                                               HorizontalAlignment="Center"
                                               Background="Transparent"
                                               EditValue="{Binding RowData.Row.UnhedgeableEquityCheckEnabled}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="UnhedgeableEquitySizePercentage"
                                    Header="Size %"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.UnhedgeableEquitySizePercentage, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment=".01"
                                              Mask="N2"
                                              MaskUseAsDisplayFormat="True"
                                              MaxValue="1"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="UnhedgeableEquityMaxSize"
                                    Header="Max Size"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.UnhedgeableEquityMaxSize, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MaxValue="150"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                </dxg:GridControlBand>

                <dxg:GridControlBand>
                    <dxg:GridColumn FieldName="RequiredLoop"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.RequiredLoop, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="D0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="ResubmitCount"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.ResubmitCount, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="D0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="MatchSignalQtyLimit"
                                    Header="Match Qty Limit"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.MatchSignalQtyLimit, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="D0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="20"
                                    FieldName="Remove"
                                    Header=""
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton BorderBrush="Transparent"
                                                 BorderThickness="0"
                                                 Command="{Binding View.DataContext.RemoveCommand}"
                                                 CommandParameter="{Binding RowData.Row}"
                                                 Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                 GlyphWidth="19" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                </dxg:GridControlBand>
            </dxg:GridControl.Bands>
        </dxg:GridControl>

        <StackPanel Grid.Row="3"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Margin="5,0"
                             Command="{Binding AddCommand}"
                             Content="Add"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                             GlyphHeight="15" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
