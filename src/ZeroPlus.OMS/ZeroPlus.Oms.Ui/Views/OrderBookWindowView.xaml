<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.OrderBookWindowView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:local="clr-namespace:ZeroPlus.Oms.Ui.Views"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="{Binding ModuleTitle}"
                 Width="1200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 DataContext="{startuphelpers:DISource Type=ViewModels:OrderBookViewModel}"
                 WindowStartupLocation="CenterScreen">

    <Grid>
        <local:OrderBookView x:Name="OrderBookView"
                             DataContext="{Binding}" />
    </Grid>
</dx:ThemedWindow>
