<UserControl x:Class="ZeroPlus.Oms.Ui.Views.NotificationItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
             Width="320"
             Height="80"
             d:DataContext="{d:DesignInstance Type=ViewModels:NotificationItemViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <helper:NotificationTypeToColorConverter x:Key="NotificationTypeToColorConverter" />
            <helper:NotificationTypeToIconConverter x:Key="NotificationTypeToIconConverter">
                <helper:NotificationTypeToIconConverter.ResourceDictionary>
                    <ResourceDictionary Source="./NotificationIconsDictionary.xaml" />
                </helper:NotificationTypeToIconConverter.ResourceDictionary>
            </helper:NotificationTypeToIconConverter>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{Binding Notification.Type, Converter={StaticResource NotificationTypeToColorConverter}, ConverterParameter='BG'}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Rectangle Grid.Row="0"
                   Grid.RowSpan="3"
                   Grid.Column="0"
                   Width="5"
                   Fill="{Binding Notification.Type, Converter={StaticResource NotificationTypeToColorConverter}}" />

        <Rectangle Grid.Row="0"
                   Grid.RowSpan="3"
                   Grid.Column="1"
                   Width="25"
                   Height="25"
                   Margin="5,0,10,0"
                   Fill="{Binding Notification.Type, Converter={StaticResource NotificationTypeToIconConverter}}" />

        <TextBlock Grid.Row="0"
                   Grid.RowSpan="2"
                   Grid.Column="2"
                   Margin="0,5,0,0"
                   Foreground="{Binding Notification.Type, Converter={StaticResource NotificationTypeToColorConverter}}"
                   Text="{Binding Notification.Text}"
                   TextWrapping="Wrap" />

        <dx:SimpleButton Grid.Row="0"
                         Grid.Column="3"
                         Width="15"
                         Height="15"
                         Margin="10,5"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Background="Transparent"
                         BorderThickness="0"
                         Command="{Binding RemoveNotificationCommand}"
                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}" />

        <TextBlock Grid.Row="2"
                   Grid.Column="2"
                   FontSize="10"
                   Foreground="{Binding Notification.Type, Converter={StaticResource NotificationTypeToColorConverter}}"
                   Text="{Binding Notification.Time, StringFormat={}{0:T}}" />

        <TextBlock Grid.Row="2"
                   Grid.Column="3"
                   FontSize="10"
                   Foreground="{Binding Notification.Type, Converter={StaticResource NotificationTypeToColorConverter}}"
                   Text="{Binding Notification.Account}" />

        <Rectangle Grid.Row="4"
                   Grid.Column="0"
                   Grid.ColumnSpan="4"
                   Height="1"
                   Fill="{Binding Notification.Type, Converter={StaticResource NotificationTypeToColorConverter}}" />
    </Grid>
</UserControl>
