<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.BasketBlockListConfigView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="Block List Config"
                 Width="850"
                 Height="250"
                 d:DataContext="{d:DesignInstance Type=ViewModels:BasketBlockListConfigViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:BasketBlockListConfigViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">
    <Grid Grid.Row="0"
          Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <dxe:ComboBoxEdit Grid.Row="0"
                          Grid.Column="1"
                          Margin="0,2"
                          DisplayMember="Title"
                          EditValue="{Binding Model}"
                          IsTextEditable="False"
                          ItemsSource="{Binding List}" />
        <DockPanel Grid.Row="1"
                   Margin="0,2">
            <Label Content="Title" />
            <dxe:TextEdit Margin="5,0,0,0"
                          EditValue="{Binding Model.Title, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>
        <dxg:GridControl Grid.Row="2"
                         AllowCollectionView="False"
                         AllowInitiallyFocusedRow="False"
                         ItemsSource="{Binding Model.BlockedSymbols}">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="SymbolsLookupsView"
                               AllowEditing="False"
                               AllowGrouping="False"
                               AllowSorting="False"
                               AutoWidth="True"
                               ShowGroupPanel="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn AllowEditing="True"
                            FieldName="Symbol"
                            Header="Symbol"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellEditTemplate>
                    <DataTemplate>
                        <dxe:TextEdit VerticalAlignment="Center"
                                      BorderBrush="#333337"
                                      BorderThickness="0"
                                      CharacterCasing="Upper"
                                      Text="{Binding RowData.Row.Symbol}" />
                    </DataTemplate>
                </dxg:GridColumn.CellEditTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Width="20"
                            FieldName="Edit"
                            Header=""
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Height="20"
                                         Padding="0"
                                         BorderThickness="0"
                                         Command="{Binding View.DataContext.RemoveSymbolCommand}"
                                         CommandParameter="{Binding RowData.Row}"
                                         Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Delete.svg}"
                                         GlyphWidth="15" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

        </dxg:GridControl>
        <StackPanel Grid.Row="3"
                    Margin="0,3"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="3,1"
                             Command="{Binding AddSymbolCommand}"
                             Content="Add"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                             GlyphHeight="15" />

            <dx:SimpleButton Width="80"
                             Margin="3,1"
                             Click="Close"
                             Command="{Binding DeleteSymbolCommand}"
                             Content="Delete"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Delete.svg}"
                             GlyphHeight="15" />

            <dx:SimpleButton Width="80"
                             Margin="3,1"
                             Click="Close"
                             Command="{Binding SaveSymbolCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Save/Save.svg}"
                             GlyphHeight="15" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
