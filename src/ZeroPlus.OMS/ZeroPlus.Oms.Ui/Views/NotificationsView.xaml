<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.NotificationsView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                 Width="300"
                 Height="250"
                 AllowsTransparency="True"
                 DataContext="{startuphelpers:DISource Type=ViewModels:NotificationsViewModel}"
                 Focusable="False"
                 Opacity="0.9"
                 ResizeMode="NoResize"
                 ShowActivated="False"
                 ShowInTaskbar="True"
                 SizeToContent="WidthAndHeight"
                 WindowStyle="None">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Window.Visibility>
        <Binding Converter="{StaticResource BooleanToVisibilityConverter}"
                 Mode="TwoWay"
                 Path="IsVisible" />
    </Window.Visibility>

    <Grid>
        <ItemsControl Grid.Row="0"
                      Grid.Column="0"
                      ItemsSource="{Binding Notifications}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <views:NotificationItemView />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</dx:ThemedWindow>
