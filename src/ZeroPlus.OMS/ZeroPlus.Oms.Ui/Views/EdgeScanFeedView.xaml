                        </ScrollViewer>
                    </dxlc:GroupBox>
                </Grid>

                <Slider x:Name="FeedGridScale"
                        Grid.Row="3"
                        Grid.Column="0"
                        Maximum="4"
                        Minimum="0.1"
                        Visibility="Hidden"
                        Value="1" />

                <Slider x:Name="FeedLogGridScale"
                        Grid.Row="3"
                        Grid.Column="0"
                        Maximum="4"
                        Minimum="0.1"
                        Visibility="Hidden"
                        Value="1" />

                <dxg:GridControl Name="FeedGrid"
                                 Grid.Row="3"
                                 Grid.Column="1"
                                 MaxHeight="3500"
                                 Margin="0,2,0,0"
                                 dx:DXSerializer.StoreLayoutMode="All"
                                 dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                                 AutoGenerateColumns="AddNew"
                                 AutoGeneratedColumns="Grid_ColumnsPopulated"
                                 CurrentItem="{Binding LatestEdgeScanFeed}"
                                 CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                                 EnableSmartColumnsGeneration="True"
                                 FilterString="{Binding FilterString, Mode=TwoWay}"
                                 ItemsSource="{Binding Trades}"
                                 PreviewMouseWheel="OnZoomMouseWheel"
                                 SelectionMode="Row"
                                 Visibility="{Binding EnableLogMode, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                    <dxg:GridControl.LayoutTransform>
                        <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=FeedGridScale, Path=Value}" ScaleY="{Binding ElementName=FeedGridScale, Path=Value}" />
                    </dxg:GridControl.LayoutTransform>
                    <dxg:GridControl.Resources>
                        <Style TargetType="dxg:GridColumn">
                            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                            <Setter Property="Visible" Value="False" />
                        </Style>
                        <Style TargetType="{x:Type dxg:TableView}">
                            <Setter Property="AllowGrouping" Value="True" />
                            <Setter Property="ColumnHeaderTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextAlignment="Center"
                                                   TextWrapping="{Binding ElementName=FeedGrid, Path=View.DataContext.HeaderTextWrapping}" />
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </dxg:GridControl.Resources>
                    <dxmvvm:Interaction.Behaviors>
                        <services:UiUpdateService />
                    </dxmvvm:Interaction.Behaviors>
                    <dxg:GridControl.View>
                        <dxg:TableView Name="TradesTableView"
                                       AllowDragDrop="True"
                                       AllowEditing="False"
                                       AutoWidth="True"
                                       CompleteRecordDragDrop="OnCompleteRecordDragDrop"
                                       DragRecordOver="TableView_DragRecordOver"
                                       EditorShowMode="MouseUp"
                                       EnableSelectedRowAppearance="True"
                                       NavigationStyle="Row"
                                       RowDoubleClickCommand="{Binding RowDoubleClickCommand}"
                                       RowStyle="{StaticResource OrderStyle}"
                                       ShowGridMenu="TableView_ShowGridMenu"
                                       ShowGroupPanel="False"
                                       StartRecordDrag="OnStartRecordDrag"
                                       VerticalScrollbarVisibility="Auto">
                            <dxg:TableView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowColumnChooserCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Column Chooser">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ClearColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Hide All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowAllColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                            <dxg:TableView.RowCellMenuCustomizations>
                                <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInComplexOrderTicketCommand}"
                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FeedGrid}"
                                                   Content="Open in Complex Order Ticket" />
                                <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInBasketTraderCommand}"
                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FeedGrid}"
                                                   Content="Open in Basket Trader" />
                                <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInTradePnlChartCommand}"
                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FeedGrid}"
                                                   Content="Open in Trade PnL Chart" />
                                <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInPositionAnalyzerCommand}"
                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FeedGrid}"
                                                   Content="Open in Position Analyzer" />
                            </dxg:TableView.RowCellMenuCustomizations>
                            <dxg:TableView.GroupValueTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="10,0,0,0"
                                               Text="{Binding Value}" />
                                </DataTemplate>
                            </dxg:TableView.GroupValueTemplate>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridColumn FieldName="OrderSent"
                                    Header="Sent"
