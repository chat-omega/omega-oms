<view:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.EdgeScanFeedView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                   xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                   xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                   xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                   xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                   xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                   xmlns:sys="clr-namespace:System;assembly=mscorlib"
                   xmlns:view="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   Title="{Binding ModuleTitle}"
                   Width="1500"
                   Height="800"
                   MinWidth="400"
                   MinHeight="300"
                   d:DataContext="{d:DesignInstance Type=ViewModels:EdgeScanFeedViewModel}"
                   d:Width="2800"
                   DataContext="{startuphelpers:DISource Type=ViewModels:EdgeScanFeedViewModel}"
                   WindowStartupLocation="CenterScreen"
                   mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:VerificationService />
        <services:LoadCustomColumnService />
        <services:GetItemsByVisualOrderService />
        <services:OmsMessageBoxService />
        <dxmvvm:WindowService />
        <dxmvvm:DispatcherService />
        <dxmvvm:CurrentWindowService />
        <dxmvvm:OpenFileDialogService />
        <dxmvvm:SaveFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

            <Image Width="20"
                   Height="20"
                   Margin="5,2,0,1"
                   Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_Clock.svg'}"
                   ToolTip="Uptime" />

            <TextBlock Padding="3,3,5,3"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Text="{Binding UpTime}"
                       TextAlignment="Right"
                       ToolTip="Uptime" />

            <dx:SimpleButton Margin="2"
                             Padding="0"
                             ButtonKind="Toggle"
                             Glyph="{dx:DXImage 'SvgImages/PDF Viewer/EnableScrolling.svg'}"
                             GlyphHeight="20"
                             IsChecked="{Binding AutoScrollEdgeFeed}"
                             ToolTip="Auto Scroll" />

            <dx:SimpleButton Margin="2"
                             Padding="0"
                             ButtonKind="Toggle"
                             Glyph="{dx:DXImage 'SvgImages/Spreadsheet/ChartHorizontalAxis_LogScale.svg'}"
                             GlyphHeight="20"
                             IsChecked="{Binding EnableLogMode}"
                             ToolTip="Enable Logger Mode" />

            <dx:SimpleButton Margin="2"
                             Padding="0"
                             ButtonKind="Toggle"
                             Glyph="{dx:DXImage 'SvgImages/XAF/State_Task_NotStarted.svg'}"
                             GlyphHeight="20"
                             IsChecked="{Binding OverrideMarketOpenCheck}"
                             ToolTip="Override Market Open Check" />

            <dx:SimpleButton Margin="2"
                             Padding="0"
                             ButtonKind="Toggle"
                             Glyph="{dx:DXImage 'SvgImages/Icon Builder/Security_Bug.svg'}"
                             GlyphHeight="20"
                             IsChecked="{Binding DebugModeEnabled}"
                             ToolTip="Enable Debug Mode" />
            <view:ModuleHeaderItems />
            <controls:AdminConfigControl ConfigSelectionChanged="LoadConfig"
                                         ReloadConfigsSelected="ReloadConfigsSelected" />
        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <Window.Resources>
        <helper:EnumToBooleanConverter x:Key="EnumToBooleanInverseConverter"
                                       Inverse="True" />
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:SignToBrushConverter x:Key="TitleSignToBrushConverter"
                                     NegativeBrush="#FF0000"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#10e411" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#02F302" />

        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="TraderStateTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                AUTO TRADER RUNNING
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                AUTO TRADER STOPPED
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="AgentStateTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                AGENT RUNNING
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                AGENT STOPPED
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TraderStateButtonTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Stop Trader
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Start Trader
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToStatusColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Green" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="DarkRed" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="ShowPriceNotificationToBackgroundConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#049ae2" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="Transparent" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="ShowPriceNotificationToForegroundConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#f8f8f8" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#ffffff" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                             Inverse="True" />
        <helper:NullToCheckGlyphConverter x:Key="NullToCheckGlyphConverter" />
        <Style x:Key="OrderStyle"
               TargetType="dxg:RowControl">
            <Style.Setters>
                <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Background'}" />
                <Setter Property="Foreground" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Foreground'}" />
            </Style.Setters>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='MouseOver'}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{Binding BorderBrush}"
            BorderThickness="4"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
                <RowDefinition x:Name="GridSplitterRow"
                               Height="0" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="5" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="5" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="1"
                      Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <dxlc:GroupBox Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Padding="10,5">

                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Left"
                                            Orientation="Horizontal">

                                    <Label Margin="3,0,0,0"
                                           Content="Runner" />

                                    <dxe:ComboBoxEdit Width="90"
                                                      Margin="3,0,0,0"
                                                      ApplyItemTemplateToSelectedItem="True"
                                                      IsEnabled="{Binding AutoTraderRunning, Converter={StaticResource BooleanNegationConverter}}"
                                                      IsTextEditable="False"
                                                      ItemsSource="{Binding EdgeScanFeedRunnerOptions}"
                                                      SelectedItem="{Binding EdgeScanFeedRunnerOption}">
                                        <dxe:ComboBoxEdit.ItemTemplate>
                                            <DataTemplate>
                                                <Label Padding="0,0.5"
                                                       HorizontalAlignment="Center"
                                                       Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}"
                                                       FontSize="11" />
                                            </DataTemplate>
                                        </dxe:ComboBoxEdit.ItemTemplate>
                                    </dxe:ComboBoxEdit>

                                    <dx:SimpleButton Width="70"
                                                     Height="22"
                                                     Margin="3,0,0,0"
                                                     Padding="2,3"
                                                     BorderThickness="0.5"
                                                     Command="{Binding ShowBannedListManagerCommand}"
                                                     Content="Ban List"
                                                     Glyph="{Binding BlockedSymbolModel, Converter={StaticResource NullToCheckGlyphConverter}}"
                                                     GlyphHeight="15"
                                                     ToolTip="{Binding BlockedSymbolModel.Title}" />

                                    <dx:SimpleButton Height="22"
                                                     Margin="3,0,0,0"
                                                     Padding="2,3"
                                                     BorderThickness="0.5"
                                                     ButtonKind="Toggle"
                                                     Command="{Binding ShowUniqueListCommand}"
                                                     Content="Unique"
                                                     Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Order List.svg}"
                                                     GlyphHeight="15"
                                                     IsChecked="{Binding ShowUniqueSelected}"
                                                     ToolTip="Show Banned Symbols List" />

                                    <dx:SimpleButton Height="22"
                                                     Margin="3,0,0,0"
                                                     Padding="2,3"
                                                     BorderThickness="0.5"
                                                     Command="{Binding ClearEdgeScanFeedTableCommand}"
                                                     Content="Clear Table"
                                                     Glyph="{dx:DXImage SvgImages/Actions/ClearTableStyle.svg}"
                                                     GlyphHeight="15"
                                                     ToolTip="Reset Current Filter" />

                                    <dx:SimpleButton Height="22"
                                                     Margin="3,0,0,0"
                                                     Padding="2,3"
                                                     HorizontalAlignment="Right"
                                                     BorderThickness="0.5"
                                                     Command="{Binding ShowFilterSelectorCommand}"
                                                     Content="Load Filter"
                                                     Glyph="{dx:DXImage 'SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Custom Filter.svg'}"
                                                     GlyphHeight="15"
                                                     ToolTip="Show Filter Selector" />

                                    <Label Margin="15,0,0,0"
                                           VerticalAlignment="Center"
                                           Content="{Binding SelectedModel.Title}"
                                           FontWeight="DemiBold" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal">
                                    <Border Margin="5,0,0,0"
                                            Background="{Binding AutoTraderRunning, Converter={StaticResource BooleanToStatusColorConverter}}"
                                            BorderBrush="{Binding AutoTraderRunning, Converter={StaticResource BooleanToStatusColorConverter}}"
                                            BorderThickness="0.7"
                                            CornerRadius="2">
                                        <TextBlock Padding="5,2"
                                                   Background="{Binding AutoTraderRunning, Converter={StaticResource BooleanToStatusColorConverter}}"
                                                   FontWeight="Medium"
                                                   Foreground="White"
                                                   Text="{Binding AutoTraderRunning, Converter={StaticResource TraderStateTextConverter}}" />
                                    </Border>

                                    <Border Margin="6,0,0,0"
                                            Background="{Binding IsServerRunnerActive, Converter={StaticResource BooleanToStatusColorConverter}}"
                                            BorderBrush="{Binding IsServerRunnerActive, Converter={StaticResource BooleanToStatusColorConverter}}"
                                            BorderThickness="0.7"
                                            CornerRadius="2"
                                            ToolTip="{Binding ServerRunnerState}"
                                            Visibility="{Binding IsServerRunnerMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Padding="5,2"
                                                   Background="{Binding IsServerRunnerActive, Converter={StaticResource BooleanToStatusColorConverter}}"
                                                   FontWeight="Medium"
                                                   Foreground="White"
                                                   Text="{Binding IsServerRunnerActive, Converter={StaticResource AgentStateTextConverter}}" />
                                    </Border>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Padding="5,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Text="{Binding AutoTraderBasketViewModel.ModuleTitle}" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <ScrollViewer Padding="5"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>

                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="5,5,0,0"
                                       Content="Max Latency" />

                                <dxe:SpinEdit Grid.Row="0"
                                              Grid.Column="1"
                                              Width="70"
                                              Margin="5,5,0,0"
                                              HorizontalAlignment="Left"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              EditValue="{Binding AutoTraderMaxLatency, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />

                                <Label Grid.Row="0"
                                       Grid.Column="2"
                                       Margin="5,5,0,0"
                                       Content="Max Allowed Orders" />

                                <dxe:SpinEdit Grid.Row="0"
                                              Grid.Column="3"
                                              Width="70"
                                              Margin="5,5,0,0"
                                              HorizontalAlignment="Left"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              EditValue="{Binding AutoTraderMaxAllowedOrders, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />

                                <Label Grid.Row="0"
                                       Grid.Column="4"
                                       Margin="5,5,0,0"
                                       Content="Edge Override" />

                                <dxe:ComboBoxEdit Grid.Row="0"
                                                  Grid.Column="5"
                                                  Width="150"
                                                  Margin="5,5,0,0"
                                                  ApplyItemTemplateToSelectedItem="True"
                                                  IsTextEditable="False"
                                                  ItemsSource="{Binding AutoTraderEdgeOverrides}"
                                                  SelectedItem="{Binding AutoTraderEdgeOverride}">
                                    <dxe:ComboBoxEdit.ItemTemplate>
                                        <DataTemplate>
                                            <Label Padding="0,0.5"
                                                   HorizontalAlignment="Center"
                                                   Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}"
                                                   FontSize="11" />
                                        </DataTemplate>
                                    </dxe:ComboBoxEdit.ItemTemplate>
                                </dxe:ComboBoxEdit>

                                <dxe:CheckEdit Grid.Row="0"
                                               Grid.Column="6"
                                               Margin="5,5,0,0"
                                               Content="Confirm With IB CoB"
                                               EditValue="{Binding ConfirmWithIbCob}" />

                                <dxe:CheckEdit Grid.Row="0"
                                               Grid.Column="7"
                                               Margin="5,5,0,0"
                                               Content="Use Trade Fill Price"
                                               EditValue="{Binding AutoTraderUseTradePrice}" />

                                <dxe:CheckEdit Grid.Row="0"
                                               Grid.Column="8"
                                               Grid.ColumnSpan="2"
                                               Margin="5,5,0,0"
                                               HorizontalAlignment="Left"
                                               Content="Load With Stock Tied Leg"
                                               EditValue="{Binding LoadWithStockTiedLeg}" />

                                <dxe:CheckEdit Grid.Row="0"
                                               Grid.Column="10"
                                               Margin="5,5,0,0"
                                               HorizontalAlignment="Left"
                                               Content="Min PnL"
                                               EditValue="{Binding MinPnlForAutoTraderEnabled}" />

                                <dxe:SpinEdit Grid.Row="0"
                                              Grid.Column="11"
                                              Width="70"
                                              Margin="5,5,0,0"
                                              HorizontalAlignment="Right"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              EditValue="{Binding MinPnlForAutoTrader, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              IsEnabled="{Binding MinPnlForAutoTraderEnabled}"
                                              Mask="N2"
                                              MaskUseAsDisplayFormat="True"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />

                                <dxe:CheckEdit Grid.Row="0"
                                               Grid.Column="12"
                                               Margin="5,5,0,0"
                                               Content="Auto Stop"
                                               EditValue="{Binding AutoStop}" />

                                <dxe:TextEdit Grid.Row="0"
                                              Grid.Column="13"
                                              Width="80"
                                              Margin="5,5,0,0"
                                              HorizontalAlignment="Left"
                                              HorizontalContentAlignment="Left"
                                              EditValue="{Binding CutoffTime, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding AutoStop}"
                                              Mask="hh:mm:ss tt"
                                              MaskType="DateTimeAdvancingCaret"
                                              MaskUseAsDisplayFormat="True" />

                                <dxe:CheckEdit Grid.Row="0"
                                               Grid.Column="14"
                                               Margin="5,5,0,0"
                                               Content="Block Area"
                                               EditValue="{Binding BlockArea}" />

                                <dxe:SpinEdit Grid.Row="0"
                                              Grid.Column="15"
                                              Width="80"
                                              Margin="5,5,0,0"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              EditValue="{Binding BlockAreaStrikeRange, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="10"
                                              IsEnabled="{Binding BlockArea}"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />

                                <dx:SimpleButton Grid.Row="0"
                                                 Grid.Column="16"
                                                 Width="80"
                                                 Margin="5,5,0,0"
                                                 Padding="0,3"
                                                 Command="{Binding OpenAutoTraderCommand}"
                                                 Content="Open Basket" />
                                <dx:SimpleButton Grid.Row="0"
                                                 Grid.Column="17"
                                                 Width="80"
                                                 Margin="5,5,0,0"
                                                 Padding="0,3"
                                                 Command="{Binding CancelAllAutoTraderCommand}"
                                                 Content="Cancel All" />

                                <Label Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="5,5,0,0"
                                       Content="Max Open Pos" />

                                <dxe:SpinEdit Grid.Row="1"
                                              Grid.Column="1"
                                              Width="70"
                                              Margin="5,5,0,0"
                                              HorizontalAlignment="Left"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              EditValue="{Binding AutoTraderMaxOpenPos, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />

                                <Label Grid.Row="1"
                                       Grid.Column="2"
                                       Margin="5,5,0,0"
                                       Content="Order Rate Per Sec" />

                                <dxe:SpinEdit Grid.Row="1"
                                              Grid.Column="3"
                                              Width="70"
                                              Margin="5,5,0,0"
                                              HorizontalAlignment="Left"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              EditValue="{Binding AutoTraderMaxOrderRateSec, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MaxValue="60"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />

                                <Label Grid.Row="1"
                                       Grid.Column="4"
                                       Margin="5,5,0,0"
                                       Content="Attempted Side" />

                                <dxe:ComboBoxEdit Grid.Row="1"
                                                  Grid.Column="5"
                                                  Width="150"
                                                  Margin="5,5,0,0"
                                                  ApplyItemTemplateToSelectedItem="True"
                                                  IsTextEditable="False"
                                                  ItemsSource="{Binding AutoTraderSideSelectionOptions}"
                                                  SelectedItem="{Binding AutoTraderSideSelector}">
                                    <dxe:ComboBoxEdit.ItemTemplate>
                                        <DataTemplate>
                                            <Label Padding="0,0.5"
                                                   HorizontalAlignment="Center"
                                                   Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}"
                                                   FontSize="11" />
                                        </DataTemplate>
                                    </dxe:ComboBoxEdit.ItemTemplate>
                                </dxe:ComboBoxEdit>

                                <dxe:CheckEdit Grid.Row="1"
                                               Grid.Column="6"
                                               Margin="5,5,0,0"
                                               Content="Apply Grid Filters"
                                               EditValue="{Binding AutoTraderCheckForVisualFilters}" />

                                <dxe:CheckEdit Grid.Row="1"
                                               Grid.Column="7"
                                               Margin="5,5,0,0"
                                               Content="Don't cross Fill Px"
                                               EditValue="{Binding AutoTraderDoNotTradeThroughFillPrice}" />

                                <dxe:CheckEdit Grid.Row="1"
                                               Grid.Column="8"
                                               Margin="5,5,0,0"
                                               HorizontalAlignment="Left"
                                               Content="Pay Up Ticks"
                                               EditValue="{Binding AutoTraderEnablePayUpTicks}" />

                                <dxe:SpinEdit Grid.Row="1"
                                              Grid.Column="9"
                                              Width="70"
                                              Margin="5,5,0,0"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              EditValue="{Binding AutoTraderPayUpTicks, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              IsEnabled="{Binding AutoTraderEnablePayUpTicks}"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MaxValue="3"
                                              MinValue="-3"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />

                                <dxe:CheckEdit Grid.Row="1"
                                               Grid.Column="10"
                                               Margin="5,5,0,0"
                                               HorizontalAlignment="Left"
                                               Content="Min PnL Max Qty"
                                               EditValue="{Binding MinPnlMaxQtyCheckEnabled}" />

                                <dxe:SpinEdit Grid.Row="1"
                                              Grid.Column="11"
                                              Width="70"
                                              Margin="5,5,0,0"
                                              HorizontalAlignment="Right"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              EditValue="{Binding MinPnlMaxQty, UpdateSourceTrigger=PropertyChanged}"
