                                    <DataTemplate>
                                        <TextBlock Margin="0,0,2,0"
                                                   Padding="2"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding RowData.Row.Logger.MidAtClose, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="PnlAtClose"
                                            Header="Pnl"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,2,0"
                                                   Padding="2"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{Binding RowData.Row.Logger.PnlAtClose, Converter={StaticResource SignToBrushConverter}}"
                                                   Text="{Binding RowData.Row.Logger.PnlAtClose, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="DeltaAtClose"
                                            Header="Delta"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,2,0"
                                                   Padding="2"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding RowData.Row.Logger.DeltaAtClose, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="GammaAtClose"
                                            Header="Gamma"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,2,0"
                                                   Padding="2"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding RowData.Row.Logger.GammaAtClose, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="VegaAtClose"
                                            Header="Vega"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,2,0"
                                                   Padding="2"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding RowData.Row.Logger.VegaAtClose, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="UnderlyingAtClose"
                                            Header="Underlying"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,2,0"
                                                   Padding="2"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding RowData.Row.Logger.UnderlyingAtClose, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="ImpliedAtClose"
                                            Header="Implied"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,2,0"
                                                   Padding="2"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding RowData.Row.Logger.ImpliedAtClose, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="DeltaAdjTheoAtClose"
                                            Header="Adj Theo"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,2,0"
                                                   Padding="2"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding RowData.Row.Logger.DeltaAdjTheoAtClose, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>
                    </dxg:GridControl.Bands>
                </dxg:GridControl>

                <Grid Grid.Row="4"
                      Grid.Column="1"
                      Height="22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Margin="0,0,0,0"
                               VerticalAlignment="Center"
                               Text="Rows:" />
                    <TextBlock Grid.Column="1"
                               Margin="3,0"
                               VerticalAlignment="Center"
                               Text="{Binding Trades.Count}" />

                    <StackPanel Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding ElementName=Basket, Path=Visibility}">
                            <TextBlock Margin="15,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="NET-Δ"
                                       TextAlignment="Right"
                                       ToolTip="Net Delta" />

                            <TextBlock Margin="2,0,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding AutoTraderBasketViewModel.NetDelta, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding AutoTraderBasketViewModel.NetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                       TextAlignment="Right" />

                            <TextBlock Margin="5,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="HEDGE-Δ"
                                       TextAlignment="Right"
                                       ToolTip="Hedge Net Delta" />

                            <TextBlock Margin="2,0,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding AutoTraderBasketViewModel.HedgeNetDelta, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding AutoTraderBasketViewModel.HedgeNetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                       TextAlignment="Right" />

                            <TextBlock Margin="5,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="TOTAL-Δ"
                                       TextAlignment="Right"
                                       ToolTip="Total Delta" />

                            <TextBlock Margin="2,0,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding AutoTraderBasketViewModel.TotalNetDelta, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding AutoTraderBasketViewModel.TotalNetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                       TextAlignment="Right" />

                            <TextBlock Margin="15,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="U-"
                                       TextAlignment="Right"
                                       ToolTip="Unrealized PnL" />

                            <Image Width="15"
                                   Height="15"
                                   Margin="0,2.3,0,0"
                                   VerticalAlignment="Center"
                                   Source="{dx:DXImage 'SvgImages/Icon Builder/Business_DollarCircled.svg'}"
                                   ToolTip="Unrealized PnL" />

                            <TextBlock Margin="2,0,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding AutoTraderBasketViewModel.UnrealizedPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding AutoTraderBasketViewModel.UnrealizedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                       TextAlignment="Right" />

                            <TextBlock Margin="5,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="DemiBold"
                                       Foreground="#039c23"
                                       Text="R-"
                                       TextAlignment="Right"
                                       ToolTip="Realized PnL" />

                            <Image Width="15"
                                   Height="15"
                                   Margin="0,2.3,0,0"
                                   VerticalAlignment="Center"
                                   Source="{dx:DXImage 'SvgImages/Icon Builder/Business_DollarCircled.svg'}"
                                   ToolTip="Realized PnL" />

                            <TextBlock Margin="2,1,0,0"
                                       Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{Binding AutoTraderBasketViewModel.AdjustedPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                                       Text="{Binding AutoTraderBasketViewModel.AdjustedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                       TextAlignment="Right" />

                            <dxe:ToggleSwitch Margin="10,0"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              AnimationMode="Always"
                                              Background="#FF0000"
                                              CheckedStateContent="✅ Risk Check"
                                              ContentPlacement="Inside"
                                              Focusable="False"
                                              FontWeight="Bold"
                                              IsChecked="{Binding AutoTraderBasketViewModel.BasketSettings.RiskCheckEnabled}"
                                              ToggleSwitchWidth="105"
                                              UncheckedStateContent="⚠ Risk Check" />

                            <dxe:ToggleSwitch Margin="10,0"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              AnimationMode="Always"
                                              Background="#FF0000"
                                              CheckedStateContent="✅ Active Uncheck"
                                              ContentPlacement="Inside"
                                              Focusable="False"
                                              FontWeight="Bold"
                                              IsChecked="{Binding AutoTraderBasketViewModel.BasketSettings.ActiveUncheckEnabled}"
                                              ToggleSwitchWidth="130"
                                              UncheckedStateContent="⚠ Active Uncheck" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>

            <GridSplitter Grid.Row="1"
                          Height="3"
                          Margin="2,0"
                          HorizontalAlignment="Stretch"
                          MouseDoubleClick="GridSplitter_MouseDoubleClick"
                          Visibility="{Binding ElementName=Basket, Path=Visibility}" />

            <dx:SimpleButton Name="ExpandCollapseGridButton"
                             Grid.Row="1"
                             Width="100"
                             Height="8"
                             Padding="0,-2.5,0,0"
                             HorizontalAlignment="Center"
                             Click="ExpandCollapseGrid_Click"
                             Content="6"
                             CornerRadius="3"
                             FontFamily="Marlett"
                             FontSize="10" />

            <views:BasketTraderContentView x:Name="Basket"
                                           Grid.Row="2"
                                           MaxHeight="3500"
                                           Margin="5,0,5,5"
                                           DataContext="{Binding AutoTraderBasketViewModel}"
                                           Visibility="Hidden" />
        </Grid>
    </Border>
</view:ModuleWindow>
