                                                          SorRoutesList="{Binding RowData.Row.Ticket.SorRoutesList}">
                                        <dxmvvm:Interaction.Behaviors>
                                            <dxmvvm:EventToCommand Command="{Binding RowData.Row.Ticket.AccountOrRouteChangedCommand}"
                                                                   EventName="EditValueChanged" />
                                        </dxmvvm:Interaction.Behaviors>
                                    </controls:RoutePicker>
                                </Grid>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
