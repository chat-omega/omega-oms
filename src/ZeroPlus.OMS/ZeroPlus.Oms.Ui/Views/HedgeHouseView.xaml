                                    IsSmart="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <dxe:CheckEdit Grid.Column="0"
                                                   Margin="2,0"
                                                   EditValue="{Binding RowData.Row.DeltaNeutralEnabled}">
                                        <dxmvvm:Interaction.Behaviors>
                                            <dxmvvm:EventToCommand Command="{Binding View.DataContext.DeltaNeutralChangedCommand}"
                                                                   CommandParameter="{Binding RowData.Row}"
                                                                   EventName="EditValueChanged" />
                                        </dxmvvm:Interaction.Behaviors>
                                    </dxe:CheckEdit>

                                    <dxe:TrackBarEdit Grid.Column="1"
                                                      EditValue="{Binding RowData.Row.DeltaNeutralPercentage}"
                                                      EditValueType="{x:Type sys:Double}"
                                                      IsEnabled="{Binding RowData.Row.DeltaNeutralEnabled}"
                                                      IsSnapToStepEnabled="True"
                                                      LargeStep=".1"
                                                      Maximum="1"
                                                      Minimum="0"
                                                      SmallStep=".05"
                                                      TickFrequency="0.05"
                                                      TickItemDisplayMode="Tick"
                                                      TickPlacement="None"
                                                      ValueToolTipPlacement="TopLeft" />
                                </Grid>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn AllowCellMerge="False"
                                    FieldName="DeltaNeutralMinQty"
