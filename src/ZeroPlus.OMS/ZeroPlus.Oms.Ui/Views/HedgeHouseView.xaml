                                              AllowSpinOnMouseWheel="True"
                                              AllowUpdateTwoWayBoundPropertiesOnSynchronization="False"
                                              Background="Transparent"
                                              EditValue="{Binding RowData.Row.MinQty, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="1"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="200"
                                    AllowCellMerge="False"
                                    FieldName="Route"
                                    Header="Route"
                                    IsSmart="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <dxe:CheckEdit Grid.Column="0"
                                                   Margin="2,0"
                                                   EditValue="{Binding RowData.Row.RouteOverrideEnabled}" />
                                    <controls:RoutePicker Grid.Column="1"
                                                          Margin="0,-1,-1,-1"
                                                          AllowUpdateTwoWayBoundPropertiesOnSynchronization="False"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          DmaRoutesList="{Binding RowData.Row.Ticket.DmaRoutesList}"
                                                          IsEnabled="{Binding RowData.Row.RouteOverrideEnabled}"
                                                          ItemsSource="{Binding RowData.Row.Ticket.RoutesList}"
