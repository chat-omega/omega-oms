<UserControl x:Class="ZeroPlus.Oms.Ui.Views.LowLatencyLoopConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:ZeroPlus.Oms.Ui.Models"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             MinWidth="320"
             d:DataContext="{d:DesignInstance Type=models:LoopModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Padding="5"
                BorderBrush="#3f3f46"
                BorderThickness="1">
            <Grid Margin="5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="0" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="1"
                       Grid.Column="1"
                       Width="70"
                       Margin="5,2,0,0"
                       Content="Loop Delay" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="2"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding LoopDelay, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </Grid>
        </Border>

        <dxg:GridControl Grid.Row="1"
                         MaxHeight="1000"
                         Margin="0,5,0,0"
                         ItemsSource="{Binding LoopTable}"
                         SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="True"
                               AllowGrouping="False"
                               AllowSorting="True"
                               AutoWidth="True"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Profit, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="Profit"
                            Header="$ Profit"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellEditTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.Profit, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="0.01"
                                      Mask="N2"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellEditTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.LoopQty, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                            FieldName="LoopQty"
                            Header="Loop Qty"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellEditTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.LoopQty, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Increment="1"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellEditTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.PayupTicks, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                            FieldName="PayupTicks"
                            Header="Payup Ticks"
                            HorizontalHeaderContentAlignment="Center"
                            IsSmart="True">
                <dxg:GridColumn.CellEditTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.PayupTicks, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Increment="1"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellEditTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>
    </Grid>
</UserControl>
