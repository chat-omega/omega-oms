                                                                  VerticalScrollBarVisibility="Auto" />
                                                </ItemsControl>
                                            </dxb:PopupControlContainer>
                                        </dxb:BarManager.DXContextMenu>
                                    </dx:SimpleButton>

                                    <dxe:SpinEdit Grid.Row="3"
                                                  Grid.Column="2"
                                                  EditValue="{Binding BasketSettings.AutoPermMaxGeneration, UpdateSourceTrigger=PropertyChanged}"
                                                  EditValueType="{x:Type sys:Int32}"
                                                  Increment="1"
                                                  MaxValue="{Binding MaxAutoPermMaxGeneration}"
                                                  MinValue="1"
                                                  Style="{StaticResource AutoPermSettingSpinEditStyle}" />
                                </Grid>
