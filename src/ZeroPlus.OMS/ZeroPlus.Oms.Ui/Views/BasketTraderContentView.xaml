                                <StackPanel Orientation="Vertical">
                                    <dx:SimpleButton HorizontalContentAlignment="Left"
                                                     Command="{Binding ClearPnlCommand}"
                                                     Content="Clear PnL"
                                                     Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Clear.svg}"
                                                     GlyphHeight="15"
                                                     GlyphWidth="15" />
