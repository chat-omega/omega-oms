<UserControl x:Class="ZeroPlus.Oms.Ui.Views.BasketTraderContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             xmlns:Views="clr-namespace:ZeroPlus.Oms.Ui.Views"
             xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
             xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:enums="clr-namespace:ZeroPlus.Oms.Ui.Enums"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DataContext="{d:DesignInstance Type=ViewModels:BasketTraderViewModel}"
             d:Height="750"
             d:Width="auto"
             mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:LoadCustomColumnService />
        <services:GetItemsByVisualOrderService />
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
        <dxmvvm:WindowService />
        <dxmvvm:DispatcherService />
        <dxmvvm:OpenFileDialogService />
        <dxmvvm:SaveFileDialogService />
        <dx:DialogService x:Name="DominatorConfigurationViewService"
                          DialogWindowStartupLocation="CenterScreen">
            <dx:DialogService.ViewTemplate>
                <DataTemplate>
                    <Views:DominatorConfigurationView />
                </DataTemplate>
            </dx:DialogService.ViewTemplate>
            <dx:DialogService.DialogStyle>
                <Style TargetType="Window">
                    <Setter Property="Height" Value="600" />
                    <Setter Property="Width" Value="800" />
                </Style>
            </dx:DialogService.DialogStyle>
        </dx:DialogService>
    </dxmvvm:Interaction.Behaviors>

    <UserControl.Resources>
        <Storyboard x:Key="AnimateFlicker"
                    RepeatBehavior="Forever">
            <DoubleAnimation AutoReverse="True"
                             RepeatBehavior="10x"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.3" />
        </Storyboard>
        <helper:CashPercentageToGlyphConverter x:Key="CashPercentageToGlyphConverter" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />

        <Style x:Key="BasketGridColumnBase"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="Visible" Value="False" />
            <Setter Property="AllowCellMerge" Value="False" />
            <Setter Property="IsSmart" Value="True" />
            <Setter Property="ReadOnly" Value="True" />
            <Setter Property="AllowMoving" Value="{Binding LayoutLocked, Converter={StaticResource BooleanNegationConverter}}" />
            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="N0NumericColumn"
               BasedOn="{StaticResource BasketGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="N0"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="N2NumericColumn"
               BasedOn="{StaticResource BasketGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="N2"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="N3NumericColumn"
               BasedOn="{StaticResource BasketGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="N3"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="C2NumericColumn"
               BasedOn="{StaticResource BasketGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="C2"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>

        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:TheoModelToDisplayTextConverter x:Key="TheoModelToDisplayTextConverter" />
        <helper:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helper:NullToCheckGlyphConverter x:Key="NullToCheckGlyphConverter" />
        <helper:BoolToCheckGlyphConverter x:Key="BoolToCheckGlyphConverter" />
        <helper:GreaterThanConverter x:Key="GreaterThanOneConverter"
                                     Limit="1" />
        <helper:BasketAutomationModeToBooleanConverter x:Key="BasketAutomationModeToBooleanConverter" />
        <helper:SizeUpTypeToVisibilityConverter x:Key="SizeUpTypeToVisibilityConverter" />
        <helper:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#B73535"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#10e411" />
        <helper:SignToBrushConverter x:Key="SignToDarkBrushConverter"
                                     NegativeBrush="#FF2100"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#F1F1F1" />
        <helper:SignToBrushConverter x:Key="TheoToMidToColorConverter"
                                     InvalidBrush="Transparent"
                                     NegativeBrush="#ff705a"
                                     PositiveBrush="#32b674"
                                     ZeroBrush="Transparent" />
        <helper:SignToBrushConverter x:Key="CountdownToBrushConverter"
                                     Limit="3"
                                     NegativeBrush="#F05126"
                                     PositiveBrush="#171718"
                                     ZeroBrush="#F05126" />
        <helper:SignToBrushConverter x:Key="CreepToBrushConverter"
                                     Limit="5"
                                     NegativeBrush="#1b9e1d"
                                     PositiveBrush="#B73535"
                                     ZeroBrush="#B73535" />
        <helper:RangeToBrushConverter x:Key="RangeToBrushConverter"
                                      AboveRangeBrush="#B73535"
                                      BelowRangeBrush="#0A8E51"
                                      InbetweenRangeBrush="#1a4c35"
                                      RangeCeil="0.50"
                                      RangeFloor="0.45" />
        <helper:RangeToBrushConverter x:Key="TheoDiffRangeToBrushConverter"
                                      AboveRangeBrush="#FF0000"
                                      BelowRangeBrush="#0A8E51"
                                      InbetweenRangeBrush="#f89942"
                                      RangeCeil="0.2"
                                      RangeFloor="0.15"
                                      UseAbsoluteValue="True" />
        <helper:RangeToBrushConverter x:Key="TradeTimeRangeToBrushConverter"
                                      AboveRangeBrush="#0A8E51"
                                      BelowRangeBrush="#FF0000"
                                      InbetweenRangeBrush="#FF0000"
                                      RangeCeil="30"
                                      RangeFloor="0"
                                      UseAbsoluteValue="False" />
        <helper:RangeToBrushConverter x:Key="HighestTheoChangeRangeToBrushConverter"
                                      AboveRangeBrush="#FF0000"
                                      BelowRangeBrush="#0A8E51"
                                      InbetweenRangeBrush="#f89942"
                                      RangeCeil="0.05"
                                      RangeFloor="0.02"
                                      UseAbsoluteValue="True" />
        <helper:MultiBooleanToAndVisibilityConverter x:Key="MultiBooleanToAndVisibilityConverter" />
        <helper:MultiBooleanToOrVisibilityConverter x:Key="MultiBooleanToOrVisibilityConverter" />
        <helper:OrderToBackBrushConverter x:Key="SideToColorConverter" />
        <helper:ThresholdToBrushConverter x:Key="ThresholdToBrushConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="ProminentButtonHeight">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                34
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                22
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="HighlightToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #1a4c35
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #587C8D
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #2D2D30
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBorderColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #FF0000
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBorderRunningColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #FF0000
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #3f3f46
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToGlyphConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                15
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                0
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToExpandCollapseConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                3
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                4
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToColorConverterRed">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F88F8F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #2D2D30
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToHiddenVisibilityConverter"
                                             HiddenInsteadOfCollapsed="False" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                             Inverse="True" />
        <dxmvvm:BooleanToObjectConverter x:Key="TheoValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #02F302
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F3A202
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TheoJumpToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #FFDF0F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #FFFFFF
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBorderWidthConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                4
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                0
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>

        <Style x:Key="SettingInfoButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Glyph" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_Info.svg'}" />
            <Setter Property="GlyphHeight" Value="11" />
            <Setter Property="GlyphWidth" Value="11" />
            <Setter Property="ToolTip" Value="Click for info" />
            <Setter Property="dxb:BarManager.MenuShowMouseButton" Value="LeftButton" />
            <Setter Property="Visibility" Value="Hidden" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type dxlc:GroupBox}}}"
                             Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GroupBoxInfoToggleButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ButtonKind" Value="Toggle" />
            <Setter Property="Glyph" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_Info.svg'}" />
            <Setter Property="GlyphHeight" Value="14" />
            <Setter Property="GlyphWidth" Value="14" />
            <Setter Property="ToolTip" Value="Toggle setting descriptions" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#3e3e40" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3e3e40" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AutoPermSettingLabelStyle"
               TargetType="{x:Type Label}">
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="AutoPermSettingSpinEditStyle"
               TargetType="{x:Type dxe:SpinEdit}">
            <Setter Property="Width" Value="80" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="AllowSpinOnMouseWheel" Value="True" />
            <Setter Property="SelectAllOnGotFocus" Value="True" />
            <Setter Property="SelectAllOnMouseUp" Value="True" />
            <EventSetter Event="PreviewMouseUp"
                         Handler="SelectAll" />
        </Style>
    </UserControl.Resources>

    <Border Margin="1"
            BorderBrush="#e26500"
            BorderThickness="{Binding BasketSettings.LegInEnabled, Converter={StaticResource BooleanToBorderWidthConverter}}"
            CornerRadius="1">
        <Border BorderBrush="{Binding BasketSettings.RiskCheckEnabled, Converter={StaticResource BooleanToBorderColorConverter}}"
                BorderThickness="4"
                CornerRadius="1">
            <Border x:Name="MixedBasketBorder"
                    Margin="2"
                    BorderBrush="{Binding MixedBasketBorderColor}"
                    BorderThickness="0"
                    CornerRadius="1">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:UIObjectService x:Name="MixedBasketBorderService" />
                </dxmvvm:Interaction.Behaviors>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="35" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="0" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0" />
                        <ColumnDefinition x:Name="GridSplitterCol"
                                          Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="0" />
                    </Grid.ColumnDefinitions>
                    <ScrollViewer Grid.Row="1"
                                  Grid.Column="1"
                                  Grid.ColumnSpan="3"
                                  d:Z.PanelIndex="-1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.ContextMenu>
                            <ContextMenu>
                                <ItemsControl>
                                    <MenuItem Header="Show Basket Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowBasketSettings}" />
                                    <MenuItem Header="Show Edge Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowEdgeSettings}" />
                                    <MenuItem Header="Show Hedge Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowHedgeSettings}" />
                                    <MenuItem Header="Show Perm Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowPermSettings}" />
                                    <MenuItem Header="Show Spread Morph"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowMorphSettings}" />
                                    <MenuItem Header="Show Submit With Delay Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowSubmitWithDelaySettings}" />
                                    <MenuItem Header="Show Route Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowRouteSettings}" />
                                    <MenuItem Header="Show Fish Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowFishSettings}" />
                                    <MenuItem Header="Show Nagbot Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowNagbotSettings}" />
                                    <MenuItem Header="Show Hedge House Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowHedgeHouseSettings}" />
                                    <MenuItem Header="Show Notification Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowNotificationSettings}" />
                                    <MenuItem Header="Show Logging Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowLoggingSettings}" />
                                    <MenuItem Header="Show Alert Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowAlerts}" />
                                    <MenuItem Header="Show Matrix Algo Routing"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowMatrixAlgos}" />
                                    <MenuItem Header="Show Auto Leg Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowAutoLegSettings}" />
                                    <MenuItem Header="Show Auto Close Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowAutoCloseSettings}" />
                                    <MenuItem Header="Show Leg Out Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowLegOutSettings}" />
                                    <MenuItem Header="Show Leg In Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowLegInSettings}" />
                                    <MenuItem Header="Show Sweep Trade Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowSweepTradeSettings}" />
                                    <MenuItem Header="Show Auto Cancel Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowAutoCancelSettings}" />
                                    <MenuItem Header="Show Auto Perm Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowAutoPermSettings}" />
                                    <MenuItem Header="Show Fish Loss Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowFishLossSettings}" />
                                    <MenuItem Header="Show Edge Overide Model Settings"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowEdgeToTheoModelSettings}" />
                                    <MenuItem Header="Show Subscription Manager"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowSubscriptionManager}" />
                                </ItemsControl>
                            </ContextMenu>
                        </ScrollViewer.ContextMenu>
                        <StackPanel x:Name="SubmodulePanel"
                                    Margin="5"
                                    AllowDrop="{Binding LayoutLocked, Converter={StaticResource BooleanNegationConverter}}"
                                    Drop="SubModulePanelDrop"
                                    MouseLeave="CheckForBasketSettingUpdate"
                                    Orientation="Horizontal">
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <ItemsControl>
                                        <MenuItem Header="Show Basket Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowBasketSettings}" />
                                        <MenuItem Header="Show Edge Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowEdgeSettings}" />
                                        <MenuItem Header="Show Hedge Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowHedgeSettings}" />
                                        <MenuItem Header="Show Perm Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowPermSettings}" />
                                        <MenuItem Header="Show Spread Morph"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowMorphSettings}" />
                                        <MenuItem Header="Show Submit Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowSubmitWithDelaySettings}" />
                                        <MenuItem Header="Show Route Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowRouteSettings}" />
                                        <MenuItem Header="Show Fish Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowFishSettings}" />
                                        <MenuItem Header="Show Nagbot Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowNagbotSettings}" />
                                        <MenuItem Header="Show Hedge House Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowHedgeHouseSettings}" />
                                        <MenuItem Header="Show Notification Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowNotificationSettings}" />
                                        <MenuItem Header="Show Logging Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowLoggingSettings}" />
                                        <MenuItem Header="Show Alert Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowAlerts}" />
                                        <MenuItem Header="Show Matrix Algo Routing"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowMatrixAlgos}" />
                                        <MenuItem Header="Show Auto Leg Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowAutoLegSettings}" />
                                        <MenuItem Header="Show Auto Close Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowAutoCloseSettings}" />
                                        <MenuItem Header="Show Leg Out Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowLegOutSettings}" />
                                        <MenuItem Header="Show Leg In Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowLegInSettings}" />
                                        <MenuItem Header="Show Sweep Trade Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowSweepTradeSettings}" />
                                        <MenuItem Header="Show Auto Cancel Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowAutoCancelSettings}" />
                                        <MenuItem Header="Show Auto Perm Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowAutoPermSettings}" />
                                        <MenuItem Header="Show Fish Loss Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowFishLossSettings}" />
                                        <MenuItem Header="Show Edge Override Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowEdgeToTheoModelSettings}" />
                                        <MenuItem Header="Show Subscription Manager"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowSubscriptionManager}" />
                                        <MenuItem Header="Show Block List Manager"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowBlockListSettings}" />
                                        <MenuItem Header="Show Basket Stats"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowBasketStats}" />
                                        <MenuItem Header="Show Stock Tied Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowStockTiedSettings}" />
                                        <MenuItem Header="Show Cheapo Settings"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowCheapoSettings}" />
                                    </ItemsControl>
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <dxlc:GroupBox Name="BasketSettingsSubModule"
                                           Margin="5,0,0,0"
                                           Padding="10,5"
                                           AllowDrop="{Binding LayoutLocked, Converter={StaticResource BooleanNegationConverter}}"
                                           DragEnter="SubModuleDragEnter"
                                           DragLeave="SubModuleDragLeave"
                                           DragOver="SubModuleDragOver"
                                           MouseDown="SubModuleMouseDown"
                                           Visibility="{Binding ShowBasketSettings, Converter={StaticResource BooleanToHiddenVisibilityConverter}}">
                                <dxlc:GroupBox.Header>
                                    <Grid Height="22">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="auto" />
                                        </Grid.ColumnDefinitions>

                                        <dx:SimpleButton Grid.Column="0"
                                                         Width="25"
                                                         Margin="2,0"
                                                         Padding="0,1"
                                                         Glyph="{dx:DXImage 'SvgImages/Dashboards/LayoutDirection.svg'}"
                                                         GlyphHeight="15"
                                                         PreviewMouseDown="BasketButton_PreviewMouseDown"
                                                         PreviewMouseMove="BasketButton_PreviewMouseMove"
                                                         PreviewMouseUp="BasketButton_PreviewMouseUp"
                                                         ToolTip="Drag Basket" />

                                        <dxe:TextEdit x:Name="NameEdit"
                                                      Grid.Column="1"
                                                      VerticalAlignment="Center"
                                                      Background="Transparent"
                                                      BorderBrush="Transparent"
                                                      BorderThickness="0"
                                                      EditValue="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                      IsHitTestVisible="False"
                                                      KeyDown="NameKeyDown"
                                                      MouseDoubleClick="ToggleEdit"
                                                      PreviewMouseUp="SelectAll"
                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True" />

                                        <dx:SimpleButton x:Name="NameEditButton"
                                                         Grid.Column="2"
                                                         Width="25"
                                                         HorizontalAlignment="Right"
                                                         ButtonKind="Toggle"
                                                         Checked="EditName"
