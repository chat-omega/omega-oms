                                                     GlyphWidth="15" />
                                    <Separator />
                                    <dx:SimpleButton HorizontalContentAlignment="Left"
                                                     Command="{Binding ClearAllOutsideWidthWindowCommand}"
                                                     Content="Remove Outside Width"
                                                     Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Clear.svg}"
                                                     GlyphHeight="15"
                                                     GlyphWidth="15" />
                                    <Separator />
                                    <dx:SimpleButton HorizontalContentAlignment="Left"
                                                     Command="{Binding CleanDuplicateStrikesCommand}"
                                                     Content="Clean Duplicate Strikes"
                                                     Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Clear.svg}"
                                                     GlyphHeight="15"
                                                     GlyphWidth="15" />
                                    <Separator />
                                    <dx:SimpleButton HorizontalContentAlignment="Left"
