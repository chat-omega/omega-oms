                                                                  Height="100"
                                                                  VerticalContentAlignment="Top"
                                                                  IsReadOnly="True"
                                                                  Text="Initial order quantity used when submitting each auto-perm."
                                                                  TextWrapping="Wrap"
                                                                  VerticalScrollBarVisibility="Auto" />
