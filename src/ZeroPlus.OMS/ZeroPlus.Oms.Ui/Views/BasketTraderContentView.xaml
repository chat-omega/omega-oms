                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      EditValue="{Binding RowData.Row.CloseSpecificQty, UpdateSourceTrigger=LostFocus}"
                                                      EditValueChanged="QtyValueChanged"
                                                      EditValueType="{x:Type sys:Int32}"
                                                      Increment="1"
                                                      MinValue="0"
                                                      PreviewMouseUp="SelectAll"
                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True" />
                                        <TextBlock Grid.Column="2"
                                                   Width="30"
                                                   Margin="0,0,2,0"
                                                   Padding="2"
                                                   HorizontalAlignment="Right"
                                                   FontWeight="DemiBold"
                                                   Text="E2M" />
                                        <dxe:SpinEdit Grid.Column="3"
                                                      Margin="-1"
                                                      AllowSpinOnMouseWheel="True"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      EditValue="{Binding RowData.Row.CloseSpecificEdgeToMid, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                                      EditValueType="{x:Type sys:Double}"
                                                      Increment=".01"
                                                      Mask="N2"
                                                      MaskUseAsDisplayFormat="True"
                                                      PreviewMouseUp="SelectAll"
                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True" />
                                        <dx:SimpleButton Grid.Column="4"
                                                         Margin="-1"
                                                         VerticalAlignment="Center"
                                                         Background="Transparent"
                                                         Command="{Binding RowData.Row.CloseSpecifiedPositionsAsyncCommand}"
                                                         Content="Close"
                                                         Foreground="#a5452d" />
                                    </Grid>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn Width="79"
                                        MinWidth="79"
                                        AllowSorting="False"
                                        FieldName="CloseAllPositions"
                                        Header="Close"
                                        IsSmart="False">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dx:SimpleButton VerticalAlignment="Center"
                                                     Background="Transparent"
                                                     BorderBrush="#f26543"
                                                     Command="{Binding RowData.Row.CloseAllPositionsAsyncCommand}"
                                                     Content="Close"
                                                     Foreground="#f26543" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn Width="79"
                                        MinWidth="79"
                                        AllowSorting="False"
                                        FieldName="CloseFast"
                                        Header="Close Fast"
                                        IsSmart="False">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dx:SimpleButton Command="{Binding RowData.Row.CloseAllPositionsFastAsyncCommand}"
                                                     Content="Close Fast"
                                                     Foreground="#333337">
                                        <dx:SimpleButton.Style>
                                            <Style TargetType="dx:SimpleButton">
                                                <Setter Property="Background" Value="#a45e5e" />
                                                <Setter Property="BorderBrush" Value="#f26543" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#714040" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </dx:SimpleButton.Style>
                                    </dx:SimpleButton>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn d:Visible="True"
                                        FieldName="ContraStatus"
                                        Header="Contra Status">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Height="23"
                                               Margin="0,0,2,0"
                                               Padding="2,4,0,0"
                                               VerticalAlignment="Center"
                                               Background="{Binding RowData.Row.ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                                               Foreground="{Binding RowData.Row.ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                                               Text="{Binding RowData.Row.ContraStatus}"
                                               TextAlignment="Center" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn d:Visible="True"
                                        FieldName="ContraFilled"
                                        Header="Contra Filled">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,2,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding RowData.Row.ContraFilled}"
                                               TextAlignment="Right" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn d:Visible="True"
                                        FieldName="ContraPrice"
                                        Header="Contra Price">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dxe:SpinEdit Margin="-1"
                                                  AllowSpinOnMouseWheel="True"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  EditValue="{Binding RowData.Row.ContraPrice, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                                  EditValueType="{x:Type sys:Double}"
                                                  Increment="{Binding RowData.Row.PriceIncrement}"
                                                  Mask="N2"
                                                  MaskUseAsDisplayFormat="True"
                                                  PreviewMouseUp="SelectAll"
                                                  SelectAllOnGotFocus="True"
                                                  SelectAllOnMouseUp="True" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn Width="72"
                                        MinWidth="72"
                                        d:Visible="True"
                                        AllowSorting="False"
                                        FieldName="ContraSubmit"
                                        Header="Contra"
                                        IsSmart="False">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dx:SimpleButton Background="Transparent"
                                                     BorderThickness="0"
                                                     Command="{Binding RowData.Row.SubmitContraAsyncCommand}"
                                                     Content="Send"
                                                     Foreground="#02F302"
                                                     IsEnabled="{Binding RowData.Row.IsContraSubmitEnabled}" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn Width="72"
                                        MinWidth="72"
                                        d:Visible="True"
                                        AllowSorting="False"
                                        FieldName="ContraCancel"
                                        Header="Contra"
                                        IsSmart="False">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dx:SimpleButton Background="Transparent"
                                                     BorderThickness="0"
                                                     Command="{Binding RowData.Row.CancelContraAsyncCommand}"
                                                     Content="Cancel"
                                                     Foreground="#FFFFFF"
                                                     IsEnabled="{Binding RowData.Row.IsContraCancelEnabled}" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn Width="72"
                                        MinWidth="72"
                                        AllowSorting="False"
                                        FieldName="NagEnabled"
                                        Header="Nag Bot"
                                        IsSmart="False">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dx:SimpleButton Background="Transparent"
                                                     BorderThickness="0"
                                                     ButtonKind="Toggle"
                                                     Content="Nag Bot"
                                                     Foreground="#FFFFFF"
                                                     IsChecked="{Binding RowData.Row.NagEnabled}"
                                                     IsEnabled="{Binding View.DataContext.NagbotEnabled}" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn AllowSorting="False"
                                        FieldName="NagCountdown"
                                        Header="Nag Bot Countdown"
                                        IsSmart="False" />
                        <dxg:GridColumn Width="45"
                                        MinWidth="45"
                                        AllowSorting="False"
                                        FieldName="IsLoopingV2"
                                        Header="Auto"
                                        IsSmart="False"
                                        ToolTip="Automation Running">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Visibility="{Binding RowData.Row.IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <DockPanel Grid.Column="1"
                                                   Margin="0,0,-2,0"
                                                   Visibility="{Binding RowData.Row.BasketSettings.AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <dxe:ButtonEdit AllowDefaultButton="False"
                                                            IsEnabled="{Binding RowData.Row.IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            ShowBorder="False"
                                                            ShowText="False">
                                                <dxe:ButtonEdit.Buttons>
                                                    <dxe:LoadingIndicatorButtonInfo />
                                                </dxe:ButtonEdit.Buttons>
                                            </dxe:ButtonEdit>
                                        </DockPanel>
                                        <dxe:ButtonEdit Grid.Column="2"
                                                        Margin="-2,0,0,0"
                                                        AllowDefaultButton="False"
                                                        IsEnabled="{Binding RowData.Row.IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        ShowBorder="False"
                                                        ShowText="False">
                                            <dxe:ButtonEdit.Buttons>
                                                <dxe:LoadingIndicatorButtonInfo />
                                            </dxe:ButtonEdit.Buttons>
                                        </dxe:ButtonEdit>
                                    </Grid>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn Width="40"
                                        MinWidth="40"
                                        d:Visible="True"
                                        AllowSorting="False"
                                        FieldName="Remove"
                                        Header="X"
                                        IsSmart="False">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <dx:SimpleButton Width="40"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Command="{Binding View.DataContext.RemoveCommand}"
                                                     CommandParameter="{Binding Path=SelectedItem, ElementName=BasketGrid}"
                                                     Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                     GlyphWidth="20" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="Side">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn Binding="{Binding Path=RowData.Row.EdgeScanFeedEdge, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                        FieldName="EdgeScanFeedEdge"
                                        Style="{StaticResource N2NumericColumn}" />
                        <dxg:GridColumn Binding="{Binding Path=RowData.Row.EdgeScanFeedUnderlying, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                        FieldName="EdgeScanFeedUnderlying"
                                        Style="{StaticResource N2NumericColumn}" />
                        <dxg:GridColumn Binding="{Binding Path=RowData.Row.EdgeScanFeedBuyPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                        FieldName="EdgeScanFeedBuyPrice"
                                        Style="{StaticResource N2NumericColumn}" />
                        <dxg:GridColumn Binding="{Binding Path=RowData.Row.EdgeScanFeedBuyPriceDeltaAdj, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                        FieldName="EdgeScanFeedBuyPriceDeltaAdj"
                                        Style="{StaticResource N2NumericColumn}" />
                        <dxg:GridColumn Binding="{Binding Path=RowData.Row.EdgeScanFeedSellPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                        FieldName="EdgeScanFeedSellPrice"
                                        Style="{StaticResource N2NumericColumn}" />
                        <dxg:GridColumn Binding="{Binding Path=RowData.Row.EdgeScanFeedSellPriceDeltaAdj, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                        FieldName="EdgeScanFeedSellPriceDeltaAdj"
                                        Style="{StaticResource N2NumericColumn}" />
                        <dxg:GridColumn Binding="{Binding Path=RowData.Row.NetTestValue, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                        FieldName="NetTestValue"
                                        Header="Test Value 1"
                                        Style="{StaticResource N2NumericColumn}" />
                        <dxg:GridColumn FieldName="PriceIncrement"
                                        Header="Min Tick" />
                        <dxg:GridColumn x:Name="MinStrikeColumn"
                                        Binding="{Binding Path=RowData.Row.MinStrike, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                        FieldName="MinStrike"
                                        Style="{StaticResource N0NumericColumn}" />
                    </dxg:GridControl>
                    <Grid Grid.Row="4"
                          Grid.Column="1"
                          Grid.ColumnSpan="3"
                          Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="Rows:" />
                        <TextBlock Grid.Column="1"
                                   Margin="3,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding BasketItems.Count}" />
                        <TextBlock Grid.Column="2"
                                   Margin="5,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding Status}" />
                        <dxe:ProgressBarEdit Grid.Column="2"
                                             ContentDisplayMode="Value"
                                             DisplayFormatString="{}{0}%"
                                             Visibility="{Binding ShowProgressBar, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             Value="{Binding ProgressValue}" />
                        <TextBlock Grid.Column="2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#F26543"
                                   Text="{Binding Message}" />
                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal">
                            <TextBlock Margin="5,2,0,1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Text="ID"
                                       TextAlignment="Right" />

                            <TextBlock Padding="3,3,5,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="DemiBold"
                                       Text="{Binding BasketSettings.Uid}"
                                       TextAlignment="Right" />

                            <Views:LatencyIndicatorView Margin="5,2,0,0"
                                                        VerticalAlignment="Center" />
                        </StackPanel>

                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Border>
</UserControl>
