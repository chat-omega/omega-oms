                                                    <dxe:TextEdit Width="250"
                                                                  Height="100"
                                                                  VerticalContentAlignment="Top"
                                                                  IsReadOnly="True"
                                                                  Text="Number of new permutations to generate in each direction (Strike Up and Strike Down).&#10;Example: Perm Count = 1 generates 1 strike up and 1 strike down."
