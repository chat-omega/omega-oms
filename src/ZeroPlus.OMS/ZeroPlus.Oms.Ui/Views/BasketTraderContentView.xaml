                                                    <dxe:TextEdit Width="250"
                                                                  Height="100"
                                                                  VerticalContentAlignment="Top"
                                                                  IsReadOnly="True"
                                                                  Text="Maximum number of perm generations (perms of perms).&#10;Example: Max Gen = 2 means a first-generation perm that reaches the 'Min Edge' will spawn its own perms, then stop."
