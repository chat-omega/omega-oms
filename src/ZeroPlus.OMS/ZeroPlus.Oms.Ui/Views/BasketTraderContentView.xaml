                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding ResubmitOnTimer, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                                <Border BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        Visibility="{Binding ModifyOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Width="65"
                                               Padding="0,2,0,0"
                                               Background="{Binding ModifyCountDown.TotalSeconds, Converter={StaticResource CountdownToBrushConverter}}"
                                               FontFamily="{StaticResource Technology}"
                                               FontSize="18"
                                               Text="{Binding ModifyCountDown, Converter={StaticResource DoubleFormatter}}"
                                               TextAlignment="Center" />
                                </Border>

                                <dxe:ToggleSwitch Margin="5,0,0,0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  AnimationMode="OnToggle"
                                                  CheckedStateContent="Modify ON"
                                                  ContentPlacement="Inside"
                                                  IsChecked="{Binding ModifyOnTimer}"
                                                  ToggleSwitchWidth="100"
                                                  UncheckedStateContent="Modify OFF" />

                                <dxe:SpinEdit Width="65"
                                              Margin="5,0,0,0"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="1,1,0,1"
                                              EditValue="{Binding ModifyIntervalSec, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                              EditValueType="{x:Type sys:Double}"
                                              MinValue="0.15"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True"
                                              Visibility="{Binding ModifyOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <Label Padding="2,3"
                                       Background="#333337"
                                       BorderBrush="#3f3f46"
                                       BorderThickness="0,1,1,1"
                                       Content="Sec"
                                       Visibility="{Binding ModifyOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding ModifyOnTimer, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                                <Border BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        Visibility="{Binding ResubmitOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Width="65"
                                               Padding="0,2,0,0"
                                               Background="{Binding ResubmitCountDown.TotalSeconds, Converter={StaticResource CountdownToBrushConverter}}"
                                               FontFamily="{StaticResource Technology}"
                                               FontSize="18"
                                               Text="{Binding ResubmitCountDown, Converter={StaticResource DoubleFormatter}}"
                                               TextAlignment="Center" />
                                </Border>

                                <dxe:ToggleSwitch Margin="5,0,0,0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  AnimationMode="OnToggle"
                                                  CheckedStateContent="Resubmit ON"
                                                  ContentPlacement="Inside"
                                                  IsChecked="{Binding ResubmitOnTimer}"
                                                  ToggleSwitchWidth="100"
                                                  UncheckedStateContent="Resubmit OFF" />

                                <dxe:SpinEdit Width="65"
                                              Margin="5,0,0,0"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="1,1,0,1"
                                              EditValue="{Binding ResubmitIntervalSec, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              MinValue="1"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True"
                                              Visibility="{Binding ResubmitOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <Label Padding="2,3"
                                       Background="#333337"
                                       BorderBrush="#3f3f46"
                                       BorderThickness="0,1,1,1"
                                       Content="Secs"
                                       Visibility="{Binding ResubmitOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <dxe:SpinEdit Width="65"
                                              Margin="5,0,0,0"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="1,1,0,1"
                                              EditValue="{Binding ResubmitIntervalCount, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              MinValue="1"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True"
                                              Visibility="{Binding ResubmitOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <Label Padding="2,3"
                                       Background="#333337"
                                       BorderBrush="#3f3f46"
                                       BorderThickness="0,1,1,1"
                                       Content="Count"
                                       Visibility="{Binding ResubmitOnTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <dx:SimpleButton Width="155"
                                             Background="#8352c9"
                                             BorderBrush="#f1f1f1"
                                             Command="{Binding SendAutoPermsCommand}"
                                             Content="Submit Auto Perms"
                                             FontWeight="DemiBold"
                                             Visibility="{Binding PermInput, Converter={StaticResource NullToVisibilityConverter}}" />
                            <dx:SimpleButton Width="155"
                                             Margin="5,0,0,0"
                                             Command="{Binding SubmitAllCommand}"
                                             Content="Submit All"
                                             FontWeight="DemiBold"
                                             Glyph="{dx:DXImage SvgImages/Spreadsheet/Time.svg}"
                                             GlyphHeight="{Binding BasketSettings.SubmitWithDelayEnabled, Converter={StaticResource BooleanToGlyphConverter}}"
                                             GlyphWidth="{Binding BasketSettings.SubmitWithDelayEnabled, Converter={StaticResource BooleanToGlyphConverter}}"
                                             IsEnabled="{Binding BasketSettings.SubmitWithDelayEnabled}" />
                            <dx:SimpleButton Width="155"
                                             Margin="5,0,0,0"
                                             Command="{Binding ModifyAllCommand}"
                                             Content="Modify All"
                                             FontWeight="DemiBold"
                                             Glyph="{dx:DXImage SvgImages/Spreadsheet/Time.svg}"
                                             GlyphHeight="{Binding BasketSettings.SubmitWithDelayEnabled, Converter={StaticResource BooleanToGlyphConverter}}"
                                             GlyphWidth="{Binding BasketSettings.SubmitWithDelayEnabled, Converter={StaticResource BooleanToGlyphConverter}}"
                                             IsEnabled="{Binding BasketSettings.SubmitWithDelayEnabled}" />
                            <dx:SimpleButton Width="155"
                                             Margin="5,0,0,0"
                                             Command="{Binding CancelAllCommand}"
                                             Content="Cancel All"
                                             FontWeight="DemiBold" />
                            <dx:SimpleButton Width="25"
                                             Margin="5,0,0,0"
                                             HorizontalAlignment="Right"
                                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                                             GlyphHeight="20"
                                             GlyphWidth="20">
                                <dxb:BarManager.DXContextMenu>
                                    <dxb:PopupControlContainer CloseOnClick="True">
                                        <ItemsControl>
                                            <StackPanel>
                                                <MenuItem Height="25"
                                                          Header="Lock Layout"
                                                          IsCheckable="True"
                                                          IsChecked="{Binding LayoutLocked}">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/Dashboards/LockNavigation.svg}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Checked="MinStrikeSortingChecked"
                                                          Header="Show By Strike"
                                                          IsCheckable="True"
                                                          IsChecked="{Binding BasketSettings.MinStrikeSortingEnabled}"
                                                          Unchecked="MinStrikeSortingUnchecked" />
                                                <MenuItem Height="25"
                                                          Click="Clone"
                                                          Header="Clone">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Click="ShareLayout"
                                                          Header="Share Layout">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Click="SaveLayout"
                                                          Header="Save Layout">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Command="{Binding BrowseLayoutsCommand}"
                                                          Header="Browse Layout">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Click="LoadLayout"
                                                          Header="Load Layout">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <dx:SuperTipItemControlSeparator />
                                                <MenuItem Height="25"
                                                          Click="BasketGrid_ExpandCollapse"
                                                          Header="Expand Rows">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/Spreadsheet/FillDown.svg}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Command="{Binding AddColumnCommand}"
                                                          Header="Add Column">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/Outlook Inspired/AddColumn.svg}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Height="25"
                                                          Command="{Binding ModuleChooserCommand}"
                                                          Header="Sub Modules">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationHorizontal.svg}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <dx:SuperTipItemControlSeparator />
                                                <MenuItem Height="25"
                                                          Padding="0,3,-7,3"
                                                          Header="Vol Trader">
                                                    <MenuItem.Icon>
                                                        <Image Width="15"
                                                               Height="15"
                                                               Source="{dx:DXImage SvgImages/RichEdit/RichEditBookmark.svg}" />
                                                    </MenuItem.Icon>
                                                    <MenuItem Command="{Binding OpenInVolTraderCommand}"
                                                              Header="Create New" />
                                                    <Separator />
                                                    <ItemsControl ItemsSource="{Binding VolTraders}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <MenuItem Command="{Binding DataContext.OpenInVolTraderCommand, ElementName=BasketGrid}"
                                                                          CommandParameter="{Binding}"
                                                                          Header="{Binding Name}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </MenuItem>
                                            </StackPanel>
                                        </ItemsControl>
                                    </dxb:PopupControlContainer>
                                </dxb:BarManager.DXContextMenu>
                            </dx:SimpleButton>
                        </StackPanel>
                    </Grid>

                    <Views:ConfigBrowserView Grid.Row="3"
                                             Grid.Column="1"
                                             Margin="0,15,0,0"
                                             DataContext="{Binding ConfigBrowserViewModel}" />

                    <Slider x:Name="BasketGridScale"
                            Grid.Row="3"
                            Grid.Column="1"
                            Maximum="4"
                            Minimum="0.1"
                            Visibility="Hidden"
                            Value="1" />

                    <GridSplitter Grid.Row="3"
                                  Grid.Column="2"
                                  Width="3"
                                  Margin="0,15,0,0"
                                  HorizontalAlignment="Stretch"
                                  MouseDoubleClick="GridSplitter_MouseDoubleClick" />
                    <dx:SimpleButton Name="ExpandCollapseGridButton"
                                     Grid.Row="3"
                                     Grid.Column="2"
                                     Width="8"
                                     Height="100"
                                     Padding="-1,0,0,0"
                                     HorizontalAlignment="Center"
                                     Click="ExpandCollapseGrid_Click"
                                     Content="3"
                                     CornerRadius="3"
                                     FontFamily="Marlett"
                                     FontSize="10" />
                    <dxg:GridControl Name="BasketGrid"
                                     Grid.Row="3"
                                     Grid.Column="3"
                                     Margin="0,15,0,0"
                                     dx:DXSerializer.StoreLayoutMode="All"
                                     dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                                     AutoGenerateColumns="None"
                                     AutoGeneratedColumns="Grid_ColumnsPopulated"
                                     CurrentItem="{Binding SelectedItem}"
                                     CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                                     EnableSmartColumnsGeneration="False"
                                     ItemsSource="{Binding BasketItems}"
                                     PreviewMouseWheel="OnZoomMouseWheel"
                                     SelectedItems="{Binding SelectedItems}"
                                     SelectionMode="Row">
                        <dxg:GridControl.LayoutTransform>
                            <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=BasketGridScale, Path=Value}" ScaleY="{Binding ElementName=BasketGridScale, Path=Value}" />
                        </dxg:GridControl.LayoutTransform>
                        <dxg:GridControl.Resources>
                            <Style BasedOn="{StaticResource BasketGridColumnBase}"
                                   TargetType="dxg:GridColumn" />
                        </dxg:GridControl.Resources>
                        <dxg:GridControl.View>
                            <dxg:TableView Name="BasketTable"
                                           AllowDragDrop="True"
                                           AllowEditing="False"
                                           AutoWidth="True"
                                           CompleteRecordDragDrop="OnCompleteRecordDragDrop"
                                           DragRecordOver="TableView_DragRecordOver"
                                           DropRecord="TableView_DropRecord"
                                           EditorShowMode="MouseUp"
                                           EnableSelectedRowAppearance="True"
                                           FadeSelectionOnLostFocus="False"
                                           RowStyle="{StaticResource BasketGridStyle}"
                                           ShowGridMenu="TableView_ShowGridMenu"
                                           ShowGroupPanel="False"
                                           ShowIndicator="True"
                                           StartRecordDrag="OnStartRecordDrag">
                                <dxg:TableView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowColumnChooserCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show Column Chooser">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ClearColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Hide All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowAllColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show All Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Height="25"
                                                  Command="{Binding ShowDefaultColumnsCommand}"
                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Header="Show Default Columns">
                                            <MenuItem.Icon>
                                                <Image Width="15"
                                                       Height="15"
                                                       Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </dxg:TableView.ContextMenu>
                                <dxg:TableView.RowCellMenuCustomizations>
                                    <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInComplexOrderTicketCommand}"
                                                       CommandParameter="{Binding Path=SelectedItem, ElementName=BasketGrid}"
                                                       Content="Open in Complex Order Ticket" />
                                    <dxb:BarButtonItem Command="{Binding View.DataContext.SearchTimeAndSalesCommand}"
                                                       CommandParameter="{Binding Path=SelectedItem, ElementName=BasketGrid}"
                                                       Content="Time and Sales" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarButtonItem Command="{Binding View.DataContext.ResetAutomationCommand}"
                                                       CommandParameter="{Binding Path=SelectedItem, ElementName=BasketGrid}"
                                                       Content="Reset Automation" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarButtonItem Command="{Binding View.DataContext.RemoveSelectedCommand}"
                                                       CommandParameter="{Binding Path=SelectedItems, ElementName=BasketGrid}"
                                                       Content="Remove Selected" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarButtonItem Command="{Binding View.DataContext.DuplicateOrderCommand}"
                                                       CommandParameter="{Binding Path=SelectedItem, ElementName=BasketGrid}"
                                                       Content="Create Duplicate Order" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarButtonItem Command="{Binding View.DataContext.CheckAllCommand}"
                                                       Content="Check All" />
                                    <dxb:BarButtonItem Command="{Binding View.DataContext.UncheckAllCommand}"
                                                       Content="Uncheck All" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarButtonItem Command="{Binding View.DataContext.CopySymbolsTosCsvCommand}"
                                                       CommandParameter="{Binding Path=SelectedItems, ElementName=BasketGrid}"
                                                       Content="Copy Selected Symbols (TOS CSV)" />
                                </dxg:TableView.RowCellMenuCustomizations>
                                <dxg:TableView.GroupValueTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="10,0,0,0"
                                                   Text="{Binding Value}" />
                                    </DataTemplate>
                                </dxg:TableView.GroupValueTemplate>
                            </dxg:TableView>
                        </dxg:GridControl.View>

                        <!--  Details Grid  -->
                        <dxg:GridControl.DetailDescriptor>
                            <dxg:DataControlDetailDescriptor ItemsSourceBinding="{Binding Legs}">
                                <dxg:DataControlDetailDescriptor.DataControl>
                                    <dxg:GridControl Name="DetailsGrid"
                                                     AutoGenerateColumns="None"
                                                     CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                                                     EnableSmartColumnsGeneration="False"
                                                     SelectionMode="Row">
                                        <dxg:GridControl.Resources>
                                            <dxe:TextEditSettings x:Key="numeric"
                                                                  Mask="##0.00"
                                                                  MaskType="Numeric" />
                                            <Style BasedOn="{StaticResource BasketGridColumnBase}"
                                                   TargetType="dxg:GridColumn" />
                                            <Style x:Key="LegRowStyle"
                                                   TargetType="dxg:RowControl">
                                                <Style.Setters>
                                                    <Setter Property="Background" Value="{Binding Path=Row.Side, Converter={StaticResource SideToColorConverter}, ConverterParameter='BACKGROUND'}" />
                                                    <Setter Property="Foreground" Value="{Binding Path=Row.Side, Converter={StaticResource SideToColorConverter}, ConverterParameter='FOREGROUND'}" />
                                                </Style.Setters>
                                            </Style>
                                        </dxg:GridControl.Resources>

                                        <dxg:GridControl.View>
                                            <dxg:TableView AutoWidth="True"
                                                           FadeSelectionOnLostFocus="False"
                                                           RowStyle="{StaticResource LegRowStyle}"
                                                           ShowGroupPanel="False"
                                                           ShowIndicator="True"
                                                           VerticalScrollbarVisibility="Auto">
                                                <dxg:TableView.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Height="25"
                                                                  Command="{Binding ShowColumnChooserCommand}"
                                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  Header="Show Column Chooser">
                                                            <MenuItem.Icon>
                                                                <Image Width="15"
                                                                       Height="15"
                                                                       Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Height="25"
                                                                  Command="{Binding ClearColumnsCommand}"
                                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  Header="Hide All Columns">
                                                            <MenuItem.Icon>
                                                                <Image Width="15"
                                                                       Height="15"
                                                                       Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Height="25"
                                                                  Command="{Binding ShowAllColumnsCommand}"
                                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  Header="Show All Columns">
                                                            <MenuItem.Icon>
                                                                <Image Width="15"
                                                                       Height="15"
                                                                       Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Height="25"
                                                                  Command="{Binding ShowDefaultColumnsCommand}"
                                                                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  Header="Show Default Columns">
                                                            <MenuItem.Icon>
                                                                <Image Width="15"
                                                                       Height="15"
                                                                       Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </dxg:TableView.ContextMenu>
                                            </dxg:TableView>
                                        </dxg:GridControl.View>

                                        <dxg:GridColumn FieldName="Symbol"
                                                        Visible="True">
                                            <dxg:GridColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="0,0,2,0"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Data.Symbol}" />
                                                </DataTemplate>
                                            </dxg:GridColumn.CellTemplate>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn FieldName="Description"
                                                        Visible="True">
                                            <dxg:GridColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="0,0,2,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="#F3A202"
                                                               Text="{Binding Data.Description}" />
                                                </DataTemplate>
                                            </dxg:GridColumn.CellTemplate>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn FieldName="Side"
                                                        Visible="True">
                                            <dxg:GridColumn.CellEditTemplate>
                                                <DataTemplate>
                                                    <dxe:ComboBoxEdit AllowUpdateTwoWayBoundPropertiesOnSynchronization="False"
                                                                      IsTextEditable="False"
                                                                      ItemsSource="{Binding Data.Sides}"
                                                                      SelectedItem="{Binding Data.Side, UpdateSourceTrigger=PropertyChanged}">
                                                        <dxmvvm:Interaction.Behaviors>
                                                            <dxmvvm:EventToCommand Command="{Binding View.DataContext.SideChangedCommand}"
                                                                                   CommandParameter="{Binding View.FocusedView.DataControl.CurrentItem, ElementName=BasketGrid}"
                                                                                   EventName="EditValueChanged" />
                                                        </dxmvvm:Interaction.Behaviors>
                                                    </dxe:ComboBoxEdit>
                                                </DataTemplate>
                                            </dxg:GridColumn.CellEditTemplate>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn FieldName="Position"
                                                        Header="Pos"
                                                        Visible="True">
                                            <dxg:GridColumn.CellEditTemplate>
                                                <DataTemplate>
                                                    <dxe:ComboBoxEdit AllowUpdateTwoWayBoundPropertiesOnSynchronization="False"
                                                                      IsTextEditable="False"
                                                                      ItemsSource="{Binding Data.PositionsList}"
