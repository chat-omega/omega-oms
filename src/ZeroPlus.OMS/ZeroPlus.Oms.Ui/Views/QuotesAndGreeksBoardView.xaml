<view:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.QuotesAndGreeksBoardView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                   xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                   xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                   xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                   xmlns:sys="clr-namespace:System;assembly=mscorlib"
                   xmlns:view="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                   Title="{Binding ModuleTitle}"
                   Width="1800"
                   Height="700"
                   MinWidth="520"
                   MinHeight="300"
                   d:DataContext="{d:DesignInstance Type=viewModels:QuotesAndGreeksBoardViewModel}"
                   DataContext="{startuphelpers:DISource Type=viewModels:QuotesAndGreeksBoardViewModel}"
                   WindowStartupLocation="CenterScreen"
                   mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:SaveFileDialogService />
        <dx:WindowedDocumentUIService x:Name="ChartWindowService" />
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <view:ModuleWindow.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:UnixEpochTimeToEmptyStringConverter x:Key="UnixEpochTimeToEmptyStringConverter" />
        <DataTemplate x:Key="TimeSeriesChartView">
            <view:TimeSeriesChartView />
        </DataTemplate>
    </view:ModuleWindow.Resources>

    <dx:ThemedWindow.HeaderItems>
        <view:ModuleHeaderItems />
    </dx:ThemedWindow.HeaderItems>

    <Grid Margin="5,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal">

            <dx:SimpleButton Width="70"
                             Command="{Binding AddCommand}"
                             Content="Add"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Add.svg}"
                             GlyphWidth="13" />

            <dx:SimpleButton Width="70"
                             Margin="5,0,0,0"
                             Command="{Binding StartCommand}"
                             Content="Start"
                             Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"
                             GlyphWidth="13"
                             Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityInverseConverter}}" />

            <dx:SimpleButton Width="70"
                             Margin="5,0,0,0"
                             Command="{Binding StopCommand}"
                             Content="Stop"
                             Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Stop.svg}"
                             GlyphWidth="13"
                             Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Label Height="22"
                   Margin="5,0,0,0"
                   Content="CSV Write Interval" />

            <dxe:CheckEdit Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="5,2,0,0"
                           HorizontalAlignment="Left"
                           Content="Tick by Tick"
                           EditValue="{Binding UseTickByTickInterval}" />

            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding UseTickByTickInterval, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                <dxe:SpinEdit Width="80"
                              Height="22"
                              Margin="5,0,0,0"
                              HorizontalAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding IntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Mask="N0"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
                <Label Height="22"
                       Margin="5,0,0,0"
                       Content="Seconds" />
            </StackPanel>

        </StackPanel>

        <dxg:GridControl x:Name="UpdatesGrid"
                         Grid.Row="1"
                         Margin="0,2"
                         AutoGenerateColumns="None"
                         CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                         EnableSmartColumnsGeneration="False"
                         ItemsSource="{Binding Updates}">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                    <Setter Property="Visible" Value="True" />
                    <Setter Property="IsSmart" Value="True" />
                    <Setter Property="ReadOnly" Value="True" />
                </Style>
                <Style TargetType="dxg:GridControlBand">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView Name="UpdatesTable"
                               AllowDragDrop="True"
                               AllowEditing="False"
                               AutoWidth="True"
                               BandSeparatorWidth="1"
                               CompleteRecordDragDrop="OnCompleteRecordDragDrop"
                               DragRecordOver="TableView_DragRecordOver"
                               DropRecord="TableView_DropRecord"
                               EnableSelectedRowAppearance="True"
                               GroupSummaryDisplayMode="AlignByColumns"
                               NavigationStyle="Cell"
                               RowStyle="{StaticResource RowStyle}"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.RowCellMenuCustomizations>
                        <dxb:BarButtonItem Command="{Binding Path=(dxg:GridControl.ActiveView).DataContext.ShowChartCommand, RelativeSource={RelativeSource Self}}"
                                           CommandParameter="{Binding Path=(dxb:GridPopupMenuBase.GridMenuInfo).Row.Row, RelativeSource={RelativeSource Self}}"
                                           Content="Show Time Series Chart"
                                           Glyph="{dx:DXImage SvgImages/Business Objects/BO_Chart.svg}" />
                    </dxg:TableView.RowCellMenuCustomizations>
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridControl.Bands>
                <dxg:GridControlBand Header="Input">
                    <dxg:GridControlBand.HeaderTemplate>
                        <DataTemplate />
                    </dxg:GridControlBand.HeaderTemplate>
                    <dxg:GridColumn FieldName="Underlying"
                                    HeaderToolTip="Underlying index or stock symbol for the spread" />
                    <dxg:GridColumn FieldName="Symbol"
                                    HeaderToolTip="TOS string representation for the spread" />
                    <dxg:GridColumn FieldName="StartTime"
                                    HeaderToolTip="Time when the session started recording updates for this module" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Underlying">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.UnderBid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="UnderBid"
                                    Header="UL Bid"
                                    HeaderToolTip="Bid quote from the OMS standard market data source for the underlying instrument" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.UnderMid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="UnderMid"
                                    Header="UL Mid"
                                    HeaderToolTip="Mid quote from the OMS standard market data source for the underlying instrument" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.UnderAsk, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="UnderAsk"
                                    Header="UL Ask"
                                    HeaderToolTip="Ask quote from the OMS standard market data source for the underlying instrument" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Adjusted EMAs">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.AdjDaEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="AdjDaEma"
                                    Header="AdjDaEma"
                                    HeaderToolTip="Raptor updated statistics for the spread price" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.AdjVolaEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="AdjVolaEma"
                                    Header="AdjVolaEma"
                                    HeaderToolTip="Raptor updated statistics for the spread price" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.AdjUnderlying, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="AdjUnderlying"
                                    Header="AdjUnderlying"
                                    HeaderToolTip="Underlying price used for delta adjustment (can be anything and updated at any time)" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Quote">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="Bid"
                                    Header="Bid" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Mid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="Mid"
                                    Header="Mid" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="Ask"
                                    Header="Ask" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Ema">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.BidEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="BidEma"
                                    Header="Bid" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.MidEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="MidEma"
                                    Header="Mid" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.AskEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="AskEma"
                                    Header="Ask" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Delta Adj Ema">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaServerSendTime}"
                                    FieldName="EmaServerSendTime"
                                    Header="Time Sent"
                                    HeaderToolTip="Time the EMA server sent the update" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaServerExchangeTime}"
                                    FieldName="EmaServerExchangeTime"
                                    Header="Exch Time"
                                    HeaderToolTip="Actual time stamp from the exchange" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaServerCalcTime}"
                                    FieldName="EmaServerCalcTime"
                                    Header="Calc Time"
                                    HeaderToolTip="Time the EMA server performed the calculation" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaServerDistributionTime}"
                                    FieldName="EmaServerDistributionTime"
                                    Header="Dist Time"
                                    HeaderToolTip="Time the EMA server distributed the data" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaServerUnderSymbol}"
                                    FieldName="EmaServerUnderSymbol"
                                    Header="Ema UL Symbol"
                                    HeaderToolTip="Underlying symbol used by the EMA server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaServerErrorCode}"
                                    FieldName="EmaServerErrorCode"
                                    Header="Ema Err Code"
                                    HeaderToolTip="Error code from the EMA server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaServerErrorMessage}"
                                    FieldName="EmaServerErrorMessage"
                                    Header="Ema Err Msg"
                                    HeaderToolTip="Error message from the EMA server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaServerIntervalMS}"
                                    FieldName="EmaServerIntervalMS"
                                    Header="Ema Interval"
                                    HeaderToolTip="Interval in milliseconds" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.EmaServerUnder, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}"
                                    FieldName="EmaServerUnder"
                                    Header="Underlying Price"
                                    HeaderToolTip="Underlying price used for fit calculation and for delta adjustment" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.DaEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}"
                                    FieldName="DaEma"
                                    Header="DaEma"
                                    HeaderToolTip="Delta Adjusted Option Price EMA" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.DaEmaUnder, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}"
                                    FieldName="DaEmaUnder"
                                    Header="DaEma UL"
                                    HeaderToolTip="Underlying price used for Delta Adjusted Option Price EMA" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.DaEmaTime}"
                                    FieldName="DaEmaTime"
                                    Header="DaEma Time"
                                    HeaderToolTip="Time of the Delta Adjusted Option Price EMA update" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}"
                                    FieldName="VolaEma"
                                    Header="VolaEma"
                                    HeaderToolTip="Delta Adjusted Volatility EMA" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaEmaUnder, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}"
                                    FieldName="VolaEmaUnder"
                                    Header="VolaEma UL"
                                    HeaderToolTip="Underlying price used for Delta Adjusted Volatility EMA" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaEmaTime}"
                                    FieldName="VolaEmaTime"
                                    Header="VolaEma Time"
                                    HeaderToolTip="Time of the Delta Adjusted Volatility EMA update" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.SpreadEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}"
                                    FieldName="SpreadEma"
                                    Header="SpreadEma"
                                    HeaderToolTip="Spread Price EMA" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.SpreadEmaUnder, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}"
                                    FieldName="SpreadEmaUnder"
                                    Header="Spread UL"
                                    HeaderToolTip="Underlying price used for Spread Price EMA" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.SpreadEmaTime}"
                                    FieldName="SpreadEmaTime"
                                    Header="Spread Time"
                                    HeaderToolTip="Time of the Spread Price EMA update" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Hanweck"
                                     HeaderToolTip="IV and Theoretical values calculated by CBOE Hanweck service">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.HanweckSequence, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="HanweckSequence"
                                    Header="Seq"
                                    HeaderToolTip="Sequence number" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.HanweckTheo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="HanweckTheo"
                                    Header="Theo"
                                    HeaderToolTip="Theoretical value calculated by CBOE Hanweck service" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.HanweckTheoAdj, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="HanweckTheoAdj"
                                    Header="Adj Theo"
                                    HeaderToolTip="Adjusted Theoretical value" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.HanweckVol, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N6}}"
                                    FieldName="HanweckVol"
                                    Header="Vol"
                                    HeaderToolTip="Implied Volatility calculated by CBOE Hanweck service" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.HanweckDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="HanweckDelta"
                                    Header="Delta"
                                    HeaderToolTip="Delta calculated by CBOE Hanweck service" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.HanweckVega, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="HanweckVega"
                                    Header="Vega"
                                    HeaderToolTip="Vega calculated by CBOE Hanweck service" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Vola V0"
                                     HeaderToolTip="Connection to independent pricing server calculating an IV surface (Instance V0)">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV0Sequence, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV0Sequence"
                                    Header="Seq"
                                    HeaderToolTip="Sequence number" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV0PriceMetric, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV0PriceMetric"
                                    Header="Price Metric"
                                    HeaderToolTip="Price Metric" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV0Theo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV0Theo"
                                    Header="Theo"
                                    HeaderToolTip="Theoretical value from Vola server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV0TheoAdj, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV0TheoAdj"
                                    Header="Adj Theo"
                                    HeaderToolTip="Adjusted Theoretical value" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV0Vol, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N6}}"
                                    FieldName="VolaV0Vol"
                                    Header="Vol"
                                    HeaderToolTip="Implied Volatility from Vola server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV0ChangeInPremium, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV0ChangeInPremium"
                                    Header="Chg in Px (IV)"
                                    HeaderToolTip="Change in Premium" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV0Spot, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV0Spot"
                                    Header="Spot"
                                    HeaderToolTip="Spot price" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV0Underlying, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV0Underlying"
                                    Header="UL Mid"
                                    HeaderToolTip="Underlying price" />
                    <dxg:GridColumn FieldName="VolaV0Config"
                                    Header="Config"
                                    HeaderToolTip="Configuration string">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Name="PART_Editor"
                                              MaxHeight="20"
                                              TextWrapping="Wrap"
                                              VerticalScrollBarVisibility="Auto" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                        <dxg:GridColumn.CellEditTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Name="PART_Editor"
                                              TextWrapping="WrapWithOverflow"
                                              VerticalScrollBarVisibility="Auto" />
                            </DataTemplate>
                        </dxg:GridColumn.CellEditTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Vola V1"
                                     HeaderToolTip="Connection to independent pricing server calculating an IV surface (Instance V1)">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV1Sequence, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV1Sequence"
                                    Header="Seq"
                                    HeaderToolTip="Sequence number" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV1PriceMetric, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV1PriceMetric"
                                    Header="Price Metric"
                                    HeaderToolTip="Price Metric" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV1Theo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV1Theo"
                                    Header="Theo"
                                    HeaderToolTip="Theoretical value from Vola server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV1TheoAdj, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV1TheoAdj"
                                    Header="Adj Theo"
                                    HeaderToolTip="Adjusted Theoretical value" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV1Vol, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N6}}"
                                    FieldName="VolaV1Vol"
                                    Header="Vol"
                                    HeaderToolTip="Implied Volatility from Vola server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV1ChangeInPremium, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV1ChangeInPremium"
                                    Header="Chg in Px (IV)"
                                    HeaderToolTip="Change in Premium" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV1Spot, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV1Spot"
                                    Header="Spot"
                                    HeaderToolTip="Spot price" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV1Underlying, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV1Underlying"
                                    Header="UL Mid"
                                    HeaderToolTip="Underlying price" />
                    <dxg:GridColumn FieldName="VolaV1Config"
                                    Header="Config"
                                    HeaderToolTip="Configuration string" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Vola V2"
                                     HeaderToolTip="Connection to independent pricing server calculating an IV surface (Instance V2)">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV2Sequence, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV2Sequence"
                                    Header="Seq"
                                    HeaderToolTip="Sequence number" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV2PriceMetric, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV2PriceMetric"
                                    Header="Price Metric"
                                    HeaderToolTip="Price Metric" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV2Theo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV2Theo"
                                    Header="Theo"
                                    HeaderToolTip="Theoretical value from Vola server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV2TheoAdj, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV2TheoAdj"
                                    Header="Adj Theo"
                                    HeaderToolTip="Adjusted Theoretical value" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV2Vol, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N6}}"
                                    FieldName="VolaV2Vol"
                                    Header="Vol"
                                    HeaderToolTip="Implied Volatility from Vola server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV2ChangeInPremium, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV2ChangeInPremium"
                                    Header="Chg in Px (IV)"
                                    HeaderToolTip="Change in Premium" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV2Spot, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV2Spot"
                                    Header="Spot"
                                    HeaderToolTip="Spot price" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV2Underlying, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV2Underlying"
                                    Header="UL Mid"
                                    HeaderToolTip="Underlying price" />
                    <dxg:GridColumn FieldName="VolaV2Config"
                                    Header="Config"
                                    HeaderToolTip="Configuration string" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Vola V3"
                                     HeaderToolTip="Connection to independent pricing server calculating an IV surface (Instance V3)"
                                     Visible="False">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV3Sequence, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV3Sequence"
                                    Header="Seq"
                                    HeaderToolTip="Sequence number" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV3PriceMetric, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV3PriceMetric"
                                    Header="Price Metric"
                                    HeaderToolTip="Price Metric" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV3Theo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV3Theo"
                                    Header="Theo"
                                    HeaderToolTip="Theoretical value from Vola server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV3TheoAdj, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV3TheoAdj"
                                    Header="Adj Theo"
                                    HeaderToolTip="Adjusted Theoretical value" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV3Vol, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N6}}"
                                    FieldName="VolaV3Vol"
                                    Header="Vol"
                                    HeaderToolTip="Implied Volatility from Vola server" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV3ChangeInPremium, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV3ChangeInPremium"
                                    Header="Chg in Px (IV)"
                                    HeaderToolTip="Change in Premium" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV3Spot, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV3Spot"
                                    Header="Spot"
                                    HeaderToolTip="Spot price" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.VolaV3Underlying, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="VolaV3Underlying"
                                    Header="UL Mid"
                                    HeaderToolTip="Underlying price" />
                    <dxg:GridColumn FieldName="VolaV3Config"
                                    Header="Config"
                                    HeaderToolTip="Configuration string" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Implied Quote">
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedBid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedBid"
                                    Header="Imp Bid"
                                    HeaderToolTip="Estimated option theoretical bid calculated by the interpolator app" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedAsk, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedAsk"
                                    Header="Imp Ask"
                                    HeaderToolTip="Estimated option theoretical ask calculated by the interpolator app" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedBidRecordPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedBidRecordPrice"
                                    Header="Bid Record Price"
                                    Visible="False" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedAskRecordPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedAskRecordPrice"
                                    Header="Ask Record Price"
                                    Visible="False" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedBidRecordTheo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedBidRecordTheo"
                                    Header="Bid Record Theo"
                                    Visible="False" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedAskRecordTheo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedAskRecordTheo"
                                    Header="Ask Record Theo"
                                    Visible="False" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedBidRecordTimestamp, Converter={StaticResource UnixEpochTimeToEmptyStringConverter}}"
                                    FieldName="ImpliedBidRecordTimestamp"
                                    Header="Bid Record Timestamp"
                                    Visible="False" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedAskRecordTimestamp, Converter={StaticResource UnixEpochTimeToEmptyStringConverter}}"
                                    FieldName="ImpliedAskRecordTimestamp"
                                    Header="Ask Record Timestamp"
                                    Visible="False" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedBidDeltaMovement, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedBidDeltaMovement"
                                    Header="Bid Delta Movement"
                                    Visible="False" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedAskDeltaMovement, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedAskDeltaMovement"
                                    Header="Ask Delta Movement"
                                    Visible="False" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedBidNonDeltaMovement, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedBidNonDeltaMovement"
                                    Header="Bid Non Delta Movement"
                                    Visible="False" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.ImpliedAskNonDeltaMovement, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ImpliedAskNonDeltaMovement"
                                    Header="Ask Non Delta Movement"
                                    Visible="False" />
                </dxg:GridControlBand>
                <dxg:GridControlBand Header="Control">
                    <dxg:GridControlBand.HeaderTemplate>
                        <DataTemplate />
                    </dxg:GridControlBand.HeaderTemplate>
                    <dxg:GridColumn Width="40"
                                    MinWidth="40"
                                    FieldName="Remove"
                                    FixedWidth="True"
                                    Header="X">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton Width="40"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Command="{Binding View.DataContext.RemoveCommand}"
                                                 CommandParameter="{Binding Path=SelectedItem, ElementName=UpdatesGrid}"
                                                 Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                 GlyphWidth="20" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>
            </dxg:GridControl.Bands>
        </dxg:GridControl>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal">

            <TextBlock Margin="5,0,0,0"
                       Text="Monitored:" />
            <TextBlock Margin="3,0"
                       Text="{Binding Updates.Count}" />

            <TextBlock Margin="5,0,0,0"
                       Text="Logged:" />
            <TextBlock Margin="3,0"
                       Text="{Binding LoggedCount}" />

            <TextBlock Margin="5,0,0,0"
                       Text="Saved:" />
            <TextBlock Margin="3,0"
                       Text="{Binding SavedCount}" />
        </StackPanel>

        <dxe:HyperlinkEdit Grid.Row="2"
                           Margin="5,0"
                           HorizontalAlignment="Right"
                           Command="{Binding OpenFileCommand}"
                           FontSize="10"
                           Text="{Binding FilePath}"
                           ToolTip="Click to open file" />
    </Grid>
</view:ModuleWindow>
