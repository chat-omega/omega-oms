<view:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.ComplexOrderTicketView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                   xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
                   xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                   xmlns:dxi="http://schemas.devexpress.com/winfx/2008/xaml/core/internal"
                   xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                   xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                   xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                   xmlns:local="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                   xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                   xmlns:sys="clr-namespace:System;assembly=mscorlib"
                   xmlns:view="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   Title="{Binding Description}"
                   Width="700"
                   Height="500"
                   MinWidth="400"
                   MinHeight="300"
                   d:DataContext="{d:DesignInstance Type=ViewModels:ComplexOrderTicketViewModel}"
                   d:Height="auto"
                   d:Width="1200"
                   DataContext="{startuphelpers:DISource Type=ViewModels:ComplexOrderTicketViewModel}"
                   FontSize="11"
                   KeyboardNavigation.DirectionalNavigation="Once"
                   MouseDown="TicketWindow_MouseDown"
                   WindowStartupLocation="CenterScreen"
                   mc:Ignorable="d">

    <view:ModuleWindow.Resources>
        <helper:BindingProxy x:Key="ProxyElement"
                             Data="{Binding}" />
        <helper:MultiBooleanToOrVisibilityConverter x:Key="MultiBooleanToOrVisibilityConverter" />
        <helper:MultiBooleanToAndVisibilityConverter x:Key="MultiBooleanToAndVisibilityConverter" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />

        <Style x:Key="OrderTicketGridColumnBase"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="Visible" Value="False" />
            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="N0NumericColumn"
               BasedOn="{StaticResource OrderTicketGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="N0"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="N2NumericColumn"
               BasedOn="{StaticResource OrderTicketGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="N2"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="N3NumericColumn"
               BasedOn="{StaticResource OrderTicketGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="N3"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="C2NumericColumn"
               BasedOn="{StaticResource OrderTicketGridColumnBase}"
               TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="C2"
                                          MaskType="Numeric"
                                          MaskUseAsDisplayFormat="True" />
                </Setter.Value>
            </Setter>
        </Style>

        <helper:OrderToBackBrushConverter x:Key="SideToColorConverter" />
        <helper:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <helper:EnumToDisplayTextConverter x:Key="EnumToDisplayTextConverter" />
        <helper:MultiValueCloneConverter x:Key="MultiValueCloneConverter" />
        <helper:PriceToConnectorConverter x:Key="PriceToConnectorConverter" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:DepthSideToColorConverter x:Key="DepthSideToColorConverter" />
        <helper:HedgeSuggestionToVisibilityConverter x:Key="HedgeSuggestionToVisibilityConverter" />
        <helper:HedgeSuggestionToGlowTriggerConverter x:Key="HedgeSuggestionToGlowTriggerConverter" />
        <helper:HedgeSuggestionToBorderColorConverter x:Key="HedgeSuggestionToBorderColorConverter" />
        <helper:HedgeSuggestionToBorderColorConverter x:Key="HedgeSuggestionToForegroundColorConverter"
                                                      DefaultColor="#FFFFFF" />
        <helper:MultiBooleanToGridVisibilityConverter x:Key="MultiBooleanToGridVisibilityConverter" />
        <helper:RangeToBrushConverter x:Key="RangeToBrushConverter"
                                      AboveRangeBrush="#B73535"
                                      BelowRangeBrush="#0A8E51"
                                      InbetweenRangeBrush="#1a4c35"
                                      RangeCeil="0.50"
                                      RangeFloor="0.45" />
        <dxmvvm:BooleanToObjectConverter x:Key="SignToHoverBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#C44E4E" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#2D9E65" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBackColorConverterRed">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F88F8F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToDeltaAdjButtonTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                FIRM BEST Î” ADJ PX
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                BEST Î” ADJ PX
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TrackerRunningToTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Cancel
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Tracker
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="SignToPressedBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#772F2F" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#1D673F" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="SignToBackBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#B73535" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#0A8E51" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="DepthBookVisibilityToBuyStatusColumnConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                1
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                2
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#FF0000"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#FFFFFF" />
        <dxmvvm:BooleanToObjectConverter x:Key="ValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Transparent" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#FF0000" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="AdjTheoValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F1F1F1
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F3A202
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="IntValueToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F3A202
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F1F1F1
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TicketTypeToStyleConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <Style TargetType="dxg:RowControl">
                    <Style.Setters>
                        <Setter Property="Background" Value="Transparent" />
                    </Style.Setters>
                </Style>
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <Style TargetType="dxg:RowControl">
                    <Style.Setters>
                        <Setter Property="Background" Value="{Binding Path=Row.Side, Converter={StaticResource SideToColorConverter}, ConverterParameter='BACKGROUND'}" />
                        <Setter Property="Foreground" Value="{Binding Path=Row.Side, Converter={StaticResource SideToColorConverter}, ConverterParameter='FOREGROUND'}" />
                    </Style.Setters>
                </Style>
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>

        <Style x:Key="submitButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding IsSellOrder, Converter={StaticResource SignToHoverBrushConverter}}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{Binding IsSellOrder, Converter={StaticResource SignToPressedBrushConverter}}" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="{Binding IsSellOrder, Converter={StaticResource SignToBackBrushConverter}}" />
        </Style>

        <Style x:Key="submitBuyButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D9E65" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1D673F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#0A8E51" />
        </Style>

        <Style x:Key="submitSellButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C44E4E" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#772F2F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#B73535" />
        </Style>

        <Style x:Key="modifyButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A053CC" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#64337F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#8835B7" />
        </Style>
    </view:ModuleWindow.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:VerificationService />
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
        <dxmvvm:DispatcherService />
        <dxmvvm:KeyToCommand Command="{Binding IncrementPriceCommand}"
                             EventName="KeyDown"
                             KeyGesture="Up" />
        <dxmvvm:KeyToCommand Command="{Binding DecrementPriceCommand}"
                             EventName="KeyDown"
                             KeyGesture="Down" />
    </dxmvvm:Interaction.Behaviors>

    <view:ModuleWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Border Width="70"
                    Margin="0,0,0,2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    dxi:WindowChrome.IsHitTestVisibleInChrome="False"
                    Background="#F55762"
                    BorderBrush="#F55762"
                    BorderThickness="2"
                    CornerRadius="2"
                    Visibility="{Binding IsLowLatencyHangManager, Converter={StaticResource BooleanToVisibilityConverter}}">

                <Label Padding="0"
                       HorizontalContentAlignment="Center"
                       Background="#F55762"
                       Content="Lo-La TICKET"
                       FontSize="10"
                       FontWeight="DemiBold"
                       Foreground="#171718" />
            </Border>

            <dxe:ComboBoxEdit Width="80"
                              Margin="15,3,0,0"
                              HorizontalAlignment="Left"
                              ApplyItemTemplateToSelectedItem="True"
                              EditValue="{Binding InstanceMode, UpdateSourceTrigger=PropertyChanged}"
                              IsTextEditable="False"
                              ItemsSource="{Binding InstanceModes}">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding ApplyInstanceModeChangesCommand}"
                                           EventName="EditValueChanged" />
                </dxmvvm:Interaction.Behaviors>
                <dxe:ComboBoxEdit.ItemTemplate>
                    <DataTemplate>
                        <Label Padding="0,0.5"
                               HorizontalAlignment="Center"
                               HorizontalContentAlignment="Center"
                               Content="{Binding Converter={StaticResource EnumToDisplayTextConverter}}" />
                    </DataTemplate>
                </dxe:ComboBoxEdit.ItemTemplate>
            </dxe:ComboBoxEdit>

            <dxe:ComboBoxEdit Width="100"
                              Margin="5,3,0,0"
                              EditValue="{Binding BrokerOverride, UpdateSourceTrigger=PropertyChanged}"
                              IsTextEditable="False"
                              ItemsSource="{Binding OmsCore.Config.AvailableBrokers}"
                              NullText="Use global">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding BrokerChangedCommand}"
                                           EventName="EditValueChanged" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:ComboBoxEdit>

            <dxe:ToggleSwitch Margin="5,3,0,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              AnimationMode="Always"
                              Background="#FF0000"
                              CheckedStateContent="✔  Risk"
                              ContentPlacement="Inside"
                              Focusable="False"
                              FontWeight="Bold"
                              IsChecked="{Binding RiskCheckEnabled}"
                              ToggleSwitchWidth="65"
                              UncheckedStateContent="⚠  Risk" />

            <view:ModuleHeaderItems ShowSaveLocation="True">
                <view:ModuleHeaderItems.AdditionalMenuItemsContent>
                    <DataTemplate>
                        <StackPanel>
                            <Separator />
                            <MenuItem Height="25"
                                      Command="{Binding SearchTimeAndSalesCommand}"
                                      Header="Time and Sales" />
                            <MenuItem Height="25"
                                      Command="{Binding OpenInGammaScalperCommand}"
                                      Header="Open in Gamma Scalper" />
                            <MenuItem Height="25"
                                      Command="{Binding OpenInLiveChartCommand}"
                                      Header="Open in Theo Chart" />
                            <MenuItem Height="25"
                                      Command="{Binding ShowFeeCalculatorCommand}"
                                      Header="Show Fee Calculator" />
                            <MenuItem Height="25"
                                      Command="{Binding SubscribeToIbCommand}"
                                      Header="Request IB Quote" />
                            <Separator />
                            <MenuItem Height="25"
                                      Checked="ShowQuickRoutesCheckBoxUpdated"
                                      Header="Show Quick Routes Panel"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowQuickRoutes}"
                                      Unchecked="ShowQuickRoutesCheckBoxUpdated" />
                            <MenuItem Height="25"
                                      Checked="ShowShowSpeedTraderCheckBoxUpdated"
                                      Header="Show Speed Trader Panel"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowSpeedTrader}"
                                      Unchecked="ShowShowSpeedTraderCheckBoxUpdated">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding ShowSpeedTraderValueCheckedCommand}"
                                                           EventName="Checked" />
                                    <dxmvvm:EventToCommand Command="{Binding ShowSpeedTraderValueCheckedCommand}"
                                                           EventName="Unchecked" />
                                </dxmvvm:Interaction.Behaviors>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Checked="ShowAutoHedgeCheckBoxUpdated"
                                      Header="Show Auto Hedge Panel"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowAutoHedge}"
                                      Unchecked="ShowAutoHedgeCheckBoxUpdated" />
                            <MenuItem Height="25"
                                      Checked="ShowMatrixAlgoPanelChecked"
                                      Header="Show Matrix Algo Routing"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowMatrixAlgoPanel}"
                                      Unchecked="ShowMatrixAlgoPanelUnchecked">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="/Images/matrix.svg" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Checked="ShowOrderInstructionsPanelCheckBoxUpdated"
                                      Header="Show Order Instructions Panel"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowOrderInstructions}"
                                      Unchecked="ShowOrderInstructionsPanelCheckBoxUpdated" />
                            <MenuItem Height="25"
                                      Checked="ShowTimeAndSalesUpdated"
                                      Header="Show Time &amp; Sales"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowTimeAndSales}"
                                      Unchecked="ShowTimeAndSalesUpdated" />
                            <MenuItem Height="25"
                                      Checked="ShowDepthBookUpdated"
                                      Header="Show Depth Boook"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowDepthBook}"
                                      Unchecked="ShowDepthBookUpdated" />
                        </StackPanel>
                    </DataTemplate>
                </view:ModuleHeaderItems.AdditionalMenuItemsContent>
            </view:ModuleHeaderItems>
        </StackPanel>
    </view:ModuleWindow.HeaderItems>

    <Grid PreviewMouseWheel="Grid_PreviewMouseWheel">
        <Grid.RowDefinitions>
            <RowDefinition Height="2" />
            <RowDefinition x:Name="GridSplitterRow">
                <RowDefinition.Height>
                    <MultiBinding Converter="{StaticResource MultiBooleanToGridVisibilityConverter}"
                                  ConverterParameter="Inverse">
                        <Binding Path="ShowDepthBook" />
                        <Binding Path="ShowTimeAndSales" />
                    </MultiBinding>
                </RowDefinition.Height>
            </RowDefinition>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition>
                <RowDefinition.Height>
                    <MultiBinding Converter="{StaticResource MultiBooleanToGridVisibilityConverter}">
                        <Binding Path="ShowDepthBook" />
                        <Binding Path="ShowTimeAndSales" />
                    </MultiBinding>
                </RowDefinition.Height>
            </RowDefinition>
            <RowDefinition Height="23" />
            <RowDefinition Height="2" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="2" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="2" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        Margin="0,0,0,3"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <dxe:ButtonEdit Width="201"
                                Margin="0,0,2,0"
                                AllowDefaultButton="False"
                                Background="#171718"
                                CharacterCasing="Upper"
                                EditValue="{Binding Underlying, UpdateSourceTrigger=PropertyChanged}"
                                EditValuePostDelay="0"
                                SelectAllOnGotFocus="True"
                                SelectAllOnMouseUp="True"
                                TabIndex="1">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:KeyToCommand Command="{Binding SearchUnderlyingCommand}"
                                             KeyGesture="Enter" />
                    </dxmvvm:Interaction.Behaviors>
                    <dxe:ButtonEdit.Buttons>
                        <dxe:ButtonInfo Command="{Binding SearchUnderlyingCommand}"
                                        GlyphKind="Search"
                                        IsDefaultButton="True" />
                    </dxe:ButtonEdit.Buttons>
                </dxe:ButtonEdit>

                <Border Width="70"
                        Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1"
                        ToolTip="{Binding AvgCost}">
                    <DockPanel>
                        <Label Padding="2,0,1,0"
                               VerticalContentAlignment="Center"
                               Content="U PnL"
                               FontSize="9" />
                        <TextBlock Padding="1,3,3,3"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding UnrealizedPnl, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding UnrealizedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                   TextAlignment="Right" />

                    </DockPanel>
                </Border>
                <Border Width="70"
                        Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1">
                    <DockPanel>
                        <Label Padding="2,0,1,0"
                               VerticalContentAlignment="Center"
                               Content="R PnL"
                               FontSize="9" />
                        <TextBlock Padding="1,3,3,3"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding AdjustedPnl, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding AdjustedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                   TextAlignment="Right" />
                    </DockPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Grid.Column="3"
                        Margin="0,0,0,3"
                        Orientation="Horizontal">

                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Content="Basket"
                                 PreviewMouseDown="BasketButton_PreviewMouseDown"
                                 PreviewMouseMove="BasketButton_PreviewMouseMove"
                                 PreviewMouseUp="BasketButton_PreviewMouseUp" />

                <dx:SimpleButton Width="45"
                                 Margin="2,0,2,0"
                                 Padding="0,1"
                                 ButtonKind="Toggle"
                                 Checked="ShowDepthBookUpdated"
                                 Content="Depth"
                                 IsChecked="{Binding ShowDepthBook}"
                                 Unchecked="ShowDepthBookUpdated" />

                <dx:SimpleButton Width="45"
                                 Margin="2,0,2,0"
                                 Padding="0,1"
                                 Command="{Binding CopySymbolCommand}"
                                 Content="Sym"
                                 Glyph="{dx:DXImage SvgImages/DiagramIcons/Copy.svg}"
                                 GlyphWidth="12"
                                 ToolTip="Copy Symbol" />

                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding ExpirationDownCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Exp" />
                        <TextBlock Margin="0,2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Marlett"
                                   Text="6" />
                    </StackPanel>
                </dx:SimpleButton>
                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding ExpirationUpCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Exp" />
                        <TextBlock Margin="0,2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Marlett"
                                   Text="5" />
                    </StackPanel>
                </dx:SimpleButton>
                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding StrikeDownCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Strike" />
                        <TextBlock Margin="0,2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Marlett"
                                   Text="6" />
                    </StackPanel>
                </dx:SimpleButton>
                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding StrikeUpCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Strike" />
                        <TextBlock Margin="0,2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Marlett"
                                   Text="5" />
                    </StackPanel>
                </dx:SimpleButton>
                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding LegOutCommand}"
                                 Content="Leg Out">
                    <dx:SimpleButton.CommandParameter>
                        <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                            <Binding Path="Width"
                                     RelativeSource="{RelativeSource Mode=FindAncestor,
