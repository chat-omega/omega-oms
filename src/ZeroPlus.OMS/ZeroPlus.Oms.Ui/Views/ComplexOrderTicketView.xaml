                                PopupAutoWidth="True"
                                Style="{StaticResource TriggerButtonStyle}">
                    <StackPanel Orientation="Vertical">
                        <ItemsControl Name="AutoCloseTierControl"
                                      ItemsSource="{Binding AutoCloseConfigModels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel HorizontalAlignment="Left"
                                                Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="30" />
                                        </Grid.ColumnDefinitions>
                                        <MenuItem Grid.Column="0"
                                                  Height="25"
                                                  Command="{Binding ElementName=AutoCloseTierControl, Path=DataContext.LoadAutoCloseTierCommand}"
                                                  CommandParameter="{Binding}"
