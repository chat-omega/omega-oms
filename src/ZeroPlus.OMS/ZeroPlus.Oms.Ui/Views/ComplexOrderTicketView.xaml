                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding ReverseCommand}"
                                 Content="Reverse" />
                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding FlipCPCommand}"
                                 Content="Flip C/P" />
                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding OppCPCommand}"
                                 Content="Opp C/P" />
                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding CloneCommand}"
                                 Content="Clone">
                    <dx:SimpleButton.CommandParameter>
                        <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                            <Binding Path="Width"
                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                     AncestorType={x:Type Window}}" />
                            <Binding Path="Height"
                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                     AncestorType={x:Type Window}}" />
                            <Binding Path="Left"
                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                     AncestorType={x:Type Window}}" />
                            <Binding Path="Top"
                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                     AncestorType={x:Type Window}}" />
                        </MultiBinding>
                    </dx:SimpleButton.CommandParameter>
                </dx:SimpleButton>
                <dx:SimpleButton Width="45"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding ContraCommand}"
