                                                  IsCheckable="True"
                                                  IsChecked="{Binding Selected}" />
                                        <MenuItem Grid.Column="1"
                                                  Height="25"
                                                  Padding="0"
                                                  Command="{Binding ElementName=AutoCloseTierControl, Path=DataContext.EditAutoCloseTierCommand}"
