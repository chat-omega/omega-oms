            </StackPanel>

            <Slider x:Name="ComplexLegsGridScale"
                    Grid.Row="3"
                    Grid.Column="0"
                    Maximum="4"
                    Minimum="0.1"
                    Visibility="Hidden"
                    Value="1" />

            <view:IbQuoteView Grid.Row="3"
                              Grid.Column="0"
                              Grid.ColumnSpan="5" />

            <dxg:GridControl x:Name="ComplexLegsGrid"
                             Grid.Row="3"
                             Grid.Column="0"
                             Grid.ColumnSpan="5"
                             MaxHeight="5000"
                             Margin="0,5,0,0"
                             AutoGeneratedColumns="Grid_ColumnsPopulated"
                             CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                             CustomSummaryCommand="{Binding CustomSummaryCommand}"
                             ItemsSource="{Binding Legs}"
                             PreviewMouseWheel="OnZoomMouseWheel"
                             PropertyChanged="ComplexLegsGrid_PropertyChanged"
                             SelectionMode="Row">
                <dxg:GridControl.LayoutTransform>
                    <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=ComplexLegsGridScale, Path=Value}" ScaleY="{Binding ElementName=ComplexLegsGridScale, Path=Value}" />
                </dxg:GridControl.LayoutTransform>
                <dxg:GridControl.Resources>

                    <Style x:Key="LegRowStyle"
                           TargetType="dxg:RowControl">
                        <Style.Setters>
                            <Setter Property="Background" Value="{Binding Path=Row.Side, Converter={StaticResource SideToColorConverter}}" />
                        </Style.Setters>
                    </Style>

                    <Style x:Key="expirationCellStyle"
                           TargetType="dxg:LightweightCellEditor">
                        <Setter Property="Background" Value="{Binding RowData.Row.IsExpirationValid, Converter={StaticResource ValidityToColorConverter}}" />
                        <Style.Triggers>
                            <Trigger Property="IsFocusedCell" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="{Binding RowData.Row.IsExpirationValid, Converter={StaticResource ValidityToColorConverter}}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="strikeCellStyle"
                           TargetType="dxg:LightweightCellEditor">
                        <Setter Property="Background" Value="{Binding RowData.Row.IsStrikeValid, Converter={StaticResource ValidityToColorConverter}}" />
                        <Style.Triggers>
                            <Trigger Property="IsFocusedCell" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="{Binding RowData.Row.IsStrikeValid, Converter={StaticResource ValidityToColorConverter}}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </dxg:GridControl.Resources>
                <dxmvvm:Interaction.Behaviors>
                    <services:UpdateSummaryService />
                </dxmvvm:Interaction.Behaviors>
                <dxg:GridControl.View>
                    <dxg:TableView AllowColumnFiltering="False"
                                   AllowGrouping="False"
                                   AllowSorting="False"
                                   AutoWidth="True"
                                   FadeSelectionOnLostFocus="False"
                                   RowStyle="{Binding ShowDepthBook, Converter={StaticResource TicketTypeToStyleConverter}}"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   ShowIndicator="True"
                                   ShowTotalSummary="True"
                                   VerticalScrollbarVisibility="Auto">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Height="25"
                                          Command="{Binding ShowColumnChooserCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Column Chooser">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ClearColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Hide All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowAllColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowDefaultColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Default Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                        <dxg:TableView.TotalSummaryContentStyle>
                            <Style TargetType="dx:DataContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                            </Style>
                        </dxg:TableView.TotalSummaryContentStyle>
                        <dxg:TableView.RowCellMenuCustomizations>
                            <dxb:BarButtonItem Command="{Binding View.DataContext.DuplicateLegCommand}"
                                               CommandParameter="{Binding Path=SelectedItem, ElementName=ComplexLegsGrid}"
                                               Content="Duplicate leg" />
                        </dxg:TableView.RowCellMenuCustomizations>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn FieldName="Side"
                                HorizontalHeaderContentAlignment="Center"
                                IsSmart="True">
                    <dxg:GridColumn.CellEditTemplate>
                        <DataTemplate>
                            <dxe:ComboBoxEdit IsTextEditable="False"
                                              ItemsSource="{Binding Data.Sides}"
                                              SelectedItem="{Binding Data.Side, UpdateSourceTrigger=PropertyChanged}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding View.DataContext.SideChangedCommand}"
                                                           CommandParameter="{Binding Path=SelectedItem, ElementName=ComplexLegsGrid}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:ComboBoxEdit>
                        </DataTemplate>
                    </dxg:GridColumn.CellEditTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Ratio"
                                HorizontalHeaderContentAlignment="Center"
                                IsSmart="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <Button Padding="0"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding View.DataContext.LockRatioCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Height="15"
                                           MinWidth="15"
                                           Margin="2,1,0,0"
                                           HorizontalAlignment="Left"
                                           Source="{dx:DXImage SvgImages/Icon Builder/Security_Lock.svg}"
                                           Visibility="{Binding View.DataContext.RatioLocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="3,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}}"
                                               Text="{Binding RowData.Row.Ratio}" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Quantity"
                                Header="Qty"
                                HorizontalHeaderContentAlignment="Center"
                                IsSmart="True">
                    <dxg:GridColumn.CellEditTemplate>
                        <DataTemplate>
                            <dxe:SpinEdit AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding Data.Quantity, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Mask="d"
                                          MinValue="0"
                                          PreviewMouseUp="SpinEdit_MouseUp"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding View.DataContext.QuantityChangedCommand}"
                                                           CommandParameter="{Binding Path=SelectedItem, ElementName=ComplexLegsGrid}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>
                        </DataTemplate>
                    </dxg:GridColumn.CellEditTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn MinWidth="100"
                                CellStyle="{StaticResource expirationCellStyle}"
                                FieldName="Expiration"
                                HorizontalHeaderContentAlignment="Center"
                                IsSmart="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Center" />
                    </dxg:GridColumn.EditSettings>

                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding RowData.Row.ExpirationInfo.Info}"
                                       TextAlignment="Center" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>

                    <dxg:GridColumn.CellEditTemplate>
                        <DataTemplate>
                            <dxe:ComboBoxEdit HorizontalContentAlignment="Center"
                                              DisplayFormatString="MMM dd yy"
                                              DisplayMember="Expiration"
                                              IsTextEditable="False"
                                              ItemsSource="{Binding RowData.Row.ExpirationsList}"
                                              PopupHeight="200"
                                              SelectedItem="{Binding RowData.Row.ExpirationInfo, UpdateSourceTrigger=PropertyChanged}">
                                <dxe:ComboBoxEdit.ItemContainerStyle>
                                    <Style TargetType="dxe:ComboBoxEditItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </dxe:ComboBoxEdit.ItemContainerStyle>
                                <dxe:ComboBoxEdit.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="200"
                                              HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0"
                                                   HorizontalAlignment="Left"
                                                   Content="{Binding Expiration}"
                                                   ContentStringFormat="MMM dd yy" />
                                            <Label Grid.Column="1"
                                                   HorizontalAlignment="Center"
                                                   Content="{Binding RootSymbol}" />
                                            <Label Grid.Column="2"
                                                   HorizontalAlignment="Right"
                                                   Content="{Binding Settlement}" />
                                        </Grid>
                                    </DataTemplate>
                                </dxe:ComboBoxEdit.ItemTemplate>
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding View.DataContext.ExpirationChangedCommand}"
                                                           CommandParameter="{Binding Path=SelectedItem, ElementName=ComplexLegsGrid}"
                                                           EventName="EditValueChanged"
                                                           UseDispatcher="True" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:ComboBoxEdit>
                        </DataTemplate>
                    </dxg:GridColumn.CellEditTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn CellStyle="{StaticResource strikeCellStyle}"
                                FieldName="Strike"
                                HorizontalHeaderContentAlignment="Center"
                                IsSmart="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Right">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <Label Margin="0,0,3,-2"
                                       Padding="0"
                                       HorizontalAlignment="Left"
                                       VerticalContentAlignment="Bottom"
                                       Content="*"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#FFDC94"
                                       Visibility="{Binding RowData.Row.Strike.IsUnique, Converter={dx:BooleanToVisibilityConverter}}" />
                                <TextBlock Grid.Column="1"
                                           Margin="0,0,3,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding RowData.Row.Strike.Strike}"
                                           Visibility="{Binding RowData.Row.StrikeVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                    <dxg:GridColumn.CellEditTemplate>
                        <DataTemplate>
                            <dxe:ComboBoxEdit DisplayMember="Strike"
                                              IsTextEditable="False"
                                              ItemsSource="{Binding RowData.Row.StrikesList}"
                                              PopupHeight="200"
                                              SelectedItem="{Binding RowData.Row.Strike, UpdateSourceTrigger=PropertyChanged}"
                                              ShowError="False">
                                <dxe:ComboBoxEdit.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="70"
                                              HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="auto" />
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0"
                                                   HorizontalAlignment="Left"
                                                   Content="{Binding Strike}" />
                                            <Label Grid.Column="1"
                                                   Margin="3,0,0,0"
                                                   HorizontalAlignment="Left"
                                                   VerticalContentAlignment="Bottom"
                                                   Content="*"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="#FFDC94"
                                                   Visibility="{Binding IsUnique, Converter={dx:BooleanToVisibilityConverter}}" />
                                        </Grid>
                                    </DataTemplate>
                                </dxe:ComboBoxEdit.ItemTemplate>
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding View.DataContext.StrikePopupOpenedCommand}"
                                                           EventName="PopupOpened"
                                                           PassEventArgsToCommand="True" />
                                    <dxmvvm:EventToCommand Command="{Binding View.DataContext.StrikeChangedCommand}"
                                                           CommandParameter="{Binding Path=SelectedItem, ElementName=ComplexLegsGrid}"
                                                           EventName="EditValueChanged"
                                                           UseDispatcher="True" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:ComboBoxEdit>
                        </DataTemplate>
                    </dxg:GridColumn.CellEditTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Type"
                                HorizontalHeaderContentAlignment="Center"
                                IsSmart="True">
                    <dxg:GridColumn.CellEditTemplate>
                        <DataTemplate>
                            <dxe:ComboBoxEdit IsTextEditable="False"
                                              ItemsSource="{Binding Data.TypesList}"
                                              SelectedItem="{Binding Data.Type, UpdateSourceTrigger=PropertyChanged}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding View.DataContext.TypeChangedCommand}"
                                                           CommandParameter="{Binding Path=SelectedItem, ElementName=ComplexLegsGrid}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:ComboBoxEdit>
                        </DataTemplate>
                    </dxg:GridColumn.CellEditTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Position"
                                Header="Pos"
