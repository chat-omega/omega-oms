                                     Margin="5,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Bottom"
                                     Command="{Binding SubmitContraAsyncCommand}"
                                     Content="Sell"
                                     FontWeight="DemiBold"
                                     IsEnabled="{Binding IsContraSubmitEnabled}"
                                     Style="{StaticResource submitSellButtonStyle}">
                        <dx:SimpleButton.ContextMenu>
                            <ContextMenu IsEnabled="{Binding IsContraSubmitEnabled}">
                                <MenuItem HorizontalContentAlignment="Center"
                                          Command="{Binding SubmitContraAsyncCommand}"
                                          CommandParameter="Resting"
                                          Header="Sell"
                                          HeaderStringFormat="{}{0} (Resting)"
                                          IsEnabled="{Binding IsContraSubmitEnabled}" />
                            </ContextMenu>
                        </dx:SimpleButton.ContextMenu>
                    </dx:SimpleButton>

                    <dx:SimpleButton Grid.Row="4"
                                     Grid.Column="6"
                                     Width="70"
                                     Height="23"
                                     Margin="5,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Bottom"
                                     Command="{Binding ModifyContraAsyncCommand}"
                                     Content="Modify"
                                     FontWeight="DemiBold"
                                     IsEnabled="{Binding IsContraModifyEnabled}"
                                     Style="{StaticResource modifyButtonStyle}" />

                    <dx:SimpleButton Grid.Row="4"
                                     Grid.Column="7"
                                     Width="70"
                                     Height="23"
                                     Margin="5,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Bottom"
                                     Command="{Binding CancelContraAsyncCommand}"
                                     Content="Cancel"
                                     FontWeight="DemiBold"
                                     IsEnabled="{Binding IsContraCancelEnabled}" />

                    <ItemsControl Name="DepthQuickRoutesSource"
                                  Grid.Row="5"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="4"
                                  Margin="0,10,0,0"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{Binding QuickRoutes}"
                                  Visibility="{Binding Path=ShowQuickRoutes, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel HorizontalAlignment="Left"
                                            Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <dx:SimpleButton MinWidth="20"
                                                 Margin="0,0,5,0"
                                                 Command="{Binding ElementName=DepthQuickRoutesSource, Path=DataContext.LoadQuickRouteCommand}"
                                                 CommandParameter="{Binding Item2}"
                                                 Content="{Binding Item1}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Name="ContraQuickRoutesSource"
                                  Grid.Row="5"
                                  Grid.Column="5"
                                  Grid.ColumnSpan="4"
                                  Margin="0,10,0,0"
                                  HorizontalAlignment="Right"
                                  ItemsSource="{Binding QuickRoutes}"
                                  Visibility="{Binding ShowQuickRoutes, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel HorizontalAlignment="Left"
                                            Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <dx:SimpleButton MinWidth="20"
                                                 Margin="5,0,0,0"
                                                 Command="{Binding ElementName=QuickRoutesSource, Path=DataContext.LoadContraQuickRouteCommand}"
                                                 CommandParameter="{Binding Item2}"
                                                 Content="{Binding Item1}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <dxg:GridControl x:Name="DepthBookBidGrid"
                                 Grid.Row="1"
                                 Grid.Column="0"
                                 MinHeight="70"
                                 MaxHeight="5000"
                                 Margin="0,5,0,0"
                                 AutoGenerateColumns="AddNew"
                                 ItemsSource="{Binding BidDepthItems}"
                                 PreviewMouseDown="DepthBookBidGrid_PreviewMouseDown"
                                 SelectionMode="Row"
                                 ShowBorder="True">
                    <dxg:GridControl.Resources>
                        <Style BasedOn="{StaticResource OrderTicketGridColumnBase}"
                               TargetType="dxg:GridColumn" />
                        <Style x:Key="RowStyle"
                               TargetType="dxg:RowControl">
                            <Style.Setters>
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Background" Value="{Binding Path=Row.Level, Converter={StaticResource DepthSideToColorConverter}, ConverterParameter='BACK'}" />
                                <Setter Property="Foreground" Value="{Binding Path=Row.Level, Converter={StaticResource DepthSideToColorConverter}, ConverterParameter='FORE'}" />
                            </Style.Setters>
                            <Style.Triggers>
                                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{Binding Path=Row.Level, Converter={StaticResource DepthSideToColorConverter}, ConverterParameter='MOVR'}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridControl.Resources>
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AllowSorting="False"
                                       AutoWidth="True"
                                       FadeSelectionOnLostFocus="False"
                                       NavigationStyle="Row"
                                       RowDoubleClickCommand="{Binding BidDepthRowDoubleClickCommand}"
                                       RowStyle="{StaticResource RowStyle}"
                                       ShowGroupPanel="False"
                                       ShowIndicator="True"
                                       ShowTotalSummary="False"
                                       VerticalScrollbarVisibility="Hidden">
                            <dxg:TableView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowColumnChooserCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Column Chooser">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ClearColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Hide All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowAllColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowDefaultColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Default Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                        </dxg:TableView>
                    </dxg:GridControl.View>
                    <dxg:GridColumn Width="20"
                                    MinWidth="20"
                                    AllowMoving="False"
                                    AllowResizing="False"
                                    FieldName="Cancel"
                                    Header=""
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton Command="{Binding View.DataContext.CancelOrderFromDepthTableCommand}"
                                                 CommandParameter="{Binding Path=RowData.Row}"
                                                 Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                 GlyphWidth="18"
                                                 Visibility="{Binding Path=RowData.Row.IsOrder, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="25"
                                    MinWidth="25"
                                    FieldName="CustFlag"
                                    Header="C"
                                    IsSmart="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Text="✔"
                                           Visibility="{Binding Path=RowData.Row.CustFlag, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn FieldName="MMID"
                                    IsSmart="True"
                                    Visible="True" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Price, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="Price"
                                    Header="Bid"
                                    IsSmart="True"
                                    Style="{StaticResource N2NumericColumn}"
                                    Visible="True" />
                    <dxg:GridColumn FieldName="Size"
                                    Header="{Binding BidSizeCaption}"
                                    IsSmart="True"
                                    Visible="True">
                        <dxg:GridColumn.HeaderTemplate>
                            <DataTemplate>
                                <Label HorizontalAlignment="Center"
                                       Content="{Binding ElementName=DepthBookBidGrid, Path=DataContext.BidSizeCaption}" />
                            </DataTemplate>
                        </dxg:GridColumn.HeaderTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>

                <dxg:GridControl x:Name="DepthBookAskGrid"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 MinHeight="70"
                                 MaxHeight="5000"
                                 Margin="0,5,0,0"
                                 AutoGenerateColumns="AddNew"
                                 ItemsSource="{Binding AskDepthItems}"
                                 PreviewMouseDown="DepthBookAskGrid_PreviewMouseDown"
                                 SelectionMode="Row"
                                 ShowBorder="True">
                    <dxg:GridControl.Resources>
                        <Style BasedOn="{StaticResource OrderTicketGridColumnBase}"
                               TargetType="dxg:GridColumn" />
                        <Style x:Key="RowStyle"
                               TargetType="dxg:RowControl">
                            <Style.Setters>
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Background" Value="{Binding Path=Row.Level, Converter={StaticResource DepthSideToColorConverter}, ConverterParameter='BACK'}" />
                                <Setter Property="Foreground" Value="{Binding Path=Row.Level, Converter={StaticResource DepthSideToColorConverter}, ConverterParameter='FORE'}" />
                            </Style.Setters>
                            <Style.Triggers>
                                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{Binding Path=Row.Level, Converter={StaticResource DepthSideToColorConverter}, ConverterParameter='MOVR'}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridControl.Resources>
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AllowSorting="False"
                                       AutoWidth="True"
                                       FadeSelectionOnLostFocus="False"
                                       NavigationStyle="Row"
                                       RowDoubleClickCommand="{Binding AskDepthRowDoubleClickCommand}"
                                       RowStyle="{StaticResource RowStyle}"
                                       ShowGroupPanel="False"
                                       ShowIndicator="True"
                                       ShowTotalSummary="False"
                                       VerticalScrollbarVisibility="Hidden">
                            <dxg:TableView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowColumnChooserCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Column Chooser">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ClearColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Hide All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowAllColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowDefaultColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Default Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                        </dxg:TableView>
                    </dxg:GridControl.View>
                    <dxg:GridColumn FieldName="MMID"
                                    IsSmart="True"
                                    Visible="True" />
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Price, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="Price"
                                    Header="Ask"
                                    IsSmart="True"
                                    Style="{StaticResource N2NumericColumn}"
                                    Visible="True" />
                    <dxg:GridColumn FieldName="Size"
                                    Header="{Binding AskSizeCaption}"
                                    IsSmart="True"
                                    Visible="True">
                        <dxg:GridColumn.HeaderTemplate>
                            <DataTemplate>
                                <Label HorizontalAlignment="Center"
                                       Content="{Binding ElementName=DepthBookAskGrid, Path=DataContext.AskSizeCaption}" />
                            </DataTemplate>
                        </dxg:GridColumn.HeaderTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="25"
                                    MinWidth="25"
                                    FieldName="CustFlag"
                                    Header="C"
                                    IsSmart="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Text="✔"
                                           Visibility="{Binding Path=RowData.Row.CustFlag, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="20"
                                    MinWidth="20"
                                    AllowMoving="False"
                                    AllowResizing="False"
                                    FieldName="Cancel"
                                    Header=""
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton Command="{Binding View.DataContext.CancelOrderFromDepthTableCommand}"
                                                 CommandParameter="{Binding Path=RowData.Row}"
                                                 Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                 GlyphWidth="18"
                                                 Visibility="{Binding Path=RowData.Row.IsOrder, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="2"
                          HorizontalAlignment="Stretch">
                <GridSplitter.Visibility>
                    <MultiBinding Converter="{StaticResource MultiBooleanToAndVisibilityConverter}">
                        <Binding Path="ShowDepthBook" />
                        <Binding Path="ShowTimeAndSales" />
                    </MultiBinding>
                </GridSplitter.Visibility>
            </GridSplitter>

            <dxg:GridControl x:Name="TronTradesGrid"
                             Grid.Column="2"
                             MinHeight="70"
                             MaxHeight="5000"
                             AutoGenerateColumns="AddNew"
                             CurrentItem="{Binding LatestTrade}"
                             ItemsSource="{Binding TronTrades}"
                             Visibility="{Binding Path=ShowTimeAndSales, Converter={StaticResource BooleanToVisibilityConverter}}">
                <dxg:GridControl.Resources>
                    <Style BasedOn="{StaticResource OrderTicketGridColumnBase}"
                           TargetType="dxg:GridColumn" />
                    <Style x:Key="TradeRowStyle"
                           TargetType="dxg:RowControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=IsSelected}"
                                         Value="True">
                                <Setter Property="Background" Value="#1d3c52" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=Row.HasAMatch}"
                                         Value="True">
                                <Setter Property="Background" Value="#8a7750" />
                            </DataTrigger>
                            <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                <Setter Property="Background" Value="#1d3c52" />
                            </Trigger>
                            <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#39393A" />
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#3E596B" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:GridControl.Resources>
                <dxg:GridControl.View>
                    <dxg:TableView AllowEditing="False"
                                   AllowGrouping="False"
                                   AutoWidth="True"
                                   FadeSelectionOnLostFocus="False"
                                   RowStyle="{StaticResource TradeRowStyle}"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   ShowIndicator="True"
                                   VerticalScrollbarVisibility="Auto">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Height="25"
                                          Command="{Binding ShowColumnChooserCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Column Chooser">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ClearColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Hide All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowAllColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowDefaultColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Default Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn FieldName="Symbol"
                                Header="Symbol"
                                ReadOnly="True"
                                Visible="True" />
                <dxg:GridColumn FieldName="TradeTime"
                                Header="Time"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                              Mask="hh:mm:ss.fffff"
                                              MaskType="DateTime"
                                              MaskUseAsDisplayFormat="True" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="LastExch"
                                Header="Exg"
                                ReadOnly="True"
                                Visible="True" />
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.LastPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                FieldName="Price"
                                ReadOnly="True"
                                Style="{StaticResource C2NumericColumn}"
                                Visible="True" />
                <dxg:GridColumn FieldName="Size"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
            </dxg:GridControl>
        </Grid>

        <Border Grid.Row="9"
                Grid.Column="1"
                Margin="0,3,0,0"
                VerticalAlignment="Bottom">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Grid.ColumnSpan="{Binding ShowDepthBook, Converter={StaticResource DepthBookVisibilityToBuyStatusColumnConverter}}"
                           Padding="3,2"
                           Background="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                           Foreground="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                           Text="{Binding Status}" />

                <StackPanel Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Center"
                            Panel.ZIndex="100"
                            Orientation="Horizontal"
                            Visibility="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <dxe:ButtonEdit Grid.Row="0"
                                    Grid.Column="0"
                                    AllowDefaultButton="False"
                                    IsEnabled="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ShowBorder="False"
                                    ShowText="False">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:LoadingIndicatorButtonInfo />
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>
                    <dxe:ButtonEdit Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="-5,0,0,0"
                                    AllowDefaultButton="False"
                                    IsEnabled="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ShowBorder="False"
                                    ShowText="False">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:LoadingIndicatorButtonInfo />
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="0,0,0,0"
                           Padding="3,2"
                           Background="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                           Foreground="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                           Text="{Binding ContraStatus}"
                           TextAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</view:ModuleWindow>
