                                    <DataTemplate>
                                        <dxe:SpinEdit Margin="-1"
                                                      HorizontalContentAlignment="Right"
                                                      AllowSpinOnMouseWheel="True"
                                                      Background="#333337"
                                                      BorderThickness="0"
                                                      DisplayFormatString="N4"
                                                      EditValue="{Binding RowData.Row.DynamicMinMarketWidthAddition, Converter={StaticResource DoubleFormatter}, UpdateSourceTrigger=PropertyChanged}"
