                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>

                            <dxg:GridColumn Width="72"
                                            MinWidth="72"
                                            MaxWidth="72"
                                            FieldName="Addition"
                                            Header="Addition"
                                            IsSmart="False"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:SpinEdit Margin="-1"
                                                      HorizontalContentAlignment="Right"
                                                      AllowSpinOnMouseWheel="True"
                                                      Background="#333337"
                                                      BorderThickness="0"
                                                      DisplayFormatString="N4"
                                                      EditValue="{Binding RowData.Row.DynamicMaxAllowedAboveVolaAddition, Converter={StaticResource DoubleFormatter}, UpdateSourceTrigger=PropertyChanged}"
                                                      EditValueType="{x:Type sys:Double}"
                                                      Increment="0.01"
                                                      IsEnabled="{Binding ElementName=DynamicDteGrid, Path=DataContext.Model.DynamicVolaRangeEnabled}"
