                                                      SelectAllOnGotFocus="True"
                                                      SelectAllOnMouseUp="True">
                                            <dxb:BarManager.DXContextMenu>
                                                <dxb:PopupMenu>
                                                    <dxb:PopupMenu.Items>
                                                        <dxb:BarButtonItem Content="Clear"
                                                                           ItemClick="ResetDynamicWidthLimitSpinEdit" />
