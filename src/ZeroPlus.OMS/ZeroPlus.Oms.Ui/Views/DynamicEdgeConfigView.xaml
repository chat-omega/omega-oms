<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.DynamicEdgeConfigView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Dynamic Edge Config - Editor"
                 Width="1500"
                 Height="500"
                 MinWidth="800"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:DynamicEdgeConfigViewModel}"
                 d:Width="auto"
                 DataContext="{startuphelpers:DISource Type=ViewModels:DynamicEdgeConfigViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <Window.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#F0E7D8" />
        <Style x:Key="RowStyle"
               TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="#1D3C52" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="#1D3C52" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1"
              Grid.Column="1"
              Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Label Width="50"
                   Margin="5,0,0,0"
                   Content="Title" />

            <dxe:TextEdit Grid.Column="1"
                          Margin="5,0,0,0"
                          Text="{Binding Model.Title}" />

            <dx:SimpleButton Grid.Column="3"
                             Width="120"
                             Margin="5,0,0,0"
                             Command="{Binding SaveCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Outlook Inspired/Save.svg}"
                             GlyphHeight="15" />

            <dx:SimpleButton Grid.Column="4"
                             Width="120"
                             Margin="5,0,0,0"
                             Command="{Binding SaveAndLoadCommand}"
                             Content="Save And Load"
                             Glyph="{dx:DXImage SvgImages/RichEdit/SelectTableRow.svg}"
                             GlyphHeight="15" />
        </Grid>

        <StackPanel Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,5"
                    Orientation="Horizontal">
            <Label Width="50"
                   Margin="5,0,0,0"
                   Content="Mode: " />
            <dxe:ToggleSwitch Margin="5,0,0,0"
                              CheckedStateContent="Dynamic Lookup"
                              ContentPlacement="Inside"
                              IsChecked="{Binding Model.DynamicLookupMode}"
                              ToggleSwitchWidth="120"
                              UncheckedStateContent="Static Lookup" />
            <Label Margin="5,0,0,0"
                   Content="Addition Under Divisor: "
                   Visibility="{Binding Model.DynamicLookupMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <dxe:SpinEdit Width="100"
                          HorizontalContentAlignment="Right"
                          AllowSpinOnMouseWheel="True"
                          BorderThickness="0"
                          DisplayFormatString="N0"
                          EditValue="{Binding Model.UnderDivisor}"
                          EditValueType="{x:Type sys:Int32}"
                          Increment="1"
                          Mask="N0"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True"
                          Visibility="{Binding Model.DynamicLookupMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <dxg:GridControl Name="DteGrid"
                         Grid.Row="3"
                         Grid.Column="1"
                         Margin="0,2,0,0"
                         dx:DXSerializer.StoreLayoutMode="All"
                         dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                         AutoGenerateColumns="None"
                         EnableSmartColumnsGeneration="True"
                         ItemsSource="{Binding Model.DteTable}"
                         SelectionMode="Row"
                         Visibility="{Binding Model.DynamicLookupMode, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView Name="DteTable"
                               AllowDragDrop="True"
                               AutoWidth="True"
                               EditorShowMode="MouseUp"
                               EnableSelectedRowAppearance="True"
                               FadeSelectionOnLostFocus="False"
                               RowStyle="{StaticResource RowStyle}"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridControl.Bands>
                <dxg:GridControlBand HorizontalHeaderContentAlignment="Center">
                    <dxg:GridColumn Width="20"
                                    MinWidth="20"
                                    MaxWidth="20"
                                    FieldName="Active"
                                    Header=""
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Background="#333337">
                                    <dxe:CheckEdit HorizontalAlignment="Center"
                                                   BorderThickness="0"
                                                   IsChecked="{Binding RowData.Row.Active}" />
                                </Grid>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header="Filter"
                                     HorizontalHeaderContentAlignment="Center">
                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="DaysToExpiration"
                                    Header="Days To Exp"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N0"
                                              EditValue="{Binding RowData.Row.DaysToExpiration, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="N0"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="82"
                                    FieldName="MinBidAskSize"
                                    FixedWidth="True"
                                    Header="Min B/A Size"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N0"
                                              EditValue="{Binding RowData.Row.MinBidAskSize, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="N0"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="82"
                                    FieldName="MinIncrement"
                                    FixedWidth="True"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              d:MinValue="0"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N2"
                                              EditValue="{Binding RowData.Row.MinIncrement, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment=".01"
                                              Mask="N2"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="82"
                                    FieldName="MinWidth"
                                    FixedWidth="True"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              d:MinValue="0"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N2"
                                              EditValue="{Binding RowData.Row.MinWidth, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment=".01"
                                              Mask="N2"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header="Min Strike Spacing"
                                     HorizontalHeaderContentAlignment="Center">
                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="MinSpacingForVertical"
                                    Header="Verticals"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N0"
                                              EditValue="{Binding RowData.Row.MinSpacingForVertical, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="1"
                                              Mask="N2"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="MinSpacingForFlys"
                                    Header="Butterflys"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N0"
                                              EditValue="{Binding RowData.Row.MinSpacingForFlys, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="1"
                                              Mask="N2"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header="Qty"
                                     HorizontalHeaderContentAlignment="Center">
                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="VerticalQty"
                                    Header="Vertical Qty"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N0"
                                              EditValue="{Binding RowData.Row.VerticalQty, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="N0"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="Qty"
                                    Header="Qty"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N0"
                                              EditValue="{Binding RowData.Row.Qty, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Increment="1"
                                              Mask="N0"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header="Edge"
                                     HorizontalHeaderContentAlignment="Center">
                    <dxg:GridColumn Width="90"
                                    FieldName="BaseEdge"
                                    FixedWidth="True"
                                    Header="Base Edge"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.HeaderTemplate>
                            <DataTemplate>
                                <dxe:ToggleSwitch HorizontalAlignment="Center"
                                                  HorizontalContentAlignment="Center"
                                                  Background="Transparent"
                                                  CheckedStateContent="Base Edge"
                                                  ContentPlacement="Inside"
                                                  IsChecked="{Binding ElementName=DteGrid, Path=DataContext.Model.BaseEdgeEnabled}"
                                                  ToggleSwitchWidth="80"
                                                  UncheckedStateContent="Base Edge" />
                            </DataTemplate>
                        </dxg:GridColumn.HeaderTemplate>
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N3"
                                              EditValue="{Binding RowData.Row.BaseEdge, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              IsEnabled="{Binding ElementName=DteGrid, Path=DataContext.Model.BaseEdgeEnabled}"
                                              Mask="N3"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="CloseEdge"
                                    Header="Close Edge"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N3"
                                              EditValue="{Binding RowData.Row.CloseEdge, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N3"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="LoopMinEdge"
                                    Header="Loop Min Edge"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.LoopMinEdge, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N3"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="AutoPermMinEdge"
                                    Header="Perm Min Edge"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.AutoPermMinEdge, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N3"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="LoopMaxLoss"
                                    Header="Loop Max Loss"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.LoopMaxLoss, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N3"
                                              MaskUseAsDisplayFormat="True"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="AdditionalEdgePerContract"
                                    Header="Addition Per Contract"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N3"
                                              EditValue="{Binding RowData.Row.AdditionalEdgePerContract, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N3"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="AdditionalEdgePerWeightedVega"
                                    Header="Addition Per 1 W. Vega"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              BorderThickness="0"
                                              DisplayFormatString="N3"
                                              EditValue="{Binding RowData.Row.AdditionalEdgePerWeightedVega, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N3"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header="Max Allowed Limits (Fish Loss)"
                                     HorizontalHeaderContentAlignment="Center">
                    <dxg:GridColumn Width="92"
                                    MinWidth="92"
                                    MaxWidth="92"
                                    FieldName="MaxAllowedPercentBid"
                                    FilterPopupMode="Disabled"
                                    Header="% Bid"
                                    IsSmart="False"
                                    Visible="True">
                        <dxg:GridColumn.HeaderTemplate>
                            <DataTemplate>
                                <dxe:ToggleSwitch HorizontalAlignment="Center"
                                                  HorizontalContentAlignment="Center"
                                                  Background="Transparent"
                                                  CheckedStateContent="% Bid ON"
                                                  ContentPlacement="Inside"
                                                  IsChecked="{Binding ElementName=DteGrid, Path=DataContext.Model.PercentBidRangeEnabled}"
                                                  ToggleSwitchWidth="80"
                                                  UncheckedStateContent="% Bid OFF" />
                            </DataTemplate>
                        </dxg:GridColumn.HeaderTemplate>
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="#333337"
                                              BorderThickness="0"
                                              DisplayFormatString="N2"
                                              EditValue="{Binding RowData.Row.MaxAllowedPercentBid, Converter={StaticResource DoubleFormatter}, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              IsEnabled="{Binding ElementName=DteGrid, Path=DataContext.Model.PercentBidRangeEnabled}"
                                              Mask="N2"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True">
                                    <dxb:BarManager.DXContextMenu>
                                        <dxb:PopupMenu>
                                            <dxb:PopupMenu.Items>
                                                <dxb:BarButtonItem Content="Clear"
                                                                   ItemClick="ResetBidPercentLimitSpinEdit" />
                                            </dxb:PopupMenu.Items>
                                        </dxb:PopupMenu>
                                    </dxb:BarManager.DXContextMenu>
                                </dxe:SpinEdit>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="92"
                                    MinWidth="92"
                                    MaxWidth="92"
                                    FieldName="MaxAllowedAboveEma"
                                    FilterPopupMode="Disabled"
                                    Header="EMA"
