<UserControl x:Class="ZeroPlus.Oms.Ui.Views.HunterControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DesignHeight="80"
             d:DesignWidth="340"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helper:SignToBrushConverter x:Key="SignToTickBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#6dc534"
                                     ZeroBrush="#FFFFFF" />
    </UserControl.Resources>
    <Grid>
        <Border Grid.Row="0"
                Padding="5"
                BorderBrush="#3f3f46"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="75" />
                    <ColumnDefinition Width="75" />
                    <ColumnDefinition Width="75" />
                    <ColumnDefinition Width="75" />
                    <ColumnDefinition Width="5" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0"
                       Grid.Column="1"
                       Width="70"
                       Margin="5,2,0,0"
                       HorizontalAlignment="Left"
                       Content="Hunt TTL"
                       IsEnabled="{Binding UseSignalPrice, Converter={StaticResource BooleanNegationConverter}}" />

                <dxe:SpinEdit Grid.Row="0"
                              Grid.Column="2"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding HuntTtl, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              IsEnabled="{Binding UseSignalPrice, Converter={StaticResource BooleanNegationConverter}}"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dxe:CheckEdit Grid.Row="0"
                               Grid.Column="3"
                               Grid.ColumnSpan="3"
                               Margin="5,2,0,0"
                               Content="Use Signal Price"
                               EditValue="{Binding UseSignalPrice, UpdateSourceTrigger=PropertyChanged}" />

                <Label Grid.Row="1"
                       Grid.Column="1"
                       Width="70"
                       Margin="5,2,0,0"
                       HorizontalAlignment="Left"
                       Content="Work TTL" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="2"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding WorkTtl, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="1"
                       Grid.Column="3"
                       Width="70"
                       Margin="5,2,0,0"
                       HorizontalAlignment="Left"
                       Content="Payup Ticks" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="4"
                              Width="70"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding PayupTicks, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Foreground="{Binding PayupTicks, Converter={StaticResource SignToTickBrushConverter}}"
                              Increment="1"
                              PreviewMouseUp="SpinEdit_MouseUp"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dxe:CheckEdit Grid.Row="2"
                               Grid.Column="1"
                               Grid.ColumnSpan="3"
                               Margin="5,2,0,0"
                               Content="Liquidate Only When Complete"
                               EditValue="{Binding LiquidateOnlyWhenComplete, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
