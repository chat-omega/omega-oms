<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.EmaConfigWindowView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:viewmodels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                 Title="Ema Configuration"
                 Width="300"
                 Height="200"
                 MinWidth="250"
                 MinHeight="150"
                 d:DataContext="{d:DesignInstance Type=viewmodels:EmaConfigWindowViewModel}"
                 DataContext="{startuphelpers:DISource Type=viewmodels:EmaConfigWindowViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0"
                    Grid.Column="0">
            <Label Grid.Row="1"
                   Grid.Column="1"
                   Margin="5,2,0,0"
                   Content="EMA-1" />

            <dxe:ToggleSwitch Margin="5,2,0,0"
                              CheckedStateContent="On"
                              ContentPlacement="Inside"
                              IsChecked="{Binding EmaConfigViewModel.EmaConfig.EmaEnabled}"
                              ToggleSwitchWidth="50"
                              UncheckedStateContent="Off" />
        </StackPanel>

        <views:EmaConfigView Grid.Row="0"
                             Grid.Column="1"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             DataContext="{Binding EmaConfigViewModel}" />

        <StackPanel Grid.Row="1"
                    Grid.Column="0">
            <Label Grid.Row="1"
                   Grid.Column="1"
                   Margin="5,2,0,0"
                   Content="EMA-2" />

            <dxe:ToggleSwitch Margin="5,2,0,0"
                              CheckedStateContent="On"
                              ContentPlacement="Inside"
                              IsChecked="{Binding Ema2ConfigViewModel.EmaConfig.EmaEnabled}"
                              ToggleSwitchWidth="50"
                              UncheckedStateContent="Off" />
        </StackPanel>

        <views:EmaConfigView Grid.Row="1"
                             Grid.Column="1"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             DataContext="{Binding Ema2ConfigViewModel}" />

        <StackPanel Grid.Row="2"
                    Grid.Column="0">
            <Label Grid.Row="1"
                   Grid.Column="1"
                   Margin="5,2,0,0"
                   Content="EMA-3" />

            <dxe:ToggleSwitch Margin="5,2,0,0"
                              CheckedStateContent="On"
                              ContentPlacement="Inside"
                              IsChecked="{Binding Ema3ConfigViewModel.EmaConfig.EmaEnabled}"
                              ToggleSwitchWidth="50"
                              UncheckedStateContent="Off" />
        </StackPanel>

        <views:EmaConfigView Grid.Row="2"
                             Grid.Column="1"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             DataContext="{Binding Ema3ConfigViewModel}" />
    </Grid>
</dx:ThemedWindow>
