<views:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.DashboardView"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                    xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                    xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                    xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                    Title="{Binding ModuleTitle}"
                    Width="1600"
                    Height="800"
                    MinWidth="400"
                    MinHeight="300"
                    d:DataContext="{d:DesignInstance Type=ViewModels:DashboardViewModel}"
                    DataContext="{startuphelpers:DISource Type=ViewModels:DashboardViewModel}"
                    WindowStartupLocation="CenterScreen"
                    mc:Ignorable="d">

    <Window.Resources>
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#F0E7D8" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:RangeToBrushConverter x:Key="RangeToColorConverter"
                                      AboveRangeBrush="#0A8E51"
                                      BelowRangeBrush="#FF0000"
                                      InbetweenRangeBrush="#f89942"
                                      RangeCeil="0.10"
                                      RangeFloor="0.02"
                                      UseAbsoluteValue="True" />
    </Window.Resources>

    <dx:ThemedWindow.HeaderItems>
        <views:ModuleHeaderItems />
    </dx:ThemedWindow.HeaderItems>

    <Grid Name="app">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Name="metrics_header"
              Grid.Row="0"
              HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Border Name="total_submissions"
                    Grid.Column="0"
                    Margin="3,2"
                    VerticalAlignment="Center"
                    BorderBrush="#3F3F46"
                    BorderThickness="1">
                <DockPanel>
                    <Label Width="100"
                           Padding="5,0,2,0"
                           VerticalContentAlignment="Center"
                           Background="#171718"
                           Content="TOTAL SUBMISSIONS"
                           FontSize="9" />
                    <TextBlock Padding="1,3,3,3"
                               Background="#171718"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#55b155"
                               Text="{Binding PortfolioManager.TotalOrdersCount, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               TextAlignment="Right" />
                </DockPanel>
            </Border>

            <Border Name="unique_submissions"
                    Grid.Column="1"
                    Margin="3,2"
                    VerticalAlignment="Center"
                    BorderBrush="#3F3F46"
                    BorderThickness="1">
                <DockPanel>
                    <Label Width="100"
                           Padding="5,0,2,0"
                           VerticalContentAlignment="Center"
                           Background="#171718"
                           Content="UNIQUE SUBMISSIONS"
                           FontSize="9" />
                    <TextBlock Padding="1,3,3,3"
                               Background="#171718"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#55b155"
                               Text="{Binding PortfolioManager.UniqueOrdersCount, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               TextAlignment="Right" />
                </DockPanel>
            </Border>

            <Border Name="total_contracts"
                    Grid.Column="2"
                    Margin="3,2"
                    VerticalAlignment="Center"
                    BorderBrush="#3F3F46"
                    BorderThickness="1">
                <DockPanel>
                    <Label Width="100"
                           Padding="5,0,2,0"
                           VerticalContentAlignment="Center"
                           Background="#171718"
                           Content="TOTAL CONTRACTS"
                           FontSize="9" />
                    <TextBlock Padding="1,3,3,3"
                               Background="#171718"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#55b155"
                               Text="{Binding PortfolioManager.FilledContractsCount, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               TextAlignment="Right" />
                </DockPanel>
            </Border>

            <Border Name="unique_contracts"
                    Grid.Column="3"
                    Margin="3,2"
                    VerticalAlignment="Center"
                    BorderBrush="#3F3F46"
                    BorderThickness="1">
                <DockPanel>
                    <Label Width="100"
                           Padding="5,0,2,0"
                           VerticalContentAlignment="Center"
                           Background="#171718"
                           Content="UNIQUE CONTRACTS"
                           FontSize="9" />
                    <TextBlock Padding="1,3,3,3"
                               Background="#171718"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#55b155"
                               Text="{Binding PortfolioManager.UniqueFillsContractsCount, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                               TextAlignment="Right" />
                </DockPanel>
            </Border>

            <Border Name="fill_rate"
                    Grid.Column="4"
                    Margin="3,2"
                    VerticalAlignment="Center"
                    BorderBrush="#3F3F46"
                    BorderThickness="1">
                <DockPanel>
                    <Label Width="100"
                           Padding="5,0,2,0"
                           VerticalContentAlignment="Center"
                           Background="#171718"
                           Content="FILL RATE"
                           FontSize="9" />
                    <TextBlock Padding="1,3,3,3"
                               Background="#171718"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#55b155"
                               Text="{Binding PortfolioManager.FillRate, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Percent}}"
                               TextAlignment="Right" />
                </DockPanel>
            </Border>

            <dx:SimpleButton Name="audio_alert_menu_popup"
                             Grid.Column="5"
                             Width="25"
                             Margin="3,2"
                             Command="{Binding DashboardAlertsCommand}"
                             Glyph="{dx:DXImage SvgImages/XAF/Action_Bell.svg}"
                             GlyphHeight="15" />
        </Grid>
        <Grid Name="main_content"
              Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <dxlc:LayoutGroup Grid.Row="0"
                                  IsCollapsible="True"
                                  Orientation="Vertical"
                                  View="GroupBox">

                    <dxlc:LayoutGroup.HeaderTemplate>
                        <DataTemplate>
                            <Grid Margin="0,-10,0,-10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <dxlc:LayoutItem Grid.Column="0"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                    <TextBlock FontWeight="Bold"
                                               Text="Firm" />
                                </dxlc:LayoutItem>
                                <dxlc:LayoutItem Grid.Column="0"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center">
                                    <dxe:ToggleSwitch CheckedStateContent="CHART"
                                                      ContentPlacement="Inside"
                                                      FontSize="11"
                                                      FontWeight="Bold"
                                                      ToggleSwitchWidth="70"
                                                      UncheckedStateContent="TABLE" />
                                </dxlc:LayoutItem>

                            </Grid>
                        </DataTemplate>
                    </dxlc:LayoutGroup.HeaderTemplate>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <dxg:GridControl Name="FirmGrid"
                                         Grid.Row="1"
                                         dx:DXSerializer.StoreLayoutMode="All"
                                         AutoGenerateColumns="AddNew"
                                         AutoGeneratedColumns="Grid_ColumnsPopulated"
                                         ItemsSource="{Binding PortfolioManager.FirmPortfolios}"
                                         RestoreStateOnSourceChange="True"
                                         SelectedItem="{Binding SelectedPortfolio}"
                                         Visibility="Visible">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding SelectedPortfolioChangedCommand}"
                                                       EventName="SelectedItemChanged" />
                            </dxmvvm:Interaction.Behaviors>
                            <dxg:GridControl.Resources>
                                <Style TargetType="dxg:GridColumn">
                                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                                    <Setter Property="Visible" Value="False" />
                                </Style>
                            </dxg:GridControl.Resources>
                            <dxg:GridControl.View>
                                <dxg:TableView AllowEditing="False"
                                               AutoWidth="True"
                                               NavigationStyle="Row"
                                               ShowGroupPanel="False"
                                               ShowIndicator="True"
                                               ShowTotalSummary="False"
                                               VerticalScrollbarVisibility="Auto">
                                    <dxg:TableView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowColumnChooserCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Column Chooser">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ClearColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Hide All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowAllColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show All Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Height="25"
                                                      Command="{Binding ShowDefaultColumnsCommand}"
                                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Header="Show Default Columns">
                                                <MenuItem.Icon>
                                                    <Image Width="15"
                                                           Height="15"
                                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </dxg:TableView.ContextMenu>
                                    <dxg:TableView.RowCellMenuCustomizations>
                                        <dxb:BarSubItem Content="Breakdown Positions">
                                            <dxb:BarSubItem.Items>
                                                <dxb:BarButtonItem Command="{Binding View.DataContext.BreakdownPortfolioByUnderlyingCommand}"
                                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FirmGrid}"
                                                                   Content="Underlying" />
                                                <dxb:BarButtonItem Command="{Binding View.DataContext.BreakdownPortfolioBySpreadCommand}"
                                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FirmGrid}"
                                                                   Content="Spread" />
                                                <dxb:BarButtonItem Command="{Binding View.DataContext.BreakdownPortfolioBySymbolCommand}"
                                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FirmGrid}"
                                                                   Content="Symbol" />
                                                <dxb:BarButtonItem Command="{Binding View.DataContext.BreakdownPortfolioByStrategyCommand}"
                                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FirmGrid}"
                                                                   Content="Strategy" />
                                                <dxb:BarButtonItem Command="{Binding View.DataContext.BreakdownPortfolioByInstanceCommand}"
                                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FirmGrid}"
                                                                   Content="Instance" />
                                                <dxb:BarButtonItem Command="{Binding View.DataContext.BreakdownPortfolioByRouteCommand}"
                                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FirmGrid}"
                                                                   Content="Route" />
                                                <dxb:BarButtonItem Command="{Binding View.DataContext.BreakdownPortfolioByExchangeCommand}"
                                                                   CommandParameter="{Binding Path=SelectedItem, ElementName=FirmGrid}"
                                                                   Content="Exchange" />
                                            </dxb:BarSubItem.Items>
                                        </dxb:BarSubItem>
                                    </dxg:TableView.RowCellMenuCustomizations>
                                </dxg:TableView>
                            </dxg:GridControl.View>
                            <dxg:GridColumn FieldName="Name"
                                            IsSmart="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="TotalSubmissions"
                                            IsSmart="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="TotalFills"
                                            IsSmart="True"
                                            Visible="True" />
                            <dxg:GridColumn FieldName="MaxResubmitEstimate"
                                            Header="Max Resub Est"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="#0;#0;-" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="MaxResubmitForFill"
                                            Header="Max Resub Fill"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="#0;#0;-" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="AvgResubmitEstimate"
                                            Header="Avg Resub Est"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="#0;#0;-" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="AvgResubmitForFill"
                                            Header="Avg Resub Fill"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="#0;#0;-" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="FillRate"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings DisplayFormat="p2" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="OrderFillRate"
                                            Header="Ord Fill Rate"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings DisplayFormat="p2" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn AllowCellMerge="False"
                                            FieldName="IbOrderFillRate"
                                            Header="IB Fill Rate"
                                            IsSmart="True"
                                            ReadOnly="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Padding="4,2"
                                                   Background="{Binding Path=RowData.Row.IbOrderFillRate, Converter={StaticResource RangeToColorConverter}}"
                                                   Foreground="#FFFFFF"
                                                   Text="{Binding Path=RowData.Row.IbOrderFillRate, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.P2}}"
                                                   TextAlignment="Right" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn Binding="{Binding Path=RowData.Row.NetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Greek}}"
                                            FieldName="NetDelta"
                                            Header="Net Delta"
                                            HorizontalHeaderContentAlignment="Center"
                                            IsSmart="True"
                                            ReadOnly="True">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="NetQty"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding RowData.Row.ShortQty, Converter={StaticResource SignToBrushConverter}}"
                                                       Text="{Binding RowData.Row.ShortQty, StringFormat={}{0:+#0;-#0;-}}" />
                                            <Label Grid.Column="1"
                                                   HorizontalAlignment="Center"
                                                   Content="|" />
                                            <TextBlock Grid.Column="2"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding RowData.Row.LongQty, Converter={StaticResource SignToBrushConverter}}"
                                                       Text="{Binding RowData.Row.LongQty, StringFormat={}{0:+#0;-#0;-}}" />
                                        </Grid>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="AdjustedPnl"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      Foreground="{Binding RowData.Row.AdjustedPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="SingleLegAdjustedPnl"
                                            Header="SL Adj PnL"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      Foreground="{Binding RowData.Row.SingleLegAdjustedPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="SpreadAdjustedPnl"
                                            Header="Spd Adj PnL"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      Foreground="{Binding RowData.Row.SpreadAdjustedPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="UnrealizedPnl"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      Foreground="{Binding RowData.Row.UnrealizedPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="NetPnl"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      Foreground="{Binding RowData.Row.NetPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="RealizedPnl"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      Foreground="{Binding RowData.Row.RealizedPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="LowestRealizedPnl"
                                            Header="Low Real PnL"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      FontWeight="DemiBold"
                                                      Foreground="{Binding RowData.Row.LowestRealizedPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="HighestRealizedPnl"
                                            Header="High Real PnL"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      FontWeight="DemiBold"
                                                      Foreground="{Binding RowData.Row.HighestRealizedPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="LowestAdjustedPnl"
                                            Header="Low Adj PnL"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      FontWeight="DemiBold"
                                                      Foreground="{Binding RowData.Row.LowestAdjustedPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="HighestAdjustedPnl"
                                            Header="High Adj PnL"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="C0"
                                                      FontWeight="DemiBold"
                                                      Foreground="{Binding RowData.Row.HighestAdjustedPnl, Converter={StaticResource SignToBrushConverter}}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="TotalOutOfMarketOrders"
                                            Header="Out Of Mkt"
                                            IsSmart="True"
                                            Visible="True">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="#0;#0;-" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="TotalOutOfMarketFills"
                                            Header="Out Of Mkt Fill"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:TextEdit Name="PART_Editor"
                                                      HorizontalContentAlignment="Right"
                                                      DisplayFormatString="#0;#0;-" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="IntroducingBrokerFee"
                                            IsSmart="True"
                                            Visible="False">
                                <dxg:GridColumn.EditSettings>
                                    <dxe:TextEditSettings Mask="C0"
                                                          MaskType="Numeric"
                                                          MaskUseAsDisplayFormat="True" />
                                </dxg:GridColumn.EditSettings>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="ExecutingBrokerFee"
                                            IsSmart="True"
                                            Visible="False">
