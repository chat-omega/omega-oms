<views:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.CloseSubsMonitorView"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                    xmlns:behaviors="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                    xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                    Width="1700"
                    Height="800"
                    MinWidth="400"
                    MinHeight="300"
                    d:DataContext="{d:DesignInstance Type=ViewModels:CloseSubsMonitorViewModel}"
                    DataContext="{startuphelpers:DISource Type=ViewModels:CloseSubsMonitorViewModel}"
                    WindowStartupLocation="CenterScreen"
                    mc:Ignorable="d">

    <views:ModuleWindow.Resources>
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#B73535"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#10e411" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
    </views:ModuleWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <dxe:CheckEdit Grid.Column="0"
                           Margin="5,0,0,0"
                           Content="Show 0 subs"
                           IsChecked="{Binding ShowZeroSubs}" />

            <Label Grid.Column="1"
                   Margin="15,0,0,0"
                   Content="Min Count" />

            <dxe:SpinEdit Grid.Column="2"
                          Width="70"
                          Margin="5,0,0,0"
                          AllowSpinOnMouseWheel="True"
                          DisplayFormatString="N0"
                          EditValue="{Binding MinCount, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Int32}"
                          Mask="N0"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True">
                <dxmvvm:Interaction.Behaviors>
                    <behaviors:SpinEditFocusSelectionBehavior />
                </dxmvvm:Interaction.Behaviors>
            </dxe:SpinEdit>

            <Label Grid.Column="3"
                   Margin="15,0,0,0"
                   Content="Clear Interval" />

            <dxe:SpinEdit Grid.Column="4"
                          Width="70"
                          Margin="5,0,0,0"
                          AllowSpinOnMouseWheel="True"
                          DisplayFormatString="N0"
                          EditValue="{Binding ClearInterval, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Int32}"
                          Mask="N0"
                          MinValue="30"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True">
                <dxmvvm:Interaction.Behaviors>
                    <behaviors:SpinEditFocusSelectionBehavior />
                </dxmvvm:Interaction.Behaviors>
            </dxe:SpinEdit>
        </Grid>

        <dxg:GridControl x:Name="ModelsGridControl"
                         Grid.Row="2"
                         Grid.Column="1"
                         MinHeight="70"
                         MaxHeight="5000"
                         Margin="0,2"
                         AutoGenerateColumns="None"
                         CurrentItem="{Binding LastModel}"
                         EnableSmartColumnsGeneration="False"
                         ItemsSource="{Binding Models}">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                    <Setter Property="Visible" Value="True" />
                    <Setter Property="IsSmart" Value="True" />
                    <Setter Property="EditSettings">
                        <Setter.Value>
                            <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                        </Setter.Value>
                    </Setter>
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView Name="ModelsTable"
                               AllowDragDrop="True"
                               AllowEditing="False"
                               AutoWidth="True"
                               BandSeparatorWidth="1"
                               EnableSelectedRowAppearance="True"
                               GroupSummaryDisplayMode="AlignByColumns"
                               NavigationStyle="Cell"
                               RowStyle="{StaticResource RowStyle}"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridColumn FieldName="Underlying">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Trader">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Symbol"
                            Visible="False">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="SpreadId">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Margin="2,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#F3A202"
                                   Text="{Binding RowData.Row.SpreadId}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Left" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="CloseSubs" />
            <dxg:GridColumn FieldName="AdjustedPnl"
                            Header="A. PnL">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,0,5,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding RowData.Row.AdjustedPnl, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.AdjustedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Time">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Padding="4,3,3,3"
                                   Foreground="#F1F1F1"
                                   Text="{Binding Path=RowData.Row.Time, StringFormat='{}{0:hh:mm:ss.fff}'}"
                                   TextAlignment="Left" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>
    </Grid>
</views:ModuleWindow>
