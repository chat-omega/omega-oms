<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.AddHedgeUnderlyingView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 Title="Add Hedge Underlying"
                 Width="300"
                 Height="150"
                 d:DataContext="{d:DesignInstance Type=viewModels:AddHedgeUnderlyingViewModel}"
                 DataContext="{startuphelpers:DISource Type=viewModels:AddHedgeUnderlyingViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
        <dxmvvm:KeyToCommand Command="{Binding SearchUnderlyingCommand}"
                             KeyGesture="Enter" />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Content="Symbol - " />
        <dxe:ButtonEdit Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,0,2,0"
                        AllowDefaultButton="False"
                        CharacterCasing="Upper"
                        EditValue="{Binding Underlying, UpdateSourceTrigger=PropertyChanged}"
                        EditValuePostDelay="0"
                        SelectAllOnGotFocus="True"
                        SelectAllOnMouseUp="True"
                        TabIndex="1">
            <dxe:ButtonEdit.Buttons>
                <dxe:ButtonInfo Command="{Binding SearchUnderlyingCommand}"
                                GlyphKind="Search"
                                IsDefaultButton="True" />
            </dxe:ButtonEdit.Buttons>
        </dxe:ButtonEdit>

        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="0,3,0,0"
               Content="Hedge Symbol - "
               Visibility="{Binding ShowFullOptions, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <dxe:TextEdit Grid.Row="2"
                      Grid.Column="2"
                      Margin="0,3,2,0"
                      CharacterCasing="Upper"
                      EditValue="{Binding HedgeUnderlying, UpdateSourceTrigger=PropertyChanged}"
                      EditValuePostDelay="0"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True"
                      TabIndex="1"
                      Visibility="{Binding ShowFullOptions, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Label Grid.Row="3"
               Grid.Column="1"
               Margin="0,3,0,0"
               Content="Hedge Multiplier - "
               Visibility="{Binding ShowFullOptions, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <dxe:SpinEdit Grid.Row="3"
                      Grid.Column="2"
                      Margin="0,3,2,0"
                      CharacterCasing="Upper"
                      EditValue="{Binding HedgeMultiplier, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="1"
                      Mask="N2"
                      MaskUseAsDisplayFormat="True"
                      MinValue="0"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True"
                      TabIndex="1"
                      Visibility="{Binding ShowFullOptions, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <StackPanel Grid.Row="5"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="3,0"
                             Command="{Binding SearchUnderlyingCommand}"
                             Content="Search"
                             IsCancel="True" />
            <dx:SimpleButton Width="80"
                             Margin="3,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel"
                             IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
