<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.StartupWindowView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:Helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 Title="{Binding ModuleTitle}"
                 Width="400"
                 Height="250"
                 DataContext="{startuphelpers:DISource Type=viewModels:StartupWindowViewModel}"
                 ResizeMode="NoResize"
                 ShowTitle="False"
                 Topmost="True"
                 UseLayoutRounding="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:DispatcherService />
        <dxmvvm:CurrentWindowService />
        <dxmvvm:OpenFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <dx:ThemedWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="loginButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#23804d" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#31b36d" />
                </Trigger>

            </Style.Triggers>
            <Setter Property="BorderBrush" Value="#1D673F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#1D673F" />
            <Setter Property="Foreground" Value="#F0F0F0" />
        </Style>

        <Style x:Key="saveButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#333337" />
                    <Setter Property="Glyph" Value="{dx:DXImage SvgImages/Dashboards/UnpinButton.svg}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="False">
                    <Setter Property="Background" Value="#333337" />
                    <Setter Property="Glyph" Value="{dx:DXImage SvgImages/Dashboards/PinButton.svg}" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="BorderThickness" Value="0" />
        </Style>

    </dx:ThemedWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
            <RowDefinition Height="15" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <dxe:HyperlinkEdit Margin="5,0"
                           HorizontalAlignment="Right"
                           Command="{Binding SettingsCommand}"
                           FontSize="10"
                           Text="Settings"
                           ToolTip="App Settings"
                           Visibility="{Binding AuthConnected, Converter={StaticResource BooleanToVisibilityInverseConverter}}" />

        <Image Grid.Row="1"
               Grid.Column="0"
               Grid.ColumnSpan="3"
               Width="230"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"
               Source="{StaticResource ZeroPlus_RGB_WordMark_Full-Color-Reverse}" />

        <Grid Grid.Row="2"
              Grid.Column="0"
              Grid.ColumnSpan="3"
              Width="230"
              Margin="5,5,5,0"
              Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0"
                  Background="#333337">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       Width="20"
                       Height="20"
                       Margin="1,0,1,1"
                       VerticalAlignment="Center"
                       Panel.ZIndex="1"
                       Source="{dx:DXImage SvgImages/Icon Builder/Actions_User.svg}" />

                <dxe:TextEdit Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Height="22"
                              Padding="22,0"
                              BorderBrush="#333337"
                              EditValue="{Binding Username}"
                              FontSize="12"
                              Foreground="#A8A8AA"
                              NullText="Username"
                              NullValue="" />

                <dx:SimpleButton Grid.Column="2"
                                 Width="22"
                                 Margin="0,1,1,2"
                                 Panel.ZIndex="1"
                                 ButtonKind="Toggle"
                                 GlyphHeight="12"
                                 IsChecked="{Binding SaveUser}"
                                 IsTabStop="False"
                                 Style="{StaticResource saveButtonStyle}"
                                 ToolTip="Save Username" />
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,7,0,0"
                  Background="#333337">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Width="20"
                       Height="20"
                       Margin="1,0,1,1"
                       VerticalAlignment="Center"
                       Panel.ZIndex="1"
                       Source="{dx:DXImage SvgImages/XAF/ModelEditor_KeyProperty.svg}" />

                <PasswordBox Grid.Column="0"
                             Grid.ColumnSpan="2"
                             Height="22"
                             Padding="23.5,1.5,0,0"
                             BorderBrush="#333337"
                             Foreground="#A8A8AA">
                    <dxmvvm:Interaction.Behaviors>
                        <Helper:PasswordBoxBindingBehavior Password="{Binding SecurePassword}" />
                    </dxmvvm:Interaction.Behaviors>
                </PasswordBox>
            </Grid>

            <dx:SimpleButton Grid.Row="2"
                             Width="100"
                             Height="24"
                             Margin="0,10,0,0"
                             Padding="0"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             Command="{Binding LoginCommand}"
                             Content="Login"
                             FontFamily="{StaticResource ZPLufga}"
                             FontSize="13"
                             IsDefault="True"
                             Style="{StaticResource loginButtonStyle}" />
        </Grid>

        <dx:WaitIndicator Grid.Row="2"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          Content="{Binding BusyMessage}"
                          DeferedVisibility="{Binding IsBusy}"
                          IsTabStop="False" />

        <StackPanel Grid.Row="3"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
            <TextBlock Margin="5,0,0,0"
                       HorizontalAlignment="Left"
                       FontSize="11"
                       Foreground="#8E8E82"
                       Text="{Binding VersionString}" />
            <TextBlock Margin="5,0"
                       HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="#1D673F"
                       Text="{Binding UpdateStatus}" />
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Center"
                   Foreground="#F26543"
                   Text="{Binding Message}" />

        <dx:DXImage Grid.Row="3"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="{dx:DXImage SvgImages/Icon Builder/Security_WarningCircled2.svg}"
                    ToolTip="Auth Server Disconnected"
                    Visibility="{Binding AuthConnected, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
            <dx:WpfSvgPalette.Palette>
                <dx:WpfSvgPalette OverridesThemeColors="True">
                    <SolidColorBrush x:Key="Red"
                                     Color="Red" />
                </dx:WpfSvgPalette>
            </dx:WpfSvgPalette.Palette>
        </dx:DXImage>

    </Grid>
</dx:ThemedWindow>
