<UserControl x:Class="ZeroPlus.Oms.Ui.Views.TimeSeriesChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewModels:TimeSeriesChartViewModel}">
    <Grid>
        <dxc:ChartControl Margin="5"
                          CrosshairEnabled="True"
                          DataSource="{Binding OhlcPoints}">
            <dxc:ChartControl.Legend>
                <dxc:Legend HorizontalPosition="Right"
                            VerticalPosition="Top" />
            </dxc:ChartControl.Legend>
            <dxc:XYDiagram2D>
                <dxc:XYDiagram2D.AxisX>
                    <dxc:AxisX2D>
                        <dxc:AxisX2D.DateTimeScaleOptions>
                            <dxc:ManualDateTimeScaleOptions MeasureUnit="Minute" />
                        </dxc:AxisX2D.DateTimeScaleOptions>
                        <dxc:AxisX2D.Label>
                            <dxc:AxisLabel TextPattern="{}{A:HH:mm}" />
                        </dxc:AxisX2D.Label>
                    </dxc:AxisX2D>
                </dxc:XYDiagram2D.AxisX>
                <dxc:XYDiagram2D.AxisY>
                    <dxc:AxisY2D>
                        <dxc:AxisY2D.WholeRange>
                            <dxc:Range dxc:AxisY2D.AlwaysShowZeroLevel="False" />
                        </dxc:AxisY2D.WholeRange>
                    </dxc:AxisY2D>
                </dxc:XYDiagram2D.AxisY>
                <dxc:StockSeries2D ArgumentDataMember="Time"
                                   CloseValueDataMember="Close"
                                   HighValueDataMember="High"
                                   LowValueDataMember="Low"
                                   OpenValueDataMember="Open"
                                   Brush="Black">
                    <dxc:StockSeries2D.Model>
                        <dxc:FlatStock2DModel />
                    </dxc:StockSeries2D.Model>
                </dxc:StockSeries2D>
            </dxc:XYDiagram2D>
        </dxc:ChartControl>
    </Grid>
</UserControl>
