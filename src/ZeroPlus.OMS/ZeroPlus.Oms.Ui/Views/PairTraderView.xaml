                <dxe:SpinEdit Grid.Row="7"
                              Grid.Column="1"
                              Width="155"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding ManualLeg1Qty, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Int32}"
                              Mask="N0"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="7"
                       Grid.Column="2"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Leg 2 Qty"
                       FontSize="10" />

                <dxe:SpinEdit Grid.Row="7"
                              Grid.Column="3"
                              Width="155"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding ManualLeg2Qty, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Int32}"
                              Mask="N0"
                              MaskUseAsDisplayFormat="True"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="8"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Buy Terms Ratio"
                       FontSize="10" />

                <dxe:SpinEdit Grid.Row="8"
                              Grid.Column="1"
                              Width="155"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding ManualBuyTermsRatio, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Double}"
                              Mask="{Binding RoundingMask}"
                              MaskUseAsDisplayFormat="True"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="8"
                       Grid.Column="2"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Sell Terms Ratio"
                       FontSize="10" />

                <dxe:SpinEdit Grid.Row="8"
                              Grid.Column="3"
                              Width="155"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding ManualSellTermsRatio, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Double}"
                              Mask="{Binding RoundingMask}"
                              MaskUseAsDisplayFormat="True"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dx:SimpleButton Grid.Row="15"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="2"
                                 Width="90"
                                 Margin="0,0,2,0"
                                 Command="{Binding SendManualOrderCommand}"
                                 Content="Send Pair"
                                 GlyphHeight="13" />

                <dx:SimpleButton Grid.Row="15"
                                 Grid.Column="2"
                                 Grid.ColumnSpan="2"
                                 Width="90"
                                 Margin="5,0,0,0"
                                 Padding="0"
                                 Command="{Binding CancelAllCommand}"
                                 Content="Cancel All"
                                 GlyphHeight="13" />
            </Grid>
        </dxlc:GroupBox>

        <GridSplitter Grid.Row="1"
                      Grid.RowSpan="5"
                      Grid.Column="2"
                      Width="2"
                      HorizontalAlignment="Stretch" />

        <Grid Grid.Row="1"
              Grid.RowSpan="5"
              Grid.Column="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Grid.Column="0"
                    Height="110"
                    Background="#111111"
                    BorderBrush="#929292"
                    BorderThickness="1"
                    CornerRadius="1"
                    Visibility="{Binding ManualMode, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="2"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="BID"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="0"
                           Grid.Column="3"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="MID"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="0"
                           Grid.Column="4"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="ASK"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Margin="15,2"
                           HorizontalAlignment="Left"
                           Content="LIVE"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="3"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Mid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="4"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />

                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Margin="15,2"
                           HorizontalAlignment="Left"
                           Content="EMA"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <dx:SimpleButton Grid.Row="2"
                                     Grid.Column="1"
                                     Width="18"
                                     Height="18"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderBrush="#7ac142"
                                     Command="{Binding ResetEmaCommand}"
                                     CornerRadius="15"
                                     Glyph="{dx:DXImage SvgImages/Dashboards/ResetLayoutOptions.svg}"
                                     GlyphHeight="14" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding BidEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="3"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Ema, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="4"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding AskEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />

                    <Label Grid.Row="3"
                           Grid.Column="0"
                           Margin="15,2"
                           HorizontalAlignment="Left"
                           Content="Hi B - Lo A"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <dx:SimpleButton Grid.Row="3"
                                     Grid.Column="1"
                                     Width="18"
                                     Height="18"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderBrush="#7ac142"
                                     Command="{Binding ResetHighBidLowAskCommand}"
                                     CornerRadius="15"
                                     Glyph="{dx:DXImage SvgImages/Dashboards/ResetLayoutOptions.svg}"
                                     GlyphHeight="14" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="2"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding HighestBid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="4"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding LowestAsk, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />

                </Grid>
            </Border>
            <Border Grid.Row="0"
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Background="#333337"
                    BorderBrush="#929292"
                    BorderThickness="1"
                    CornerRadius="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowWarning}"
                                         Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="beginAnimation">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames FillBehavior="HoldEnd"
                                                                          RepeatBehavior="Forever"
                                                                          Storyboard.TargetProperty="Background.Color"
                                                                          Duration="0:0:2">
                                                <ColorAnimationUsingKeyFrames.KeyFrames>
                                                    <LinearColorKeyFrame KeyTime="0:0:1"
                                                                         Value="#b7363d" />
                                                    <LinearColorKeyFrame KeyTime="0:0:2"
                                                                         Value="#2d2d30" />
                                                </ColorAnimationUsingKeyFrames.KeyFrames>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="beginAnimation" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="1"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="POS"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="0"
                           Grid.Column="2"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="TOTAL BUY"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="0"
                           Grid.Column="3"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="TOTAL SELL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="0"
                           Grid.Column="4"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="AVG BUY"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="0"
                           Grid.Column="5"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="AVG SELL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="0"
                           Grid.Column="5"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="AVG SELL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="0"
                           Grid.Column="6"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="FEES"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#00A8FF"
                               Text="{Binding LcdPosition}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#00A8FF"
                               Text="{Binding TotalBuyQty}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="3"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#00A8FF"
                               Text="{Binding TotalSellQty}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="4"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding AvgBuyPrice, Converter={StaticResource TitleSignToBrushConverter}}"
                               Text="{Binding AvgBuyPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="5"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding AvgSellPrice, Converter={StaticResource TitleSignToBrushConverter}}"
                               Text="{Binding AvgSellPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="6"
                                  HorizontalContentAlignment="Center"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  EditValue="{Binding Fees}"
                                  EditValueType="{x:Type sys:Double}"
                                  FontWeight="Bold"
                                  Increment="0.01"
                                  Mask="{Binding RoundingMask}"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="REAL PnL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="2"
                           Grid.Column="2"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="U.REAL PnL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="2"
                           Grid.Column="3"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="NET PnL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="2"
                           Grid.Column="4"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="HIGH BID"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="2"
                           Grid.Column="5"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="LOW ASK"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <Label Grid.Row="2"
                           Grid.Column="6"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           Content="SEC FEE"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding AdjPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                               Text="{Binding AdjPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />
                    <TextBlock Grid.Row="3"
                               Grid.Column="2"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding UnrealPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                               Text="{Binding UnrealPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />
                    <TextBlock Grid.Row="3"
                               Grid.Column="3"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding NetPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                               Text="{Binding NetPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="4"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#32ce4a"
                               Text="{Binding HighestBuyPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="5"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#f4241e"
                               Text="{Binding LowestSellPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}" />

                    <dxe:SpinEdit Grid.Row="3"
                                  Grid.Column="6"
                                  HorizontalContentAlignment="Center"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  EditValue="{Binding SecFees}"
                                  EditValueType="{x:Type sys:Double}"
                                  FontWeight="Bold"
                                  Increment="0.000001"
                                  Mask="N7"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />
                </Grid>
            </Border>
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <dx:SimpleButton Width="70"
                                 Margin="2"
                                 Command="{Binding SwitchOrderbookToAllCommand}"
                                 Content="All" />
                <dx:SimpleButton Width="70"
                                 Margin="2"
                                 Command="{Binding SwitchOrderbookToFillsCommand}"
                                 Content="Filled" />
            </StackPanel>
            <dxg:GridControl x:Name="OrdersGrid"
                             Grid.Row="3"
                             Grid.Column="0"
                             Grid.ColumnSpan="2"
                             MinHeight="70"
                             MaxHeight="5000"
                             Margin="0,2,0,5"
                             HorizontalAlignment="Center"
                             AutoGenerateColumns="AddNew"
                             CurrentItem="{Binding LastPairOrder}"
                             ItemsSource="{Binding PairOrders}">
                <dxg:GridControl.LayoutTransform>
                    <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=GridScale, Path=Value}" ScaleY="{Binding ElementName=GridScale, Path=Value}" />
                </dxg:GridControl.LayoutTransform>
                <dxg:GridControl.Resources>
                    <Style TargetType="dxg:GridColumn">
                        <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                        <Setter Property="Visible" Value="False" />
                    </Style>
                    <Style x:Key="PairOrderRowStyle"
                           TargetType="dxg:RowControl">
                        <Style.Setters>
                            <Setter Property="FontWeight" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='FONTWEIGHT'}" />
                            <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Background'}" />
                            <Setter Property="Foreground" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Foreground'}" />
                        </Style.Setters>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=IsSelected}"
                                         Value="True">
                                <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                            </DataTrigger>
                            <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='MouseOver'}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </dxg:GridControl.Resources>
                <dxg:GridControl.View>
                    <dxg:TableView Name="OrdersTableView"
                                   AllowEditing="False"
                                   AllowGrouping="False"
                                   AutoWidth="True"
                                   FadeSelectionOnLostFocus="False"
                                   RowStyle="{StaticResource PairOrderRowStyle}"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   ShowIndicator="True"
                                   VerticalScrollbarVisibility="Auto">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Height="25"
                                          Command="{Binding ShowColumnChooserCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Column Chooser">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ClearColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Hide All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowAllColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowDefaultColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Default Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn FieldName="SubmitTime"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                              Mask="hh:mm:ss.ffff"
                                              MaskType="DateTime"
                                              MaskUseAsDisplayFormat="True" />
