                                  Margin="1"
                                  Padding="0"
                                  AllowSpinOnMouseWheel="True"
                                  BorderThickness=".6"
                                  EditValue="{Binding SellPercentChange}"
                                  EditValueType="{x:Type sys:Double}"
                                  FontSize="10"
                                  Increment=".01"
                                  Mask="N2"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  Visibility="Collapsed" />

                    <dx:SimpleButton Grid.Row="0"
                                     Grid.Column="11"
                                     Width="20"
                                     Height="20"
                                     Margin="1"
                                     BorderThickness=".6"
                                     Command="{Binding RaiseSellsByPercentCommand}"
                                     CornerRadius="2"
                                     Glyph="{dx:DXImage SvgImages/Spreadsheet/Top10Percent.svg}"
                                     GlyphHeight="13"
                                     Visibility="Collapsed" />

                    <dx:SimpleButton Grid.Row="0"
                                     Grid.Column="12"
                                     Width="20"
                                     Height="20"
                                     Margin="1"
                                     BorderThickness=".6"
                                     Command="{Binding ReduceSellsByPercentCommand}"
                                     CornerRadius="2"
                                     Glyph="{dx:DXImage SvgImages/Spreadsheet/Bottom10Percent.svg}"
                                     GlyphHeight="13"
                                     Visibility="Collapsed" />

                    <dx:SimpleButton Grid.Row="0"
                                     Grid.Column="13"
                                     Width="20"
                                     Height="20"
                                     Margin="5,1,1,1"
                                     BorderThickness=".6"
                                     Command="{Binding AddSellTriggerCommand}"
                                     CornerRadius="2"
                                     Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Add.svg'}"
                                     GlyphHeight="13" />

                </Grid>

                <dxg:GridControl Grid.Row="4"
                                 Grid.Column="0"
                                 MaxHeight="1000"
                                 AllowCollectionView="False"
                                 AllowInitiallyFocusedRow="False"
                                 Background="{Binding OrderEnabled, Converter={StaticResource OrderEnabledToSellBackBrushConverter}}"
                                 ItemsSource="{Binding SellTriggers}">
                    <dxg:GridControl.Style>
                        <Style TargetType="dxg:GridControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSellWarning}"
                                             Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="beginAnimation">
                                            <Storyboard>
                                                <ColorAnimationUsingKeyFrames FillBehavior="HoldEnd"
                                                                              RepeatBehavior="Forever"
                                                                              Storyboard.TargetProperty="Background.Color"
                                                                              Duration="0:0:2">
                                                    <ColorAnimationUsingKeyFrames.KeyFrames>
                                                        <LinearColorKeyFrame KeyTime="0:0:1"
                                                                             Value="#b7363d" />
                                                        <LinearColorKeyFrame KeyTime="0:0:2"
                                                                             Value="#2d2d30" />
                                                    </ColorAnimationUsingKeyFrames.KeyFrames>
                                                </ColorAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="beginAnimation" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridControl.Style>
                    <dxg:GridControl.View>
                        <dxg:TableView x:Name="SellTriggersLookupView"
                                       AllowEditing="False"
                                       AllowGrouping="False"
                                       AllowSorting="True"
                                       AutoWidth="True"
                                       ShowGroupPanel="False"
                                       ShowIndicator="True"
                                       VerticalScrollbarVisibility="Auto">
                            <dxg:TableView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowColumnChooserCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Column Chooser">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ClearColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Hide All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowAllColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowDefaultColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Default Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridColumn Width="25"
                                    AllowEditing="True"
                                    FieldName="Sent"
                                    Header=""
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <dx:DXImage Grid.Row="0"
                                                Grid.Column="0"
                                                Height="15"
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                Source="{dx:DXImage 'SvgImages/Icon Builder/Security_WarningCircled2.svg'}"
                                                Visibility="{Binding RowData.Row.Sent, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                                        <dx:WpfSvgPalette.Palette>
                                            <dx:WpfSvgPalette OverridesThemeColors="True">
                                                <SolidColorBrush x:Key="Red"
                                                                 Color="#ffb900" />
                                            </dx:WpfSvgPalette>
                                        </dx:WpfSvgPalette.Palette>
                                    </dx:DXImage>

                                    <dx:DXImage Grid.Row="0"
                                                Grid.Column="0"
                                                Height="15"
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_CheckCircled.svg'}"
                                                Visibility="{Binding RowData.Row.Sent, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="35"
                                    FieldName="Level"
                                    Header="#"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True" />

                    <dxg:GridColumn AllowEditing="True"
                                    FieldName="State"
                                    Header="State"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True" />

                    <dxg:GridColumn Width="65"
                                    AllowEditing="True"
                                    FieldName="Base"
                                    Header="Base"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True"
                                    Visible="{Binding PairTriggerType, Converter={StaticResource PairTriggerTypeToVisibilityConverter}}">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.Base, Converter={StaticResource DoubleFormatter}}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              IsEnabled="{Binding View.DataContext.PairTriggerType, Converter={StaticResource PairTriggerTypeToVisibilityConverter}}"
                                              Mask="{Binding View.DataContext.RoundingMask}"
                                              MaskUseAsDisplayFormat="True"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="65"
                                    AllowEditing="True"
                                    Binding="{Binding Path=RowData.Row.ChangeToEma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}"
                                    FieldName="ChangeToEma"
                                    Header="Req"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True" />

                    <dxg:GridColumn AllowEditing="True"
                                    FieldName="ProfitTarget"
                                    Header="Profit"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.ProfitTarget, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N3}}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment="0.01"
                                              Mask="N3"
                                              MaskUseAsDisplayFormat="True"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn AllowEditing="True"
                                    FieldName="Qty"
                                    Header="Qty"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.Qty, Converter={StaticResource DoubleFormatter}}"
                                              EditValueType="{x:Type sys:Int32}"
                                              Mask="N0"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn AllowCellMerge="False"
                                    Binding="{Binding Path=RowData.Row.OpeningPx, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="OpeningPx"
                                    Header="Open Px"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True"
                                    ReadOnly="True"
                                    Visible="True" />
                    <dxg:GridColumn AllowCellMerge="False"
                                    Binding="{Binding Path=RowData.Row.ClosingPx, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                    FieldName="ClosingPx"
                                    Header="Close Px"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True"
                                    ReadOnly="True"
                                    Visible="True" />
                    <dxg:GridColumn AllowCellMerge="False"
                                    FieldName="TotalUnitPnl"
                                    Header="Total Tick PnL"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="-1"
                                           Padding="3"
                                           Background="Transparent"
                                           Foreground="{Binding RowData.Row.TotalUnitPnl, Converter={StaticResource SignToBrushConverter}}"
                                           Text="{Binding RowData.Row.TotalUnitPnl, Converter={StaticResource DoubleFormatter}}"
                                           TextAlignment="Right" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn AllowCellMerge="False"
                                    FieldName="AvgUnitPnl"
                                    Header="Avg Tick PnL"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="-1"
                                           Padding="3"
                                           Background="Transparent"
                                           Foreground="{Binding RowData.Row.AvgUnitPnl, Converter={StaticResource SignToBrushConverter}}"
                                           Text="{Binding RowData.Row.AvgUnitPnl, Converter={StaticResource DoubleFormatter}}"
                                           TextAlignment="Right" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn AllowCellMerge="False"
                                    FieldName="Target"
                                    Header="Target"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Margin="2,0,0,0"
                                               Padding="3"
                                               HorizontalAlignment="Left"
                                               Background="Transparent"
                                               Foreground="{Binding RowData.Row.TargetDiff, Converter={StaticResource SignToBrushConverter}}"
                                               Text="{Binding RowData.Row.TargetDiff, Converter={StaticResource DoubleFormatter}}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="-1"
                                               Padding="3"
                                               HorizontalAlignment="Right"
                                               Background="Transparent"
                                               Text="{Binding RowData.Row.Target, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                                </Grid>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn AllowCellMerge="False"
                                    FieldName="OpenClose"
                                    Header="Open-Close"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Background="{Binding RowData.Row.OpenCloseCounter.IsFlat, Converter={StaticResource BooleanToOpenPosColorConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Margin="-1"
                                               Padding="3"
                                               Background="Transparent"
                                               Text="{Binding RowData.Row.OpenCloseCounter.Open, Converter={StaticResource DoubleFormatter}}"
                                               TextAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Margin="-1"
                                               Padding="3"
                                               Background="Transparent"
                                               Text="{Binding RowData.Row.OpenCloseCounter.Close, Converter={StaticResource DoubleFormatter}}"
                                               TextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="20"
                                    FieldName="Reset"
                                    Header=""
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton Height="20"
                                                 Padding="0"
                                                 BorderThickness="0"
                                                 Command="{Binding View.DataContext.ResetCommand}"
                                                 CommandParameter="{Binding RowData.Row}"
                                                 Glyph="{dx:DXImage SvgImages/Outlook Inspired/ResetView.svg}"
                                                 GlyphWidth="15" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="20"
                                    FieldName="Remove"
                                    Header=""
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton Height="20"
                                                 Padding="0"
                                                 BorderThickness="0"
                                                 Command="{Binding View.DataContext.RemoveSellTriggerCommand}"
                                                 CommandParameter="{Binding RowData.Row}"
                                                 Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Delete.svg}"
                                                 GlyphWidth="15" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </Grid>
        </dxlc:GroupBox>
        <Grid Grid.Row="6"
              Grid.Column="1"
              Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Height="22"
                       Padding="3,2"
                       Panel.ZIndex="1"
                       Background="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding Status}" />
            <TextBlock Grid.Column="1"
                       Height="22"
                       Padding="3,2"
                       Panel.ZIndex="1"
                       Background="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding ContraStatus}"
                       TextAlignment="Right" />
        </Grid>
    </Grid>
</dx:ThemedWindow>
