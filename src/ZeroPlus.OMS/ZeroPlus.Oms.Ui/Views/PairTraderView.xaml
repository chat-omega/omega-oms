<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.PairTraderView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:local="clr-namespace:ZeroPlus.Oms.Ui.Views"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Pairs Trader"
                 Width="1400"
                 Height="800"
                 d:DataContext="{d:DesignInstance Type=ViewModels:PairTraderViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:PairTraderViewModel}"
                 mc:Ignorable="d">

    <dx:ThemedWindow.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SideToColorConverter x:Key="SideToColorConverter" />
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:PairTriggerTypeToVisibilityConverter x:Key="PairTriggerTypeToVisibilityConverter" />
        <helper:TriggerMethodToDisplayTextConverter x:Key="TriggerMethodToDisplayTextConverter" />
        <helper:TriggerMethodToMinTriggerValueConverter x:Key="TriggerMethodToSpreadEnabledConverter"
                                                        Inverse="True" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
        <helper:SignToBrushConverter x:Key="TitleSignToBrushConverter"
                                     NegativeBrush="#f4241e"
                                     PositiveBrush="#32ce4a"
                                     ZeroBrush="#fefdff" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#B73535"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#fefdff" />

        <Style x:Key="submitBuyButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D9E65" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1D673F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#0A8E51" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="submitSellButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C44E4E" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#772F2F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#B73535" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToOpenPosColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #0472c8
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="OrderEnabledToBorderBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #637ee4
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #333337
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="OrderEnabledToBuyBackBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #033222
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #252526
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="OrderEnabledToSellBackBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #31100e
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #252526
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                             Inverse="True" />
    </dx:ThemedWindow.Resources>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

            <dx:DropDownButton Width="115"
                               Margin="2"
                               Padding="3,1,7,1"
                               HorizontalAlignment="Right"
                               Content="Settings"
                               Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Settings.svg}"
                               GlyphHeight="15">
                <ItemsControl>
                    <StackPanel Orientation="Vertical">
                        <MenuItem Command="{Binding OpenEmaChartCommand}"
                                  Header="Open EMA Chart"
                                  IsEnabled="{Binding IsLoaded}" />
                        <MenuItem Header="Manual Mode"
                                  IsCheckable="True"
                                  IsChecked="{Binding ManualMode}" />
                        <MenuItem Click="ClearFiltersClick"
                                  Header="Clear Filters" />
                        <MenuItem Click="ClearSortingClick"
                                  Header="Clear Sorting" />
                    </StackPanel>
                </ItemsControl>
            </dx:DropDownButton>

            <dx:SimpleButton Width="23"
                             Margin="2"
                             HorizontalAlignment="Right"
                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                             GlyphHeight="17">
                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupControlContainer>
                        <ItemsControl>
                            <StackPanel>
                                <MenuItem Height="25"
                                          Click="CloneModule"
                                          Header="Clone">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="ShareLayout"
                                          Header="Share Config">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="SaveLayout"
                                          Header="Save Config">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="LoadLayout"
                                          Header="Load Config">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </StackPanel>
                        </ItemsControl>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>
        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:SaveFileDialogService />
        <dxmvvm:WindowService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="650" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="10,5"
                Background="#333337"
                BorderBrush="#3f3f46"
                BorderThickness="1"
                Visibility="{Binding ManualMode, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
            <Grid Margin="0,5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Content="RATIO"
                       FontSize="8" />

                <Label Grid.Row="0"
                       Grid.Column="1"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Content="SYMBOL"
                       FontSize="8" />

                <Label Grid.Row="0"
                       Grid.Column="2"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Content="Bid"
                       FontSize="8" />

                <Label Grid.Row="0"
                       Grid.Column="3"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Content="Ask"
                       FontSize="8" />

                <Label Grid.Row="0"
                       Grid.Column="4"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Content="POSITION"
                       FontSize="8" />

                <Label Grid.Row="0"
                       Grid.Column="5"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Content="WORKING"
                       FontSize="8" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="0"
                              Width="75"
                              Margin="0,2,0,0"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="{Binding PairLeg1.Side, Converter={StaticResource SideToColorConverter}}"
                              EditValue="{Binding PairLeg1.Quantity, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Int32}"
                              IsReadOnly="{Binding IsLoaded}"
                              Mask="N0"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True"
                              ShowEditorButtons="{Binding IsLoaded, Converter={StaticResource BooleanNegationConverter}}" />

                <dxe:TextEdit Grid.Row="1"
                              Grid.Column="1"
                              Width="75"
                              Margin="5,2,0,0"
                              CharacterCasing="Upper"
                              EditValue="{Binding PairLeg1.Symbol, UpdateSourceTrigger=PropertyChanged}"
                              IsReadOnly="{Binding IsLoaded}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Width="75"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding PairLeg1.Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                           TextAlignment="Right" />

                <TextBlock Grid.Row="1"
                           Grid.Column="3"
                           Width="75"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding PairLeg1.Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                           TextAlignment="Right" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="4"
                              Width="75"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Center"
                              AllowSpinOnMouseWheel="True"
                              DisplayFormatString="#0;-#0;-"
                              EditValue="{Binding PairLeg1.FilledQty}"
                              EditValueType="{x:Type sys:Int32}"
                              FontWeight="Bold"
                              Foreground="{Binding PairLeg1.FilledQty, Converter={StaticResource SignToBrushConverter}}"
                              Increment="1"
                              IsReadOnly="True"
                              Mask="D0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="5"
                              Width="75"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Center"
                              AllowSpinOnMouseWheel="True"
                              DisplayFormatString="#0;-#0;-"
                              EditValue="{Binding PairLeg1.WorkingQty}"
                              EditValueType="{x:Type sys:Int32}"
                              FontWeight="Bold"
                              Foreground="{Binding PairLeg1.WorkingQty, Converter={StaticResource SignToBrushConverter}}"
                              Increment="1"
                              IsReadOnly="True"
                              Mask="D0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dx:SimpleButton Grid.Row="1"
                                 Grid.Column="6"
                                 Width="75"
                                 Margin="5,2,0,0"
                                 Command="{Binding LoadCommand}"
                                 Content="Load" />

                <dxe:SpinEdit Grid.Row="2"
                              Grid.Column="0"
                              Width="75"
                              Margin="0,2,0,0"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="{Binding PairLeg2.Side, Converter={StaticResource SideToColorConverter}}"
                              EditValue="{Binding PairLeg2.Quantity, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Int32}"
                              IsReadOnly="{Binding IsLoaded}"
                              Mask="N0"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True"
                              ShowEditorButtons="{Binding IsLoaded, Converter={StaticResource BooleanNegationConverter}}" />

                <dxe:TextEdit Grid.Row="2"
                              Grid.Column="1"
                              Margin="5,2,0,0"
                              CharacterCasing="Upper"
                              EditValue="{Binding PairLeg2.Symbol, UpdateSourceTrigger=PropertyChanged}"
                              IsReadOnly="{Binding IsLoaded}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Width="75"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding PairLeg2.Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                           TextAlignment="Right" />

                <TextBlock Grid.Row="2"
                           Grid.Column="3"
                           Width="75"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding PairLeg2.Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                           TextAlignment="Right" />

                <dxe:SpinEdit Grid.Row="2"
                              Grid.Column="4"
                              Width="75"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Center"
                              AllowSpinOnMouseWheel="True"
                              DisplayFormatString="#0;-#0;-"
                              EditValue="{Binding PairLeg2.FilledQty}"
                              EditValueType="{x:Type sys:Int32}"
                              FontWeight="Bold"
                              Foreground="{Binding PairLeg2.FilledQty, Converter={StaticResource SignToBrushConverter}}"
                              Increment="1"
                              IsReadOnly="True"
                              Mask="D0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dxe:SpinEdit Grid.Row="2"
                              Grid.Column="5"
                              Width="75"
                              Margin="5,2,0,0"
                              HorizontalContentAlignment="Center"
                              AllowSpinOnMouseWheel="True"
                              DisplayFormatString="#0;-#0;-"
                              EditValue="{Binding PairLeg2.WorkingQty}"
                              EditValueType="{x:Type sys:Int32}"
                              FontWeight="Bold"
                              Foreground="{Binding PairLeg2.WorkingQty, Converter={StaticResource SignToBrushConverter}}"
                              Increment="1"
                              IsReadOnly="True"
                              Mask="D0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dx:SimpleButton Grid.Row="2"
                                 Grid.Column="6"
                                 Width="75"
                                 Margin="5,2,0,0"
                                 Command="{Binding StopCommand}"
                                 Content="Stop"
                                 Glyph="{dx:DXImage SvgImages/Icon Builder/Security_Stop.svg}"
                                 GlyphHeight="13" />

                <dxe:SpinEdit Grid.Row="3"
                              Grid.Column="0"
                              Width="75"
                              Margin="0,2,0,0"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding SpreadQty, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Int32}"
                              Mask="N0"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dxe:TextEdit Grid.Row="3"
                              Grid.Column="1"
                              Grid.ColumnSpan="5"
                              Margin="5,2,0,0"
                              CharacterCasing="Upper"
                              EditValue="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                              IsReadOnly="True" />

                <dx:SimpleButton Grid.Row="3"
                                 Grid.Column="6"
                                 Width="75"
                                 Margin="5,2,0,0"
                                 Padding="0"
                                 Command="{Binding ReverseCommand}"
                                 Content="Reverse"
                                 Glyph="{dx:DXImage SvgImages/Outlook Inspired/ReversSort.svg}"
                                 GlyphHeight="13" />
            </Grid>
        </Border>

        <dxlc:GroupBox Grid.Row="1"
                       Grid.RowSpan="5"
                       Grid.Column="1"
                       Margin="0,2,0,5"
                       Padding="10,5"
                       Panel.ZIndex="-1"
                       Visibility="{Binding ManualMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <dxlc:GroupBox.Header>
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0"
                           Padding="0"
                           VerticalAlignment="Center"
                           Content="Manual Order Control"
                           FontWeight="Bold"
                           Foreground="#AFAFB0"
                           IsHitTestVisible="False" />

                    <dxe:CheckEdit Grid.Column="1"
                                   Content="Manual Mode"
                                   IsChecked="{Binding ManualMode}" />
                </Grid>

            </dxlc:GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Margin="5,0,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Account"
                       FontSize="10" />

                <dxe:ComboBoxEdit Grid.Row="0"
                                  Grid.Column="1"
                                  Width="155"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  FontSize="10"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding AccountsList}"
                                  SelectedItem="{Binding Account}" />

                <Label Grid.Row="0"
                       Grid.Column="2"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Execution Style"
                       FontSize="10" />

                <dxe:ComboBoxEdit Grid.Row="0"
                                  Grid.Column="3"
                                  Width="155"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  FontSize="10"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding ExecutionStyles}"
                                  SelectedItem="{Binding ManualExecutionStyle}" />

                <Label Grid.Row="2"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Trigger Method"
                       FontSize="10" />

                <dxe:ComboBoxEdit Grid.Row="2"
                                  Grid.Column="1"
                                  Width="155"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  FontSize="10"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding ManualTriggerMethods}"
                                  SelectedItem="{Binding ManualOrderTriggerMethod}" />

                <Label Grid.Row="2"
                       Grid.Column="2"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Init Side"
                       FontSize="10" />

                <dxe:ComboBoxEdit Grid.Row="2"
                                  Grid.Column="3"
                                  Width="155"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  FontSize="10"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding InitSides}"
                                  SelectedItem="{Binding ManualInitialSide}" />

                <Label Grid.Row="4"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Trigger Value"
                       FontSize="10" />

                <dxe:SpinEdit Grid.Row="4"
                              Grid.Column="1"
                              Width="155"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding ManualOrderTriggerValue, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Double}"
                              Increment=".01"
                              Mask="{Binding RoundingMask}"
                              MaskUseAsDisplayFormat="True"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="4"
                       Grid.Column="2"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Trigger Value CCY"
                       FontSize="10" />

                <dxe:ComboBoxEdit Grid.Row="4"
                                  Grid.Column="3"
                                  Width="155"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  FontSize="10"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding CurrencyOptions}"
                                  SelectedItem="{Binding ManualTriggerValueCurrency}" />

                <Label Grid.Row="5"
                       Grid.Column="0"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Leg 1 Symbol"
                       FontSize="10" />

                <dxe:TextEdit Grid.Row="5"
                              Grid.Column="1"
                              Width="155"
                              Margin="5,2,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              CharacterCasing="Upper"
                              EditValue="{Binding ManualLeg1Symbol}"
                              NullText="Leg 1 Symbol"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <Label Grid.Row="5"
                       Grid.Column="2"
                       Margin="5,2,0,0"
                       Padding="2,2,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Content="Leg 2 Symbol"
                       FontSize="10" />

                <dxe:TextEdit Grid.Row="5"
