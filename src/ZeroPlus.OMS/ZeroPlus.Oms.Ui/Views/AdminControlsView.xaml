<view:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.AdminControlsView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                   xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:enums="clr-namespace:ZeroPlus.Models.Data.Enums;assembly=ZeroPlus.Models"
                   xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                   xmlns:view="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                   Title="{Binding ModuleTitle}"
                   Width="800"
                   Height="500"
                   MinWidth="400"
                   MinHeight="300"
                   d:DataContext="{d:DesignInstance Type=viewModels:AdminControlsViewModel}"
                   DataContext="{startuphelpers:DISource Type=viewModels:AdminControlsViewModel}"
                   WindowStartupLocation="CenterScreen"
                   mc:Ignorable="d">

    <dx:ThemedWindow.Resources>
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
    </dx:ThemedWindow.Resources>

    <dx:ThemedWindow.HeaderItems>
        <view:ModuleHeaderItems />
    </dx:ThemedWindow.HeaderItems>

    <dx:DXTabControl>
        <dx:DXTabItem Header="Mass Cancel">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0"
                       VerticalAlignment="Center"
                       Content="Venue" />
                <dxe:ComboBoxEdit Grid.Row="0" Grid.Column="1"
                                  Margin="0,3"
                                  EditValue="{Binding SelectedVenue, UpdateSourceTrigger=PropertyChanged}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding Venues}" />

                <Label Grid.Row="1" Grid.Column="0"
                       VerticalAlignment="Center"
                       Content="Broker" />
                <dxe:ComboBoxEdit Grid.Row="1" Grid.Column="1"
                                  Margin="0,3"
                                  EditValue="{Binding SelectedBroker, UpdateSourceTrigger=PropertyChanged}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding Brokers}" />

                <Label Grid.Row="2" Grid.Column="0"
                       VerticalAlignment="Center"
                       Content="Cancel Type" />
                <dxe:ComboBoxEdit Grid.Row="2" Grid.Column="1"
                                  Margin="0,3"
                                  ApplyItemTemplateToSelectedItem="True"
                                  EditValue="{Binding SelectedMassCancelType, UpdateSourceTrigger=PropertyChanged}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding MassCancelTypes}">
                    <dxe:ComboBoxEdit.ItemTemplate>
                        <DataTemplate>
                            <Label Padding="0,0.5"
                                   HorizontalAlignment="Center"
                                   Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}"
                                   FontSize="11" />
                        </DataTemplate>
                    </dxe:ComboBoxEdit.ItemTemplate>
                </dxe:ComboBoxEdit>

                <Label Grid.Row="3" Grid.Column="0"
                       VerticalAlignment="Center"
                       Content="Exchange" />
                <dxe:ComboBoxEdit Grid.Row="3" Grid.Column="1"
                                  Margin="0,3"
                                  AllowNullInput="True"
                                  EditValue="{Binding SelectedExchange, UpdateSourceTrigger=PropertyChanged}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding FilteredExchanges}"
                                  NullText="(None)" />

                <dx:SimpleButton Grid.Row="5" Grid.Column="1"
                                 Width="120"
                                 HorizontalAlignment="Left"
                                 Command="{Binding SendMassCancelCommand}"
                                 Content="Send" />
            </Grid>
        </dx:DXTabItem>
    </dx:DXTabControl>
</view:ModuleWindow>
