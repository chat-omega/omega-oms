                            <Style.Triggers>
                                <Trigger Property="IsFocusedCell" Value="True">
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Background" Value="{Binding RowData.Row.IsStrikeValid, Converter={StaticResource ValidityToColorConverter}}" />
                                </Trigger>
                            </Style.Triggers>
