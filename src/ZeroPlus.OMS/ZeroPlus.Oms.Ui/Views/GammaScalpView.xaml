<views:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.GammaScalpView"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                    xmlns:behaviors="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                    xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                    xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                    Width="1700"
                    Height="800"
                    MinWidth="400"
                    MinHeight="300"
                    d:DataContext="{d:DesignInstance Type=ViewModels:GammaScalpViewModel}"
                    DataContext="{startuphelpers:DISource Type=ViewModels:GammaScalpViewModel}"
                    WindowStartupLocation="CenterScreen"
                    mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:SaveFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <views:ModuleWindow.Resources>
        <helper:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToStateColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#c6c6c6" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#F30005" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToFillColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#9fffb2" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="Transparent" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#6dc534"
                                     ZeroBrush="#6dc534" />
        <dxmvvm:BooleanToObjectConverter x:Key="StateTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                RUNNING
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                STOPPED
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="RunningToActionConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Stop
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Start
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToStatusColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Green" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="DarkRed" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="ValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Transparent" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#FF0000" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
    </views:ModuleWindow.Resources>

    <views:ModuleWindow.HeaderItems>
        <views:ModuleHeaderItems />
    </views:ModuleWindow.HeaderItems>

    <Grid Margin="3">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,0,0"
                    Padding="2"
                    BorderBrush="#3f3f46"
                    BorderThickness="2.1"
                    CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Margin="2,2,0,0"
                           Content="SYMBOL"
                           FontSize="11" />

                    <dxe:TextEdit Grid.Row="0"
                                  Grid.Column="1"
                                  Margin="2,2,0,0"
                                  CharacterCasing="Upper"
                                  EditValue="{Binding Underlying, UpdateSourceTrigger=PropertyChanged}"
                                  EditValuePostDelay="0"
                                  IsEnabled="{Binding UnderlyingLoaded, Converter={StaticResource BooleanNegationConverter}}"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  TabIndex="1" />

                    <dx:SimpleButton Grid.Row="0"
                                     Grid.Column="3"
                                     Width="75"
                                     Height="22"
                                     Margin="0,2,0,0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Command="{Binding SearchUnderlyingCommand}"
                                     Content="Search"
                                     FontSize="11"
                                     FontWeight="DemiBold" />

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Margin="2,2,0,0"
                           Content="HEDGE"
                           FontSize="11" />

                    <dxe:TextEdit Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="2,2,0,0"
                                  CharacterCasing="Upper"
                                  EditValue="{Binding HedgeUnderlying, UpdateSourceTrigger=PropertyChanged}"
                                  EditValuePostDelay="0"
                                  IsEnabled="{Binding UnderlyingLoaded, Converter={StaticResource BooleanNegationConverter}}"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  TabIndex="1" />

                    <Label Grid.Row="1"
                           Grid.Column="2"
                           Margin="1,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Content="X" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="3"
                                  Width="75"
                                  Margin="0,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N0"
                                  EditValue="{Binding HedgeMultiplier, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  IsEnabled="{Binding UnderlyingLoaded, Converter={StaticResource BooleanNegationConverter}}"
                                  Mask="N0"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True">
                        <dxmvvm:Interaction.Behaviors>
                            <behaviors:SpinEditFocusSelectionBehavior />
                        </dxmvvm:Interaction.Behaviors>
                    </dxe:SpinEdit>
                </Grid>
            </Border>
            <Border Grid.Row="0"
                    Grid.Column="2"
                    Margin="3,0,0,0"
                    Padding="2"
                    BorderBrush="#3f3f46"
                    BorderThickness="2.1"
                    CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           HorizontalAlignment="Center"
                           Content="BID"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="1"
                           HorizontalAlignment="Center"
                           Content="MID"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="2"
                           HorizontalAlignment="Center"
                           Content="ASK"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Scalper.Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Scalper.Mid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Scalper.Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                </Grid>
            </Border>
            <Border Grid.Row="0"
                    Grid.Column="4"
                    Margin="3,0,0,0"
                    Padding="2"
                    BorderBrush="#3f3f46"
                    BorderThickness="2.1"
                    CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           HorizontalAlignment="Center"
                           Content="TOTAL DELTA"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <Canvas Width="8"
                                Height="8">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{Binding Scalper.InSync, Converter={StaticResource BooleanToFillColorConverter}}"
                                     Stroke="{Binding Scalper.InSync, Converter={StaticResource BooleanToStateColorConverter}}" />
                        </Canvas>
                        <Label Margin="4,0,0,0"
                               HorizontalAlignment="Center"
                               Content="NET DELTA"
                               FontWeight="DemiBold"
                               Foreground="#AFAFB0" />
                    </StackPanel>
                    <Label Grid.Row="0"
                           Grid.Column="2"
                           HorizontalAlignment="Center"
                           Content="NET GAMMA"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="3"
                           HorizontalAlignment="Center"
                           Content="NET THETA"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Scalper.TotalDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Scalper.NetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Scalper.NetGamma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="3"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Scalper.NetTheta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                </Grid>
            </Border>
            <Border Grid.Row="0"
                    Grid.Column="6"
                    Margin="3,0,0,0"
                    Padding="2"
                    BorderBrush="#3f3f46"
                    BorderThickness="2.1"
                    CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           HorizontalAlignment="Center"
                           Content="POS"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="1"
                           HorizontalAlignment="Center"
                           Content="REQ #"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="2"
                           HorizontalAlignment="Center"
                           Content="HEDGED #"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding OrderTicket.LcdPosition, Converter={StaticResource SignToBrushConverter}}"
                               Text="{Binding OrderTicket.LcdPosition, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding Scalper.HedgeQty, Converter={StaticResource SignToBrushConverter}}"
                               Text="{Binding Scalper.HedgeQty, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}" />
                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="2"
                                  HorizontalAlignment="Center"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  DisplayFormatString="N0"
                                  EditValue="{Binding Scalper.FilledQty}"
                                  EditValueType="{x:Type sys:Int32}"
                                  FontWeight="Bold"
                                  Foreground="{Binding Scalper.FilledQty, Converter={StaticResource SignToBrushConverter}}"
                                  Increment="1"
                                  Mask="N0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  ShowEditorButtons="False" />
                </Grid>
            </Border>
            <Border Grid.Row="0"
                    Grid.Column="8"
                    Margin="3,0,0,0"
                    Padding="2"
                    BorderBrush="#3f3f46"
                    BorderThickness="2.1"
                    CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           HorizontalAlignment="Center"
                           Content="STK P&amp;L"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="1"
                           HorizontalAlignment="Center"
                           Content="OPT P&amp;L"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="2"
                           HorizontalAlignment="Center"
                           Content="NET P&amp;L"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding Scalper.ScalpNetPnl, Converter={StaticResource SignToBrushConverter}}"
                               Text="{Binding Scalper.ScalpNetPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C0}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding Scalper.PositionNetPnl, Converter={StaticResource SignToBrushConverter}}"
                               Text="{Binding Scalper.PositionNetPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C0}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding Scalper.NetPnl, Converter={StaticResource SignToBrushConverter}}"
                               Text="{Binding Scalper.NetPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C0}}" />

                </Grid>
            </Border>
            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,3,0,0"
                    Padding="2"
                    BorderBrush="#3f3f46"
                    BorderThickness="2.1"
                    CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Width="90"
                            Margin="2,2,0,0"
                            HorizontalAlignment="Center"
                            Background="{Binding Scalper.Running, Converter={StaticResource BooleanToStatusColorConverter}}"
                            BorderBrush="{Binding Scalper.Running, Converter={StaticResource BooleanToStatusColorConverter}}"
                            BorderThickness="0.7"
                            CornerRadius="2">
                        <TextBlock Padding="5,2"
                                   HorizontalAlignment="Center"
                                   Background="{Binding Scalper.Running, Converter={StaticResource BooleanToStatusColorConverter}}"
                                   FontWeight="Medium"
                                   Foreground="White"
                                   Text="{Binding Scalper.Running, Converter={StaticResource StateTextConverter}}" />
                    </Border>

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Margin="5,2,0,0"
                           Content="Greek Source"
                           FontSize="11" />

                    <dxe:ComboBoxEdit Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="5,2,0,0"
                                      ApplyItemTemplateToSelectedItem="True"
                                      EditValue="{Binding Scalper.GreekSource, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding GreekSources}">
                        <dxe:ComboBoxEdit.ItemTemplate>
                            <DataTemplate>
                                <Label Padding="0,0.5"
                                       HorizontalAlignment="Center"
                                       Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}"
                                       FontSize="11" />
                            </DataTemplate>
                        </dxe:ComboBoxEdit.ItemTemplate>
                    </dxe:ComboBoxEdit>

                    <Label Grid.Row="1"
                           Grid.Column="2"
                           Margin="5,2,0,0"
                           Content="HW Time Diff"
                           FontSize="11"
                           Visibility="{Binding Scalper.GreekSource, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Hanweck'}" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="3"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N0"
                                  EditValue="{Binding Scalper.MaxHwTimeDiff, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Mask="N0"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  Visibility="{Binding Scalper.GreekSource, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='Hanweck'}">
                        <dxmvvm:Interaction.Behaviors>
                            <behaviors:SpinEditFocusSelectionBehavior />
                        </dxmvvm:Interaction.Behaviors>
                    </dxe:SpinEdit>

                    <dxe:CheckEdit Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="5,2,0,0"
                                   Content="Delta Chg"
                                   EditValue="{Binding Scalper.MinDeltaChangeEnabled, UpdateSourceTrigger=PropertyChanged}"
                                   FontSize="11" />

                    <dxe:SpinEdit Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding Scalper.MinDeltaChange, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment=".01"
                                  IsEnabled="{Binding Scalper.MinDeltaChangeEnabled}"
                                  Mask="N5"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True">
                        <dxmvvm:Interaction.Behaviors>
                            <behaviors:SpinEditFocusSelectionBehavior />
                        </dxmvvm:Interaction.Behaviors>
                    </dxe:SpinEdit>

                    <dxe:CheckEdit Grid.Row="2"
                                   Grid.Column="2"
                                   Margin="5,2,0,0"
                                   Content="Min Time"
                                   EditValue="{Binding Scalper.MinHedgeIntervalEnabled, UpdateSourceTrigger=PropertyChanged}"
                                   FontSize="11" />

                    <dxe:SpinEdit Grid.Row="2"
                                  Grid.Column="3"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  DisplayFormatString="N0"
                                  EditValue="{Binding Scalper.MinHedgeInterval, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  IsEnabled="{Binding Scalper.MinHedgeIntervalEnabled}"
                                  Mask="N0"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True">
                        <dxmvvm:Interaction.Behaviors>
                            <behaviors:SpinEditFocusSelectionBehavior />
                        </dxmvvm:Interaction.Behaviors>
                    </dxe:SpinEdit>

                    <GroupBox Grid.Row="3"
                              Grid.Column="0"
                              Grid.ColumnSpan="4"
                              Margin="0,0"
                              Padding="-6,-3,-6,2"
                              BorderThickness="0,1">
                        <GroupBox.Header>
                            <dxe:CheckEdit Margin="5,2,0,0"
                                           Content="Smart Hedge"
                                           EditValue="{Binding Scalper.SmartHedgeEnabled, UpdateSourceTrigger=PropertyChanged}"
                                           FontSize="11" />
                        </GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0"
                                   Margin="5,2,0,0"
                                   Content="Stock Bid %"
                                   FontSize="11" />

                            <dxe:SpinEdit Grid.Column="1"
                                          Margin="5,2,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding Scalper.SmartHedgeBidPercent, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment=".01"
                                          IsEnabled="{Binding Scalper.SmartHedgeEnabled}"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <behaviors:SpinEditFocusSelectionBehavior />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <Label Grid.Column="2"
                                   Margin="5,2,0,0"
                                   Content="Rest Time"
                                   FontSize="11" />

                            <dxe:SpinEdit Grid.Column="3"
                                          Margin="5,2,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          DisplayFormatString="N0"
                                          EditValue="{Binding Scalper.SmartHedgeRestPeriod, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          IsEnabled="{Binding Scalper.SmartHedgeEnabled}"
                                          Mask="N0"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
