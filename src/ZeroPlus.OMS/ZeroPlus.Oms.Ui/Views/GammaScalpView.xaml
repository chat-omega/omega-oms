                    <dxmvvm:Interaction.Behaviors>
                        <services:UpdateSummaryService />
                    </dxmvvm:Interaction.Behaviors>
                    <dxg:GridControl.View>
                        <dxg:TableView AllowColumnFiltering="False"
                                       AllowDragDrop="True"
                                       AllowGrouping="False"
                                       AllowSorting="False"
                                       AutoWidth="True"
                                       CompleteRecordDragDrop="OnCompleteRecordDragDrop"
                                       DragRecordOver="OnDragRecordOver"
                                       DropRecord="OnDropRecord"
                                       FadeSelectionOnLostFocus="False"
                                       ShowGridMenu="TableView_ShowGridMenu"
                                       ShowGroupPanel="False"
                                       ShowIndicator="True"
                                       ShowTotalSummary="False"
                                       VerticalScrollbarVisibility="Auto">
