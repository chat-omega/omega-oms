                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding RowData.Row.NetDelta, Converter={StaticResource SignToBrushConverter}}"
                                           Text="{Binding RowData.Row.NetDelta, Converter={StaticResource DoubleFormatter}}"
                                           TextAlignment="Right" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="NetTheta"
                                    IsSmart="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding RowData.Row.NetTheta, Converter={StaticResource SignToBrushConverter}}"
                                           Text="{Binding RowData.Row.NetTheta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                           TextAlignment="Right" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn FieldName="NetGamma"
                                    IsSmart="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding RowData.Row.NetGamma, Converter={StaticResource SignToBrushConverter}}"
                                           Text="{Binding RowData.Row.NetGamma, Converter={StaticResource DoubleFormatter}}"
                                           TextAlignment="Right" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Gamma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Greek}}"
                                    FieldName="Gamma"
                                    Header="Gamma"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="False"
                                    ReadOnly="True"
                                    Visible="False">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Vega, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Greek}}"
                                    FieldName="Vega"
                                    Header="Vega"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="False"
                                    ReadOnly="True"
                                    Visible="False">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Theta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Greek}}"
                                    FieldName="Theta"
                                    Header="Theta"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="False"
                                    ReadOnly="True"
                                    Visible="False">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Rho, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Greek}}"
                                    FieldName="Rho"
                                    Header="Rho"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="False"
                                    ReadOnly="True"
                                    Visible="False">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Implied, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Greek}}"
                                    FieldName="Implied"
                                    Header="Implied"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="False"
                                    ReadOnly="True"
                                    Visible="False">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="20"
                                    MinWidth="20"
                                    AllowMoving="False"
                                    AllowResizing="False"
                                    FieldName="Remove"
                                    Header="-"
                                    HorizontalHeaderContentAlignment="Center"
                                    IsSmart="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton Command="{Binding View.DataContext.OrderTicket.RemoveLegCommand}"
                                                 CommandParameter="{Binding Path=SelectedItem, ElementName=PositionsGrid}"
                                                 Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                 GlyphWidth="19" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridControl.TotalSummary>
                        <dxg:GridSummaryItem FieldName="NetGamma"
                                             ShowInColumn="NetGamma"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="NetTheta"
                                             ShowInColumn="NetTheta"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="Delta"
                                             ShowInColumn="Delta"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="Gamma"
                                             ShowInColumn="Gamma"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="Vega"
                                             ShowInColumn="Vega"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="Theta"
                                             ShowInColumn="Theta"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="Rho"
                                             ShowInColumn="Rho"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="Implied"
                                             ShowInColumn="Implied"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="Theo"
                                             ShowInColumn="Theo"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="DeltaAdjTheo"
                                             ShowInColumn="DeltaAdjTheo"
                                             SummaryType="Custom" />
                        <dxg:GridSummaryItem FieldName="Quantity"
                                             ShowInColumn="Quantity"
                                             SummaryType="Custom" />
                    </dxg:GridControl.TotalSummary>
                </dxg:GridControl>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="1"
                      Height="2"
                      Margin="1.3,0"
                      HorizontalAlignment="Stretch"
                      Visibility="Collapsed" />

        <Border Grid.Row="2"
                Margin="0,2,0,0"
                BorderBrush="#3f3f46"
                BorderThickness="1"
                CornerRadius="2">
            <dxg:GridControl x:Name="HedgeOrdersGrid"
                             MinHeight="70"
                             MaxHeight="5000"
                             HorizontalAlignment="Center"
                             AutoGenerateColumns="AddNew"
                             CurrentItem="{Binding Scalper.LastOrderModel}"
                             ItemsSource="{Binding Scalper.Orders}">
                <dxg:GridControl.Resources>
                    <Style TargetType="dxg:GridColumn">
                        <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                        <Setter Property="Visible" Value="False" />
                    </Style>
                    <Style x:Key="OrdersRowStyle"
                           TargetType="dxg:RowControl">
                        <Style.Setters>
                            <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Background'}" />
                            <Setter Property="Foreground" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Foreground'}" />
                        </Style.Setters>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=IsSelected}"
                                         Value="True">
                                <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                            </DataTrigger>
                            <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{Binding Path=Row.OrderUpdateModel, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='MouseOver'}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </dxg:GridControl.Resources>
                <dxg:GridControl.View>
                    <dxg:TableView x:Name="OrdersTableView"
                                   AllowEditing="False"
                                   AllowGrouping="False"
                                   AutoWidth="True"
                                   FadeSelectionOnLostFocus="False"
                                   RowStyle="{StaticResource OrdersRowStyle}"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   ShowIndicator="True"
                                   VerticalScrollbarVisibility="Auto">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Height="25"
                                          Command="{Binding ShowColumnChooserCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Column Chooser">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ClearColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Hide All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowAllColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowDefaultColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Default Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn FieldName="Timestamp"
                                Header="Time"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                              Mask="hh:mm:ss.ffff"
                                              MaskType="DateTime"
                                              MaskUseAsDisplayFormat="True" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Symbol"
                                ReadOnly="True"
                                Visible="True" />
                <dxg:GridColumn FieldName="Side"
                                ReadOnly="True"
                                Visible="True" />
                <dxg:GridColumn FieldName="Qty"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.Price, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                FieldName="Price"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.UnderBid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                FieldName="UnderBid"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.UnderMid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                FieldName="UnderMid"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.UnderAsk, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                FieldName="UnderAsk"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                FieldName="Bid"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.Mid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                FieldName="Mid"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                FieldName="Ask"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.TotalDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.Greek}}"
                                FieldName="TotalDelta"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Binding="{Binding Path=RowData.Row.NetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                FieldName="NetDelta"
                                ReadOnly="True"
                                Visible="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="OrderStatus"
                                ReadOnly="True"
                                Visible="True" />
            </dxg:GridControl>
        </Border>

        <Grid Grid.Row="3"
              Margin="0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Padding="5,4"
                       VerticalAlignment="Center"
                       Background="{Binding Scalper.BuyStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding Scalper.BuyStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding Scalper.BuyStatus}"
                       TextAlignment="Left" />

            <TextBlock Grid.Column="1"
                       Padding="2,4"
                       VerticalAlignment="Center"
                       Background="{Binding Scalper.StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding Scalper.StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding Scalper.Status}"
                       TextAlignment="Center" />

            <TextBlock Grid.Column="2"
                       Padding="5,4"
                       VerticalAlignment="Center"
                       Background="{Binding Scalper.SellStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding Scalper.SellStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding Scalper.SellStatus}"
                       TextAlignment="Right" />
        </Grid>
    </Grid>
</views:ModuleWindow>
