<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.PositionManagerView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Position Manager"
                 Height="400"
                 DataContext="{startuphelpers:DISource Type=ViewModels:PositionManagerViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
        <dxmvvm:DispatcherService />
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Content="Account" />

        <dxe:TextEdit Grid.Row="1"
                      Grid.Column="2"
                      Grid.ColumnSpan="3"
                      Margin="5,0,0,0"
                      EditValue="{Binding AccountAcronym, UpdateSourceTrigger=PropertyChanged}" />

        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Symbol" />

        <dxe:TextEdit Grid.Row="2"
                      Grid.Column="2"
                      Grid.ColumnSpan="3"
                      Margin="5,5,0,0"
                      EditValue="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}" />

        <Label Grid.Row="3"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Net Qty" />

        <dxe:SpinEdit Grid.Row="3"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="N0"
                      EditValue="{Binding NewNetQty, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Int32}"
                      Mask="N0"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="3"
               Grid.Column="3"
               Margin="5,5,0,0"
               Content="Open Qty" />

        <dxe:SpinEdit Grid.Row="3"
                      Grid.Column="4"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="N0"
                      EditValue="{Binding OpeningQty, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Int32}"
                      Mask="N0"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="4"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Buy Qty" />

        <dxe:SpinEdit Grid.Row="4"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="N0"
                      EditValue="{Binding TradingBuyQty, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Int32}"
                      Mask="N0"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="4"
               Grid.Column="3"
               Margin="5,5,0,0"
               Content="Buy Price" />

        <dxe:SpinEdit Grid.Row="4"
                      Grid.Column="4"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding TradingBuyAvePrice, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="5"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Sell Qty" />

        <dxe:SpinEdit Grid.Row="5"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="N0"
                      EditValue="{Binding TradingSellQty, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Int32}"
                      Mask="N0"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="5"
               Grid.Column="3"
               Margin="5,5,0,0"
               Content="Sell Price" />

        <dxe:SpinEdit Grid.Row="5"
                      Grid.Column="4"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding TradingSellAvePrice, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="6"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Trading Qty" />

        <dxe:SpinEdit Grid.Row="6"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="N0"
                      EditValue="{Binding TradingNetQty, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Int32}"
                      Mask="N0"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="6"
               Grid.Column="3"
               Margin="5,5,0,0"
               Content="Trading Cost" />

        <dxe:SpinEdit Grid.Row="6"
                      Grid.Column="4"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding TradingAveCost, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="7"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Marked Cost" />

        <dxe:SpinEdit Grid.Row="7"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding MarkedCost, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="7"
               Grid.Column="3"
               Margin="5,5,0,0"
               Content="Opening Cost" />

        <dxe:SpinEdit Grid.Row="7"
                      Grid.Column="4"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding OpeningCost, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="8"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Avg Cost" />

        <dxe:SpinEdit Grid.Row="8"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding AvgCost, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="8"
               Grid.Column="3"
               Margin="5,5,0,0"
               Content="Trading PnL" />

        <dxe:SpinEdit Grid.Row="8"
                      Grid.Column="4"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding TradingPL, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="9"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Real PnL" />

        <dxe:SpinEdit Grid.Row="9"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding RealizedPL, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="9"
               Grid.Column="3"
               Margin="5,5,0,0"
               Content="Unreal PnL" />

        <dxe:SpinEdit Grid.Row="9"
                      Grid.Column="4"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding UnrealizedPL, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="10"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Day PnL" />

        <dxe:SpinEdit Grid.Row="10"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding DayPL, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="10"
               Grid.Column="3"
               Margin="5,5,0,0"
               Content="Net PnL" />

        <dxe:SpinEdit Grid.Row="10"
                      Grid.Column="4"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding NetPL, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="11"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Notional Val" />

        <dxe:SpinEdit Grid.Row="11"
                      Grid.Column="2"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding NotionalValue, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="11"
               Grid.Column="3"
               Margin="5,5,0,0"
               Content="Mkt Value" />

        <dxe:SpinEdit Grid.Row="11"
                      Grid.Column="4"
                      Margin="5,5,0,0"
                      AllowSpinOnMouseWheel="True"
                      DisplayFormatString="C2"
                      EditValue="{Binding MarketValue, UpdateSourceTrigger=PropertyChanged}"
                      EditValueType="{x:Type sys:Double}"
                      Mask="C2"
                      PreviewMouseUp="SpinEdit_Click"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <StackPanel Grid.Row="13"
                    Grid.Column="1"
                    Grid.ColumnSpan="4"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding UpdateCommand}"
                             Content="Update"
                             Glyph="{dx:DXImage SvgImages/Dashboards/UpdateDataExtract.svg}"
                             GlyphHeight="15"
                             IsDefault="True" />

            <dx:SimpleButton Width="80"
                             Margin="5,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
