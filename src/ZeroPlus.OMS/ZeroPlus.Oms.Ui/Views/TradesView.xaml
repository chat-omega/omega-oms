<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.TradesView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="1200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:TradesViewModel}"
                 d:Width="2250"
                 DataContext="{startuphelpers:DISource Type=ViewModels:TradesViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:LoadCustomColumnService />
        <services:GetItemsByVisualOrderService />
        <services:OmsMessageBoxService />
        <dxmvvm:WindowService />
        <dxmvvm:DispatcherService />
        <dxmvvm:OpenFileDialogService />
        <dxmvvm:SaveFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <Window.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#02F302" />

        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <helper:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <Style x:Key="OrderStyle"
               TargetType="dxg:RowControl">
            <Style.Setters>
                <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Background'}" />
                <Setter Property="Foreground" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Foreground'}" />
            </Style.Setters>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='Focused'}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding Path=Row, Converter={StaticResource OrderToBackBrushConverter}, ConverterParameter='MouseOver'}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Row="0"
                  Grid.Column="0"
                  Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Width="75"
                       Content="Symbol" />
                <dxe:TextEdit Grid.Column="1"
                              Height="24"
                              Margin="1.2,0,0,0"
                              VerticalAlignment="Center"
                              CharacterCasing="Upper"
                              EditValue="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
                <dxe:ButtonEdit Grid.Column="1"
                                Margin="5,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                AllowDefaultButton="False"
                                ShowBorder="False"
                                ShowText="False"
                                Visibility="{Binding InProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <dxe:ButtonEdit.Buttons>
                        <dxe:LoadingIndicatorButtonInfo />
                    </dxe:ButtonEdit.Buttons>
                </dxe:ButtonEdit>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <Label Height="22"
                           Margin="5,0"
                           Content="Delta Adj Interval (sec)" />

                    <dxe:SpinEdit Width="80"
                                  Height="22"
                                  HorizontalAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding DeltaAdjEdgeIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  MinValue="1"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />
                </StackPanel>
                <dxe:CheckEdit Grid.Column="3"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Match IOI Trades"
                               EditValue="{Binding MatchIoiTrades}" />
            </Grid>

            <dxlc:GroupBox Grid.Row="0"
                           Grid.RowSpan="4"
                           Grid.Column="3"
                           Margin="7,0,0,0"
                           Padding="5,0">

                <dxlc:GroupBox.Header>
                    <dxe:ToggleSwitch Grid.Column="0"
                                      Margin="0,0,0,0"
                                      HorizontalAlignment="Center"
                                      AnimationMode="Always"
                                      CheckedStateContent="Auto Block On"
                                      ContentPlacement="Inside"
                                      IsChecked="{Binding AutoBlockEnabled}"
                                      ToggleSwitchWidth="120"
                                      UncheckedStateContent="Auto Block Off" />
                </dxlc:GroupBox.Header>

                <Grid IsEnabled="{Binding AutoBlockEnabled}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Height="22"
                           Margin="5,2,0,0"
                           Content="Max" />

                    <dxe:SpinEdit Grid.Row="0"
                                  Grid.Column="1"
                                  Width="70"
                                  Height="22"
                                  Margin="2,2,0,0"
                                  HorizontalAlignment="Left"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding MaxBlock, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Mask="d"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:CheckEdit Grid.Row="1"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Margin="5,2,0,0"
                                   HorizontalAlignment="Left"
                                   Content="Auto Submit"
                                   EditValue="{Binding AutoSubmit}" />
                </Grid>
            </dxlc:GroupBox>

            <dxlc:GroupBox Grid.Row="0"
                           Grid.RowSpan="4"
                           Grid.Column="5"
                           Margin="7,0,0,0"
                           Padding="5,0">

                <dxlc:GroupBox.Header>
                    <dxe:ToggleSwitch Name="autoRefreshToggleSwith"
                                      Grid.Column="0"
                                      Margin="0,0,0,0"
                                      HorizontalAlignment="Center"
                                      AnimationMode="Always"
                                      CheckedStateContent="Auto Refresh On"
                                      ContentPlacement="Inside"
                                      IsChecked="{Binding AutoRefresh}"
                                      ToggleSwitchWidth="120"
                                      UncheckedStateContent="Auto Refresh Off" />
                </dxlc:GroupBox.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                           Margin="2,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="Interval"
                           IsEnabled="{Binding Path=IsChecked, ElementName=autoRefreshToggleSwith}" />

                    <dxe:SpinEdit Grid.Column="1"
                                  Width="65"
                                  Margin="0,2,0,0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding RefreshInterval, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  IsEnabled="{Binding Path=IsChecked, ElementName=autoRefreshToggleSwith}"
                                  Mask="d"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Column="2"
                           Margin="2,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="ms"
                           IsEnabled="{Binding Path=IsChecked, ElementName=autoRefreshToggleSwith}" />

                </Grid>
            </dxlc:GroupBox>

            <dxlc:GroupBox Grid.Row="0"
                           Grid.RowSpan="4"
                           Grid.Column="9"
                           Margin="7,0,0,0"
                           Padding="5,0">

                <dxlc:GroupBox.Header>
                    <dxe:ToggleSwitch Name="edgeNotificationToggleSwith"
                                      Grid.Column="0"
                                      Margin="0,0,0,0"
                                      HorizontalAlignment="Center"
                                      AnimationMode="Always"
                                      CheckedStateContent="Notification On"
                                      ContentPlacement="Inside"
                                      IsChecked="{Binding NotificationEnabled}"
                                      ToggleSwitchWidth="120"
                                      UncheckedStateContent="Notification Off" />
                </dxlc:GroupBox.Header>

                <Grid IsEnabled="{Binding Path=IsChecked, ElementName=edgeNotificationToggleSwith}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Height="22"
                           Margin="5,2,0,0"
                           Content="Edge" />

                    <dxe:SpinEdit Grid.Row="0"
                                  Grid.Column="1"
                                  Width="70"
                                  Height="22"
                                  Margin="2,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding NotificationEdge, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment=".01"
                                  Mask="N2"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="0"
                           Grid.Column="2"
                           Height="22"
                           Margin="5,2,0,0"
                           Content="Time" />

                    <dxe:SpinEdit Grid.Row="0"
                                  Grid.Column="3"
                                  Width="70"
                                  Height="22"
                                  Margin="2,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding NotificationTimeSpan, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  Mask="d"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dx:SimpleButton Grid.Row="1"
                                     Grid.Column="0"
                                     Margin="2,2,0,0"
                                     BorderThickness="0"
                                     ButtonKind="Toggle"
                                     Glyph="{dx:DXImage SvgImages/Business Objects/BO_Notifications.svg}"
                                     GlyphHeight="15"
                                     IsChecked="{Binding NotificationSoundEnabled, UpdateSourceTrigger=PropertyChanged}" />

                    <dxe:ComboBoxEdit Grid.Row="1"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="3"
                                      Margin="2,2,0,0"
                                      IsEnabled="{Binding NotificationSoundEnabled}"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding NotificationManager.SoundsList}"
                                      SelectedItem="{Binding NotificationSound, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="{Binding NotificationSound}" />

                </Grid>
            </dxlc:GroupBox>

            <dxlc:GroupBox Grid.Row="0"
                           Grid.RowSpan="4"
                           Grid.Column="10"
                           Margin="7,0,0,0"
                           Padding="5,0">

                <dxlc:GroupBox.Header>
                    <Label Margin="0,0,0,0"
                           HorizontalAlignment="Center"
                           Content="" />
                </dxlc:GroupBox.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <dxe:CheckEdit Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="10,0,0,0"
                                   Content="Live Under"
                                   EditValue="{Binding SubscribeToLast}" />

                    <dx:SimpleButton Grid.Row="0"
                                     Grid.Column="1"
                                     Width="100"
                                     Height="22"
                                     Margin="5,2,0,0"
                                     Padding="0"
                                     HorizontalAlignment="Left"
                                     Command="{Binding LoadFromTwsCommand}"
                                     Content="Load from TWS" />

                    <dxe:CheckEdit Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="10,0,0,0"
                                   Content="Live Greeks"
                                   EditValue="{Binding SubscribeToGreeks}" />

                    <dx:SimpleButton Grid.Row="1"
                                     Grid.Column="1"
                                     Width="100"
                                     Height="22"
                                     Margin="5,2,0,0"
                                     Padding="0"
                                     HorizontalAlignment="Left"
                                     Command="{Binding OpenInBasketCommand}"
                                     Content="Open In Basket" />

                    <Grid Grid.Row="2"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          Margin="5,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <dx:DXImage Grid.Column="0"
                                    Height="15"
                                    HorizontalAlignment="Right"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="{dx:DXImage 'SvgImages/Dashboards/FilterQuery.svg'}" />

                        <dxe:ComboBoxEdit Grid.Column="1"
                                          Margin="2,0,0,0"
                                          DisplayMember="Name"
                                          EditValue="{Binding SelectedFilter, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding Filters}"
                                          ToolTip="{Binding SelectedFilter.Filter}">
                            <dxe:ComboBoxEdit.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="170"
                                          HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0"
                                               Padding="0,0"
                                               VerticalAlignment="Center"
                                               Content="{Binding Name}" />
                                        <dx:SimpleButton Grid.Column="1"
                                                         HorizontalAlignment="Right"
                                                         Background="Transparent"
                                                         Command="{Binding DataContext.RemoveFilterCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                         CommandParameter="{Binding}"
                                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                         GlyphWidth="18" />
                                    </Grid>
                                </DataTemplate>
                            </dxe:ComboBoxEdit.ItemTemplate>
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding ApplyFilterCommand}"
                                                       EventName="EditValueChanged" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:ComboBoxEdit>

                        <dx:SimpleButton Grid.Column="2"
                                         Width="22"
                                         Height="22"
                                         BorderThickness="1"
                                         Command="{Binding SaveFilterCommand}"
                                         Glyph="{dx:DXImage SvgImages/Save/Save.svg}"
                                         GlyphHeight="13"
                                         GlyphWidth="13" />
                    </Grid>
                </Grid>
            </dxlc:GroupBox>

            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,7,0,0"
                        Orientation="Horizontal">
                <Label Width="75"
                       Height="22"
                       Content="Time Range" />

                <dx:SimpleButton Name="ManualTime"
                                 Width="65"
                                 Height="22"
                                 Margin="1.2,0,0,0"
                                 Padding="6,0,0,0"
                                 ButtonKind="Toggle"
                                 Content=""
                                 Glyph="{dx:DXImage SvgImages/Scheduling/SwitchTimeScalesTo.svg}"
                                 GlyphHeight="17"
                                 IsChecked="{Binding UseManualTime}"
                                 ToolTip="Manually set time range" />

                <dxe:TextEdit Width="162"
                              Height="22"
                              Margin="5,0,0,0"
                              HorizontalContentAlignment="Center"
                              EditValue="{Binding StartTime}"
                              IsEnabled="{Binding ElementName=ManualTime, Path=IsChecked}"
                              Mask="G"
                              MaskType="DateTimeAdvancingCaret"
                              MaskUseAsDisplayFormat="True" />

                <dxe:TextEdit Width="162"
                              Height="22"
                              Margin="5,0,0,0"
                              HorizontalContentAlignment="Center"
                              EditValue="{Binding EndTime}"
                              IsEnabled="{Binding ElementName=ManualTime, Path=IsChecked}"
                              Mask="G"
                              MaskType="DateTimeAdvancingCaret"
                              MaskUseAsDisplayFormat="True" />

                <dxe:ComboBoxEdit Width="100"
                                  Height="22"
                                  Margin="5,0,0,0"
                                  HorizontalContentAlignment="Center"
                                  EditValue="{Binding SelectedTime}"
                                  IsEnabled="{Binding ElementName=ManualTime, Path=IsChecked, Converter={StaticResource BooleanNegationConverter}}"
                                  IsTextEditable="False">
                    <dxe:ComboBoxEditItem Content="1 Min" />
                    <dxe:ComboBoxEditItem Content="2 Min" />
                    <dxe:ComboBoxEditItem Content="3 Min" />
                    <dxe:ComboBoxEditItem Content="5 Min" />
                    <dxe:ComboBoxEditItem Content="10 Min" />
                    <dxe:ComboBoxEditItem Content="15 Min" />
                    <dxe:ComboBoxEditItem Content="20 Min" />
                    <dxe:ComboBoxEditItem Content="30 Min" />
                    <dxe:ComboBoxEditItem Content="1 Hour" />
                    <dxe:ComboBoxEditItem Content="Today" />
                </dxe:ComboBoxEdit>

                <Grid Margin="5,0,0,0">
                    <dx:SimpleButton Width="80"
                                     Height="22"
                                     Command="{Binding RefreshCommand}"
                                     Content="Refresh"
                                     Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Refresh.svg}"
                                     GlyphHeight="13"
                                     IsDefault="True" />

                    <dx:SimpleButton Width="80"
                                     Height="22"
                                     Command="{Binding CancelRefreshCommand}"
                                     Content="Cancel"
                                     GlyphHeight="13"
                                     IsCancel="True"
                                     IsDefault="True"
                                     Visibility="{Binding InProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Grid.Column="0"
                        Margin="0,7,0,0"
                        Orientation="Horizontal">
                <Label Width="75"
                       Height="22"
                       Content="Conditions"
                       DockPanel.Dock="Left" />

                <dxe:ComboBoxEdit Width="65"
                                  Height="22"
                                  Margin="1.2,0,0,0"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding SourceLegTypes}"
                                  SelectedItem="{Binding LegTypes}" />

                <dxe:ComboBoxEdit Width="162"
                                  Height="22"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Right"
                                  DisplayMember="Code"
                                  EditValue="{Binding SelectedTradeConditionCodes, UpdateSourceTrigger=PropertyChanged}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding TradeConditionCodes}"
                                  ValueMember="Code">
                    <dxe:ComboBoxEdit.StyleSettings>
                        <dxe:CheckedComboBoxStyleSettings />
                    </dxe:ComboBoxEdit.StyleSettings>
                    <dxe:ComboBoxEdit.ItemTemplate>
                        <DataTemplate>
                            <Label HorizontalAlignment="Stretch"
                                   Content="{Binding Description}" />
                        </DataTemplate>
                    </dxe:ComboBoxEdit.ItemTemplate>
                </dxe:ComboBoxEdit>

                <dxe:ComboBoxEdit Width="162"
                                  Height="22"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Right"
                                  DisplayMember="Code"
                                  EditValue="{Binding SelectedSingleTradeConditionCodes, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding LegTypes, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='All'}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding SingleLegTradeConditionCodes}"
                                  ValueMember="Code">
                    <dxe:ComboBoxEdit.StyleSettings>
                        <dxe:CheckedComboBoxStyleSettings />
                    </dxe:ComboBoxEdit.StyleSettings>
                    <dxe:ComboBoxEdit.ItemTemplate>
                        <DataTemplate>
                            <Label HorizontalAlignment="Stretch"
                                   Content="{Binding Description}" />
                        </DataTemplate>
                    </dxe:ComboBoxEdit.ItemTemplate>
                </dxe:ComboBoxEdit>

                <Label Width="100"
                       Height="22"
                       Margin="5,0,0,0"
                       Content="Min Strike Spacing"
                       DockPanel.Dock="Left" />

                <dxe:SpinEdit Width="80"
                              Height="22"
                              Margin="5,0,0,0"
                              HorizontalAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding MinStrikeSpacing, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Mask="N2"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>

            <Grid Grid.Row="3"
                  Grid.Column="0"
                  Margin="0,7,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <dxe:CheckEdit Grid.Column="0"
                               Width="75"
                               Height="22"
                               Margin="0,0,0,0"
                               HorizontalAlignment="Left"
                               Content="Max Count"
                               EditValue="{Binding MaxCountEnabled}" />

                <dxe:SpinEdit Grid.Column="1"
                              Width="65"
                              Height="22"
                              Margin="1.2,0,0,0"
                              HorizontalAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding MaxCount, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              IsEnabled="{Binding MaxCountEnabled}"
                              Mask="d"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />

                <dxe:CheckEdit Grid.Column="2"
                               Margin="5,0,0,0"
                               Content="Unique"
                               EditValue="{Binding Unique}" />

                <dxe:CheckEdit Grid.Column="4"
                               Margin="5,0,0,0"
                               Content="Tick Type"
                               EditValue="{Binding LoadTickType}" />

                <dxe:CheckEdit Grid.Column="5"
                               Margin="5,0,0,0"
                               Content="Stats"
                               EditValue="{Binding StatProcessingEnabled}" />

                <dxe:CheckEdit Grid.Column="6"
                               Margin="5,0,0,0"
                               Content="Real Time"
                               EditValue="{Binding RealTime}" />

                <dxe:CheckEdit Grid.Column="7"
                               Margin="5,0,0,0"
                               Content="Use Databento"
                               EditValue="{Binding UseDatabento}" />

                <dx:SimpleButton Grid.Column="8"
                                 Width="39"
                                 Height="22"
