                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,5,0,0"
                         d:Visibility="Hidden"
                         dx:DXSerializer.StoreLayoutMode="All"
                         dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                         AutoGenerateColumns="AddNew"
                         AutoGeneratedColumns="Grid_ColumnsPopulated"
                         CurrentItem="{Binding CurrentDatabentoItem}"
                         CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                         EnableSmartColumnsGeneration="True"
                         FilterString="{Binding FilterString, Mode=TwoWay}"
                         ItemsSource="{Binding DatabentoTrades}"
                         PreviewMouseWheel="OnZoomMouseWheel"
                         SelectedItems="{Binding SelectedDatabentoItems}"
                         SelectionMode="Row"
                         Visibility="{Binding UseDatabento, Converter={StaticResource BooleanToVisibilityConverter}}">
            <dxg:GridControl.LayoutTransform>
                <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=TradeGridScale, Path=Value}" ScaleY="{Binding ElementName=TradeGridScale, Path=Value}" />
            </dxg:GridControl.LayoutTransform>
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                    <Setter Property="Visible" Value="True" />
                    <Setter Property="IsSmart" Value="True" />
                </Style>
            </dxg:GridControl.Resources>
            <dxmvvm:Interaction.Behaviors>
                <services:UiUpdateService />
            </dxmvvm:Interaction.Behaviors>
            <dxg:GridControl.View>
                <dxg:TableView Name="DatabentoTradesTableView"
                               AllowDragDrop="True"
                               AllowEditing="False"
                               AutoWidth="True"
                               CompleteRecordDragDrop="OnCompleteRecordDragDrop"
                               DragRecordOver="TableView_DragRecordOver"
                               DropRecord="TableView_DropRecord"
                               EditorShowMode="MouseUp"
                               EnableSelectedRowAppearance="True"
                               NavigationStyle="Row"
                               RowDoubleClickCommand="{Binding RowDoubleClickCommand}"
                               RowStyle="{StaticResource OrderStyle}"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               StartRecordDrag="OnStartRecordDrag">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.RowCellMenuCustomizations>
                        <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInComplexOrderTicketCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=DatabentoTradeGrid}"
                                           Content="Open in Order Ticket" />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.OpenInBasketTraderCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=DatabentoTradeGrid}"
                                           Content="Open in Basket Trader" />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.SearchTimeAndSalesOnLegsCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=DatabentoTradeGrid}"
                                           Content="Time and Sales of legs" />
                        <dxb:BarButtonItem Command="{Binding View.DataContext.BlockInBasketTraderCommand}"
                                           CommandParameter="{Binding Path=SelectedItem, ElementName=DatabentoTradeGrid}"
                                           Content="Block in Basket Trader" />
                    </dxg:TableView.RowCellMenuCustomizations>
                    <dxg:TableView.GroupValueTemplate>
                        <DataTemplate>
                            <TextBlock Margin="10,0,0,0"
                                       Text="{Binding Value}" />
                        </DataTemplate>
                    </dxg:TableView.GroupValueTemplate>
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridColumn FieldName="Symbol" />
            <dxg:GridColumn FieldName="Publisher" />
            <dxg:GridColumn FieldName="InstrumentId" />
            <dxg:GridColumn FieldName="TsEvent" />
            <dxg:GridColumn FieldName="TsRecv" />
            <dxg:GridColumn FieldName="Price" />
            <dxg:GridColumn FieldName="Size" />
            <dxg:GridColumn FieldName="Action" />
            <dxg:GridColumn FieldName="Side" />
            <dxg:GridColumn FieldName="Flags" />
            <dxg:GridColumn FieldName="Depth" />
            <dxg:GridColumn FieldName="Sequence" />
        </dxg:GridControl>

        <Grid Grid.Row="3"
              Grid.Column="1"
              Height="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Margin="5,0,0,0"
                       VerticalAlignment="Center"
                       Text="Rows" />
            <TextBlock Grid.Column="1"
                       Margin="3,0"
                       VerticalAlignment="Center"
                       Text="{Binding Trades.Count}" />
        </Grid>
    </Grid>
</dx:ThemedWindow>
