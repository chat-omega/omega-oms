<UserControl x:Class="ZeroPlus.Oms.Ui.Views.EmaConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:viewmodels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:EmaConfigViewModel}"
             d:Height="70"
             d:Width="250"
             mc:Ignorable="d">

    <UserControl.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="0" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="0" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Margin="5,2,0,0"
               Content="Smoothing" />

        <Label Grid.Row="1"
               Grid.Column="2"
               Margin="5,2,0,0"
               Content="Periods" />

        <Label Grid.Row="1"
               Grid.Column="3"
               Margin="5,2,0,0"
               Content="Interval" />

        <dxe:SpinEdit Grid.Row="2"
                      Grid.Column="1"
                      Width="75"
                      Margin="5,2,0,0"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding EmaConfig.EmaSmoothing}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="1"
                      Mask="N0"
                      MaskUseAsDisplayFormat="True"
                      MinValue="0"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <dxe:SpinEdit Grid.Row="2"
                      Grid.Column="2"
                      Width="75"
                      Margin="5,2,0,0"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding EmaConfig.EmaPeriods}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="1"
                      Mask="N0"
                      MaskUseAsDisplayFormat="True"
                      MinValue="0"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <dxe:SpinEdit Grid.Row="2"
                      Grid.Column="3"
                      Width="75"
                      Margin="5,2,0,0"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding EmaConfig.EmaInterval}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="1"
                      Mask="N0"
                      MaskUseAsDisplayFormat="True"
                      MinValue="0"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />
    </Grid>
</UserControl>
