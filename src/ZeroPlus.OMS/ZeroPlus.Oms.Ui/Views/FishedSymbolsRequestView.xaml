<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.FishedSymbolsRequestView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="{Binding ModuleTitle}"
                 Width="500"
                 Height="250"
                 DataContext="{startuphelpers:DISource Type=ViewModels:FishedSymbolsRequestViewModel}"
                 WindowStartupLocation="CenterScreen">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
        <dxmvvm:DispatcherService />
        <dxmvvm:SaveFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Label Grid.Row="2"
               Grid.Column="1"
               Content="Type" />

        <dxe:CheckEdit Grid.Row="2"
                       Grid.Column="2"
                       Margin="5,0,0,0"
                       Content="Outrights"
                       EditValue="{Binding IncludeOutrights}" />

        <dxe:CheckEdit Grid.Row="2"
                       Grid.Column="3"
                       Margin="5,0,0,0"
                       Content="Spreads"
                       EditValue="{Binding IncludeSpreads}" />

        <Label Grid.Row="3"
               Grid.Column="1"
               Content="Range" />

        <dxe:CheckEdit Grid.Row="3"
                       Grid.Column="2"
                       Margin="5,0,0,0"
                       Content="Include Backdays"
                       EditValue="{Binding IncludeBackdays}" />

        <dxe:TextEdit Grid.Row="3"
                      Grid.Column="3"
                      Width="190"
                      Margin="5,0,0,0"
                      HorizontalAlignment="Left"
                      HorizontalContentAlignment="Center"
                      EditValue="{Binding LastDateToInclude}"
                      IsEnabled="{Binding IncludeBackdays}"
                      Mask="G"
                      MaskType="DateTimeAdvancingCaret"
                      MaskUseAsDisplayFormat="True" />

        <Label Grid.Row="6"
               Grid.Column="1"
               Margin="0,5,0,0"
               Content="Underlyings" />

        <dxe:TextEdit Grid.Row="6"
                      Grid.Column="2"
                      Grid.ColumnSpan="2"
                      Width="405"
                      Margin="5,5,0,0"
                      HorizontalAlignment="Left"
                      EditValue="{Binding Underlyings}" />

        <Label Grid.Row="7"
               Grid.Column="1"
               Margin="0,5,0,5"
               VerticalAlignment="Bottom"
               Content="Status" />

        <Label Grid.Row="7"
               Grid.Column="2"
               Grid.ColumnSpan="2"
               Margin="0,5,0,5"
               VerticalAlignment="Bottom"
               Content="{Binding Status}" />

        <StackPanel Grid.Row="8"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="70"
                             Margin="3,0"
                             Command="{Binding LoadCommand}"
                             Content="Load" />
            <dx:SimpleButton Width="70"
                             Margin="3,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel" />
            <dx:SimpleButton Width="70"
                             Margin="3,0"
                             Command="{Binding ExportCommand}"
                             Content="Export" />
        </StackPanel>

    </Grid>
</dx:ThemedWindow>
