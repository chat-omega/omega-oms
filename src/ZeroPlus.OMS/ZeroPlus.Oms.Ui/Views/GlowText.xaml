<UserControl x:Class="ZeroPlus.Oms.Ui.Views.GlowText"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ZeroPlus.Oms.Ui.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="BaseStyle"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="Text" Value="{Binding Path=Text, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:GlowText}}}" />
                <Setter Property="Foreground" Value="{Binding Path=Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:GlowText}}}" />
                <Setter Property="FontSize" Value="{Binding Path=FontSize, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:GlowText}}}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Storyboard x:Key="glowBoard">
                <DoubleAnimation AutoReverse="True"
                                 RepeatBehavior="Forever"
                                 Storyboard.TargetProperty="(Effect).Opacity"
                                 From="0.0"
                                 To="1.0"
                                 Duration="0:0:2" />
            </Storyboard>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <TextBlock>
            <TextBlock.Style>
                <Style BasedOn="{StaticResource BaseStyle}"
                       TargetType="{x:Type TextBlock}">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="3"
                                              ShadowDepth="0"
                                              Color="WhiteSmoke" />
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=ActivateGlow, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:GlowText}}}"
                                     Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="bsb"
                                                 Storyboard="{StaticResource glowBoard}" />
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <RemoveStoryboard BeginStoryboardName="bsb" />
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Style="{StaticResource BaseStyle}">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="2"
                                  ShadowDepth="0"
                                  Color="{Binding Path=GlowColor, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:GlowText}}}" />
            </TextBlock.Effect>
        </TextBlock>
        <TextBlock Style="{StaticResource BaseStyle}">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="1"
                                  ShadowDepth="0"
                                  Color="white" />
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</UserControl>