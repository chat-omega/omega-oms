<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.DominatorListRollerView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="500"
                 Height="250"
                 d:DataContext="{d:DesignInstance Type=ViewModels:DominatorListRollerViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:DominatorListRollerViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <Window.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
    </Window.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:SaveFileDialogService />
        <dxmvvm:OpenFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Row="1"
                   Grid.Column="1"
                   Margin="0,2">
            <Label Width="75"
                   Margin="5,0"
                   Content="Input List"
                   DockPanel.Dock="Left" />
            <dx:SimpleButton Width="70"
                             Margin="5,0"
                             Command="{Binding BrowseFilesAsyncCommand}"
                             Content="Browse"
                             DockPanel.Dock="Right" />
            <dxe:TextEdit IsReadOnly="True"
                          Text="{Binding InputListName}"
                          ToolTip="{Binding InputListPath}" />
        </DockPanel>

        <StackPanel Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,2"
                    Orientation="Horizontal">
            <Label Width="75"
                   Margin="5,0"
                   Content="Creation Date"
                   DockPanel.Dock="Left" />
            <dxe:TextEdit Width="150"
                          HorizontalAlignment="Left"
                          EditValue="{Binding CreationDate}"
                          Mask="M.d.yy"
                          MaskType="DateTimeAdvancingCaret"
                          MaskUseAsDisplayFormat="True" />
            <Label Width="65"
                   Margin="5,0"
                   Content="Days To Roll" />
            <dxe:SpinEdit Grid.Column="1"
                          Width="70"
                          Margin="0,2,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding DatesToRoll, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                          EditValueType="{x:Type sys:Double}"
                          Mask="D"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

            <Label Width="26"
                   Margin="4,0,0,0"
                   Content="DTE" />

            <dxe:SpinEdit Grid.Column="1"
                          Width="70"
                          Margin="5,2,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          DisplayFormatString="N0"
                          EditValue="{Binding MaxDte, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          Mask="N0"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />
        </StackPanel>

        <DockPanel Grid.Row="3"
                   Grid.Column="1"
                   Margin="0,2">
            <Label Width="75"
                   Margin="5,0"
                   Content="Swap Under"
                   DockPanel.Dock="Left" />
            <dxe:TextEdit Width="150"
                          HorizontalAlignment="Left"
                          Text="{Binding Underlying}" />
            <Label Width="65"
                   Margin="5,0"
                   Content="Saved Last" />
            <dxe:SpinEdit Grid.Column="1"
                          Width="70"
                          Margin="0,2,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          DisplayFormatString="N2"
                          EditValue="{Binding SavedLastPrice, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                          EditValueType="{x:Type sys:Double}"
                          Mask="N2"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />
            <Label Width="25"
                   Margin="5,0"
                   HorizontalContentAlignment="Center"
                   Content="Δ" />
            <dxe:SpinEdit Grid.Column="1"
                          Width="70"
                          Margin="0,2,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          DisplayFormatString="N2"
                          EditValue="{Binding ChangeInLastPrice, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                          EditValueType="{x:Type sys:Double}"
                          Mask="N2"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />
        </DockPanel>
        <StackPanel Grid.Row="4"
                    Grid.Column="1"
                    Margin="85,2,0,2"
                    Orientation="Horizontal">
            <dxe:CheckEdit Content="Fill in missing expirations"
                           EditValue="{Binding FillInMissingExpirations}" />

            <Label Width="65"
                   Margin="4,0,0,0"
                   Content="Near Exps" />

            <dxe:SpinEdit Grid.Column="1"
                          Width="70"
                          Margin="5,2,0,0"
                          HorizontalAlignment="Left"
                          AllowSpinOnMouseWheel="True"
                          DisplayFormatString="N0"
                          EditValue="{Binding RollRange, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Int32}"
                          IsEnabled="{Binding FillInMissingExpirations}"
                          Mask="N0"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />
        </StackPanel>

        <dxe:ProgressBarEdit Grid.Row="6"
                             Grid.Column="1"
                             Width="315"
                             Height="24"
                             Margin="5"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Bottom"
                             ContentDisplayMode="Content"
                             Visibility="{Binding ShowProgressBar, Converter={StaticResource BooleanToVisibilityConverter}}">
            <dxe:ProgressBarEdit.StyleSettings>
                <dxe:ProgressBarMarqueeStyleSettings />
            </dxe:ProgressBarEdit.StyleSettings>
        </dxe:ProgressBarEdit>

        <TextBlock Grid.Row="6"
                   Grid.Column="1"
                   Margin="5,5"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="{Binding ProgressStatus}" />

        <StackPanel Grid.Row="7"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SplitButton Width="100"
                            Height="24"
                            Margin="5,0,0,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding ExportAsyncCommand}"
                            Content="Export"
                            PopupAutoWidth="True">
                <dx:SimpleButton VerticalAlignment="Bottom"
                                 Command="{Binding ParseSpreadsCommand}"
                                 Content="Parse List" />
            </dx:SplitButton>
            <dx:SimpleButton Width="100"
                             Margin="5,0"
                             Command="{Binding RollListAsyncCommand}"
                             Content="Roll"
                             IsDefault="True" />
            <dx:SimpleButton Width="100"
                             Margin="5,0"
                             Command="{Binding CancelCommand}"
                             Content="Cancel"
                             IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
