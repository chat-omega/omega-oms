<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.AvgTimeCloseConfigView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 Title="Close Config"
                 Width="400"
                 Height="250"
                 d:DataContext="{d:DesignInstance Type=viewModels:PairTraderViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterOwner"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <dx:DXTabControl Padding="0">
            <dx:DXTabItem Header="Stop Loss">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="5" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="5" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="5" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           Padding="2,2,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="Stop Loss" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="2"
                                  Width="75"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding StopLoss}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment=".01"
                                  Mask="N2"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:CheckEdit Grid.Row="2"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="5,2,0,0"
                                   Content="Block reentry after stoploss"
                                   EditValue="{Binding BlockReentryAfterStoploss}" />


                </Grid>
            </dx:DXTabItem>
            <dx:DXTabItem Header="Avg Time Close">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="5" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="5" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="5" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           Padding="2,2,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="State" />

                    <dxe:ToggleSwitch Grid.Row="1"
                                      Grid.Column="2"
                                      Margin="5,2,0,0"
                                      HorizontalAlignment="Left"
                                      Background="#f4241e"
                                      CheckedStateContent="Enabled"
                                      ContentPlacement="Inside"
                                      IsChecked="{Binding CloseByAvgCloseTime}"
                                      ToggleSwitchWidth="75"
                                      UncheckedStateContent="Disabled" />

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           Padding="2,2,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="Avg Lookback time (sec)" />

                    <dxe:SpinEdit Grid.Row="2"
                                  Grid.Column="2"
                                  Width="75"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AvgCloseTimeLookbackSeconds}"
                                  EditValueType="{x:Type sys:Double}"
                                  Mask="N0"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="3"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           Padding="2,2,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="Avg close multiplier" />

                    <dxe:SpinEdit Grid.Row="3"
                                  Grid.Column="2"
                                  Width="75"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AvgCloseTimeMultiplier}"
                                  EditValueType="{x:Type sys:Double}"
                                  Mask="N2"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="4"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           Padding="2,2,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="Min close time (sec)" />

                    <dxe:SpinEdit Grid.Row="4"
                                  Grid.Column="2"
                                  Width="75"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding MinCloseTimeSec}"
                                  EditValueType="{x:Type sys:Double}"
                                  Mask="N0"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="15"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="5"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           Padding="2,2,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="Historic EMA Period" />

                    <dxe:SpinEdit Grid.Row="5"
                                  Grid.Column="2"
                                  Width="75"
                                  Margin="5,2,0,0"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding HistoricAvgCloseTimeEmaPeriod}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Mask="N0"
                                  MaskUseAsDisplayFormat="True"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:CheckEdit Grid.Row="6"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="5,2,0,0"
                                   Content="Block reentry after stoploss"
                                   EditValue="{Binding BlockReentryAfterAvgTimeClose}" />

                </Grid>
            </dx:DXTabItem>
        </dx:DXTabControl>

        <dx:SimpleButton Grid.Row="1"
                         Grid.ColumnSpan="3"
                         Width="80"
                         Margin="3,2"
                         HorizontalAlignment="Center"
                         Click="Close"
                         Content="Save"
                         Glyph="{dx:DXImage SvgImages/Save/Save.svg}"
                         GlyphHeight="15" />
    </Grid>
</dx:ThemedWindow>
