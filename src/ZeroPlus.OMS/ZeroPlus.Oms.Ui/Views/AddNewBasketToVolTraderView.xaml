<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.AddNewBasketToVolTraderView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="Add New Basket"
                 Width="225"
                 Height="200"
                 d:DataContext="{d:DesignInstance Type=ViewModels:VolTraderViewModel}"
                 ResizeMode="NoResize"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Margin="5,0"
               Content="Symbol" />

        <dxe:ButtonEdit Grid.Row="1"
                        Grid.Column="2"
                        AllowDefaultButton="False"
                        CharacterCasing="Upper"
                        EditValue="{Binding NewUnderlying, UpdateSourceTrigger=PropertyChanged}"
                        EditValuePostDelay="0"
                        SelectAllOnGotFocus="True"
                        SelectAllOnMouseUp="True"
                        TabIndex="1">
            <dxe:ButtonEdit.Buttons>
                <dxe:ButtonInfo Command="{Binding SearchUnderlyingCommand}"
                                GlyphKind="Search"
                                IsDefaultButton="True" />
            </dxe:ButtonEdit.Buttons>
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:KeyToCommand Command="{Binding SearchUnderlyingCommand}"
                                     KeyGesture="Enter" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ButtonEdit>

        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="5,0"
               Content="Expiration" />

        <dxe:ComboBoxEdit Grid.Row="2"
                          Grid.Column="2"
                          Margin="0,2,0,0"
                          HorizontalContentAlignment="Left"
                          DisplayFormatString="MMM dd yy"
                          DisplayMember="Expiration"
                          IsTextEditable="False"
                          ItemsSource="{Binding ExpirationsList}"
                          PopupHeight="200"
                          SelectedItem="{Binding ExpirationInfo, UpdateSourceTrigger=PropertyChanged}">
            <dxe:ComboBoxEdit.ItemTemplate>
                <DataTemplate>
                    <Grid Width="200"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0"
                               HorizontalAlignment="Left"
                               Content="{Binding Expiration}"
                               ContentStringFormat="MMM dd yy" />
                        <Label Grid.Column="1"
                               HorizontalAlignment="Center"
                               Content="{Binding RootSymbol}" />
                        <Label Grid.Column="2"
                               HorizontalAlignment="Right"
                               Content="{Binding Settlement}" />
                    </Grid>
                </DataTemplate>
            </dxe:ComboBoxEdit.ItemTemplate>
        </dxe:ComboBoxEdit>

        <Label Grid.Row="3"
               Grid.Column="1"
               Margin="5,0"
               Content="Types" />

        <dxe:ComboBoxEdit Grid.Row="3"
                          Grid.Column="2"
                          Margin="0,2,0,0"
                          IsTextEditable="False"
                          ItemsSource="{Binding TypesList}"
                          SelectedItem="{Binding NewType, UpdateSourceTrigger=PropertyChanged}" />

        <Label Grid.Row="4"
               Grid.Column="1"
               Margin="5,0"
               Content="Strike" />
        <Grid Grid.Row="4"
              Grid.Column="2"
              Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <dxe:SpinEdit Grid.Column="0"
                          Width="70"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding NewMinStrike, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

            <Label Grid.Column="1"
                   Margin="2,0,0,0"
                   Content="-" />

            <dxe:SpinEdit Grid.Column="2"
                          Width="70"
                          Margin="2,0,0,0"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding NewMaxStrike, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          MinValue="0"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />
        </Grid>
        <StackPanel Grid.Row="6"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="70"
                             Margin="2,0"
                             Click="CloseButton_Click"
                             Command="{Binding AddBasketFromSymbolAndExpirationCommand}"
                             Content="Add" />
            <dx:SimpleButton Width="70"
                             Margin="2,0"
                             Click="CloseButton_Click"
                             Content="Close" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
