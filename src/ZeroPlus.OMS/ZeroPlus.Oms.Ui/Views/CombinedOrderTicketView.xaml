                       FontWeight="DemiBold"
                       Foreground="{Binding StockHedgeQty, Converter={StaticResource SignToBrushConverter}}" />

                <dxe:SpinEdit Grid.Row="1"
                              Grid.Column="8"
                              Width="70"
                              Margin="5,0,0,0"
                              HorizontalAlignment="Left"
                              AllowSpinOnMouseWheel="True"
                              Background="#171718"
                              DisplayFormatString="N2"
                              EditValue="{Binding StockHedgePercent, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Double}"
                              Increment="0.01"
                              Mask="N2"
                              MaxValue="{Binding OmsCore.Config.MaxAutoHedgePercentV2}"
                              MinValue="0"
                              PreviewMouseUp="SpinEdit_Click"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding UpdateStockPositionsCommand}"
                                               EventName="EditValueChanged" />
                        <behavior:SpinEditFocusSelectionBehavior />
                    </dxmvvm:Interaction.Behaviors>
                </dxe:SpinEdit>

            </Grid>
        </dxlc:GroupBox>

        <dxg:GridControl x:Name="GammaScalpRiskGrid"
                         Grid.Row="6"
                         Grid.Column="1"
                         Height="167"
                         Margin="0,3,0,0"
                         Padding="4,6"
                         VerticalAlignment="Bottom"
                         dx:DXSerializer.StoreLayoutMode="All"
                         dxg:DataControlSerializationOptions.RemoveOldColumns="False"
                         AutoGenerateColumns="AddNew"
                         AutoGeneratedColumns="Grid_ColumnsPopulated"
                         CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                         EnableSmartColumnsGeneration="True"
                         ItemsSource="{Binding PositionsRisk}"
                         PreviewMouseWheel="OnZoomMouseWheel"
                         RestoreStateOnSourceChange="True"
                         SelectionMode="Row"
                         Visibility="{Binding Path=IsChecked, ElementName=showRiskRunPanelCheckBox, Converter={StaticResource BooleanToVisibilityConverter}}">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
                <Style x:Key="RowStyle"
                       TargetType="dxg:RowControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=IsSelected}"
                                     Value="True">
                            <Setter Property="Background" Value="#1d3c52" />
                        </DataTrigger>
                        <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                            <Setter Property="Background" Value="#1d3c52" />
                        </Trigger>
                        <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#39393A" />
                        </Trigger>
                        <DataTrigger Binding="{Binding Path=Row.IsCurrent}"
                                     Value="True">
                            <Setter Property="Background" Value="#8a7750" />
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#3E596B" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False"
                               AllowSorting="False"
                               AutoWidth="True"
                               EnableSelectedRowAppearance="True"
                               GroupSummaryDisplayMode="AlignByColumns"
                               NavigationStyle="Row"
                               RowStyle="{StaticResource RowStyle}"
                               ShowFilterPanelMode="Never"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="False"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.TotalSummaryContentStyle>
                        <Style TargetType="dx:DataContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </dxg:TableView.TotalSummaryContentStyle>
                    <dxg:TableView.TotalSummaryItemTemplate>
                        <DataTemplate>
                            <TextBlock Padding="2"
                                       Foreground="{Binding Column.TotalSummaryText, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding Column.TotalSummaryText, StringFormat='{}{0:C0}'}" />
                        </DataTemplate>
                    </dxg:TableView.TotalSummaryItemTemplate>
                    <dxg:TableView.GroupColumnSummaryItemTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Right"
                                       Foreground="{Binding Value, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding Value}" />
                        </DataTemplate>
                    </dxg:TableView.GroupColumnSummaryItemTemplate>
                    <dxg:TableView.GroupValueTemplate>
                        <DataTemplate>
                            <TextBlock Margin="10,0,0,0"
                                       Text="{Binding Value}" />
                        </DataTemplate>
                    </dxg:TableView.GroupValueTemplate>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="UnderlyingPrice"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding RowData.Row.UnderlyingPrice, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="NetDelta"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.NetDelta, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.NetDelta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="NetTheta"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.NetTheta, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.NetTheta, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="NetGamma"
                            IsSmart="True"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RowData.Row.NetGamma, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.NetGamma, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>

        <dxlc:GroupBox Grid.Row="7"
                       Grid.Column="1"
                       Height="70"
                       Margin="0,3,0,0"
                       Padding="4,6"
                       Header="Order Instructions"
                       Visibility="{Binding Path=IsChecked, ElementName=showOrderInstructionsPanelCheckBox, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <dx:SimpleButton Grid.Row="0"
                                 Grid.Column="0"
                                 Margin="0,0,0,0"
                                 Padding="2,2,0,0"
                                 VerticalAlignment="Bottom"
                                 HorizontalContentAlignment="Stretch"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ButtonKind="Toggle"
                                 IsChecked="{Binding AccountLocked}">
                    <DockPanel HorizontalAlignment="Left">
                        <Label Margin="1,0,0,0"
                               Padding="0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Content="ACCOUNT"
                               FontSize="8" />
                        <dx:DXImage Height="10"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="{dx:DXImage SvgImages/Icon Builder/Security_Lock.svg}"
                                    Visibility="{Binding AccountLocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </DockPanel>
                </dx:SimpleButton>
                <Label Grid.Row="0"
                       Grid.Column="1"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="TIF"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="2"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="TAG"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="3"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="LOCATE"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="4"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="DISPLAY #"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="5"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="MODE"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="6"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="BROKER"
                       FontSize="8" />
                <Label Grid.Row="0"
                       Grid.Column="7"
                       Margin="6,0,0,0"
                       Padding="0"
                       VerticalAlignment="Bottom"
                       Content="GTH"
                       FontSize="8" />
                <dxe:ComboBoxEdit Grid.Row="1"
                                  Grid.Column="0"
                                  Width="145"
                                  Margin="0,0,0,0"
                                  HorizontalAlignment="Left"
                                  Background="#171718"
                                  IsEnabled="{Binding AccountLocked, Converter={StaticResource BooleanNegationConverter}}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding AccountsList}"
                                  SelectedItem="{Binding Account}">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding AccountOrRouteChangedCommand}"
                                               EventName="EditValueChanged" />
                    </dxmvvm:Interaction.Behaviors>
                </dxe:ComboBoxEdit>
                <dxe:ComboBoxEdit Grid.Row="1"
                                  Grid.Column="1"
                                  Width="70"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  Background="#171718"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding TifsList}"
                                  SelectedItem="{Binding TimeInForce}" />
                <dxe:TextEdit Grid.Row="1"
                              Grid.Column="2"
                              Width="125"
                              Margin="5,0,0,0"
                              Background="#171718"
                              Text="{Binding Path=Tag}" />

                <DockPanel Grid.Row="1"
                           Grid.Column="3"
                           Width="125"
                           Margin="5,0,0,0"
                           Background="#171718">
                    <dxe:TextEdit Background="#171718" />
                </DockPanel>

                <DockPanel Grid.Row="1"
                           Grid.Column="4"
                           Width="70"
                           Margin="5,0,0,0"
                           Background="#171718">
                    <dxe:SpinEdit Background="#171718" />
                </DockPanel>

                <dxe:ComboBoxEdit Grid.Row="1"
                                  Grid.Column="5"
                                  Width="90"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  Background="#171718"
                                  EditValue="{Binding InstanceMode}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding InstanceModes}">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding ApplyInstanceModeChangesCommand}"
                                               EventName="EditValueChanged" />
                    </dxmvvm:Interaction.Behaviors>
                </dxe:ComboBoxEdit>

                <dxe:ComboBoxEdit Grid.Row="1"
                                  Grid.Column="6"
                                  Width="100"
                                  Margin="5,0,0,0"
                                  EditValue="{Binding BrokerOverride, UpdateSourceTrigger=PropertyChanged}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding OmsCore.Config.AvailableBrokers}"
                                  NullText="Use global">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding BrokerChangedCommand}"
                                               EventName="EditValueChanged" />
                    </dxmvvm:Interaction.Behaviors>
                </dxe:ComboBoxEdit>

                <dxe:ToggleSwitch Grid.Row="1"
                                  Grid.Column="7"
                                  Margin="5,0,0,0"
                                  HorizontalAlignment="Left"
                                  Background="#171718"
                                  CheckedStateContent="ON"
                                  ContentPlacement="Inside"
                                  IsChecked="{Binding IsGTH, UpdateSourceTrigger=PropertyChanged}"
                                  ToggleSwitchWidth="70"
                                  UncheckedStateContent="OFF" />
            </Grid>
        </dxlc:GroupBox>

        <Border Grid.Row="8"
                Grid.Column="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Height="20"
                           Margin="0,0,5,1"
                           Padding="3"
                           VerticalAlignment="Bottom"
                           Background="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                           Foreground="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                           Text="{Binding Status}" />

                <Grid Grid.Column="1"
                      Visibility="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,0,0"
                           Padding="2,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"
                           Content="AUTO CANCEL"
                           FontSize="8" />

                    <Label Grid.Row="0"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Margin="5,0,0,0"
                           Padding="2,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"
                           Content="CANCEL RANGE"
                           FontSize="8" />

                    <Label Grid.Row="0"
                           Grid.Column="3"
                           Margin="5,0,0,0"
                           Padding="2,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"
                           Content="RESUBMIT"
                           FontSize="8" />

                    <dxe:ComboBoxEdit Grid.Row="1"
                                      Grid.Column="0"
                                      Width="70"
                                      Margin="0,0,0,0"
                                      HorizontalAlignment="Left"
                                      Background="#171718"
                                      FontSize="10"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding AutoCancelModes}"
                                      SelectedItem="{Binding AutoCancelMode}" />

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Width="70"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Left"
                            Background="#171718"
                            BorderBrush="#3F3F46"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <dxe:SpinEdit Width="32"
                                          Margin="0,0,0,0"
                                          HorizontalContentAlignment="Left"
                                          AllowSpinOnMouseWheel="True"
                                          Background="#171718"
                                          EditValue="{Binding AutoCancelIntervalMin, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          MinValue="0"
                                          PreviewMouseUp="SpinEdit_Click"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True"
                                          ShowBorder="False"
                                          ShowEditorButtons="False" />
                            <TextBlock Width="4"
                                       Height="18"
                                       Foreground="White"
                                       Text="-"
                                       TextAlignment="Center" />
                            <dxe:SpinEdit Width="32"
                                          Margin="0,0,0,0"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          Background="#171718"
                                          EditValue="{Binding AutoCancelIntervalMax, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          MinValue="{Binding AutoCancelIntervalMin}"
                                          PreviewMouseUp="SpinEdit_Click"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True"
                                          ShowBorder="False"
                                          ShowEditorButtons="False" />
                        </StackPanel>
                    </Border>

                    <dxe:ToggleSwitch Grid.Row="1"
                                      Grid.Column="3"
                                      Margin="5,0,0,0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      AnimationMode="OnToggle"
                                      Background="#171718"
                                      BorderThickness="0.7"
                                      CheckedStateContent="ON"
                                      ContentPlacement="Inside"
                                      IsChecked="{Binding ResubmitAfterCancel}"
                                      ToggleSwitchWidth="70"
                                      UncheckedStateContent="OFF" />

                </Grid>

                <StackPanel Grid.Column="1"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Panel.ZIndex="100"
                            Orientation="Horizontal"
                            Visibility="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <dxe:ButtonEdit AllowDefaultButton="False"
                                    IsEnabled="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ShowBorder="False"
                                    ShowText="False">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:LoadingIndicatorButtonInfo />
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>
                    <dxe:ButtonEdit Margin="-5,0,0,0"
                                    AllowDefaultButton="False"
                                    IsEnabled="{Binding IsLooping, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ShowBorder="False"
                                    ShowText="False">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:LoadingIndicatorButtonInfo />
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Height="20"
                           Margin="5,0,0,1"
                           Padding="3"
                           VerticalAlignment="Bottom"
                           Background="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                           Foreground="{Binding ContraStatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                           Text="{Binding ContraStatus}"
                           TextAlignment="Right" />

            </Grid>
        </Border>
    </Grid>
</dx:ThemedWindow>
