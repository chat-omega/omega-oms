<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.CombinedOrderTicketView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
                 xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxi="http://schemas.devexpress.com/winfx/2008/xaml/core/internal"
                 xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
                 Title="{Binding Description}"
                 Width="750"
                 Height="400"
                 MinWidth="400"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:ComplexOrderTicketViewModel}"
                 d:Height="auto"
                 DataContext="{startuphelpers:DISource Type=ViewModels:ComplexOrderTicketViewModel}"
                 FontSize="11"
                 KeyboardNavigation.DirectionalNavigation="Once"
                 MouseDown="TicketWindow_MouseDown"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <Window.Resources>
        <helper:BindingProxy x:Key="ProxyElement"
                             Data="{Binding}" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:MultiValueCloneConverter x:Key="MultiValueCloneConverter" />
        <helper:PriceToConnectorConverter x:Key="PriceToConnectorConverter" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:LoopPricingModeToDisplayTextConverter x:Key="LoopPricingModeToDisplayTextConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helper:RangeToBrushConverter x:Key="RangeToBrushConverter"
                                      AboveRangeBrush="#B73535"
                                      BelowRangeBrush="#0A8E51"
                                      InbetweenRangeBrush="#1a4c35"
                                      RangeCeil="0.50"
                                      RangeFloor="0.45" />
        <helper:SignToBrushConverter x:Key="CountdownToBrushConverter"
                                     Limit="3"
                                     NegativeBrush="#F05126"
                                     PositiveBrush="#171718"
                                     ZeroBrush="#F05126" />
        <dxmvvm:BooleanToObjectConverter x:Key="SignToHoverBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#C44E4E" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#2D9E65" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="SignToPressedBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#772F2F" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#1D673F" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="SignToBackBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#B73535" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#0A8E51" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="SignToForeBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="#FF0000" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#02F302" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBorderColorConverterRed">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F88F8F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #3F3F46
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBackColorConverterRed">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F88F8F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToButtonTextConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Stop
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                Start
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helper:DoubleToVisibilityConverter x:Key="DoubleToVisibilityConverter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#FF0000"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#FFFFFF" />
        <helper:OrderToBackBrushConverter x:Key="SideToColorConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToBorderColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                Transparent
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #FF0000
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="ValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                <SolidColorBrush Color="Transparent" />
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                <SolidColorBrush Color="#FF0000" />
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TheoValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #02F302
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F3A202
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>

        <dxmvvm:BooleanToObjectConverter x:Key="AdjTheoValidityToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F1F1F1
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F3A202
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>

        <Style x:Key="submitButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding IsSellOrder, Converter={StaticResource SignToHoverBrushConverter}}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{Binding IsSellOrder, Converter={StaticResource SignToPressedBrushConverter}}" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="{Binding IsSellOrder, Converter={StaticResource SignToBackBrushConverter}}" />
        </Style>

        <Style x:Key="contraSubmitButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding IsContraSellOrder, Converter={StaticResource SignToHoverBrushConverter}}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{Binding IsContraSellOrder, Converter={StaticResource SignToPressedBrushConverter}}" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="{Binding IsContraSellOrder, Converter={StaticResource SignToBackBrushConverter}}" />
        </Style>

        <Style x:Key="modifyButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A053CC" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#64337F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#8835B7" />
        </Style>
        <Style x:Key="closeButtonStyle"
               TargetType="{x:Type dx:SimpleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#584ab4" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#64337F" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="Background" Value="#7160e8" />
        </Style>
    </Window.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:VerificationService />
        <services:OmsMessageBoxService />
        <dxmvvm:DispatcherService />
        <dxmvvm:CurrentWindowService />
        <dxmvvm:KeyToCommand Command="{Binding SearchUnderlyingCommand}"
                             KeyGesture="Enter" />
        <dxmvvm:KeyToCommand Command="{Binding IncrementPriceCommand}"
                             EventName="KeyDown"
                             KeyGesture="Up" />
        <dxmvvm:KeyToCommand Command="{Binding DecrementPriceCommand}"
                             EventName="KeyDown"
                             KeyGesture="Down" />
    </dxmvvm:Interaction.Behaviors>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center"
                       dxi:WindowChrome.IsHitTestVisibleInChrome="False"
                       FontSize="12"
                       Text="CREATED" />
            <TextBlock Margin="5,0,0,0"
                       VerticalAlignment="Center"
                       dxi:WindowChrome.IsHitTestVisibleInChrome="False"
                       FontFamily="{StaticResource Technology}"
                       FontSize="17"
                       Text="{Binding CreationTime, StringFormat={}{0:hh:mm:ss}}" />

            <TextBlock Margin="10,2,0,1"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       dxi:WindowChrome.IsHitTestVisibleInChrome="False"
                       FontSize="11"
                       FontWeight="DemiBold"
                       Text="Submit"
                       TextAlignment="Right" />

            <TextBlock Margin="4,2,0,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       dxi:WindowChrome.IsHitTestVisibleInChrome="False"
                       FontSize="11"
                       FontWeight="Bold"
                       Text="{Binding SubmitLatency}"
                       TextAlignment="Right" />

            <TextBlock Margin="10,2,0,1"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       dxi:WindowChrome.IsHitTestVisibleInChrome="False"
                       FontSize="11"
                       FontWeight="DemiBold"
                       Text="Status"
                       TextAlignment="Right" />

            <TextBlock Margin="4,2,0,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       dxi:WindowChrome.IsHitTestVisibleInChrome="False"
                       FontSize="11"
                       FontWeight="Bold"
                       Text="{Binding PendingNewLatency}"
                       TextAlignment="Right" />

            <dxe:ToggleSwitch Margin="5,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              AnimationMode="Always"
                              Background="#FF0000"
                              CheckedStateContent="✓  Risk"
                              ContentPlacement="Inside"
                              Focusable="False"
                              FontWeight="Bold"
                              IsChecked="{Binding RiskCheckEnabled}"
                              ToggleSwitchWidth="65"
                              UncheckedStateContent="⚠ Risk" />

            <dx:SimpleButton Width="22"
                             Margin="5,0"
                             HorizontalAlignment="Right"
                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                             GlyphHeight="15">
                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupControlContainer>
                        <ItemsControl>
                            <StackPanel Margin="5">
                                <MenuItem Height="25"
                                          Command="{Binding CloneCommand}"
                                          Header="Clone">
                                    <MenuItem.CommandParameter>
                                        <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                                            <Binding Path="Width"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type Window}}" />
                                            <Binding Path="Height"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type Window}}" />
                                            <Binding Path="Left"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type Window}}" />
                                            <Binding Path="Top"
                                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                     AncestorType={x:Type Window}}" />
                                        </MultiBinding>
                                    </MenuItem.CommandParameter>
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="ShareLayout"
                                          Header="Share Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="SaveLayout"
                                          Header="Save Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding BrowseLayoutsCommand}"
                                          Header="Browse Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="LoadLayout"
                                          Header="Load Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <dx:SuperTipItemControlSeparator />
                                <MenuItem Height="25"
                                          Command="{Binding SearchTimeAndSalesCommand}"
                                          Header="Time and Sales" />
                                <MenuItem Height="25"
                                          Command="{Binding OpenInGammaScalperCommand}"
                                          Header="Open in Gamma Scalper" />
                                <MenuItem Height="25"
                                          Command="{Binding OpenInLiveChartCommand}"
                                          Header="Open in Theo Chart" />
                                <MenuItem Height="25"
                                          Command="{Binding ShowFeeCalculatorCommand}"
                                          Header="Show Fee Calculator" />
                                <MenuItem Height="25"
                                          Command="{Binding SubscribeToIbCommand}"
                                          Header="Request IB Quote" />
                                <MenuItem Name="showQuickRoutesCheckBox"
                                          Height="25"
                                          Checked="ShowQuickRoutesCheckBoxUpdated"
                                          Header="Show Quick Routes Panel"
                                          IsCheckable="True"
                                          IsChecked="{Binding ShowQuickRoutes}"
                                          Unchecked="ShowQuickRoutesCheckBoxUpdated" />
                                <MenuItem Name="showSpeedTraderCheckBox"
                                          Height="25"
                                          Checked="ShowShowSpeedTraderCheckBoxUpdated"
                                          Header="Show Speed Trader Panel"
                                          IsCheckable="True"
                                          IsChecked="{Binding ShowSpeedTrader}"
                                          Unchecked="ShowShowSpeedTraderCheckBoxUpdated">
                                    <dxmvvm:Interaction.Behaviors>
                                        <dxmvvm:EventToCommand Command="{Binding ShowSpeedTraderValueCheckedCommand}"
                                                               EventName="Checked" />
                                        <dxmvvm:EventToCommand Command="{Binding ShowSpeedTraderValueCheckedCommand}"
                                                               EventName="Unchecked" />
                                    </dxmvvm:Interaction.Behaviors>
                                </MenuItem>
                                <MenuItem Name="showAutoHedgePanelCheckBox"
                                          Height="25"
                                          Checked="ShowAutoHedgeCheckBoxUpdated"
                                          Header="Show Auto Hedge Panel"
                                          IsCheckable="True"
                                          Unchecked="ShowAutoHedgeCheckBoxUpdated" />
                                <MenuItem Name="showRiskRunPanelCheckBox"
                                          Height="25"
                                          Checked="ShowRiskRunCheckBoxUpdated"
                                          Header="Show Risk Run Panel"
                                          IsCheckable="True"
                                          IsChecked="{Binding ShowRiskRunPanel}"
                                          Unchecked="ShowRiskRunCheckBoxUpdated" />
                                <MenuItem Name="showSubmitWithDelayPanelCheckBox"
                                          Height="25"
                                          Checked="ShowSubmitWithDelayPanelCheckBoxUpdated"
                                          Header="Show Submit With Delay Panel"
                                          IsCheckable="True"
                                          IsChecked="{Binding ShowSubmitWithDelayPanel}"
                                          Unchecked="ShowSubmitWithDelayPanelCheckBoxUpdated" />
                                <MenuItem Name="showStopLossPanelCheckBox"
                                          Height="25"
                                          Checked="ShowStopLossPanelCheckBoxUpdated"
                                          Header="Show Stop Loss Panel"
                                          IsCheckable="True"
                                          IsChecked="{Binding ShowStopLossPanel}"
                                          Unchecked="ShowStopLossPanelCheckBoxUpdated" />
                                <MenuItem Name="showOrderInstructionsPanelCheckBox"
                                          Height="25"
                                          Checked="ShowOrderInstructionsPanelCheckBoxUpdated"
                                          Header="Show Order Instructions Panel"
                                          IsCheckable="True"
                                          Unchecked="ShowOrderInstructionsPanelCheckBoxUpdated" />
                                <MenuItem Height="25"
                                          Header="Show Clearing Instructions Panel"
                                          IsCheckable="True" />
                            </StackPanel>
                        </ItemsControl>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>
        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <Grid PreviewMouseWheel="Grid_PreviewMouseWheel">
        <Grid.RowDefinitions>
            <RowDefinition Height="2" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="2" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="2" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="2" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        Margin="1,0,0,3"
                        Orientation="Horizontal">
                <dxe:ButtonEdit Width="90"
                                Margin="0,0,2,0"
                                AllowDefaultButton="False"
                                Background="#171718"
                                CharacterCasing="Upper"
                                EditValue="{Binding Underlying, UpdateSourceTrigger=PropertyChanged}"
                                EditValuePostDelay="0"
                                SelectAllOnGotFocus="True"
                                SelectAllOnMouseUp="True"
                                TabIndex="1">
                    <dxe:ButtonEdit.Buttons>
                        <dxe:ButtonInfo Command="{Binding SearchUnderlyingCommand}"
                                        GlyphKind="Search"
                                        IsDefaultButton="True" />
                    </dxe:ButtonEdit.Buttons>
                </dxe:ButtonEdit>

                <Border Width="65"
                        Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1">
                    <DockPanel>
                        <Label Padding="3,0,2,0"
                               VerticalContentAlignment="Center"
                               Background="#171718"
                               Content="HEDGE"
                               FontSize="9" />
                        <TextBlock Padding="1,3,3,3"
                                   Background="#171718"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding HedgedStocks, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding HedgedStocks, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                   TextAlignment="Right" />
                    </DockPanel>
                </Border>
                <Border Width="65"
                        Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1">
                    <DockPanel>
                        <Label Padding="3,0,2,0"
                               VerticalContentAlignment="Center"
                               Background="#171718"
                               Content="REQ"
                               FontSize="9" />
                        <TextBlock Padding="1,3,3,3"
                                   Background="#171718"
                                   FontWeight="DemiBold"
                                   Foreground="{Binding RequiredStocks, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RequiredStocks, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                                   TextAlignment="Right" />
                    </DockPanel>
                </Border>

                <Border Width="77"
                        Margin="1,0,2,0"
                        BorderBrush="#3F3F46"
                        BorderThickness="1">
                    <DockPanel>
                        <Label Padding="3,0,2,0"
                               VerticalContentAlignment="Center"
                               Content="U.PNL"
                               FontSize="9" />
                        <Grid>
                            <TextBlock Padding="1,3,3,3"
                                       FontWeight="DemiBold"
                                       Foreground="{Binding UnrealizedPnl, Converter={StaticResource SignToBrushConverter}}"
                                       Text="{Binding UnrealizedPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                       TextAlignment="Right" />
                        </Grid>
                    </DockPanel>
                </Border>

            </StackPanel>

            <Border Grid.Row="1"
                    Grid.RowSpan="2"
                    Grid.Column="2"
                    Width="65"
                    HorizontalAlignment="Center"
                    BorderBrush="#3F3F46"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Content="POS"
                           FontSize="9" />
                    <Label Grid.Row="1"
                           Padding="0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalContentAlignment="Center"
                           VerticalContentAlignment="Center"
                           Content="{Binding LcdPosition}"
                           FontSize="20"
                           FontWeight="ExtraBold"
                           Foreground="#e8b44f" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Grid.Column="3"
                        Margin="0,0,0,3"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">

                <dx:SimpleButton Width="48"
                                 Margin="0,0,2,0"
                                 Padding="0,1"
                                 Content="Basket"
                                 PreviewMouseDown="BasketButton_PreviewMouseDown"
                                 PreviewMouseMove="BasketButton_PreviewMouseMove"
                                 PreviewMouseUp="BasketButton_PreviewMouseUp" />
                <dx:SimpleButton Width="48"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding CloneCommand}"
                                 Content="Clone">
                    <dx:SimpleButton.CommandParameter>
                        <MultiBinding Converter="{StaticResource MultiValueCloneConverter}">
                            <Binding Path="Width"
                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                     AncestorType={x:Type Window}}" />
                            <Binding Path="Height"
                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                     AncestorType={x:Type Window}}" />
                            <Binding Path="Left"
                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                     AncestorType={x:Type Window}}" />
                            <Binding Path="Top"
                                     RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                     AncestorType={x:Type Window}}" />
                        </MultiBinding>
                    </dx:SimpleButton.CommandParameter>
                </dx:SimpleButton>
                <dx:SimpleButton Width="48"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding OppCPCommand}"
                                 Content="Opp C/P" />
                <dx:SimpleButton Width="48"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding ExpirationUpCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Exp" />
                        <TextBlock Margin="0,2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Marlett"
                                   Text="5" />
                    </StackPanel>
                </dx:SimpleButton>
                <dx:SimpleButton Width="48"
                                 Margin="2,0"
                                 Padding="0,1"
                                 Command="{Binding StrikeUpCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Strike" />
                        <TextBlock Margin="0,2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Marlett"
                                   Text="5" />
                    </StackPanel>
                </dx:SimpleButton>

