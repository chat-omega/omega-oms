<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.LowLatencyManualAdjustmentRequestView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="445"
                 Height="230"
                 d:DataContext="{d:DesignInstance Type=ViewModels:LowLatencyManualAdjustmentRequestViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:LowLatencyManualAdjustmentRequestViewModel}"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dx:ThemedWindow.Resources>
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
    </dx:ThemedWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Margin="5,5,0,0"
               Content="Username" />

        <dxe:ComboBoxEdit Grid.Row="1"
                          Grid.Column="2"
                          Grid.ColumnSpan="7"
                          Margin="5,5,0,0"
                          CharacterCasing="Upper"
                          EditValue="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                          IsTextEditable="True"
                          ItemsSource="{Binding Usernames}">
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding UsernameChangedCommand}"
                                       EventName="EditValueChanged" />
            </dxmvvm:Interaction.Behaviors>
        </dxe:ComboBoxEdit>

        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="5,5,0,0"
               Content="Symbol" />

        <dxe:ComboBoxEdit Grid.Row="2"
                          Grid.Column="2"
                          Grid.ColumnSpan="7"
                          Margin="5,5,0,0"
                          CharacterCasing="Upper"
                          EditValue="{Binding Symbol}"
                          IsTextEditable="True"
                          ItemsSource="{Binding Symbols}" />

        <Label Grid.Row="3"
               Grid.Column="1"
               Margin="5,5,0,0"
               Content="Fill Price" />

        <dxe:SpinEdit Grid.Row="3"
                      Grid.Column="2"
                      Width="75"
                      Margin="5,5,0,0"
                      HorizontalAlignment="Left"
                      HorizontalContentAlignment="Right"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding FillPrice}"
                      EditValueType="{x:Type sys:Double}"
                      Increment="0.01"
                      Mask="N2"
                      MaskUseAsDisplayFormat="True"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="3"
               Grid.Column="4"
               Margin="5,5,0,0"
               Content="Fill Qty" />

        <dxe:SpinEdit Grid.Row="3"
                      Grid.Column="5"
                      Width="75"
                      Margin="5,5,0,0"
                      HorizontalAlignment="Left"
                      HorizontalContentAlignment="Right"
                      AllowSpinOnMouseWheel="True"
                      EditValue="{Binding FillQty}"
                      EditValueType="{x:Type sys:Int32}"
                      Increment="1"
                      Mask="N0"
                      MaskUseAsDisplayFormat="True"
                      PreviewMouseUp="SelectAll"
                      SelectAllOnGotFocus="True"
                      SelectAllOnMouseUp="True" />

        <Label Grid.Row="3"
               Grid.Column="7"
               Margin="5,5,0,0"
               Content="Side" />

        <dxe:ComboBoxEdit Grid.Row="3"
                          Grid.Column="8"
                          Width="75"
                          Margin="5,5,0,0"
                          HorizontalAlignment="Left"
                          ApplyItemTemplateToSelectedItem="True"
                          EditValue="{Binding FillSide, UpdateSourceTrigger=PropertyChanged}"
                          IsTextEditable="False"
                          ItemsSource="{Binding Sides}">
            <dxe:ComboBoxEdit.ItemTemplate>
                <DataTemplate>
                    <Label Padding="0,0.5"
                           HorizontalAlignment="Center"
                           Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}"
                           FontSize="11" />
                </DataTemplate>
            </dxe:ComboBoxEdit.ItemTemplate>
        </dxe:ComboBoxEdit>

        <Label Grid.Row="4"
               Grid.Column="1"
               Margin="5,5,0,0"
               Content="Fill Order ID" />

        <dxe:TextEdit Grid.Row="4"
                      Grid.Column="2"
                      Grid.ColumnSpan="7"
                      Margin="5,5,0,0"
                      EditValue="{Binding FillClOrderId}" />

        <StackPanel Grid.Row="5"
                    Grid.Column="2"
                    Grid.ColumnSpan="4"
                    Margin="5,5,0,0"
                    Orientation="Horizontal">
            <dxe:CheckEdit Content="Bypass Risk"
                           EditValue="{Binding ByPassRisk}" />
            <dxe:CheckEdit Margin="10,0,0,0"
                           Content="Do Nothing"
                           EditValue="{Binding DoNothing}" />
        </StackPanel>

        <StackPanel Grid.Row="7"
                    Grid.Column="1"
                    Grid.ColumnSpan="8"
                    Margin="5,5,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">

            <dx:SimpleButton Margin="5,0"
                             Command="{Binding SaveCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Outlook Inspired/Save.svg}"
                             GlyphHeight="15" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
