<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.OptionSelectorView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:controls="clr-namespace:ZeroPlus.Oms.Ui.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:startupHelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 Title="{Binding ModuleTitle}"
                 Width="1000"
                 Height="500"
                 MinWidth="500"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=viewModels:OptionSelectorViewModel}"
                 DataContext="{startupHelpers:DISource Type=viewModels:OptionSelectorViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">
    <dx:ThemedWindow.Resources>
        <Style x:Key="tokenComboStyle"
               TargetType="dxe:ComboBoxEdit">
            <Setter Property="ShowBorder" Value="False" />
            <Setter Property="AllowDefaultButton" Value="False" />
            <Setter Property="DisplayMember" Value="{Binding DisplayMember}" />
            <Setter Property="StyleSettings">
                <Setter.Value>
                    <dxe:TokenComboBoxStyleSettings AllowEditTokens="False"
                                                    NewTokenPosition="None" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="EditValue" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="controls:TokenAutoSuggestEdit">
            <Setter Property="ImmediatePopup" Value="True" />
            <Setter Property="NullText" Value="Symbol" />
            <Setter Property="EditTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <DockPanel LastChildFill="True">
                            <dxe:ComboBoxEdit x:Name="innerTokenComboBox"
                                              DockPanel.Dock="Left"
                                              Style="{StaticResource tokenComboStyle}" />
                            <TextBox x:Name="PART_Editor"
                                     BorderThickness="0" />
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </dx:ThemedWindow.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <controls:TokenAutoSuggestEdit x:Name="tokenAutoSuggestEdit"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       VerticalAlignment="Top"
                                       QuerySubmitted="AutoSuggestEdit_QuerySubmitted"
                                       SelectedTokens="{Binding SelectedTokens}" />
        <ListBox Grid.Row="0"
                 Grid.Column="1"
                 ItemsSource="{Binding ElementName=tokenAutoSuggestEdit, Path=SelectedTokens}" />

        <dx:SimpleButton Grid.Row="1"
                         Grid.Column="0"
                         Grid.ColumnSpan="2"
                         Width="100"
                         Margin="5"
                         Command="{Binding UpdateSelectionCommand}"
                         CommandParameter="{Binding ElementName=tokenAutoSuggestEdit, Path=SelectedTokens}"
                         Content="Save" />
    </Grid>
</dx:ThemedWindow>
