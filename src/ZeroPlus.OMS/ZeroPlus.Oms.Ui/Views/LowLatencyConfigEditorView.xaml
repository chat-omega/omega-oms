<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.LowLatencyConfigEditorView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 Title="{Binding Model.Title, StringFormat='{}{0} - Config'}"
                 Width="500"
                 Height="500"
                 MinWidth="500"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=viewModels:LowLatencyConfigEditorViewModel}"
                 DataContext="{startuphelpers:DISource Type=viewModels:LowLatencyConfigEditorViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="3" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3" />
            <ColumnDefinition x:Name="GridSplitterCol"
                              Width="auto"
                              MaxWidth="500"
                              d:Width="0" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="3" />
        </Grid.ColumnDefinitions>

        <Grid x:Name="SideBarGrid"
              Grid.Row="1"
              Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <dx:SimpleButton Grid.Row="0"
                             Grid.Column="0"
                             Height="22"
                             Command="{Binding ConfigBrowserViewModel.RefreshCommand}"
                             Content="Refresh"
                             Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Refresh.svg}"
                             GlyphHeight="15" />

            <dxg:TreeListControl Name="ConfigsTable"
                                 Grid.Row="1"
                                 Grid.Column="0"
                                 MaxHeight="2000"
                                 AutoGenerateColumns="AddNew"
                                 ItemsSource="{Binding ConfigBrowserViewModel.Configs}"
                                 SelectedItem="{Binding ConfigBrowserViewModel.SelectedConfig}"
                                 SelectionMode="Row">
                <dxg:TreeListColumn Width="150"
                                    MinWidth="150"
                                    FieldName="Title"
                                    Header="Name"
                                    IsSmart="True" />
                <dxg:TreeListColumn Width="150"
                                    MinWidth="150"
                                    MaxWidth="150"
                                    FieldName="Username"
                                    Header="Contributors"
                                    IsSmart="True" />
                <dxg:TreeListColumn Width="150"
                                    MinWidth="150"
                                    MaxWidth="150"
                                    FieldName="SaveTime"
                                    Header="Time"
                                    IsSmart="True" />
                <dxg:TreeListControl.View>
                    <dxg:TreeListView AllowEditing="False"
                                      AutoExpandAllNodes="True"
                                      AutoWidth="True"
                                      ChildNodesPath="Configs"
                                      RowDoubleClickCommand="{Binding ConfigRowDoubleClickCommand}"
                                      TreeDerivationMode="ChildNodesSelector"
                                      VerticalScrollbarVisibility="Auto">
                        <dxg:TreeListView.RowCellMenuCustomizations>
                            <dxb:BarButtonItem Command="{Binding View.DataContext.LoadSavedConfigCommand}"
                                               CommandParameter="{Binding Path=SelectedItem, ElementName=ConfigsTable}"
                                               Content="Load" />
                            <dxb:BarButtonItem Command="{Binding View.DataContext.ConfigBrowserViewModel.EditConfigCommand}"
                                               CommandParameter="{Binding Path=SelectedItem, ElementName=ConfigsTable}"
                                               Content="Edit" />
                            <dxb:BarButtonItem Command="{Binding View.DataContext.ConfigBrowserViewModel.DeleteConfigCommand}"
                                               CommandParameter="{Binding Path=SelectedItem, ElementName=ConfigsTable}"
                                               Content="Delete" />
                        </dxg:TreeListView.RowCellMenuCustomizations>
                    </dxg:TreeListView>
                </dxg:TreeListControl.View>
            </dxg:TreeListControl>
        </Grid>

        <GridSplitter Grid.Row="1"
                      Grid.Column="2"
                      Width="3"
                      Margin="0,25,0,0"
                      HorizontalAlignment="Stretch" />

        <dx:SimpleButton Name="ExpandCollapseGridButton"
                         Grid.Row="1"
                         Grid.Column="2"
                         Width="8"
                         Height="100"
                         Margin="0,35,0,0"
                         Padding="-1,0,0,0"
                         HorizontalAlignment="Center"
                         Click="ExpandCollapseGrid_Click"
                         Content="3"
                         CornerRadius="3"
                         FontFamily="Marlett"
                         FontSize="10" />

        <Grid Grid.Row="1"
              Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Width="50"
                       Margin="5,2,0,0"
                       Content="Title" />

                <dxe:TextEdit Grid.Row="0"
                              Grid.Column="1"
                              Grid.ColumnSpan="5"
                              Margin="5,2,0,0"
                              Text="{Binding Model.Title}" />

                <Label Grid.Row="1"
                       Grid.Column="0"
                       Width="50"
                       Margin="5,2,0,0"
                       Content="Creator" />

                <dxe:TextEdit Grid.Row="1"
                              Grid.Column="1"
                              Margin="5,2,0,0"
                              IsReadOnly="True"
                              Text="{Binding Model.Creator}" />

                <Label Grid.Row="1"
                       Grid.Column="2"
                       Margin="5,2,0,0"
                       Content="Last Updated" />

                <dxe:TextEdit Grid.Row="1"
                              Grid.Column="3"
                              Margin="5,2,0,0"
                              IsReadOnly="True"
                              Text="{Binding Model.LastUpdateTime}" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Grid.Column="0"
                          Margin="5,5,0,0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Grid x:Name="Container" />
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <dx:SimpleButton Width="80"
                             Margin="3,0"
                             Command="{Binding SaveCommand}"
                             Content="Save"
                             Glyph="{dx:DXImage SvgImages/Outlook Inspired/Save.svg}"
                             GlyphHeight="15" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
