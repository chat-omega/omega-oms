                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.PriceChainDeviationMinDeviation, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment=".01"
                                              Mask="N2"
                                              MaskUseAsDisplayFormat="True"
