                </dxg:GridControlBand>
                <dxg:GridControlBand>
                    <dxg:GridColumn Width="40"
                                    MinWidth="40"
                                    MaxWidth="40"
                                    FieldName="Remove"
                                    Header="">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton Width="40"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Command="{Binding View.DataContext.RemoveCommand}"
                                                 CommandParameter="{Binding Path=SelectedItem, ElementName=GridControl}"
                                                 Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                                 GlyphWidth="20" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>
            </dxg:GridControl.Bands>
        </dxg:GridControl>

        <dx:DXTabControl x:Name="FilterTabControl"
                         Grid.Row="2"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Margin="0,5"
                         Padding="0"
                         d:Visibility="Hidden"
                         ItemsSource="{Binding Model.Filters}"
                         Visibility="{Binding TableMode, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
            <dx:DXTabControl.ItemHeaderTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontWeight="DemiBold"
                                   Text="{Binding Header}" />
                        <dx:SimpleButton Grid.Column="1"
                                         Width="15"
                                         Height="15"
                                         Margin="10,0,0,0"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         BorderThickness="0"
                                         Command="{Binding Path=DataContext.RemoveCommand, ElementName=FilterTabControl}"
                                         CommandParameter="{Binding}"
                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                         GlyphHeight="15"
                                         GlyphWidth="15"
                                         ToolTip="Remove" />
                    </Grid>
                </DataTemplate>
            </dx:DXTabControl.ItemHeaderTemplate>
            <dx:DXTabControl.ControlBoxRightTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,10,0"
                                Orientation="Horizontal" />
                </DataTemplate>
            </dx:DXTabControl.ControlBoxRightTemplate>
            <dx:DXTabControl.ItemTemplate>
                <DataTemplate>
                    <views:EdgeScanFeedFilterEditorView />
                </DataTemplate>
            </dx:DXTabControl.ItemTemplate>
        </dx:DXTabControl>
    </Grid>
</dx:ThemedWindow>
