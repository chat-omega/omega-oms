                            <DataTemplate>
                                <dxe:SpinEdit Margin="-1"
                                              HorizontalContentAlignment="Right"
                                              AllowSpinOnMouseWheel="True"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding RowData.Row.PriceChainDeviationMaxChangeInUnder, UpdateSourceTrigger=PropertyChanged}"
                                              EditValueType="{x:Type sys:Double}"
                                              Increment=".01"
                                              Mask="N4"
                                              MaskUseAsDisplayFormat="True"
                                              MinValue="0"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="PriceChainDeviationMinDeviation"
                                    Header="Min Deviation">
