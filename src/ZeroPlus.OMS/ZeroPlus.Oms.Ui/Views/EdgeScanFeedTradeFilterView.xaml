                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="72"
                                    MinWidth="72"
                                    MaxWidth="72"
                                    FieldName="PriceChainDeviationMaxChangeInUnder"
