                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                        </dxg:TableView>
                    </dxg:GridControl.View>
                    <dxg:GridColumn FieldName="Timestamp"
                                    Header="Time"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                                  Mask="dd hh:mm:ss.ffff"
                                                  MaskType="DateTime"
                                                  MaskUseAsDisplayFormat="True" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                    FieldName="Bid"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Name="PART_Editor"
                                              Margin="2,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalContentAlignment="Right"
                                              Foreground="{Binding Path=RowData.Row.BidChange, Converter={StaticResource SignToBrushConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                    FieldName="Ask"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Name="PART_Editor"
                                              Margin="2,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalContentAlignment="Right"
                                              Foreground="{Binding Path=RowData.Row.AskChange, Converter={StaticResource SignToBrushConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
                <dxg:GridControl x:Name="HedgeQuoteGrid"
                                 Grid.Row="1"
                                 MinHeight="70"
                                 MaxHeight="5000"
                                 HorizontalAlignment="Center"
                                 AutoGenerateColumns="AddNew"
                                 CurrentItem="{Binding HedgeTrader.LastUpdate}"
                                 IsEnabled="{Binding HedgeEnabled}"
                                 ItemsSource="{Binding HedgeTrader.Updates}">
                    <dxg:GridControl.Resources>
                        <Style TargetType="dxg:GridColumn">
                            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                            <Setter Property="Visible" Value="False" />
                        </Style>
                        <Style x:Key="TradeRowStyle"
                               TargetType="dxg:RowControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=IsSelected}"
                                             Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </DataTrigger>
                                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                                    <Setter Property="Background" Value="#1d3c52" />
                                </Trigger>
                                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#39393A" />
                                </Trigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" Value="#3E596B" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridControl.Resources>
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AllowGrouping="False"
                                       AutoWidth="True"
                                       FadeSelectionOnLostFocus="False"
                                       RowStyle="{StaticResource TradeRowStyle}"
                                       ShowGroupPanel="False"
                                       ShowIndicator="True"
                                       VerticalScrollbarVisibility="Auto">
                            <dxg:TableView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowColumnChooserCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Column Chooser">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ClearColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Hide All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowAllColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show All Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Height="25"
                                              Command="{Binding ShowDefaultColumnsCommand}"
                                              CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Header="Show Default Columns">
                                        <MenuItem.Icon>
                                            <Image Width="15"
                                                   Height="15"
                                                   Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </dxg:TableView.ContextMenu>
                        </dxg:TableView>
                    </dxg:GridControl.View>
                    <dxg:GridColumn FieldName="Timestamp"
                                    Header="Time"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                                  Mask="dd hh:mm:ss.ffff"
                                                  MaskType="DateTime"
                                                  MaskUseAsDisplayFormat="True" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                    FieldName="Bid"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Name="PART_Editor"
                                              Margin="2,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalContentAlignment="Right"
                                              Foreground="{Binding Path=RowData.Row.BidChange, Converter={StaticResource SignToBrushConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Binding="{Binding Path=RowData.Row.Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}"
                                    FieldName="Ask"
                                    ReadOnly="True"
                                    Visible="True">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Name="PART_Editor"
                                              Margin="2,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalContentAlignment="Right"
                                              Foreground="{Binding Path=RowData.Row.AskChange, Converter={StaticResource SignToBrushConverter}}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </Grid>
        </Grid>

        <Grid Grid.Row="2"
              Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Padding="2,4,0,4"
                       VerticalAlignment="Center"
                       Background="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding Status}"
                       TextAlignment="Center" />

            <TextBlock Grid.Column="1"
                       Padding="2,4,0,4"
                       VerticalAlignment="Center"
                       Background="{Binding StatusModeSell, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding StatusModeSell, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding StatusSell}"
                       TextAlignment="Center" />
        </Grid>

        <Grid Grid.Row="3"
              Grid.ColumnSpan="3"
              Margin="0,2,0,0"
              Visibility="{Binding HedgeEnabled}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Padding="2,4,0,4"
                       VerticalAlignment="Center"
                       Background="{Binding HedgeTrader.StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding HedgeTrader.StatusMode, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding HedgeTrader.Status}"
                       TextAlignment="Center" />

            <TextBlock Grid.Column="1"
                       Padding="2,4,0,4"
                       VerticalAlignment="Center"
                       Background="{Binding HedgeTrader.StatusModeSell, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='BACKGROUND'}"
                       Foreground="{Binding HedgeTrader.StatusModeSell, Converter={StaticResource StatusModeToColorConverter}, ConverterParameter='FOREGROUND'}"
                       Text="{Binding HedgeTrader.StatusSell}"
                       TextAlignment="Center" />
        </Grid>
    </Grid>
</dx:ThemedWindow>
