<dx:ThemedWindow x:Name="window"
                 x:Class="ZeroPlus.Oms.Ui.Views.ModelTraderView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                 xmlns:dxct="http://schemas.devexpress.com/winfx/2008/xaml/charts/themekeys"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="1200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:ModelTraderViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:ModelTraderViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:LoadCustomColumnService />
        <services:GetItemsByVisualOrderService />
        <services:OmsMessageBoxService />
        <dxmvvm:CurrentWindowService />
        <dxmvvm:WindowService />
        <dxmvvm:DispatcherService />
        <dxmvvm:OpenFileDialogService />
        <dxmvvm:SaveFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <Window.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SizeUpTypeToVisibilityConverter x:Key="SizeUpTypeToVisibilityConverter" />
        <helper:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <helper:PriceToConnectorConverter x:Key="PriceToConnectorConverter" />
        <helper:StatusModeToColorConverter x:Key="StatusModeToColorConverter" />
        <helper:OrderToBackBrushConverter x:Key="OrderToBackBrushConverter" />
        <helper:MarketMakerOffsetTypeToVisibilityConverter x:Key="MarketMakerOffsetTypeToVisibilityConverter" />
        <helper:MarketMakerOffsetTypeToDisplayTextConverter x:Key="MarketMakerOffsetTypeToDisplayTextConverter" />
        <helper:LoopPricingModeToDisplayTextConverter x:Key="LoopPricingModeToDisplayTextConverter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#f4241e"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#fefdff" />
        <helper:SignToBrushConverter x:Key="TitleSignToBrushConverter"
                                     NegativeBrush="#f4241e"
                                     PositiveBrush="#32ce4a"
                                     ZeroBrush="#fefdff" />
        <helper:SignToBrushConverter x:Key="CountdownToBrushConverter"
                                     Limit="3"
                                     NegativeBrush="#F05126"
                                     PositiveBrush="#2d2d30"
                                     ZeroBrush="#F05126" />
    </Window.Resources>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <dx:DropDownButton Grid.Row="0"
                               Grid.Column="12"
                               Width="115"
                               Margin="2"
                               Padding="3,1,7,1"
                               HorizontalAlignment="Right"
                               Content="Settings"
                               Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Settings.svg}"
                               GlyphHeight="15">
                <ItemsControl>
                    <StackPanel Orientation="Vertical">
                        <MenuItem Header="Auto Scroll"
                                  IsCheckable="True"
                                  IsChecked="{Binding AutoScrollEdgeFeed}" />

                        <dx:SuperTipItemControlSeparator />

                        <MenuItem Click="ClearSortingClick"
                                  Header="Clear Sorting" />
                    </StackPanel>
                </ItemsControl>
            </dx:DropDownButton>

            <dx:SimpleButton Width="23"
                             Margin="2"
                             HorizontalAlignment="Right"
                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                             GlyphHeight="17">

                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupControlContainer>
                        <ItemsControl>
                            <StackPanel>
                                <MenuItem Height="25"
                                          Click="CloneLayout"
                                          Header="Clone">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="ShareLayout"
                                          Header="Share Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="SaveLayout"
                                          Header="Save Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="LoadLayout"
                                          Header="Load Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </StackPanel>
                        </ItemsControl>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>

        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.Column="0"
              Grid.ColumnSpan="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    VerticalAlignment="Top"
                    BorderBrush="#3f3f46"
                    BorderThickness="0,0,0,2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           HorizontalAlignment="Center"
                           Content="LOW"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="1"
                           HorizontalAlignment="Center"
                           Content="HIGH"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="2"
                           HorizontalAlignment="Center"
                           Content="BID"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="3"
                           HorizontalAlignment="Center"
                           Content="MID"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="4"
                           HorizontalAlignment="Center"
                           Content="ASK"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="5"
                           HorizontalAlignment="Center"
                           Content="POS"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="6"
                           HorizontalAlignment="Center"
                           Content="WORKING"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="7"
                           HorizontalAlignment="Center"
                           Content="TOTAL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="8"
                           HorizontalAlignment="Center"
                           Content="Con. PnL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="9"
                           HorizontalAlignment="Center"
                           Content="Real. PnL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <Label Grid.Row="0"
                           Grid.Column="10"
                           HorizontalAlignment="Center"
                           Content="Unreal. PnL"
                           FontWeight="DemiBold"
                           Foreground="#AFAFB0" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#f4241e"
                               Text="{Binding Low, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#32ce4a"
                               Text="{Binding High, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Bid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="3"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Mid, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="4"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Ask, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}" />
                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="5"
                                  HorizontalAlignment="Center"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  DisplayFormatString="N0"
                                  EditValue="{Binding FilledQty}"
                                  EditValueType="{x:Type sys:Int32}"
                                  FontWeight="Bold"
                                  Foreground="#00A8FF"
                                  Increment="1"
                                  IsReadOnly="{Binding OrderEnabled}"
                                  Mask="N0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  ShowEditorButtons="False" />
                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="6"
                                  HorizontalAlignment="Center"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  DisplayFormatString="N0"
                                  EditValue="{Binding WorkingQty}"
                                  EditValueType="{x:Type sys:Int32}"
                                  FontWeight="Bold"
                                  Foreground="{Binding WorkingQty, Converter={StaticResource SignToBrushConverter}}"
                                  Increment="1"
                                  IsReadOnly="{Binding OrderEnabled}"
                                  Mask="N0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  ShowEditorButtons="False" />
                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="7"
                                  HorizontalAlignment="Center"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  DisplayFormatString="N0"
                                  EditValue="{Binding TotalQty}"
                                  EditValueType="{x:Type sys:Int32}"
                                  FontWeight="Bold"
                                  Foreground="{Binding TotalQty, Converter={StaticResource SignToBrushConverter}}"
                                  Increment="1"
                                  IsReadOnly="True"
                                  Mask="N0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  ShowEditorButtons="False" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="8"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding RealPnlPerShare, Converter={StaticResource TitleSignToBrushConverter}}"
                               Text="{Binding RealPnlPerShare, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="9"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding RealPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                               Text="{Binding RealPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="10"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding UnrealPnl, Converter={StaticResource TitleSignToBrushConverter}}"
                               Text="{Binding UnrealPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C2}}" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              Grid.Column="1"
              Grid.ColumnSpan="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <dxlc:GroupBox Grid.Row="0"
                               MinWidth="200"
                               Padding="3,5"
                               BorderThickness="1">
                    <dxlc:GroupBox.Header>
                        <Grid>
                            <Label Padding="0"
                                   HorizontalAlignment="Center"
                                   Content="Setup"
                                   Foreground="#AFAFB0" />
                        </Grid>
                    </dxlc:GroupBox.Header>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               Content="Model Type" />

                        <dxe:ComboBoxEdit Grid.Row="0"
                                          Grid.Column="1"
                                          Margin="0,2,0,0"
                                          Background="Transparent"
                                          IsSynchronizedWithCurrentItem="True"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding ModelTypes}"
                                          SelectedItem="{Binding ModelType}" />

                        <Label Grid.Row="1"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Symbol" />

                        <dxe:ButtonEdit Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,2,0,0"
                                        AllowDefaultButton="False"
                                        AutomationProperties.AutomationId="SymbolButtonEdit"
                                        Background="#2d2d30"
                                        CharacterCasing="Upper"
                                        EditValue="{Binding Underlying, UpdateSourceTrigger=PropertyChanged}"
                                        EditValuePostDelay="0"
                                        SelectAllOnGotFocus="True"
                                        SelectAllOnMouseUp="True"
                                        TabIndex="1">
                            <dxe:ButtonEdit.Buttons>
                                <dxe:ButtonInfo Command="{Binding SearchUnderlyingCommand}"
                                                GlyphKind="Search"
                                                IsDefaultButton="True" />
                            </dxe:ButtonEdit.Buttons>
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:KeyToCommand Command="{Binding SearchUnderlyingCommand}"
                                                     KeyGesture="Enter" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:ButtonEdit>

                        <Label Grid.Row="2"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Model" />

                        <dxe:ButtonEdit Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,2,0,0"
                                        AllowDefaultButton="False"
                                        Background="#2d2d30"
                                        CharacterCasing="Upper"
                                        EditValue="{Binding LoadedModelName, UpdateSourceTrigger=PropertyChanged}"
                                        EditValuePostDelay="0"
                                        SelectAllOnGotFocus="True"
                                        SelectAllOnMouseUp="True"
                                        TabIndex="1">
                            <dxe:ButtonEdit.Buttons>
                                <dxe:ButtonInfo Command="{Binding SearchModelCommand}"
                                                GlyphKind="Search"
                                                IsDefaultButton="True" />
                            </dxe:ButtonEdit.Buttons>
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:KeyToCommand Command="{Binding SearchModelCommand}"
                                                     KeyGesture="Enter" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:ButtonEdit>

                        <Label Grid.Row="3"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Candle Period" />

                        <dxe:SpinEdit Grid.Row="3"
                                      Grid.Column="1"
                                      Margin="0,2,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      Background="#2d2d30"
                                      EditValue="{Binding CandlePeriod, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="1"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue="1"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True"
                                      ShowEditorButtons="False" />

                        <Label Grid.Row="4"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Input Lag" />

                        <dxe:SpinEdit Grid.Row="4"
                                      Grid.Column="1"
                                      Margin="0,2,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      Background="#2d2d30"
                                      DisplayFormatString="N0"
                                      EditValue="{Binding InputShape, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Int64}"
                                      Increment="1"
                                      Mask="N0"
                                      MaxValue="1000"
                                      MinValue="1"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True"
                                      ShowEditorButtons="False" />

                        <Label Grid.Row="5"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Quantity" />

                        <dxe:SpinEdit Grid.Row="5"
                                      Grid.Column="1"
                                      Margin="0,2,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      Background="#2d2d30"
                                      DisplayFormatString="N0"
                                      EditValue="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Int32}"
                                      Increment="1"
                                      Mask="N0"
                                      MaxValue="100"
                                      MinValue="1"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True"
                                      ShowEditorButtons="False" />

                        <Label Grid.Row="6"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Stop Loss +/- $" />

                        <dxe:SpinEdit Grid.Row="6"
                                      Grid.Column="1"
                                      Margin="0,2,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      Background="#2d2d30"
                                      DisplayFormatString="N2"
                                      EditValue="{Binding StopLoss, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".01"
                                      Mask="N2"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True"
                                      ShowEditorButtons="False" />

                        <Label Grid.Row="7"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Stop Loss Target" />

                        <dxe:SpinEdit Grid.Row="7"
                                      Grid.Column="1"
                                      Margin="0,2,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      Background="#2d2d30"
                                      DisplayFormatString="C2"
                                      EditValue="{Binding StopLossTarget, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment=".01"
                                      Mask="C2"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True"
                                      ShowEditorButtons="False" />

                        <Label Grid.Row="8"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               Content="Liquidity Type" />

                        <dxe:ComboBoxEdit Grid.Row="8"
                                          Grid.Column="1"
                                          Margin="0,2,0,0"
                                          Background="Transparent"
                                          IsSynchronizedWithCurrentItem="True"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding LiquidityTypes}"
                                          SelectedItem="{Binding LiquidityType}" />

                        <Label Grid.Row="9"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Add Liquidity Rest (Sec)" />

                        <dxe:SpinEdit Grid.Row="9"
                                      Grid.Column="1"
                                      Margin="0,2,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      Background="#2d2d30"
                                      EditValue="{Binding AddLiquidityRestPeriod}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="1"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue="0"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True"
                                      ShowEditorButtons="False" />

                        <Label Grid.Row="11"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Interval (Min)" />

                        <dxe:SpinEdit Grid.Row="11"
                                      Grid.Column="1"
                                      Margin="0,2,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      Background="#2d2d30"
                                      EditValue="{Binding Interval}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="100"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue="1"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True"
                                      ShowEditorButtons="False" />

                        <Label Grid.Row="12"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Cache (Min)" />

                        <dxe:SpinEdit Grid.Row="12"
                                      Grid.Column="1"
                                      Margin="0,2,0,0"
                                      AllowSpinOnMouseWheel="True"
                                      Background="#2d2d30"
                                      EditValue="{Binding CacheInterval}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="100"
                                      Mask="N0"
                                      MaskUseAsDisplayFormat="True"
                                      MinValue="10"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True"
                                      ShowEditorButtons="False" />

                        <Label Grid.Row="13"
                               Grid.Column="0"
                               Margin="5,2,0,0"
                               HorizontalAlignment="Left"
                               Content="Auto Close (Min)" />

                        <Grid Grid.Row="13"
