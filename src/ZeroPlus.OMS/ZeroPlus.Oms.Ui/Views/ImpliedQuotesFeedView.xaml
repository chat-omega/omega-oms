<view:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.ImpliedQuotesFeedView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                   xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                   xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                   xmlns:view="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                   Title="{Binding ModuleTitle}"
                   Width="1800"
                   Height="700"
                   MinWidth="520"
                   MinHeight="300"
                   d:DataContext="{d:DesignInstance Type=viewModels:ImpliedQuotesFeedViewModel}"
                   DataContext="{startuphelpers:DISource Type=viewModels:ImpliedQuotesFeedViewModel}"
                   WindowStartupLocation="CenterScreen"
                   mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:SaveFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <dx:ThemedWindow.HeaderItems>
        <dx:SimpleButton Margin="2"
                         Padding="0"
                         ButtonKind="Toggle"
                         Glyph="{dx:DXImage 'SvgImages/PDF Viewer/EnableScrolling.svg'}"
                         GlyphHeight="20"
                         IsChecked="{Binding AutoScroll}"
                         ToolTip="Auto Scroll" />
        <view:ModuleHeaderItems />
    </dx:ThemedWindow.HeaderItems>

    <Grid Margin="5,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal">
            <dxe:ButtonEdit Width="132"
                            HorizontalAlignment="Left"
                            AllowDefaultButton="False"
                            CharacterCasing="Upper"
                            EditValue="{Binding UnderlyingInput, UpdateSourceTrigger=PropertyChanged}"
                            EditValuePostDelay="0"
                            IsEnabled="{Binding IsSubscribed, Converter={StaticResource BooleanNegationConverter}}"
                            NullText="Underlying"
                            SelectAllOnGotFocus="True"
                            SelectAllOnMouseUp="True"
                            ShowNullTextForEmptyValue="True"
                            TabIndex="1">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:KeyToCommand Command="{Binding SearchUnderlyingCommand}"
                                         KeyGesture="Enter" />
                </dxmvvm:Interaction.Behaviors>
                <dxe:ButtonEdit.Buttons>
                    <dxe:ButtonInfo Command="{Binding SearchUnderlyingCommand}"
                                    GlyphKind="Search"
                                    IsDefaultButton="True" />
                </dxe:ButtonEdit.Buttons>
            </dxe:ButtonEdit>

            <dx:SimpleButton Width="25"
                             Margin="2,0,0,0"
                             Padding="0,1"
                             Command="{Binding UnsubscribeCommand}"
                             Glyph="{dx:DXImage 'SvgImages/Arrows/Stop.svg'}"
                             GlyphHeight="15"
                             Visibility="{Binding IsSubscribed, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Label Margin="5,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="Min Cross" />

            <dxe:SpinEdit Width="60"
                          Margin="5,0,0,0"
                          HorizontalContentAlignment="Right"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding MinCross, UpdateSourceTrigger=PropertyChanged}"
                          EditValueType="{x:Type sys:Double}"
                          Increment="0.01"
                          Mask="####0.00#"
                          MaskUseAsDisplayFormat="True"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <dxg:GridControl x:Name="UpdatesGrid"
                             Grid.Row="1"
                             MinHeight="70"
                             MaxHeight="5000"
                             Margin="0,5"
                             AutoGenerateColumns="None"
                             CurrentItem="{Binding LastUpdate}"
                             CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                             EnableSmartColumnsGeneration="False"
                             ItemsSource="{Binding Updates}">
                <dxg:GridControl.Resources>
                    <Style TargetType="dxg:GridColumn">
                        <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                        <Setter Property="Visible" Value="True" />
                        <Setter Property="IsSmart" Value="True" />
                    </Style>
                </dxg:GridControl.Resources>
                <dxg:GridControl.View>
                    <dxg:TableView Name="UpdatesTable"
                                   AllowDragDrop="True"
                                   AllowEditing="False"
                                   AutoWidth="True"
                                   BandSeparatorWidth="1"
                                   EnableSelectedRowAppearance="True"
                                   GroupSummaryDisplayMode="AlignByColumns"
                                   NavigationStyle="Cell"
                                   RowStyle="{StaticResource RowStyle}"
                                   ShowGridMenu="TableView_ShowGridMenu"
                                   ShowGroupPanel="False"
                                   ShowIndicator="True"
                                   ShowTotalSummary="False"
                                   VerticalScrollbarVisibility="Auto">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Height="25"
                                          Command="{Binding ShowColumnChooserCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Column Chooser">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ClearColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Hide All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowAllColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show All Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding ShowDefaultColumnsCommand}"
                                          CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Show Default Columns">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                        <dxg:TableView.RowCellMenuCustomizations>
                            <dxb:BarButtonItem Command="{Binding View.DataContext.ClearCommand}"
                                               Content="Clear Table"
                                               Glyph="{dx:DXImage 'SvgImages/Snap/ClearTableStyle.svg'}" />
                        </dxg:TableView.RowCellMenuCustomizations>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn FieldName="Underlying" />
                <dxg:GridColumn FieldName="Symbol" />
                <dxg:GridColumn FieldName="Bid" />
                <dxg:GridColumn FieldName="Ask" />
                <dxg:GridColumn FieldName="Theo" />
                <dxg:GridColumn FieldName="UnderBid" />
                <dxg:GridColumn FieldName="UnderAsk" />
                <dxg:GridColumn FieldName="ImpliedBid" />
                <dxg:GridColumn FieldName="ImpliedAsk" />
                <dxg:GridColumn FieldName="ImpliedBidRecordPrice" />
                <dxg:GridColumn FieldName="ImpliedBidRecordTheo" />
                <dxg:GridColumn FieldName="ImpliedBidRecordMovement" />
                <dxg:GridColumn FieldName="ImpliedBidRecordNonDeltaMovement" />
                <dxg:GridColumn FieldName="ImpliedBidRecordTime" />
                <dxg:GridColumn FieldName="ImpliedAskRecordPrice" />
                <dxg:GridColumn FieldName="ImpliedAskRecordTheo" />
                <dxg:GridColumn FieldName="ImpliedAskRecordMovement" />
                <dxg:GridColumn FieldName="ImpliedAskRecordNonDeltaMovement" />
                <dxg:GridColumn FieldName="ImpliedAskRecordTime" />

            </dxg:GridControl>
        </Grid>

    </Grid>
</view:ModuleWindow>
