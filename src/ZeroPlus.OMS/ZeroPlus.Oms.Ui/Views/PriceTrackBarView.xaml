<UserControl x:Class="ZeroPlus.Oms.Ui.Views.PriceTrackBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">
    <Grid PreviewMouseWheel="Grid_PreviewMouseWheel">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   HorizontalAlignment="Left"
                   FontSize="8"
                   Text="{Binding Low, StringFormat='#,###.00;(#,###.00);.00'}" />

        <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   HorizontalAlignment="Right"
                   FontSize="8"
                   Text="{Binding High, StringFormat='#,###.00;(#,###.00);.00'}" />

        <dxe:TrackBarEdit x:Name="PriceTrackBar"
                          Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Background="#336E96"
                          BorderBrush="#5CBAF9"
                          EditValueChanged="PriceTrackBar_EditValueChanged"
                          EditValueChanging="PriceTrackBar_EditValueChanging"
                          Foreground="#336E96"
                          Maximum="{Binding MaximumRange, UpdateSourceTrigger=PropertyChanged}"
                          Minimum="{Binding MinimumRange, UpdateSourceTrigger=PropertyChanged}"
                          SmallStep="{Binding PriceIncrement}"
                          TickPlacement="TopLeft" />
    </Grid>
</UserControl>
