<UserControl x:Class="ZeroPlus.Oms.Ui.Views.LowLatencyLiquidatorConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:ZeroPlus.Oms.Ui.Models"
             xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
             MinWidth="350"
             d:DataContext="{d:DesignInstance Type=models:LiquidatorModel}"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="5"
                BorderBrush="#3f3f46"
                BorderThickness="1">

            <Grid Margin="5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="0" />
                </Grid.ColumnDefinitions>
                <Label Grid.Row="1"
                       Grid.Column="1"
                       Width="70"
                       Margin="5,2,0,0"
                       Content="Route" />

                <dxe:ComboBoxEdit Grid.Row="1"
                                  Grid.Column="2"
                                  Width="165"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  CharacterCasing="Upper"
                                  EditValue="{Binding Route}"
                                  IsTextEditable="True"
                                  ItemsSource="{Binding RoutesList}" />
            </Grid>
        </Border>

        <views:ChaserControlView Grid.Row="1"
                                 Grid.Column="0"
                                 Margin="0,5,0,0"
                                 DataContext="{Binding ChaserModel}" />
    </Grid>
</UserControl>
