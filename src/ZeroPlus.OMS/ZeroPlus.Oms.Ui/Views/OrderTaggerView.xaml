<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.OrderTaggerView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 Title="Order Details"
                 Width="800"
                 Height="500"
                 d:DataContext="{d:DesignInstance Type=ViewModels:OrderTaggerViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:OrderTaggerViewModel}"
                 Topmost="True"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="ToolWindow"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="1"
               Grid.Column="1"
               Margin="5,2"
               Content="ID" />

        <dxe:TextEdit Grid.Row="1"
                      Grid.Column="2"
                      Margin="5,2"
                      EditValue="{Binding OrderId}"
                      IsReadOnly="True" />

        <dxe:TextEdit Grid.Row="1"
                      Grid.Column="3"
                      Margin="0,2,5,2"
                      EditValue="{Binding SpreadId}"
                      IsReadOnly="True" />

        <Label Grid.Row="2"
               Grid.Column="1"
               Margin="5,2"
               Content="Tagger" />

        <dxe:TextEdit Grid.Row="2"
                      Grid.Column="2"
                      Grid.ColumnSpan="2"
                      Margin="5,2"
                      EditValue="{Binding Tagger}"
                      IsReadOnly="True" />

        <Label Grid.Row="3"
               Grid.Column="1"
               Margin="5,2"
               Content="Message" />

        <dxe:TextEdit Grid.Row="3"
                      Grid.Column="2"
                      Grid.ColumnSpan="2"
                      Margin="5,2"
                      VerticalContentAlignment="Top"
                      AcceptsReturn="True"
                      EditValue="{Binding Message}"
                      NullText="Message for tag..."
                      TextWrapping="Wrap"
                      VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="4"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">

            <dx:SimpleButton Margin="5"
                             HorizontalAlignment="Center"
                             Command="{Binding SendTagCommand}"
                             Content="Submit"
                             IsDefault="True" />

            <dx:SimpleButton Margin="5"
                             HorizontalAlignment="Center"
                             Command="{Binding CancelCommand}"
                             Content="Cancel"
                             IsCancel="True" />
        </StackPanel>

    </Grid>
</dx:ThemedWindow>
