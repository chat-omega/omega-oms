<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.OptionChainView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="1200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=ViewModels:OptionChainViewModel}"
                 DataContext="{startuphelpers:DISource Type=ViewModels:OptionChainViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <services:GetItemsByVisualOrderService />
        <dxmvvm:DispatcherService />
        <dxmvvm:SaveFileDialogService />
        <dxmvvm:KeyToCommand Command="{Binding LoadOptionChainCommand}"
                             KeyGesture="Enter" />
    </dxmvvm:Interaction.Behaviors>
    <Window.Resources>
        <helper:UnixEpochTimeToEmptyStringConverter x:Key="UnixEpochTimeToEmptyStringConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="IntValueToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F3A202
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F1F1F1
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="TheoCrossToForegroundConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F30005
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #F1F1F1
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:CrossedValueToColorConverter x:Key="CrossedValueToColorConverter" />
        <helper:CrossedValueToFontWeightConverter x:Key="CrossedValueToFontWeightConverter" />
        <helper:SignToBrushConverter x:Key="CrosseToColorConverter"
                                     NegativeBrush="#569cd6"
                                     PositiveBrush="#F1F1F1"
                                     ZeroBrush="#F1F1F1" />
        <helper:SignToBrushConverter x:Key="DeltaToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#F1F1F1" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#F30005"
                                     PositiveBrush="#02F302"
                                     ZeroBrush="#F0E7D8" />
        <dxmvvm:BooleanToObjectConverter x:Key="OptionChainRowToBackgroundBrushConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #292C2F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #171718
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <Style x:Key="RowStyle"
               TargetType="dxg:RowControl">
            <Setter Property="Opacity" Value=".8" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="Transparent" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Opacity" Value="1" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="45" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <!--  Row 1  -->
        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Orientation="Horizontal">

            <dxe:ButtonEdit Width="120"
                            AllowDefaultButton="False"
                            Background="#171718"
                            CharacterCasing="Upper"
                            EditValue="{Binding Underlying, UpdateSourceTrigger=PropertyChanged}"
                            EditValuePostDelay="0"
                            SelectAllOnGotFocus="True"
                            SelectAllOnMouseUp="True"
                            TabIndex="1">
                <dxe:ButtonEdit.Buttons>
                    <dxe:ButtonInfo Command="{Binding LoadOptionChainCommand}"
                                    GlyphKind="Search"
                                    IsDefaultButton="True" />
                </dxe:ButtonEdit.Buttons>
            </dxe:ButtonEdit>

            <dxe:ComboBoxEdit Width="100"
                              Margin="5,0,0,0"
                              HorizontalAlignment="Left"
                              Background="#171718"
                              IsTextEditable="False"
                              ItemsSource="{Binding AccountsList}"
                              SelectedItem="{Binding SelectedAccount}" />

            <Label Margin="5,0,0,0"
                   Content="Group by:" />
            <dxe:ComboBoxEdit Name="GroupByComboBox"
                              Width="125"
                              Margin="5,0,0,0"
                              HorizontalAlignment="Left"
                              Background="#171718"
                              EditValueChanged="ComboBoxEdit_EditValueChanged"
                              IsTextEditable="False"
                              ItemsSource="{Binding GroupingOptions}" />

            <Label Margin="5,0,0,0"
                   Content="Visible Strikes:" />
            <dxe:ComboBoxEdit Width="60"
                              Margin="5,0,0,0"
                              HorizontalAlignment="Left"
                              Background="#171718"
                              IsTextEditable="False"
                              ItemsSource="{Binding VisibleStrikesList}"
                              SelectedItem="{Binding VisibleStrikes}">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding LoadOptionChainCommand}"
                                           EventName="EditValueChanged" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:ComboBoxEdit>
            <Label Margin="5,0,0,0"
                   Content="Best Price Lookback:" />

            <dxe:SpinEdit Width="75"
                          Margin="5,0,0,0"
                          AllowSpinOnMouseWheel="True"
                          Background="#171718"
                          EditValue="{Binding BestPriceLookback}"
                          EditValueType="{x:Type sys:Int32}"
                          Increment="1"
                          Mask="N0"
                          MaskUseAsDisplayFormat="True"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

            <dx:SimpleButton Margin="5,0,0,0"
                             HorizontalAlignment="Right"
                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                             GlyphHeight="20">
                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupControlContainer>
                        <ItemsControl>
                            <StackPanel>
                                <MenuItem Height="25"
                                          Command="{Binding CloneCommand}"
                                          Header="Clone">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="ShareLayout"
                                          Header="Share Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="SaveLayout"
                                          Header="Save Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding BrowseLayoutsCommand}"
                                          Header="Browse Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="LoadLayout"
                                          Header="Load Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </StackPanel>
                        </ItemsControl>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>
        </StackPanel>
        <!--  Row 2  -->
        <dxg:GridControl x:Name="UnderlyingInfoGrid"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,2,0,0"
                         CustomGroupDisplayTextCommand="{Binding CustomGroupDisplayTextCommand}"
                         ItemsSource="{Binding UnderlyingInformation}">
            <dxg:GridControl.View>
                <dxg:TableView AllowColumnFiltering="False"
                               AllowEditing="False"
                               AutoWidth="True"
                               FadeSelectionOnLostFocus="False"
                               RowStyle="{StaticResource RowStyle}"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               VerticalScrollbarVisibility="Hidden">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                    <Setter Property="IsSmart" Value="True" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>
            </dxg:GridControl.Resources>

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Last, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Last"
                            Header="Last"
                            Visible="True" />

            <dxg:GridColumn FieldName="NetChange"
                            Header="Net Cng"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,0,2,0"
                                   Padding="2"
                                   HorizontalAlignment="Right"
                                   Foreground="{Binding RowData.Row.NetChange, Converter={StaticResource DeltaToBrushConverter}}"
                                   Text="{Binding Path=RowData.Row.NetChange, Converter={StaticResource DoubleFormatter}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="PercentChange"
                            Header="% Cng"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,0,2,0"
                                   Padding="2"
                                   HorizontalAlignment="Right"
                                   Foreground="{Binding RowData.Row.PercentChange, Converter={StaticResource DeltaToBrushConverter}}"
                                   Text="{Binding Path=RowData.Row.PercentChange, Converter={StaticResource DoubleFormatter}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Bid, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Bid"
                            Header="Bid"
                            Visible="True" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Ask, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Ask"
                            Header="Ask"
                            Visible="True" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Volume, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                            FieldName="Volume"
                            Header="Volume"
                            Visible="True" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Open, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Open"
                            Header="Open"
                            Visible="True" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.High, Converter={StaticResource DoubleFormatter}}"
                            FieldName="High"
                            Header="High"
                            Visible="True" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Low, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Low"
                            Header="Low"
                            Visible="True" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Earnings, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Earnings"
                            Header="Earnings"
                            Visible="True" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.ExDividend, Converter={StaticResource DoubleFormatter}}"
                            FieldName="ExDividend"
                            Header="Ex-Dividend"
                            Visible="True" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.AnnualDividend, Converter={StaticResource DoubleFormatter}}"
                            FieldName="AnnualDividend"
                            Header="Annual Dividend" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.AskSize, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                            FieldName="AskSize"
                            Header="Ask Size" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.AvgVol, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                            FieldName="AvgVol"
                            Header="Avg Vol" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Beta, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Beta"
                            Header="Beta" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.BidSize, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N0}}"
                            FieldName="BidSize"
                            Header="Bid Size" />

            <dxg:GridColumn FieldName="Description"
                            Header="Description" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.DivAmount, Converter={StaticResource DoubleFormatter}}"
                            FieldName="DivAmount"
                            Header="Div Amount" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Eps, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Eps"
                            Header="Eps" />

            <dxg:GridColumn FieldName="Industry"
                            Header="Industry" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.LastSize, Converter={StaticResource DoubleFormatter}}"
                            FieldName="LastSize"
                            Header="Last Size" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Mark, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Mark"
                            Header="Mark" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.MarketCap, Converter={StaticResource DoubleFormatter}}"
                            FieldName="MarketCap"
                            Header="Market Cap" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.PE, Converter={StaticResource DoubleFormatter}}"
                            FieldName="PE"
                            Header="PE" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.PrevClose, Converter={StaticResource DoubleFormatter}}"
                            FieldName="PrevClose"
                            Header="Prev Close" />

            <dxg:GridColumn FieldName="Sector"
                            Header="Sector" />

            <dxg:GridColumn Binding="{Binding Path=RowData.Row.Yield, Converter={StaticResource DoubleFormatter}}"
                            FieldName="Yield"
                            Header="Yield" />

        </dxg:GridControl>

        <!--  Row 5  -->

        <Slider x:Name="OptionChainGridScale"
                Grid.Row="5"
                Grid.Column="0"
                Maximum="4"
                Minimum="0.1"
                Visibility="Hidden"
                Value="1" />

        <dxg:GridControl x:Name="OptionChainGrid"
                         Grid.Row="5"
                         Grid.Column="1"
                         CustomGroupDisplayTextCommand="{Binding CustomGroupDisplayTextCommand}"
                         ItemsSource="{Binding Options}"
                         PreviewMouseWheel="OnZoomMouseWheel"
                         SelectionMode="Row">

            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:ReadOnlyDependencyPropertyBindingBehavior Binding="{Binding VisibleItems, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  Property="VisibleItems" />
            </dxmvvm:Interaction.Behaviors>

            <dxg:GridControl.LayoutTransform>
                <ScaleTransform CenterX="0" CenterY="0" ScaleX="{Binding ElementName=OptionChainGridScale, Path=Value}" ScaleY="{Binding ElementName=OptionChainGridScale, Path=Value}" />
            </dxg:GridControl.LayoutTransform>
            <dxg:GridControl.Resources>
                <Style TargetType="{x:Type dxg:TableView}">
                    <Setter Property="AllowGrouping" Value="True" />
                    <Setter Property="ColumnHeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           TextAlignment="Center"
                                           TextWrapping="WrapWithOverflow" />
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style TargetType="dxg:GridColumn">
                    <Setter Property="Visible" Value="False" />
                    <Setter Property="IsSmart" Value="True" />
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                </Style>

                <Style x:Key="StrikeCellStyle"
                       TargetType="dxg:LightweightCellEditor">
                    <Setter Property="Background" Value="#000000" />
                    <Setter Property="Foreground" Value="#FE9900" />
                    <Setter Property="TextBlock.FontWeight" Value="Bold" />
                </Style>

                <Style x:Key="greekCellStyle"
                       TargetType="dxg:LightweightCellEditor">
                    <Setter Property="Foreground" Value="#FE9900" />
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView Name="OptionChainTable"
                               AllowColumnFiltering="False"
                               AllowDragDrop="True"
                               AllowEditing="False"
                               AutoWidth="True"
                               CompleteRecordDragDrop="OnCompleteRecordDragDrop"
                               FadeSelectionOnLostFocus="False"
                               RowStyle="{StaticResource RowStyle}"
                               ScrollViewer.ScrollChanged="OnScrollChanged"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               StartRecordDrag="TableView_StartRecordDrag"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                    <dxg:TableView.GroupValueTemplate>
                        <DataTemplate>
                            <TextBlock Margin="10,0,0,0"
                                       Text="{Binding Value}" />
                        </DataTemplate>
                    </dxg:TableView.GroupValueTemplate>
                    <dxg:TableView.GroupRowStyle>
                        <Style TargetType="dxg:GroupRowControl">
                            <Setter Property="Background" Value="#0f0f10" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectionState}"
                                             Value="Focused">
                                    <Setter Property="Background" Value="#1e1e1e" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:TableView.GroupRowStyle>
                    <dxg:TableView.RowCellMenuCustomizations>
                        <dxb:BarSubItem Name="AddToBlockListSubButton"
                                        Content="Add to Block List" />
                        <dxb:BarSubItem Name="RemoveFromBlockListSubButton"
                                        Content="Remove from Block List" />
                        <dxb:BarItemSeparator />
                    </dxg:TableView.RowCellMenuCustomizations>
                    <dxg:TableView.GroupRowMenuCustomizations>
                        <dxb:BarSubItem Name="AddToGroupBlockListSubButton"
                                        Content="Add to Block List" />
                        <dxb:BarSubItem Name="RemoveFromGroupBlockListSubButton"
                                        Content="Remove from Block List" />
                        <dxb:BarItemSeparator />
                    </dxg:TableView.GroupRowMenuCustomizations>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridColumn FieldName="CallPnl"
                            Header="cP&amp;L">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,0,2,0"
                                   Padding="2"
                                   Background="{Binding RowData.Row.CallITM, Converter={StaticResource OptionChainRowToBackgroundBrushConverter}}"
                                   Foreground="{Binding RowData.Row.CallPnl, Converter={StaticResource SignToBrushConverter}}"
                                   Text="{Binding RowData.Row.CallPnl, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.C0}}"
                                   TextAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn d:Visible="True"
                            FieldName="CallAttempted"
                            Header="cAttempted">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Grid Background="{Binding RowData.Row.CallITM, Converter={StaticResource OptionChainRowToBackgroundBrushConverter}}">
                            <dx:DXImage Height="15"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        d:Visibility="Visible"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_CheckCircled.svg'}"
                                        Visibility="{Binding RowData.Row.CallAttempted, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>

            <dxg:GridColumn FieldName="CallSymbol"
                            Header="cSymbol">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,0,2,0"
                                   Padding="2"
                                   Background="{Binding RowData.Row.CallITM, Converter={StaticResource OptionChainRowToBackgroundBrushConverter}}"
                                   Text="{Binding RowData.Row.CallSymbol}"
