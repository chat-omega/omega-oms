<UserControl x:Class="ZeroPlus.Oms.Ui.Views.FishLossConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:FishLossConfigViewModel}"
             d:DesignHeight="300"
             d:DesignWidth="300"
             mc:Ignorable="d">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <dxlc:GroupBox Grid.Row="1"
                       Grid.Column="1"
                       Header="Quote Checks">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <dxe:CheckEdit Grid.Row="0"
                               Content="Width Range"
                               EditValue="{Binding MarketWidthCheckEnabled}" />

                <StackPanel Grid.Row="0"
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            IsEnabled="{Binding MarketWidthCheckEnabled}"
                            Orientation="Horizontal">

                    <dxe:SpinEdit Width="70"
                                  Margin="5,0,0,0"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding MinMarketWidth, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  Mask="N2"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:SpinEdit Width="70"
                                  Margin="5,0,0,0"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding MaxMarketWidth, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  Mask="N2"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="{Binding MinMarketWidth}"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />
                </StackPanel>
            </Grid>
        </dxlc:GroupBox>
    </Grid>
</UserControl>
