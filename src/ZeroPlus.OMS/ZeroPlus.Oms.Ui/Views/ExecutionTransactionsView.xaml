<view:ModuleWindow x:Class="ZeroPlus.Oms.Ui.Views.ExecutionTransactionsView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                   xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:models="clr-namespace:ZeroPlus.Models.Data.Enums;assembly=ZeroPlus.Models"
                   xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                   xmlns:view="clr-namespace:ZeroPlus.Oms.Ui.Views"
                   xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                   Title="{Binding ModuleTitle}"
                   Width="1800"
                   Height="700"
                   MinWidth="520"
                   MinHeight="300"
                   d:DataContext="{d:DesignInstance Type=viewModels:ExecutionTransactionsViewModel}"
                   DataContext="{startuphelpers:DISource Type=viewModels:ExecutionTransactionsViewModel}"
                   WindowStartupLocation="CenterScreen"
                   mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:SaveFileDialogService />
    </dxmvvm:Interaction.Behaviors>

    <view:ModuleWindow.Resources>
        <Style x:Key="RowStyle"
               TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsSelected}"
                             Value="True">
                    <Setter Property="Background" Value="#2d313b" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Path=Row.Side}"
                             Value="{x:Static models:Side.Buy}">
                    <Setter Property="Foreground" Value="#4ec9b0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Path=Row.Side}"
                             Value="{x:Static models:Side.Sell}">
                    <Setter Property="Foreground" Value="#ff4f4f" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Path=Row.Side}"
                             Value="{x:Static models:Side.SellShort}">
                    <Setter Property="Foreground" Value="#ff4f4f" />
                </DataTrigger>
                <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                    <Setter Property="Background" Value="#3b404a" />
                </Trigger>
                <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4e5563" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#4d4d4d" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

    </view:ModuleWindow.Resources>

    <dx:ThemedWindow.HeaderItems>
        <dx:SimpleButton Margin="2"
                         Padding="0"
                         ButtonKind="Toggle"
                         Glyph="{dx:DXImage 'SvgImages/PDF Viewer/EnableScrolling.svg'}"
                         GlyphHeight="20"
                         IsChecked="{Binding AutoScroll}"
                         ToolTip="Auto Scroll" />
        <view:ModuleHeaderItems />
    </dx:ThemedWindow.HeaderItems>

    <Grid>
        <dxg:GridControl x:Name="TransactionsGrid"
                         MinHeight="70"
                         MaxHeight="5000"
                         Margin="5"
                         AutoGenerateColumns="None"
                         CurrentItem="{Binding LastTransaction}"
                         CustomColumnDisplayText="GridControl_CustomColumnsDisplayText"
                         EnableSmartColumnsGeneration="False"
                         ItemsSource="{Binding Transactions}"
                         OptimizeSummaryCalculation="True"
                         SelectionMode="MultipleRow">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                    <Setter Property="Visible" Value="True" />
                    <Setter Property="IsSmart" Value="True" />
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView Name="TransactionsTable"
                               AllowDragDrop="True"
                               AllowEditing="False"
                               AutoWidth="True"
                               BandSeparatorWidth="1"
                               EnableSelectedRowAppearance="True"
                               GroupSummaryDisplayMode="AlignByColumns"
                               NavigationStyle="Row"
                               RowStyle="{StaticResource RowStyle}"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               ShowTotalSummary="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="OrderId" />
                <dxg:GridColumn FieldName="UpdateTime" />
                <dxg:GridColumn FieldName="Underlying" />
                <dxg:GridColumn FieldName="Symbol" />
                <dxg:GridColumn FieldName="Trader" />
                <dxg:GridColumn FieldName="Side" />
                <dxg:GridColumn FieldName="OrderQty" />
                <dxg:GridColumn FieldName="ExecutionType">
                    <dxg:GridColumn.CellStyle>
                        <Style TargetType="dxg:LightweightCellEditor">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Value}"
                                             Value="{x:Static models:ExecutionType.PartiallyFilled}">
                                    <Setter Property="Foreground" Value="#d0d07f" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:GridColumn.CellStyle>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Qty"
                                Header="Filled Qty" />
                <dxg:GridColumn FieldName="NominalPrice">
                    <dxg:GridColumn.CellDisplayTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Value, StringFormat='###,###,##0.00;(###,###,##0.00)'}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellDisplayTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Price" />
                <dxg:GridColumn FieldName="Venue" />

                <dxg:GridColumn FieldName="Route" />
                <dxg:GridColumn FieldName="Account" />


            </dxg:GridControl.Columns>
            <dxg:GridControl.GroupSummary>
                <dxg:GridSummaryItem DisplayFormat="###,###,##0.00;(###,###,##0.00)"
                                     FieldName="NominalPrice"
                                     ShowInColumn="NominalPrice"
                                     SummaryType="Sum" />
                <dxg:GridSummaryItem DisplayFormat="###,###,##0"
                                     FieldName="Qty"
                                     SummaryType="Sum" />
            </dxg:GridControl.GroupSummary>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem DisplayFormat="Records: {0}"
                                     ShowInColumn="Trader"
                                     SummaryType="Count" />
                <dxg:GridSummaryItem DisplayFormat="###,###,##0.00;(###,###,##0.00)"
                                     FieldName="NominalPrice"
                                     SummaryType="Sum" />
                <dxg:GridSummaryItem DisplayFormat="Fills: {0}"
                                     FieldName="Qty"
                                     ShowInColumn="Qty"
                                     SummaryType="Sum" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</view:ModuleWindow>
