<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.VolTraderView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxgt="http://schemas.devexpress.com/winfx/2008/xaml/grid/themekeys"
                 xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 Title="{Binding ModuleTitle}"
                 Width="2200"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 Padding="0"
                 d:DataContext="{d:DesignInstance Type=ViewModels:VolTraderViewModel}"
                 d:Width="3000"
                 DataContext="{startuphelpers:DISource Type=ViewModels:VolTraderViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <services:LoadCustomColumnService />
        <services:OmsMessageBoxService />
    </dxmvvm:Interaction.Behaviors>
    <Window.Resources>
        <helper:LoopPricingModeToDisplayTextConverter x:Key="LoopPricingModeToDisplayTextConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToColorConverterRed">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F88F8F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #2D2D30
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToExpandCollapseConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                3
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                4
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:SignToBrushConverter x:Key="SignToBrushConverter"
                                     NegativeBrush="#B73535"
                                     PositiveBrush="#10e411"
                                     ZeroBrush="#10e411" />
        <helper:SignToBrushConverter x:Key="CountdownToBrushConverter"
                                     Limit="3"
                                     NegativeBrush="#F05126"
                                     PositiveBrush="#171718"
                                     ZeroBrush="#F05126" />
    </Window.Resources>

    <dx:ThemedWindow.HeaderItems>
        <StackPanel Margin="1,4,2,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

            <dx:SimpleButton Grid.Row="0"
                             Grid.Column="3"
                             Width="100"
                             Height="22"
                             Margin="5,0,0,0"
                             Padding="0,1"
                             VerticalAlignment="Top"
                             Command="{Binding CancelAllCommand}"
                             Content="Cancel All" />

            <dx:SimpleButton Grid.Row="0"
                             Grid.Column="4"
                             Width="100"
                             Height="22"
                             Margin="5,0,0,0"
                             Padding="0"
                             VerticalAlignment="Top"
                             Command="{Binding StopAllCommand}"
                             Content="Stop All"
                             Style="{StaticResource EmergencyStopButtonStyle}" />

            <dxe:ToggleSwitch Margin="10,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              AnimationMode="Always"
                              Background="#FF0000"
                              CheckedStateContent="✅ Risk Check"
                              ContentPlacement="Inside"
                              Focusable="False"
                              FontWeight="Bold"
                              IsChecked="{Binding RiskCheckEnabled}"
                              ToggleSwitchWidth="105"
                              UncheckedStateContent="⚠ Risk Check">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding RiskCheckChangedCommand}"
                                           EventName="Checked" />
                    <dxmvvm:EventToCommand Command="{Binding RiskCheckChangedCommand}"
                                           EventName="Unchecked" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:ToggleSwitch>

            <dxe:ToggleSwitch Margin="10,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              AnimationMode="Always"
                              Background="#FF0000"
                              CheckedStateContent="✅ Active Uncheck"
                              ContentPlacement="Inside"
                              Focusable="False"
                              FontWeight="Bold"
                              IsChecked="{Binding ActiveUncheckEnabled}"
                              ToggleSwitchWidth="130"
                              UncheckedStateContent="⚠ Active Uncheck">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand Command="{Binding ActiveUncheckChangedCommand}"
                                           EventName="Checked" />
                    <dxmvvm:EventToCommand Command="{Binding ActiveUncheckChangedCommand}"
                                           EventName="Unchecked" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:ToggleSwitch>

            <dx:SimpleButton Grid.Row="0"
                             Grid.Column="5"
                             Height="22"
                             Margin="5,0,0,0"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             dxb:BarManager.MenuShowMouseButton="LeftButton"
                             Glyph="{dx:DXImage SvgImages/DiagramIcons/Orientation/ListOrientationVertical.svg}"
                             GlyphHeight="18">
                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupControlContainer>
                        <ItemsControl>
                            <StackPanel>
                                <MenuItem Height="25"
                                          Command="{Binding CloneCommand}"
                                          Header="Clone">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/XAF/Action_CloneMerge_Merge_Object.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="ShareLayout"
                                          Header="Share Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Icon Builder/Actions_Send.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="SaveLayout"
                                          Header="Save Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Save/Save.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Command="{Binding BrowseLayoutsCommand}"
                                          Header="Browse Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/ServerMode.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Height="25"
                                          Click="LoadLayout"
                                          Header="Load Layout">
                                    <MenuItem.Icon>
                                        <Image Width="15"
                                               Height="15"
                                               Source="{dx:DXImage SvgImages/Dashboards/LoadMap.svg}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </StackPanel>
                        </ItemsControl>
                    </dxb:PopupControlContainer>
                </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>

        </StackPanel>
    </dx:ThemedWindow.HeaderItems>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <ScrollViewer.ContextMenu>
                    <ContextMenu>
                        <ItemsControl>
                            <MenuItem Header="Show Submit With Delay Settings"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowSubmitWithDelaySettings}" />
                            <MenuItem Header="Show Route Settings"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowRouteSettings}" />
                            <MenuItem Header="Show Auto Close Settings"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowAutoCloseSettings}" />
                            <MenuItem Header="Show Auto Cancel Settings"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowAutoCancelSettings}" />
                        </ItemsControl>
                    </ContextMenu>
                </ScrollViewer.ContextMenu>
                <StackPanel Orientation="Horizontal">
                    <dxlc:GroupBox Grid.Row="0"
                                   Grid.RowSpan="2"
                                   Grid.Column="0"
                                   Padding="10,5">
                        <dxlc:GroupBox.Header>
                            <Grid Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>

                                <dxe:TextEdit x:Name="NameEdit"
                                              Grid.Column="0"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              EditValue="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                              KeyDown="NameKeyDown"
                                              MouseDoubleClick="ToggleEdit"
                                              PreviewMouseUp="SelectAll"
                                              SelectAllOnGotFocus="True"
                                              SelectAllOnMouseUp="True" />

                                <dx:SimpleButton x:Name="NameEditButton"
                                                 Grid.Column="1"
                                                 Width="25"
                                                 HorizontalAlignment="Right"
                                                 ButtonKind="Toggle"
                                                 Checked="EditName"
                                                 Glyph="{dx:DXImage SvgImages/Dashboards/RenameQuery.svg}"
                                                 GlyphHeight="15"
                                                 ToolTip="Edit Instance Title"
                                                 Unchecked="SetName" />

                                <dxe:ButtonEdit Grid.Row="0"
                                                Grid.Column="2"
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                AllowDefaultButton="False"
                                                ShowBorder="False"
                                                ShowText="False"
                                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <dxe:ButtonEdit.Buttons>
                                        <dxe:LoadingIndicatorButtonInfo />
                                    </dxe:ButtonEdit.Buttons>
                                </dxe:ButtonEdit>

                            </Grid>
                        </dxlc:GroupBox.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="75" />
                                <ColumnDefinition Width="75" />
                                <ColumnDefinition Width="75" />
                                <ColumnDefinition Width="75" />
                            </Grid.ColumnDefinitions>

                            <dx:SimpleButton Grid.Row="0"
                                             Grid.Column="0"
                                             Padding="0,1"
                                             Command="{Binding AddNewBasketCommand}"
                                             Content="Add Basket"
                                             IsEnabled="{Binding IsBusy, Converter={StaticResource BooleanNegationConverter}}" />

                            <Label Grid.Row="0"
                                   Grid.Column="1"
                                   Margin="5,0,0,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Content="Perm Count" />

                            <dxe:SpinEdit Grid.Row="0"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,0,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding BasketCount, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Mask="d"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dx:SimpleButton Grid.Row="0"
                                             Grid.Column="3"
                                             Width="70"
                                             Margin="5,0,0,0"
                                             Padding="0,1"
                                             Command="{Binding ExpirationDownCommand}"
                                             CommandParameter="{Binding Path=SelectedItem, ElementName=VolTraderGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Exp" />
                                    <TextBlock Margin="0,2,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Marlett"
                                               Text="6" />
                                </StackPanel>
                            </dx:SimpleButton>

                            <dx:SimpleButton Grid.Row="0"
                                             Grid.Column="4"
                                             Width="70"
                                             Margin="5,0,0,0"
                                             Padding="0,1"
                                             Command="{Binding ExpirationUpCommand}"
                                             CommandParameter="{Binding Path=SelectedItem, ElementName=VolTraderGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Exp" />
                                    <TextBlock Margin="0,2,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Marlett"
                                               Text="5" />
                                </StackPanel>
                            </dx:SimpleButton>

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,5,0,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Content="Strike Range"
                                           EditValue="{Binding StrikeRangeEnabled, UpdateSourceTrigger=PropertyChanged}" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="1"
                                          Width="70"
                                          Margin="5,5,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding MinStrike, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          IsEnabled="{Binding StrikeRangeEnabled}"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,5,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding MaxStrike, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Double}"
                                          IsEnabled="{Binding StrikeRangeEnabled}"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="3"
                                           Width="70"
                                           Margin="5,5,0,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Content="Decimal"
                                           EditValue="{Binding IncludeDecimalStrikes, UpdateSourceTrigger=PropertyChanged}"
                                           IsEnabled="{Binding StrikeRangeEnabled}" />

                            <dx:SimpleButton Grid.Row="1"
                                             Grid.Column="4"
                                             Width="70"
                                             Margin="5,0,0,0"
                                             Padding="0,1"
                                             Command="{Binding CloneAndFlipCallPutCommand}"
                                             Content="Clone C/P" />

                            <dxe:CheckEdit Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="0,5,0,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Content="Delta Range"
                                           EditValue="{Binding DeltaRangeEnabled, UpdateSourceTrigger=PropertyChanged}" />

                            <dxe:SpinEdit Grid.Row="2"
                                          Grid.Column="1"
                                          Width="70"
                                          Margin="5,5,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding MinDelta, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment=".01"
                                          IsEnabled="{Binding DeltaRangeEnabled}"
                                          Mask="N3"
                                          MaskUseAsDisplayFormat="True"
                                          MaxValue="1"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:SpinEdit Grid.Row="2"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,5,0,0"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding MaxDelta, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment=".01"
                                          IsEnabled="{Binding DeltaRangeEnabled}"
                                          Mask="N3"
                                          MaskUseAsDisplayFormat="True"
                                          MaxValue="1"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dx:SimpleButton Grid.Row="2"
                                             Grid.Column="3"
                                             Width="70"
                                             Margin="5,5,0,0"
                                             Padding="0,1"
                                             Command="{Binding RefreshRangeCommand}"
                                             Content="Clean" />

                            <dx:SimpleButton Grid.Row="2"
                                             Grid.Column="4"
                                             Width="70"
                                             Margin="5,5,0,0"
                                             Padding="0,1"
                                             Command="{Binding ResetQtyCommand}"
                                             Content="Reset Qty" />
                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Margin="5,0,0,0"
                                   Padding="10,5"
                                   Visibility="{Binding ShowSubmitWithDelaySettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <dxlc:GroupBox.Header>
                            <Grid Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <Label Padding="0"
                                       Content="Submit With Delay"
                                       FontWeight="Bold"
                                       Foreground="#AFAFB0" />

                                <dxe:CheckEdit Grid.Column="1"
                                               Margin="0"
                                               Padding="0"
                                               HorizontalAlignment="Right"
                                               CheckBoxHeight="11"
                                               CheckBoxWidth="11"
                                               Content="Enable"
                                               EditValue="{Binding SubmitWithDelayEnabled}">
                                    <dxmvvm:Interaction.Behaviors>
                                        <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                               EventName="EditValueChanged" />
                                    </dxmvvm:Interaction.Behaviors>
                                </dxe:CheckEdit>

                                <dx:SimpleButton Grid.Column="2"
                                                 IsChecked="{Binding ShowSubmitWithDelaySettings}"
                                                 Style="{StaticResource XButtonStyle}" />

                            </Grid>
                        </dxlc:GroupBox.Header>
                        <Grid Margin="0,5,0,0"
                              IsEnabled="{Binding SubmitWithDelayEnabled}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,0,0"
                                   VerticalAlignment="Center"
                                   Content="Delay Range" />

                            <dxe:SpinEdit Grid.Row="0"
                                          Grid.Column="1"
                                          Width="70"
                                          Margin="5,0,0,0"
                                          HorizontalAlignment="Left"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding SubmitWithDelayInterval, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          MinValue="{Binding OmsCore.Config.SubmitWithDelayIntervalMin}"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <dxe:SpinEdit Grid.Row="0"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,0,0,0"
                                          HorizontalAlignment="Left"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding SubmitWithDelayIntervalEnd, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          MinValue="{Binding SubmitWithDelayInterval}"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="3"
                                           Margin="5,0,0,0"
                                           Content="Adjust Px"
                                           EditValue="{Binding AdjustPriceBeforeSubmit}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:CheckEdit>

                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="4"
                                           Margin="5,0,0,0"
                                           Content="Open Tickets On Fill"
                                           EditValue="{Binding OpenTicketForFills}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:CheckEdit>

                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,0,0"
                                   VerticalAlignment="Center"
                                   Content="Cancel On" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="1"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding CancelOnAmountOfFillsCount, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          MaxValue="{Binding OmsCore.Config.MaxCancelOnLimit}"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="2"
                                           Grid.ColumnSpan="2"
                                           Margin="5,0,0,0"
                                           Content="Randomize On Submit"
                                           EditValue="{Binding Randomize}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:CheckEdit>

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="4"
                                           Margin="5,0,0,0"
                                           Content="Open Contra Tickets"
                                           EditValue="{Binding AlsoOpenContraTicketEnabled}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:CheckEdit>

                            <dxe:CheckEdit Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="0,0,0,0"
                                           HorizontalAlignment="Left"
                                           Content="Max Resting"
                                           EditValue="{Binding MaxRestingOrdersEnabled}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:CheckEdit>

                            <dxe:SpinEdit Grid.Row="2"
                                          Grid.Column="1"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding MaxRestingOrdersCount, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueType="{x:Type sys:Int32}"
                                          IsEnabled="{Binding MaxRestingOrdersEnabled}"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:SpinEdit>

                            <dxe:CheckEdit Grid.Row="2"
                                           Grid.Column="2"
                                           Grid.ColumnSpan="2"
                                           Margin="5,0,0,0"
                                           HorizontalAlignment="Left"
                                           Content="Start From Selected Row"
                                           EditValue="{Binding StartProcessingFromSelectedRow}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding SubmitWithDelayUpdatedCommand}"
                                                           EventName="EditValueChanged" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:CheckEdit>

                            <dxe:CheckEdit Grid.Row="2"
                                           Grid.Column="4"
                                           Margin="5,0,0,0"
