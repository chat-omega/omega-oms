                                   Padding="0,2,0,0"
                                   VerticalAlignment="Center"
                                   Background="{Binding RowData.Row.ResubmitCountDown.TotalSeconds, Converter={StaticResource CountdownToBrushConverter}}"
                                   FontFamily="{StaticResource Technology}"
                                   FontSize="18"
                                   Text="{Binding RowData.Row.ResubmitCountDown, Converter={StaticResource DoubleFormatter}}"
                                   TextAlignment="Center" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="85"
                            FieldName="ResubmitIntervalSec"
                            Header="Interval"
                            IsSmart="False"
                            ReadOnly="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>

                    <DataTemplate>
                        <dxe:SpinEdit HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      BorderThickness="0"
                                      EditValue="{Binding RowData.Row.ResubmitIntervalSec, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueChanged="ResubmitIntervalChanged"
                                      EditValueType="{x:Type sys:Int32}"
                                      MinValue="1"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />

                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="105"
                            MinWidth="105"
                            MaxWidth="105"
                            FieldName="ResubmitSide"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:ComboBoxEdit BorderThickness="0"
                                          EditValue="{Binding RowData.Row.ResubmitSide, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueChanged="ResubmitSideChanged"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding RowData.Row.ResubmitSides}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="105"
                            MinWidth="105"
                            MaxWidth="105"
                            FieldName="EdgeType"
                            Header="Edge Type"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:ComboBoxEdit BorderThickness="0"
                                          EditValue="{Binding RowData.Row.BasketSettings.EdgeType, UpdateSourceTrigger=PropertyChanged}"
                                          EditValueChanged="EdgeTypeChanged"
                                          IsTextEditable="False"
                                          ItemsSource="{Binding RowData.Row.EdgeTypes}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding RowData.Row.EdgeTypeChangedCommand}"
                                                       EventName="EditValueChanged" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:ComboBoxEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="75"
                            MinWidth="75"
                            MaxWidth="75"
                            FieldName="BuyEdge"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      BorderThickness="0"
                                      DisplayFormatString="N2"
                                      EditValue="{Binding RowData.Row.BasketSettings.BuyEdge, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueChanged="BuyEdgeChanged"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="0.01"
                                      Mask="N2"
                                      MinValue="{Binding RowData.Row.OmsCore.Config.MinimumVolTraderEdgeLimit}"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding RowData.Row.BuyEdgeChangedCommand}"
                                                       EventName="Spin" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:SpinEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="75"
                            MinWidth="75"
                            MaxWidth="75"
                            FieldName="SubmitBuy"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Padding="0"
                                         BorderThickness="0"
                                         Command="{Binding RowData.Row.SubmitBuysWithBuyEdgeCommand}"
                                         Content="Submit Buy"
                                         Foreground="#10e411" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="75"
                            MinWidth="75"
                            MaxWidth="75"
                            FieldName="Cancel"
                            Header="Cancel"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton BorderThickness="0"
                                         Command="{Binding RowData.Row.CancelAllCommand}"
                                         Content="Cancel" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="75"
                            MinWidth="75"
                            MaxWidth="75"
                            FieldName="SubmitSell"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Padding="0"
                                         BorderThickness="0"
                                         Command="{Binding RowData.Row.SubmitSellssWithSellEdgeCommand}"
                                         Content="Submit Sell"
                                         Foreground="#B73535" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="75"
                            MinWidth="75"
                            MaxWidth="75"
                            FieldName="SellEdge"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      BorderThickness="0"
                                      DisplayFormatString="N2"
                                      EditValue="{Binding RowData.Row.BasketSettings.SellEdge, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueChanged="SellEdgeChanged"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="0.01"
                                      Mask="N2"
                                      MinValue="{Binding RowData.Row.OmsCore.Config.MinimumVolTraderEdgeLimit}"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding RowData.Row.SellEdgeChangedCommand}"
                                                       EventName="Spin" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:SpinEdit>
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="75"
                            MinWidth="75"
                            MaxWidth="75"
                            FieldName="ContraFishEdge"
                            Header="Close Edge"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:SpinEdit HorizontalContentAlignment="Right"
                                      AllowSpinOnMouseWheel="True"
                                      BorderThickness="0"
                                      DisplayFormatString="N2"
                                      EditValue="{Binding RowData.Row.BasketSettings.AutomationConfig.ContraFishEdge, UpdateSourceTrigger=PropertyChanged}"
                                      EditValueType="{x:Type sys:Double}"
                                      Increment="0.01"
                                      IsEnabled="{Binding View.DataContext.UseGlobalCloseEdge, Converter={StaticResource BooleanNegationConverter}}"
                                      Mask="N2"
                                      MinValue="{Binding RowData.Row.BasketSettings.AutomationConfig.CloseEdgeMinValue}"
                                      PreviewMouseUp="SelectAll"
                                      SelectAllOnGotFocus="True"
                                      SelectAllOnMouseUp="True" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="75"
                            MinWidth="75"
                            MaxWidth="75"
                            FieldName="Clean"
                            Header="Clean"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton BorderThickness="0"
                                         Command="{Binding RowData.Row.CleanCommand}"
                                         Content="Clean" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Width="40"
                            MinWidth="40"
                            MaxWidth="40"
                            FieldName="Remove"
                            Header="X"
                            IsSmart="False"
                            Visible="True">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Width="40"
                                         BorderThickness="0"
                                         Command="{Binding View.DataContext.RemoveBasketCommand}"
                                         CommandParameter="{Binding Path=SelectedItems, ElementName=VolTraderGrid}"
                                         Glyph="{dx:DXImage SvgImages/HybridDemoIcons/BottomPanel/HybridDemo_Close.svg}"
                                         GlyphWidth="20" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
        </dxg:GridControl>
    </Grid>
</dx:ThemedWindow>
