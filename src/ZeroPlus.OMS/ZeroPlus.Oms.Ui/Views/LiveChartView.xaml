<dx:ThemedWindow x:Class="ZeroPlus.Oms.Ui.Views.LiveChartView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                 xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                 xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
                 xmlns:startuphelpers="clr-namespace:ZeroPlus.Oms.Ui.StartupHelpers"
                 xmlns:viewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
                 Title="{Binding ModuleTitle}"
                 Width="1500"
                 Height="800"
                 MinWidth="400"
                 MinHeight="300"
                 d:DataContext="{d:DesignInstance Type=viewModels:LiveChartViewModel}"
                 DataContext="{startuphelpers:DISource Type=viewModels:LiveChartViewModel}"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">

    <Window.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:MultiBooleanToAndConverter x:Key="MultiBooleanToAndConverter" />
        <helper:ChartConstantLineModeToColorConverter x:Key="ChartConstantLineModeToColorConverter" />
        <helper:ChartConstantLineModeToAlignmentConverter x:Key="ChartConstantLineModeToAlignmentConverter" />
    </Window.Resources>

    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:SaveFileDialogService />
        <dxmvvm:KeyToCommand Command="{Binding SearchCommand}"
                             KeyGesture="Enter" />
    </dxmvvm:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1"
              Grid.Column="1"
              Grid.ColumnSpan="3"
              Margin="0,0,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Padding="3"
                   Background="#171718"
                   Content="Symbol - " />

            <dxe:ButtonEdit Grid.Column="1"
                            Width="350"
                            Margin="0,0,0,0"
                            AllowDefaultButton="False"
                            Background="#171718"
                            BorderBrush="#171718"
                            BorderThickness="0"
                            CharacterCasing="Upper"
                            EditValue="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                            EditValuePostDelay="0"
                            SelectAllOnGotFocus="True"
                            SelectAllOnMouseUp="True"
                            TabIndex="1">
                <dxe:ButtonEdit.Buttons>
                    <dxe:ButtonInfo Command="{Binding SearchCommand}"
                                    GlyphKind="Search"
                                    IsDefaultButton="True" />
                </dxe:ButtonEdit.Buttons>
            </dxe:ButtonEdit>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal">
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Match Seq"
                               EditValue="{Binding MatchSequence}" />
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Test Value"
                               EditValue="{Binding ShowTestValue}" />
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Base Line"
                               EditValue="{Binding ShowBaseLine}" />
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Derived Values"
                               EditValue="{Binding ShowDerivedValues}" />
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Adj Theo"
                               EditValue="{Binding ShowAdjTheo}" />
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Adj Ema"
                               EditValue="{Binding ShowAdjEma}" />
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Hanweck Theo"
                               EditValue="{Binding ShowHwTheo}" />
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Hanweck Leg Theo"
                               EditValue="{Binding ShowLegTheo}" />
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Underlying"
                               EditValue="{Binding ShowUnderlying}" />
                <dxe:CheckEdit Margin="5,0,0,0"
                               Content="Auto Scroll Table"
                               EditValue="{Binding AutoScroll}" />
            </StackPanel>
        </Grid>

        <dxc:ChartControl x:Name="chart"
                          Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,2,0,0">
            <dxc:ChartControl.Legend>
                <dxc:Legend HorizontalPosition="Left" />
            </dxc:ChartControl.Legend>
            <dxc:ChartControl.Diagram>
                <dxc:XYDiagram2D Name="diagram"
                                 DependentAxesYRange="True"
                                 EnableAxisXNavigation="True"
                                 EnableAxisYNavigation="True">
                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisAdj}"
                                      DataSource="{Binding TestValueDataPoints}"
                                      DisplayName="Test Value"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowTestValue}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisAdj}"
                                      DataSource="{Binding BaseLineDataPoints}"
                                      DisplayName="Base Line"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowBaseLine}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisAdj}"
                                      DataSource="{Binding TradeIntBidDataPoints}"
                                      DisplayName="Trade Int Bid"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowDerivedValues}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisAdj}"
                                      DataSource="{Binding TradeIntAskDataPoints}"
                                      DisplayName="Trade Int Ask"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowDerivedValues}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisAdj}"
                                      DataSource="{Binding BestBidDataPoints}"
                                      DisplayName="Best Bid"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowDerivedValues}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisAdj}"
                                      DataSource="{Binding BestAskDataPoints}"
                                      DisplayName="Best Ask"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowDerivedValues}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisAdj}"
                                      DataSource="{Binding AdjTheoDataPoints}"
                                      DisplayName="Adj Theo"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowAdjTheo}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisAdj}"
                                      DataSource="{Binding AdjEmaDataPoints}"
                                      DisplayName="Adj Ema"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowAdjEma}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisAdj}"
                                      DataSource="{Binding HanweckTheoDataPoints}"
                                      DisplayName="HW Theo"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowHwTheo}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisLeg1}"
                                      DataSource="{Binding Leg1DataPoints}"
                                      DisplayName="Leg 1 Theo"
                                      ValueDataMember="Value">
                        <dxc:LineSeries2D.Visible>
                            <MultiBinding Converter="{StaticResource MultiBooleanToAndConverter}">
                                <Binding Path="ShowLegTheo" />
                                <Binding Path="Leg1TheoLoaded" />
                            </MultiBinding>
                        </dxc:LineSeries2D.Visible>
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisLeg2}"
                                      DataSource="{Binding Leg2DataPoints}"
                                      DisplayName="Leg 2 Theo"
                                      ValueDataMember="Value">
                        <dxc:LineSeries2D.Visible>
                            <MultiBinding Converter="{StaticResource MultiBooleanToAndConverter}">
                                <Binding Path="ShowLegTheo" />
                                <Binding Path="Leg2TheoLoaded" />
                            </MultiBinding>
                        </dxc:LineSeries2D.Visible>
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisLeg3}"
                                      DataSource="{Binding Leg3DataPoints}"
                                      DisplayName="Leg 3 Theo"
                                      ValueDataMember="Value">
                        <dxc:LineSeries2D.Visible>
                            <MultiBinding Converter="{StaticResource MultiBooleanToAndConverter}">
                                <Binding Path="ShowLegTheo" />
                                <Binding Path="Leg3TheoLoaded" />
                            </MultiBinding>
                        </dxc:LineSeries2D.Visible>
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      AxisY="{Binding ElementName=SecondaryAxisLeg4}"
                                      DataSource="{Binding Leg4DataPoints}"
                                      DisplayName="Leg 4 Theo"
                                      ValueDataMember="Value">
                        <dxc:LineSeries2D.Visible>
                            <MultiBinding Converter="{StaticResource MultiBooleanToAndConverter}">
                                <Binding Path="ShowLegTheo" />
                                <Binding Path="Leg4TheoLoaded" />
                            </MultiBinding>
                        </dxc:LineSeries2D.Visible>
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:LineSeries2D ArgumentDataMember="Timestamp"
                                      DataSource="{Binding UnderlyingDataPoints}"
                                      DisplayName="Underlying"
                                      ValueDataMember="Value"
                                      Visible="{Binding ShowUnderlying}">
                        <dxc:LineSeries2D.LastPoint>
                            <dxc:SidePoint LabelDisplayMode="SeriesPoint">
                                <dxc:SidePoint.Label>
                                    <dxc:SeriesLabel TextPattern="{}{V:f2}" />
                                </dxc:SidePoint.Label>
                            </dxc:SidePoint>
                        </dxc:LineSeries2D.LastPoint>
                    </dxc:LineSeries2D>

                    <dxc:XYDiagram2D.AxisX>
                        <dxc:AxisX2D ConstantLineInFrontItemsSource="{Binding ResetPoints}">

                            <dxc:AxisX2D.ConstantLineInFrontItemTemplate>
                                <DataTemplate>
                                    <dxc:ConstantLine Brush="{Binding LineMode, Converter={StaticResource ChartConstantLineModeToColorConverter}}"
                                                      Value="{Binding Value}">
                                        <dxc:ConstantLine.Title>
                                            <dxc:ConstantLineTitle Alignment="{Binding LineMode, Converter={StaticResource ChartConstantLineModeToAlignmentConverter}}"
                                                                   Content="{Binding Title}"
                                                                   Foreground="{Binding LineMode, Converter={StaticResource ChartConstantLineModeToColorConverter}}" />
                                        </dxc:ConstantLine.Title>
                                    </dxc:ConstantLine>
                                </DataTemplate>
                            </dxc:AxisX2D.ConstantLineInFrontItemTemplate>

                            <dxc:AxisX2D.Title>
                                <dxc:AxisTitle Content="Update Time" />
                            </dxc:AxisX2D.Title>
                            <dxc:AxisX2D.DateTimeScaleOptions>
                                <dxc:ContinuousDateTimeScaleOptions />
                            </dxc:AxisX2D.DateTimeScaleOptions>
                        </dxc:AxisX2D>
                    </dxc:XYDiagram2D.AxisX>

                    <dxc:XYDiagram2D.AxisY>
                        <dxc:AxisY2D Name="MainAxisY"
                                     Visible="{Binding ShowUnderlying}">
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Under" />
                            </dxc:AxisY2D.Title>
                            <dxc:AxisY2D.WholeRange>
                                <dxc:Range dxc:AxisY2D.AlwaysShowZeroLevel="False" />
                            </dxc:AxisY2D.WholeRange>
                        </dxc:AxisY2D>
                    </dxc:XYDiagram2D.AxisY>

                    <dxc:XYDiagram2D.SecondaryAxesY>
                        <dxc:SecondaryAxisY2D Name="SecondaryAxisAdj">
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Adj Theo/HW Theo/Adj EMA" />
                            </dxc:AxisY2D.Title>
                            <dxc:SecondaryAxisY2D.WholeRange>
                                <dxc:Range dxc:AxisY2D.AlwaysShowZeroLevel="False" />
                            </dxc:SecondaryAxisY2D.WholeRange>
                        </dxc:SecondaryAxisY2D>
                        <dxc:SecondaryAxisY2D Name="SecondaryAxisLeg1">
                            <dxc:SecondaryAxisY2D.Visible>
                                <MultiBinding Converter="{StaticResource MultiBooleanToAndConverter}">
                                    <Binding Path="ShowLegTheo" />
                                    <Binding Path="Leg1TheoLoaded" />
                                </MultiBinding>
                            </dxc:SecondaryAxisY2D.Visible>
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Leg 1 Theo" />
                            </dxc:AxisY2D.Title>
                            <dxc:SecondaryAxisY2D.WholeRange>
                                <dxc:Range dxc:AxisY2D.AlwaysShowZeroLevel="False" />
                            </dxc:SecondaryAxisY2D.WholeRange>
                        </dxc:SecondaryAxisY2D>
                        <dxc:SecondaryAxisY2D Name="SecondaryAxisLeg2">
                            <dxc:SecondaryAxisY2D.Visible>
                                <MultiBinding Converter="{StaticResource MultiBooleanToAndConverter}">
                                    <Binding Path="ShowLegTheo" />
                                    <Binding Path="Leg2TheoLoaded" />
                                </MultiBinding>
                            </dxc:SecondaryAxisY2D.Visible>
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Leg 2 Theo" />
                            </dxc:AxisY2D.Title>
                            <dxc:SecondaryAxisY2D.WholeRange>
                                <dxc:Range dxc:AxisY2D.AlwaysShowZeroLevel="False" />
                            </dxc:SecondaryAxisY2D.WholeRange>
                        </dxc:SecondaryAxisY2D>
                        <dxc:SecondaryAxisY2D Name="SecondaryAxisLeg3">
                            <dxc:SecondaryAxisY2D.Visible>
                                <MultiBinding Converter="{StaticResource MultiBooleanToAndConverter}">
                                    <Binding Path="ShowLegTheo" />
                                    <Binding Path="Leg3TheoLoaded" />
                                </MultiBinding>
                            </dxc:SecondaryAxisY2D.Visible>
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Leg 3 Theo" />
                            </dxc:AxisY2D.Title>
                            <dxc:SecondaryAxisY2D.WholeRange>
                                <dxc:Range dxc:AxisY2D.AlwaysShowZeroLevel="False" />
                            </dxc:SecondaryAxisY2D.WholeRange>
                        </dxc:SecondaryAxisY2D>
                        <dxc:SecondaryAxisY2D Name="SecondaryAxisLeg4">
                            <dxc:SecondaryAxisY2D.Visible>
                                <MultiBinding Converter="{StaticResource MultiBooleanToAndConverter}">
                                    <Binding Path="ShowLegTheo" />
                                    <Binding Path="Leg4TheoLoaded" />
                                </MultiBinding>
                            </dxc:SecondaryAxisY2D.Visible>
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="Leg 4 Theo" />
                            </dxc:AxisY2D.Title>
                            <dxc:SecondaryAxisY2D.WholeRange>
                                <dxc:Range dxc:AxisY2D.AlwaysShowZeroLevel="False" />
                            </dxc:SecondaryAxisY2D.WholeRange>
                        </dxc:SecondaryAxisY2D>
                    </dxc:XYDiagram2D.SecondaryAxesY>
                </dxc:XYDiagram2D>
            </dxc:ChartControl.Diagram>
        </dxc:ChartControl>

        <GridSplitter Grid.Row="2"
                      Grid.Column="2"
                      Width="1"
                      HorizontalAlignment="Stretch" />

        <dxg:GridControl x:Name="QuoteGrid"
                         Grid.Row="2"
                         Grid.Column="3"
                         MinHeight="70"
                         MaxHeight="5000"
                         HorizontalAlignment="Center"
                         AutoGenerateColumns="AddNew"
                         CurrentItem="{Binding LastUpdate}"
                         ItemsSource="{Binding Updates}"
                         SelectionMode="MultipleRow">
            <dxg:GridControl.Resources>
                <Style TargetType="dxg:GridColumn">
                    <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
                    <Setter Property="Visible" Value="False" />
                </Style>
                <Style x:Key="TradeRowStyle"
                       TargetType="dxg:RowControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=IsSelected}"
                                     Value="True">
                            <Setter Property="Background" Value="#1d3c52" />
                        </DataTrigger>
                        <Trigger Property="dxg:GridViewBase.IsFocusedRow" Value="True">
                            <Setter Property="Background" Value="#1d3c52" />
                        </Trigger>
                        <Trigger Property="dxg:GridViewBase.IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#39393A" />
                        </Trigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Path=IsSelected}" Value="True" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#3E596B" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </dxg:GridControl.Resources>
            <dxg:GridControl.View>
                <dxg:TableView x:Name="UpdatesTable"
                               AllowEditing="False"
                               AllowGrouping="False"
                               AutoWidth="True"
                               FadeSelectionOnLostFocus="False"
                               RowStyle="{StaticResource TradeRowStyle}"
                               ShowGridMenu="TableView_ShowGridMenu"
                               ShowGroupPanel="False"
                               ShowIndicator="True"
                               VerticalScrollbarVisibility="Auto">
                    <dxg:TableView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Height="25"
                                      Command="{Binding ShowColumnChooserCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Column Chooser">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'SvgImages/Dashboards/ArrangeInRows.svg'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ClearColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Hide All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Hide_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowAllColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show All Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Actions/Show_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Height="25"
                                      Command="{Binding ShowDefaultColumnsCommand}"
                                      CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Header="Show Default Columns">
                                <MenuItem.Icon>
                                    <Image Width="15"
                                           Height="15"
                                           Source="{dx:DXImage 'Images/Function Library/RecentlyUse_16x16.png'}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </dxg:TableView.ContextMenu>
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridColumn FieldName="Timestamp"
                            Header="Time"
                            ReadOnly="True"
                            Visible="True">
                <dxg:GridColumn.EditSettings>
                    <dxe:TextEditSettings HorizontalContentAlignment="Right"
                                          Mask="hh:mm:ss.ffff"
                                          MaskType="DateTime"
                                          MaskUseAsDisplayFormat="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.TestValue, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="TestValue"
                            ReadOnly="True"
                            Visible="{Binding ShowTestValue}">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:TextEdit Name="PART_Editor"
                                      Margin="2,0,0,0"
                                      VerticalAlignment="Center"
                                      HorizontalContentAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn Binding="{Binding Path=RowData.Row.AdjTheo, Converter={StaticResource DoubleFormatter}, ConverterParameter={x:Static helper:DoubleFormat.N2}}"
                            FieldName="AdjTheo"
                            ReadOnly="True"
                            Visible="{Binding ShowAdjTheo}">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <dxe:TextEdit Name="PART_Editor"
                                      Margin="2,0,0,0"
                                      VerticalAlignment="Center"
                                      HorizontalContentAlignment="Right" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
