<UserControl x:Class="ZeroPlus.Oms.Ui.Views.AutoCancelSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DataContext="{d:DesignInstance Type=ViewModels:AutoCancelSettingsViewModel}"
             d:Height="auto"
             d:Width="auto"
             mc:Ignorable="d">

    <UserControl.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToColorConverterRed">
            <dxmvvm:BooleanToObjectConverter.TrueValue>
                #F88F8F
            </dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>
                #2D2D30
            </dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
    </UserControl.Resources>
    <dxlc:GroupBox Name="AutoCancelSettingsSubModule"
                   Margin="5,0,0,0"
                   Padding="10,5">

        <dxlc:GroupBox.Header>
            <Grid Height="22">
                <Label Padding="0"
                       VerticalAlignment="Center"
                       Content="Auto Cancel"
                       FontWeight="Bold"
                       Foreground="#AFAFB0"
                       IsHitTestVisible="False" />
            </Grid>
        </dxlc:GroupBox.Header>

        <Grid Margin="0,5,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0"
                        Grid.Column="0"
                        Background="{DXBinding '@e(CancelWithEdgeToTheoCheckEdit).IsChecked',
                                               Converter={StaticResource BooleanToColorConverterRed}}">
                <dxe:CheckEdit x:Name="CancelWithEdgeToTheoCheckEdit"
                               IsChecked="{Binding AutoCancelConfig.CancelWithEdgeToTheoEnabled}"
                               Visibility="Collapsed" />
                <dx:SimpleButton Width="65"
                                 Margin="5,5,5,2"
                                 Background="{DXBinding '@e(CancelWithEdgeToTheoCheckEdit).IsChecked',
                                                        Converter={StaticResource BooleanToColorConverterRed}}"
                                 Command="{DXCommand '@e(CancelWithEdgeToTheoCheckEdit).IsChecked = !@e(CancelWithEdgeToTheoCheckEdit).IsChecked'}"
                                 Content="Theo"
                                 Style="{StaticResource CancelButtonStyle}" />

                <dxe:SpinEdit Width="65"
                              Margin="5,0,5,5"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="{DXBinding '@e(CancelWithEdgeToTheoCheckEdit).IsChecked',
                                                     Converter={StaticResource BooleanToColorConverterRed}}"
                              EditValue="{Binding AutoCancelConfig.CancelWithTheoEdge, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Double}"
                              Increment="0.01"
                              Mask="####0.00#"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Background="{DXBinding '@e(CancelWithEdgeToAdjTheoCheckEdit).IsChecked',
                                               Converter={StaticResource BooleanToColorConverterRed}}">
                <dxe:CheckEdit x:Name="CancelWithEdgeToAdjTheoCheckEdit"
                               IsChecked="{Binding AutoCancelConfig.CancelWithEdgeToAdjTheoEnabled}"
                               Visibility="Collapsed" />
                <dx:SimpleButton Width="65"
                                 Margin="5,5,5,2"
                                 Padding="0,3"
                                 Background="{DXBinding '@e(CancelWithEdgeToAdjTheoCheckEdit).IsChecked',
                                                        Converter={StaticResource BooleanToColorConverterRed}}"
                                 Command="{DXCommand '@e(CancelWithEdgeToAdjTheoCheckEdit).IsChecked = !@e(CancelWithEdgeToAdjTheoCheckEdit).IsChecked'}"
                                 Content="Adj Theo"
                                 Style="{StaticResource CancelButtonStyle}" />

                <dxe:SpinEdit Width="65"
                              Margin="5,0,5,5"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="{DXBinding '@e(CancelWithEdgeToAdjTheoCheckEdit).IsChecked',
                                                     Converter={StaticResource BooleanToColorConverterRed}}"
                              EditValue="{Binding AutoCancelConfig.CancelWithAdjTheoEdge, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Double}"
                              Increment="0.01"
                              Mask="####0.00#"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="2"
                        Background="{DXBinding '@e(CancelWithUnderlyingPxCheckEdit).IsChecked',
                                               Converter={StaticResource BooleanToColorConverterRed}}">
                <dxe:CheckEdit x:Name="CancelWithUnderlyingPxCheckEdit"
                               IsChecked="{Binding AutoCancelConfig.CancelWithUnderlyingPxEnabled}"
                               Visibility="Collapsed" />
                <dx:SimpleButton Width="65"
                                 Margin="5,5,5,2"
                                 Background="{DXBinding '@e(CancelWithUnderlyingPxCheckEdit).IsChecked',
                                                        Converter={StaticResource BooleanToColorConverterRed}}"
                                 Command="{DXCommand '@e(CancelWithUnderlyingPxCheckEdit).IsChecked = !@e(CancelWithUnderlyingPxCheckEdit).IsChecked'}"
                                 Content="Under"
                                 Style="{StaticResource CancelButtonStyle}" />

                <dxe:SpinEdit Width="65"
                              Margin="5,0,5,5"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="{DXBinding '@e(CancelWithUnderlyingPxCheckEdit).IsChecked',
                                                     Converter={StaticResource BooleanToColorConverterRed}}"
                              EditValue="{Binding AutoCancelConfig.CancelWithUnderlyingPx, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Double}"
                              Increment="0.01"
                              Mask="####0.00#"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="3"
                        Background="{DXBinding '@e(CancelWithUnderlyingDeltaPxCheckEdit).IsChecked',
                                               Converter={StaticResource BooleanToColorConverterRed}}">
                <dxe:CheckEdit x:Name="CancelWithUnderlyingDeltaPxCheckEdit"
                               IsChecked="{Binding AutoCancelConfig.CancelWithUnderlyingDeltaPxEnabled}"
                               Visibility="Collapsed" />
                <dx:SimpleButton Width="65"
                                 Margin="5,5,5,2"
                                 Padding="0,4.3"
                                 Background="{DXBinding '@e(CancelWithUnderlyingDeltaPxCheckEdit).IsChecked',
                                                        Converter={StaticResource BooleanToColorConverterRed}}"
                                 Command="{DXCommand '@e(CancelWithUnderlyingDeltaPxCheckEdit).IsChecked = !@e(CancelWithUnderlyingDeltaPxCheckEdit).IsChecked'}"
                                 Content="Under X Delta"
                                 FontSize="10"
                                 Style="{StaticResource CancelButtonStyle}" />

                <dxe:SpinEdit Width="65"
                              Margin="5,0,5,5"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="{DXBinding '@e(CancelWithUnderlyingDeltaPxCheckEdit).IsChecked',
                                                     Converter={StaticResource BooleanToColorConverterRed}}"
                              EditValue="{Binding AutoCancelConfig.CancelWithUnderlyingDeltaPx, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Double}"
                              Increment="0.01"
                              Mask="####0.00#"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="4"
                        Background="{DXBinding '@e(CancelWithEdgeToMidCheckEdit).IsChecked',
                                               Converter={StaticResource BooleanToColorConverterRed}}">

                <dxe:CheckEdit x:Name="CancelWithEdgeToMidCheckEdit"
                               IsChecked="{Binding AutoCancelConfig.CancelWithEdgeToMidEnabled}"
                               Visibility="Collapsed" />

                <dx:SimpleButton Width="65"
                                 Margin="5,5,5,2"
                                 Background="{DXBinding '@e(CancelWithEdgeToMidCheckEdit).IsChecked',
                                                        Converter={StaticResource BooleanToColorConverterRed}}"
                                 Command="{DXCommand '@e(CancelWithEdgeToMidCheckEdit).IsChecked = !@e(CancelWithEdgeToMidCheckEdit).IsChecked'}"
                                 Content="Mid"
                                 Style="{StaticResource CancelButtonStyle}" />

                <dxe:SpinEdit Width="65"
                              Margin="5,0,5,5"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="{DXBinding '@e(CancelWithEdgeToMidCheckEdit).IsChecked',
                                                     Converter={StaticResource BooleanToColorConverterRed}}"
                              EditValue="{Binding AutoCancelConfig.CancelWithMidEdge, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Double}"
                              Increment="0.01"
                              Mask="####0.00#"
                              MaskUseAsDisplayFormat="True"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="5"
                        Background="{DXBinding '@e(CancelWithTimerCheckEdit).IsChecked',
                                               Converter={StaticResource BooleanToColorConverterRed}}">

                <dxe:CheckEdit x:Name="CancelWithTimerCheckEdit"
                               IsChecked="{Binding AutoCancelConfig.CancelWithTimerEnabled}"
                               Visibility="Collapsed" />

                <dx:SimpleButton Width="65"
                                 Margin="5,5,5,2"
                                 Background="{DXBinding '@e(CancelWithTimerCheckEdit).IsChecked',
                                                        Converter={StaticResource BooleanToColorConverterRed}}"
                                 Command="{DXCommand '@e(CancelWithTimerCheckEdit).IsChecked = !@e(CancelWithTimerCheckEdit).IsChecked'}"
                                 Content="Timer"
                                 Style="{StaticResource CancelButtonStyle}" />

                <dxe:SpinEdit Width="65"
                              Margin="5,0,5,5"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              Background="{DXBinding '@e(CancelWithTimerCheckEdit).IsChecked',
                                                     Converter={StaticResource BooleanToColorConverterRed}}"
                              EditValue="{Binding AutoCancelConfig.CancelWithTimer, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                              EditValueType="{x:Type sys:Double}"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True" />
            </StackPanel>
            <dxe:CheckEdit Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Content="Resubmit After Cancel"
                           IsChecked="{Binding ResubmitAfterCancel}" />

            <dxe:CheckEdit Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="6"
                           Margin="5,0,0,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Content="Use Hedge Underlying"
                           IsChecked="{Binding UseHedgeUnderlyingForAutoCancel}" />

            <dxe:CheckEdit Grid.Row="1"
                           Grid.Column="4"
                           Grid.ColumnSpan="2"
                           Margin="5,0,0,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Content="Cancel On Close"
                           IsChecked="{Binding CancelOnClose}" />

        </Grid>
    </dxlc:GroupBox>
</UserControl>