<UserControl x:Class="ZeroPlus.Oms.Ui.Views.LooperSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
             d:DataContext="{d:DesignInstance Type=ViewModels:AutomationSettingsViewModel}"
             d:Height="auto"
             d:Width="auto"
             mc:Ignorable="d">

    <UserControl.Resources>
        <dxmvvm:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helper:NullToCheckGlyphConverter x:Key="NullToCheckGlyphConverter" />
        <helper:BoolToCheckGlyphConverter x:Key="BoolToCheckGlyphConverter" />
        <helper:SizeUpTypeToVisibilityConverter x:Key="SizeUpTypeToVisibilityConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="HighlightToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>#1a4c35</dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>Transparent</dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToExpandCollapseConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>3</dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>4</dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
    </UserControl.Resources>



    <dxmvvm:Interaction.Behaviors>
        <services:OmsMessageBoxService />
        <dxmvvm:WindowService x:Name="Advanced">
            <dxmvvm:WindowService.WindowStyle>
                <Style TargetType="dx:ThemedWindow">
                    <Setter Property="Width" Value="600" />
                    <Setter Property="Height" Value="900" />
                    <Setter Property="MinHeight" Value="200" />
                    <Setter Property="MinWidth" Value="500" />
                </Style>
            </dxmvvm:WindowService.WindowStyle>
            <dxmvvm:WindowService.ViewTemplate>
                <DataTemplate x:Name="Editor">
                    <views:AdvancedLooperView DataContext="{Binding}" />
                </DataTemplate>
            </dxmvvm:WindowService.ViewTemplate>
        </dxmvvm:WindowService>
    </dxmvvm:Interaction.Behaviors>

    <dxlc:GroupBox Name="LooperSettingsSubModule"
                   Grid.Row="0"
                   Margin="5,0,0,0"
                   Padding="10,5"
                   IsEnabled="{Binding AutomationConfig.AutoLegEnabled, Converter={StaticResource BooleanNegationConverter}}">

        <dxlc:GroupBox.Header>
            <Grid Height="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0"
                       Padding="0"
                       VerticalAlignment="Center"
                       Content="Looper"
                       FontWeight="Bold"
                       Foreground="#AFAFB0"
                       IsHitTestVisible="False" />

                <dx:DXImage Grid.Column="1"
                            Height="20"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Right"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="{dx:DXImage 'SvgImages/Dashboards/InsertBubbleMap.svg'}"
                            ToolTip="Underlying Mapping In Use"
                            Visibility="{Binding UnderlyingToAutomationConfigModelLookup, Converter={StaticResource NullToVisibilityConverter}}" />

                <dxe:ToggleSwitch Grid.Column="4"
                                  Margin="5,0"
                                  HorizontalAlignment="Center"
                                  CheckedStateContent="Looper"
                                  ContentPlacement="Inside"
                                  FontWeight="DemiBold"
                                  Foreground="#AFAFB0"
                                  IsChecked="{Binding AutomationConfig.CloseOrderMode}"
                                  IsThreeState="True"
                                  ToggleSwitchWidth="85"
                                  UncheckedStateContent="Auto Close" />

                <dx:SimpleButton Grid.Column="5"
                                 Margin="4,0,0,0"
                                 Padding="2,0"
                                 BorderBrush="#7ac142"
                                 Command="{Binding ShowLoopAdvancedConfigsCommand}"
                                 Content="Adv"
                                 CornerRadius="2"
                                 Foreground="#7ac142"
                                 IsEnabled="{Binding AutomationConfig.GoFishAutoCloseEnabled}" />

            </Grid>
        </dxlc:GroupBox.Header>

        <Grid Margin="0,5,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0"
                    Grid.Column="0"
                    Margin="5,0,0,0"
                    Padding="2,1"
                    d:Background="#1a4c35"
                    Background="{Binding OmsCore.Config.BasketAutomationHighlightEdge, Converter={StaticResource HighlightToColorConverter}}"
                    CornerRadius="2"
                    IsEnabled="{Binding AutomationConfig.GoFishAutoCloseEnabled}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <Label Width="55"
                           VerticalAlignment="Center"
                           Content="Edge" />

                    <dxe:ComboBoxEdit Grid.Column="1"
                                      Width="75"
                                      Margin="0,0,0,0"
                                      HorizontalAlignment="Left"
                                      ApplyItemTemplateToSelectedItem="True"
                                      Background="Transparent"
                                      EditValue="{Binding AutomationConfig.LoopCloseEdgeType, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding LoopCloseEdgeTypes}">
                        <dxmvvm:Interaction.Behaviors />
                    </dxe:ComboBoxEdit>

                    <dxe:SpinEdit Grid.Column="2"
                                  Width="70"
                                  Margin="5,0,0,0"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  EditValue="{Binding AutomationConfig.ContraFishEdge, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  Mask="####0.00#"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="{Binding AutomationConfig.CloseEdgeMinValue}"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  Visibility="{Binding AutomationConfig.LoopCloseEdgeType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Static'}">
                        <dxmvvm:Interaction.Behaviors />
                    </dxe:SpinEdit>

                    <dx:SimpleButton Grid.Column="2"
                                     Width="70"
                                     Margin="5,0,0,0"
                                     Padding="0,0,7,0"
                                     HorizontalContentAlignment="Right"
                                     Background="Transparent"
                                     Command="{Binding ShowLoopCloseEdgeConfigPanelCommand}"
                                     Glyph="{Binding AutomationConfig.DynamicEdgeModel, Converter={StaticResource NullToCheckGlyphConverter}}"
                                     GlyphWidth="15"
                                     ToolTip="{Binding AutomationConfig.DynamicEdgeModel.Title}"
                                     Visibility="{Binding AutomationConfig.LoopCloseEdgeType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Dynamic'}">
                        <TextBlock Width="60"
                                   HorizontalAlignment="Stretch"
                                   Text="{Binding AutomationConfig.DynamicEdgeModel.Title, StringFormat='{}{0}', TargetNullValue='Config'}" />
                    </dx:SimpleButton>
                </Grid>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="2"
                    Margin="5,0,0,0"
                    Padding="2,1"
                    d:Visibility="Hidden"
                    Background="{Binding OmsCore.Config.BasketAutomationHighlightMinEdge, Converter={StaticResource HighlightToColorConverter}}"
                    CornerRadius="2"
                    Visibility="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <Label Width="65"
                           VerticalAlignment="Center"
                           Content="Min Edge" />

                    <dxe:SpinEdit Width="72"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  EditValue="{Binding AutomationConfig.LoopMinEdge, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  Mask="####0.00#"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True">
                        <dxmvvm:Interaction.Behaviors />
                    </dxe:SpinEdit>
                </StackPanel>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="2"
                    Margin="5,0,0,0"
                    Padding="2,1"
                    CornerRadius="2"
                    IsEnabled="{Binding AutomationConfig.GoFishAutoCloseEnabled}"
                    Visibility="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                <StackPanel Orientation="Horizontal">
                    <Label Width="40"
                           VerticalAlignment="Center"
                           Content="Mode" />

                    <dxe:ComboBoxEdit Width="97"
                                      ApplyItemTemplateToSelectedItem="True"
                                      Background="Transparent"
                                      EditValue="{Binding AutomationConfig.ClosingMode}"
                                      IsSynchronizedWithCurrentItem="True"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding ClosingTypes}">
                        <dxe:ComboBoxEdit.ItemTemplate>
                            <DataTemplate>
                                <Label Padding="0,0.5"
                                       HorizontalAlignment="Center"
                                       Content="{Binding Converter={StaticResource DisplayTextCamelCaseConverter}}"
                                       FontSize="11" />
                            </DataTemplate>
                        </dxe:ComboBoxEdit.ItemTemplate>
                    </dxe:ComboBoxEdit>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1"
                  Grid.Column="0"
                  Margin="5,2,0,0"
                  d:Visibility="Hidden"
                  IsEnabled="{Binding AutomationConfig.GoFishAutoCloseEnabled}"
                  Visibility="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanToVisibilityInverseConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <Label Width="55"
                       VerticalAlignment="Center"
                       Content="Interval" />

                <dxe:ComboBoxEdit Grid.Column="1"
                                  Width="75"
                                  Margin="0,0,0,0"
                                  HorizontalAlignment="Left"
                                  ApplyItemTemplateToSelectedItem="True"
                                  EditValue="{Binding AutomationConfig.LoopIntervalType, UpdateSourceTrigger=PropertyChanged}"
                                  IsTextEditable="False"
                                  ItemsSource="{Binding LoopIntervalTypes}">
                </dxe:ComboBoxEdit>

                <dxe:SpinEdit Grid.Column="2"
                              Width="70"
                              Margin="5,0,0,0"
                              HorizontalContentAlignment="Right"
                              AllowSpinOnMouseWheel="True"
                              EditValue="{Binding AutomationConfig.ContraFishInterval, UpdateSourceTrigger=PropertyChanged}"
                              EditValueType="{x:Type sys:Int32}"
                              Increment="1"
                              MinValue="0"
                              PreviewMouseUp="SelectAll"
                              SelectAllOnGotFocus="True"
                              SelectAllOnMouseUp="True">
                </dxe:SpinEdit>

                <dx:SimpleButton Grid.Column="2"
                                 Width="70"
                                 Margin="5,0,0,0"
                                 Padding="0,0,7,0"
                                 HorizontalContentAlignment="Right"
                                 Command="{Binding ShowDynamicIntervalConfigPanelCommand}"
                                 Content="Config"
                                 Glyph="{Binding AutomationConfig.DynamicIntervalModel, Converter={StaticResource NullToCheckGlyphConverter}}"
                                 GlyphWidth="15"
                                 ToolTip="{Binding AutomationConfig.DynamicIntervalModel.Title}"
                                 Visibility="{Binding AutomationConfig.LoopIntervalType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Dynamic'}" />
            </Grid>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="5,2,0,0"
                    Padding="2,1"
                    Background="{Binding OmsCore.Config.BasketAutomationHighlightSizeup, Converter={StaticResource HighlightToColorConverter}}"
                    CornerRadius="2"
                    Visibility="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                           Width="55"
                           VerticalAlignment="Center"
                           Content="Size-Up" />

                    <dxe:ComboBoxEdit Grid.Column="1"
                                      Width="75"
                                      Margin="0,0,0,0"
                                      HorizontalAlignment="Left"
                                      ApplyItemTemplateToSelectedItem="True"
                                      Background="Transparent"
                                      EditValue="{Binding AutomationConfig.LoopSizeupType, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding LoopSizeupTypes}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SizeUpConfigChangedCommand}"
                                                   EventName="EditValueChanged" />

                        </dxmvvm:Interaction.Behaviors>
                    </dxe:ComboBoxEdit>

                    <dxe:SpinEdit Grid.Column="2"
                                  Width="70"
                                  Margin="5,0,0,0"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  EditValue="{Binding AutomationConfig.LoopSizeupQty, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  Visibility="{Binding AutomationConfig.LoopSizeupType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Static'}">
                        <dxmvvm:Interaction.Behaviors />
                    </dxe:SpinEdit>

                    <dx:SimpleButton Grid.Column="2"
                                     Width="70"
                                     Margin="5,0,0,0"
                                     Padding="0,0,7,0"
                                     HorizontalContentAlignment="Right"
                                     Background="Transparent"
                                     Command="{Binding ShowSizeupConfigPanelCommand}"
                                     Glyph="{Binding SizeupConfig, Converter={StaticResource NullToCheckGlyphConverter}}"
                                     GlyphWidth="15"
                                     ToolTip="{Binding SizeupConfig.Title}"
                                     Visibility="{Binding AutomationConfig.LoopSizeupType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Dynamic'}">
                        <TextBlock Width="60"
                                   HorizontalAlignment="Stretch"
                                   Text="{Binding SizeupConfig.Title, StringFormat='{}{0}', TargetNullValue='Config'}" />
                    </dx:SimpleButton>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="2"
                    Margin="5,2,0,0"
                    Padding="2,1"
                    Background="{Binding OmsCore.Config.BasketAutomationHighlightMaxLoss, Converter={StaticResource HighlightToColorConverter}}"
                    CornerRadius="2"
                    IsEnabled="{Binding AutomationConfig.GoFishAutoCloseEnabled}">
                <StackPanel Orientation="Horizontal">

                    <Label Width="65"
                           VerticalAlignment="Center"
                           Content="Max Loss" />

                    <dxe:SpinEdit Width="72"
                                  Margin="0,0,0,0"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  EditValue="{Binding AutomationConfig.LoopMaxLoss, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  Mask="####0.00#"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True">
                        <dxmvvm:Interaction.Behaviors />
                    </dxe:SpinEdit>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="0"
                    Margin="5,2,0,0"
                    Padding="2,1"
                    Background="{Binding OmsCore.Config.BasketAutomationHighlightPxInc, Converter={StaticResource HighlightToColorConverter}}"
                    CornerRadius="2"
                    IsEnabled="{Binding AutomationConfig.GoFishAutoCloseEnabled}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <Label Width="55"
                           VerticalAlignment="Center"
                           Content="Px Inc" />

                    <dxe:ComboBoxEdit Grid.Column="1"
                                      Width="75"
                                      Margin="0,0,0,0"
                                      HorizontalAlignment="Left"
                                      ApplyItemTemplateToSelectedItem="True"
                                      Background="Transparent"
                                      EditValue="{Binding AutomationConfig.LoopIncrementType, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding LoopIncrementTypes}" />

                    <dxe:SpinEdit Grid.Column="2"
                                  Width="70"
                                  Margin="5,0,0,0"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  EditValue="{Binding AutomationConfig.ContraFishPriceIncrement, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  Visibility="{Binding AutomationConfig.LoopIncrementType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Static'}">
                        <dxmvvm:Interaction.Behaviors />
                    </dxe:SpinEdit>

                    <dx:SimpleButton Grid.Column="2"
                                     Width="70"
                                     Margin="5,0,0,0"
                                     Padding="0,0,7,0"
                                     HorizontalContentAlignment="Right"
                                     Background="Transparent"
                                     Command="{Binding ShowLoopIncrementConfigPanelCommand}"
                                     Glyph="{Binding AutomationConfig.LoopIncrementConfigModel, Converter={StaticResource NullToCheckGlyphConverter}}"
                                     GlyphWidth="15"
                                     ToolTip="{Binding AutomationConfig.LoopIncrementConfigModel.Title}"
                                     Visibility="{Binding AutomationConfig.LoopIncrementType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Dynamic'}">
                        <TextBlock Width="60"
                                   HorizontalAlignment="Stretch"
                                   Text="{Binding AutomationConfig.LoopIncrementConfigModel.Title, StringFormat='{}{0}', TargetNullValue='Config'}" />
                    </dx:SimpleButton>
                </Grid>
            </Border>

            <dxe:CheckEdit Grid.Row="2"
                           Grid.Column="2"
                           Margin="5,2,0,0"
                           HorizontalAlignment="Left"
                           d:Visibility="Hidden"
                           Content="Leave Resting"
                           EditValue="{Binding AutomationConfig.LeaveAutoCloseResting}"
                           IsEnabled="{Binding AutomationConfig.GoFishAutoCloseEnabled}"
                           Visibility="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanToVisibilityInverseConverter}}" />

            <Border Grid.Row="2"
                    Grid.Column="2"
                    Margin="5,2,0,0"
                    Padding="2,1"
                    Background="{Binding OmsCore.Config.BasketAutomationHighlightMaxLoop, Converter={StaticResource HighlightToColorConverter}}"
                    CornerRadius="2"
                    Visibility="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">

                    <Label Width="65"
                           VerticalAlignment="Center"
                           Content="Max Loop" />

                    <dxe:SpinEdit Width="72"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  Background="Transparent"
                                  EditValue="{Binding AutomationConfig.MaxLoopCount, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="0.01"
                                  Mask="N0"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True">
                        <dxmvvm:Interaction.Behaviors />
                    </dxe:SpinEdit>
                </StackPanel>
            </Border>
        </Grid>
    </dxlc:GroupBox>

</UserControl>