<UserControl x:Class="ZeroPlus.Oms.Ui.Views.AutoHedgeSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:views="clr-namespace:ZeroPlus.Oms.Ui.Views"
             d:DataContext="{d:DesignInstance Type=ViewModels:AutomationSettingsViewModel}"
             d:Height="auto"
             d:Width="auto"
             mc:Ignorable="d">

    <UserControl.Resources>
        <dxmvvm:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:CamelCaseFormatter x:Key="DisplayTextCamelCaseConverter" />
        <helper:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helper:NullToCheckGlyphConverter x:Key="NullToCheckGlyphConverter" />
        <helper:BoolToCheckGlyphConverter x:Key="BoolToCheckGlyphConverter" />
        <helper:SizeUpTypeToVisibilityConverter x:Key="SizeUpTypeToVisibilityConverter" />
        <dxmvvm:BooleanToObjectConverter x:Key="HighlightToColorConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>#1a4c35</dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>Transparent</dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
        <dxmvvm:BooleanToObjectConverter x:Key="BooleanToExpandCollapseConverter">
            <dxmvvm:BooleanToObjectConverter.TrueValue>3</dxmvvm:BooleanToObjectConverter.TrueValue>
            <dxmvvm:BooleanToObjectConverter.FalseValue>4</dxmvvm:BooleanToObjectConverter.FalseValue>
        </dxmvvm:BooleanToObjectConverter>
    </UserControl.Resources>

    <dxlc:GroupBox Name="AutoHedgeSettingsSubModule"
                   Grid.Row="2"
                   Margin="5,0,0,0"
                   Padding="10,5">

        <dxlc:GroupBox.Header>
            <Grid Height="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <dx:DXImage Grid.Column="0"
                            Height="15"
                            HorizontalAlignment="Right"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="{dx:DXImage SvgImages/Icon Builder/Actions_Home.svg}" />

                <Label Grid.Column="1"
                       Margin="2,0"
                       Padding="0"
                       VerticalAlignment="Center"
                       Content="Hedge House"
                       FontWeight="Bold"
                       Foreground="#AFAFB0"
                       IsHitTestVisible="False" />

                <dxe:ToggleSwitch Grid.Column="2"
                                  Margin="0,0,5,0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  AnimationMode="Always"
                                  CheckedStateContent="Enabled"
                                  ContentPlacement="Inside"
                                  FontSize="11"
                                  IsChecked="{Binding AutomationConfig.AutoHedgeOnClose}"
                                  ToggleSwitchHeight="16"
                                  ToggleSwitchWidth="70"
                                  UncheckedStateContent="Disabled" />
            </Grid>
        </dxlc:GroupBox.Header>

        <Grid Margin="0,5,0,0"
              IsEnabled="{Binding AutomationConfig.AutoHedgeOnClose}">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0"
                   Grid.Column="0"
                   Margin="0,2,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="Minimum Edge"
                   IsEnabled="{Binding AutomationConfig.AutoHedgeOnClose}" />

            <dxe:SpinEdit Grid.Row="0"
                          Grid.Column="1"
                          Margin="5,2,0,0"
                          HorizontalContentAlignment="Right"
                          AllowSpinOnMouseWheel="True"
                          EditValue="{Binding AutomationConfig.MinHedgeHouseEdge, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                          EditValueType="{x:Type sys:Double}"
                          Increment="0.01"
                          IsEnabled="{Binding AutomationConfig.AutoHedgeOnClose}"
                          PreviewMouseUp="SelectAll"
                          SelectAllOnGotFocus="True"
                          SelectAllOnMouseUp="True" />

            <dxe:CheckEdit Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,2,0,0"
                           HorizontalAlignment="Left"
                           Content="Size Only"
                           EditValue="{Binding AutomationConfig.AutoHedgeOnCloseSizeOnly}"
                           IsEnabled="{Binding AutomationConfig.AutoHedgeOnClose}" />

            <dxe:CheckEdit Grid.Row="1"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           Content="Open Ticket"
                           EditValue="{Binding AutomationConfig.AutoHedgeOpenTicket}"
                           IsEnabled="{Binding AutomationConfig.AutoHedgeOnClose}" />

            <dxe:CheckEdit Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,2,0,0"
                           Content="Hedge Partial"
                           EditValue="{Binding AutomationConfig.AutoHedgePartial}"
                           IsEnabled="{Binding AutomationConfig.AutoHedgeOnClose}" />

            <dxe:CheckEdit Grid.Row="2"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           Content="On Failure"
                           EditValue="{Binding AutomationConfig.AutoHedgeOnFailure}"
                           IsEnabled="{Binding AutomationConfig.AutoHedgeOnClose}" />
        </Grid>
    </dxlc:GroupBox>

</UserControl>
