<UserControl x:Class="ZeroPlus.Oms.Ui.Views.AdvancedLooperView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.Ui.ViewModels"
             xmlns:behavior="clr-namespace:ZeroPlus.Oms.Ui.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:helper="clr-namespace:ZeroPlus.Oms.Ui.Helper"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:ZeroPlus.Oms.Ui.Services"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DataContext="{d:DesignInstance Type=ViewModels:AutomationSettingsViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helper:DoubleFormatter x:Key="DoubleFormatter" />
        <helper:NullToCheckGlyphConverter x:Key="NullToCheckGlyphConverter" />
        <helper:SizeUpTypeToVisibilityConverter x:Key="SizeUpTypeToVisibilityConverter" />
        <helper:LoopPricingModeToDisplayTextConverter x:Key="LoopPricingModeToDisplayTextConverter" />
    </UserControl.Resources>
    <dx:DXTabControl>
        <dx:DXTabItem Header="Loop">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="5" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="5" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="5" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Pricing Mode" />

                    <dxe:ComboBoxEdit Grid.Row="1"
                                      Grid.Column="2"
                                      Grid.ColumnSpan="2"
                                      Margin="5,2,0,0"
                                      ApplyItemTemplateToSelectedItem="True"
                                      EditValue="{Binding AutomationConfig.LoopPricingMode}"
                                      IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding LoopPricingModes}">
                        <dxe:ComboBoxEdit.ItemTemplate>
                            <DataTemplate>
                                <Label Padding="0,0.5"
                                       Content="{Binding Converter={StaticResource LoopPricingModeToDisplayTextConverter}}"
                                       FontSize="11" />
                            </DataTemplate>
                        </dxe:ComboBoxEdit.ItemTemplate>
                    </dxe:ComboBoxEdit>

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Under Mapping" />
                    <Grid Grid.Row="2"
                          Grid.Column="2"
                          Grid.ColumnSpan="2"
                          Margin="5,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <dx:SimpleButton Grid.Column="0"
                                         Height="22"
                                         Padding="0"
                                         Command="{Binding ConfigAutomationConfigCommand}"
                                         Content="Config"
                                         Glyph="{dx:DXImage SvgImages/Actions/NewTableStyle.svg}"
                                         GlyphHeight="15"
                                         IsEnabled="{Binding AutomationConfig.LoopingEnabled}" />
                        <dx:SimpleButton Grid.Column="1"
                                         Width="22"
                                         Height="22"
                                         Margin="2,0,0,0"
                                         Command="{Binding ClearAutomationConfigCommand}"
                                         Glyph="{dx:DXImage 'SvgImages/Snap/ClearTableStyle.svg'}"
                                         GlyphHeight="15"
                                         IsEnabled="{Binding AutomationConfig.LoopingEnabled}" />
                    </Grid>
                    <Label Grid.Row="3"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Interval" />

                    <dxe:ComboBoxEdit Grid.Row="3"
                                      Grid.Column="2"
                                      Width="70"
                                      Margin="5,2,0,0"
                                      HorizontalAlignment="Left"
                                      ApplyItemTemplateToSelectedItem="True"
                                      EditValue="{Binding AutomationConfig.LoopIntervalType, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                      IsTextEditable="False"
                                      ItemsSource="{Binding LoopIntervalTypes}" />

                    <dxe:SpinEdit Grid.Row="3"
                                  Grid.Column="3"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.ContraFishInterval, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dx:SimpleButton Grid.Row="3"
                                     Grid.Column="3"
                                     Width="70"
                                     Margin="5,2,0,0"
                                     Padding="0,0,7,0"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Right"
                                     Command="{Binding ShowDynamicIntervalConfigPanelCommand}"
                                     Glyph="{Binding AutomationConfig.DynamicIntervalModel, Converter={StaticResource NullToCheckGlyphConverter}}"
                                     GlyphWidth="15"
                                     IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                     ToolTip="{Binding AutomationConfig.DynamicIntervalModel.Title}"
                                     Visibility="{Binding AutomationConfig.LoopIntervalType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Dynamic'}">
                        <TextBlock Width="60"
                                   HorizontalAlignment="Stretch"
                                   Text="{Binding AutomationConfig.DynamicIntervalModel.Title, StringFormat='{}{0}', TargetNullValue='Config'}" />
                    </dx:SimpleButton>

                    <Label Grid.Row="4"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Loop Interval" />

                    <dxe:SpinEdit Grid.Row="4"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.LoopInterval, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="5"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Loop Before Size-Up" />

                    <dxe:SpinEdit Grid.Row="5"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.LoopCountBeforeSizeup, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="6"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Resubmit All" />

                    <dxe:SpinEdit Grid.Row="6"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.AttemptResubmit, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="7"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Resubmit Last" />

                    <dxe:SpinEdit Grid.Row="7"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.LoopResubmit, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="8"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Adj Loop Resubmit" />

                    <dxe:SpinEdit Grid.Row="8"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.MaxBelowEdgeResubmit, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="9"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Partial Resubmit" />

                    <dxe:SpinEdit Grid.Row="9"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.AutomationPartialResubmitCount, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="10"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Partial Fill (%)" />

                    <dxe:SpinEdit Grid.Row="10"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.AutomationRequiredPartialFillPercentage, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment=".01"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  Mask="N2"
                                  MaskUseAsDisplayFormat="True"
                                  MaxValue="1"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="11"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Edge Tighten (%)" />

                    <dxe:SpinEdit Grid.Row="11"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.LastEdgeTightenPercent, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment=".01"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  Mask="N2"
                                  MaskUseAsDisplayFormat="True"
                                  MaxValue="1"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="12"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           Content="Edge Exp(%)"
                           Visibility="{Binding AutomationConfig.LoopCloseEdgeType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Dynamic'}" />

                    <dxe:SpinEdit Grid.Row="12"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.DynamicEdgeExpansion, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  Mask="N2"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  Visibility="{Binding AutomationConfig.LoopCloseEdgeType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Dynamic'}" />

                    <Label Grid.Row="13"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Size Exp(%)"
                           Visibility="{Binding AutomationConfig.LoopCloseEdgeType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Dynamic'}" />

                    <dxe:SpinEdit Grid.Row="13"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.DynamicSizeExpansion, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                  EditValueType="{x:Type sys:Double}"
                                  Increment="0.01"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                  Mask="N2"
                                  MaskUseAsDisplayFormat="True"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True"
                                  Visibility="{Binding AutomationConfig.LoopCloseEdgeType, Converter={StaticResource SizeUpTypeToVisibilityConverter}, ConverterParameter='Dynamic'}" />

                    <dxe:CheckEdit Grid.Row="18"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="5,2,0,0"
                                   HorizontalAlignment="Left"
                                   Content="Maintain Last Edge"
                                   EditValue="{Binding AutomationConfig.MaintainLastEdge}"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                   Visibility="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <dxe:CheckEdit Grid.Row="19"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="5,2,0,0"
                                   HorizontalAlignment="Left"
                                   Content="Size-Up on Closing"
                                   DockPanel.Dock="Left"
                                   EditValue="{Binding AutomationConfig.SizeUpOnClosingLoop}"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled}" />

                    <dxe:CheckEdit Grid.Row="20"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="5,2,0,0"
                                   Content="Size-Up on Hard Side"
                                   DockPanel.Dock="Right"
                                   EditValue="{Binding AutomationConfig.SizeUpOnHardSideOnly}"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled}" />

                    <dxe:CheckEdit Grid.Row="21"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="3"
                                   Margin="5,2,0,0"
                                   HorizontalAlignment="Left"
                                   Content="Require Adj Edge For Size-Up"
                                   EditValue="{Binding AutomationConfig.RequireAdjEdgeForSizeUp}"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled}" />

                    <dxe:CheckEdit Grid.Row="22"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="5,2,0,0"
                                   HorizontalAlignment="Left"
                                   Content="Adjust out of market prices"
                                   EditValue="{Binding AutomationConfig.AdjustClosingPriceToMarket}"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                   ToolTip="Adjust closing price to market, when price is below bid or above ask." />

                    <dxlc:GroupBox Grid.Row="23"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="4"
                                   Margin="0,5,0,0"
                                   Padding="0"
                                   VerticalAlignment="Top"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled}">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>

                                <dx:DXImage Grid.Column="0"
                                            Height="15"
                                            HorizontalAlignment="Right"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{dx:DXImage 'SvgImages/Find/Find.svg'}" />

                                <Label Grid.Column="1"
                                       Margin="2,0"
                                       Padding="0"
                                       VerticalAlignment="Center"
                                       Content="Free Look"
                                       Foreground="#AFAFB0"
                                       IsHitTestVisible="False" />

                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid IsEnabled="{Binding AutomationConfig.LoopingEnabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="5" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="5" />
                            </Grid.RowDefinitions>

                            <dxe:CheckEdit Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="5,2,0,0"
                                           HorizontalAlignment="Left"
                                           Content="Free Look Last"
                                           EditValue="{Binding AutomationConfig.LoopFreeLook}" />

                            <dxe:CheckEdit Grid.Row="1"
                                           Grid.Column="1"
                                           Margin="5,2,0,0"
                                           HorizontalAlignment="Left"
                                           Content="Free Look All"
                                           EditValue="{Binding AutomationConfig.LoopFreeLookOnAll}" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.FreeLookOnAllIncrement, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <Label Grid.Row="1"
                                   Grid.Column="3"
                                   Margin="5,2,0,0"
                                   Content="Increment" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="4"
                                          Margin="5,2,0,0"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.FreeLookOnAllWalkBackIncrement, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          MaxValue="{Binding AutomationConfig.FreeLookOnAllIncrement}"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:CheckEdit Grid.Row="2"
                                           Grid.Column="1"
                                           Margin="5,2,0,0"
                                           HorizontalAlignment="Left"
                                           Content="Free Look Nickel"
                                           EditValue="{Binding AutomationConfig.LoopFreeLookOnNickelNames}" />

                            <dxe:SpinEdit Grid.Row="2"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.LoopFreeLookOnNickelNamesIncrement, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          IsEnabled="{Binding AutomationConfig.LoopFreeLookOnNickelNames}"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:TextEdit Grid.Row="2"
                                          Grid.Column="3"
                                          Grid.ColumnSpan="2"
                                          Margin="5,2,0,0"
                                          EditValue="{Binding AutomationConfig.LoopFreeLookOnNickelNamesRoute}"
                                          IsEnabled="{Binding AutomationConfig.LoopFreeLookOnNickelNames}"
                                          NullText="Route" />

                            <dxe:CheckEdit Grid.Row="3"
                                           Grid.Column="1"
                                           Margin="5,2,0,0"
                                           HorizontalAlignment="Left"
                                           Content="Free Look Dime"
                                           EditValue="{Binding AutomationConfig.LoopFreeLookOnDimeNames}" />

                            <dxe:SpinEdit Grid.Row="3"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.LoopFreeLookOnDimeNamesIncrement, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          IsEnabled="{Binding AutomationConfig.LoopFreeLookOnDimeNames}"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <dxe:TextEdit Grid.Row="3"
                                          Grid.Column="3"
                                          Grid.ColumnSpan="2"
                                          Margin="5,2,0,0"
                                          EditValue="{Binding AutomationConfig.LoopFreeLookOnDimeNamesRoute}"
                                          IsEnabled="{Binding AutomationConfig.LoopFreeLookOnDimeNames}"
                                          NullText="Route" />

                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Row="24"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="4"
                                   Margin="0,5,0,0"
                                   Padding="0"
                                   VerticalAlignment="Top"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled}">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>

                                <dx:DXImage Grid.Column="0"
                                            Height="15"
                                            HorizontalAlignment="Right"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{dx:DXImage 'SvgImages/RichEdit/InsertPageCount.svg'}" />

                                <Label Grid.Column="1"
                                       Margin="2,0"
                                       Padding="0"
                                       VerticalAlignment="Center"
                                       Content="Manually Close Low Delta"
                                       Foreground="#AFAFB0"
                                       IsHitTestVisible="False" />

                                <dxe:ToggleSwitch Grid.Column="2"
                                                  Margin="10,0,5,0"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  AnimationMode="Always"
                                                  CheckedStateContent="On"
                                                  ContentPlacement="Inside"
                                                  FontSize="11"
                                                  IsChecked="{Binding AutomationConfig.ScratchOnLowDeltaSize}"
                                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled}"
                                                  ToggleSwitchHeight="16"
                                                  ToggleSwitchWidth="50"
                                                  UncheckedStateContent="Off" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid IsEnabled="{Binding AutomationConfig.ScratchOnLowDeltaSize}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="85" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="5" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="5" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Max Delta"
                                   IsEnabled="{Binding AutomationConfig.ScratchOnLowDeltaSize}" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.ScratchOnLowDeltaMax, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment="0.01"
                                          IsEnabled="{Binding AutomationConfig.ScratchOnLowDeltaSize}"
                                          Mask="N3"
                                          MaskUseAsDisplayFormat="True"
                                          MaxValue="1"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Min Size"
                                   IsEnabled="{Binding AutomationConfig.ScratchOnLowDeltaSize}" />

                            <dxe:SpinEdit Grid.Row="2"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.ScratchOnLowDeltaMinSize, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Increment="1"
                                          IsEnabled="{Binding AutomationConfig.ScratchOnLowDeltaSize}"
                                          Mask="N0"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="1"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <Label Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Max Loss"
                                   IsEnabled="{Binding AutomationConfig.ScratchOnLowDeltaSize}" />

                            <dxe:SpinEdit Grid.Row="3"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.ScratchOnLowDeltaMaxLoss, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment=".01"
                                          IsEnabled="{Binding AutomationConfig.ScratchOnLowDeltaSize}"
                                          Mask="N2"
                                          MaskUseAsDisplayFormat="True"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Row="25"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="4"
                                   Margin="0,5,0,0"
                                   Padding="0"
                                   VerticalAlignment="Top"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled}">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>

                                <dx:DXImage Grid.Column="0"
                                            Height="15"
                                            HorizontalAlignment="Right"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{dx:DXImage 'SvgImages/Spreadsheet/MultipleSheet.svg'}" />

                                <Label Grid.Column="1"
                                       Margin="2,0"
                                       Padding="0"
                                       VerticalAlignment="Center"
                                       Content="Dynamic Edge Multiplier"
                                       Foreground="#AFAFB0"
                                       IsHitTestVisible="False" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="85" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="85" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="5" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="5" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Edge Mul" />

                            <dxe:SpinEdit Grid.Row="0"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.EdgeMultiplier, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment=".01"
                                          Mask="N3"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <Label Grid.Row="0"
                                   Grid.Column="3"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Max Loss Mul" />

                            <dxe:SpinEdit Grid.Row="0"
                                          Grid.Column="4"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.MaxLossMultiplier, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Double}"
                                          Increment=".01"
                                          Mask="N3"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </Grid>
                    </dxlc:GroupBox>

                    <dxlc:GroupBox Grid.Row="26"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="4"
                                   Margin="0,5,0,0"
                                   Padding="0"
                                   VerticalAlignment="Top"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled}">
                        <dxlc:GroupBox.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>

                                <dx:DXImage Grid.Column="0"
                                            Height="15"
                                            HorizontalAlignment="Right"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{dx:DXImage 'SvgImages/Icon Builder/Travel_Mountains.svg'}" />

                                <Label Grid.Column="1"
                                       Margin="2,0"
                                       Padding="0"
                                       VerticalAlignment="Center"
                                       Content="Iceberg Closer"
                                       Foreground="#AFAFB0"
                                       IsHitTestVisible="False" />

                                <dxe:ToggleSwitch Grid.Column="2"
                                                  Margin="10,0,5,0"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  AnimationMode="Always"
                                                  CheckedStateContent="On"
                                                  ContentPlacement="Inside"
                                                  FontSize="11"
                                                  IsChecked="{Binding AutomationConfig.IcebergCloserEnabled}"
                                                  ToggleSwitchHeight="16"
                                                  ToggleSwitchWidth="50"
                                                  UncheckedStateContent="Off" />
                            </Grid>
                        </dxlc:GroupBox.Header>

                        <Grid IsEnabled="{Binding AutomationConfig.IcebergCloserEnabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="85" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="5" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="5" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Display Size" />

                            <dxe:SpinEdit Grid.Row="1"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.IcebergDisplaySize, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Increment="1"
                                          Mask="N0"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Total/Min Size" />

                            <dxe:SpinEdit Grid.Row="2"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.IcebergTotalSize, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Increment="1"
                                          Mask="N0"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />

                            <Label Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="5,2,0,0"
                                   VerticalAlignment="Center"
                                   Content="Max Resubmit" />

                            <dxe:SpinEdit Grid.Row="3"
                                          Grid.Column="2"
                                          Width="70"
                                          Margin="5,2,0,0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Right"
                                          AllowSpinOnMouseWheel="True"
                                          EditValue="{Binding AutomationConfig.IcebergMaxResubmit, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleFormatter}}"
                                          EditValueType="{x:Type sys:Int32}"
                                          Increment="1"
                                          Mask="N0"
                                          MaskUseAsDisplayFormat="True"
                                          MinValue="0"
                                          PreviewMouseUp="SelectAll"
                                          SelectAllOnGotFocus="True"
                                          SelectAllOnMouseUp="True" />
                        </Grid>
                    </dxlc:GroupBox>
                </Grid>
            </ScrollViewer>
        </dx:DXTabItem>
        <dx:DXTabItem Header="Auto-Close">
            <GroupBox VerticalAlignment="Top"
                      Header="3-way Close">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="5" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="5" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="5" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Max perms" />

                    <dxe:SpinEdit Grid.Row="1"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.ThreeWayCloseMaxPerms, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Vertical closer max resubmit" />

                    <dxe:SpinEdit Grid.Row="2"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.ThreeWayVerticalResubmit, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <Label Grid.Row="3"
                           Grid.Column="1"
                           Margin="5,2,0,0"
                           VerticalAlignment="Center"
                           Content="Max strike spacing" />

                    <dxe:SpinEdit Grid.Row="3"
                                  Grid.Column="2"
                                  Width="70"
                                  Margin="5,2,0,0"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Right"
                                  AllowSpinOnMouseWheel="True"
                                  EditValue="{Binding AutomationConfig.ThreeWayCloseMaxSpacing, UpdateSourceTrigger=PropertyChanged}"
                                  EditValueType="{x:Type sys:Int32}"
                                  Increment="1"
                                  IsEnabled="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}"
                                  MinValue="0"
                                  PreviewMouseUp="SelectAll"
                                  SelectAllOnGotFocus="True"
                                  SelectAllOnMouseUp="True" />

                    <dxe:CheckEdit Grid.Row="4"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="5,2,0,0"
                                   HorizontalAlignment="Left"
                                   Content="Attempt regular close as part of 3-way"
                                   EditValue="{Binding AutomationConfig.AttemptRegularCloseIn3Way}"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}" />

                    <dxe:CheckEdit Grid.Row="5"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="3"
                                   Margin="5,2,0,0"
                                   HorizontalAlignment="Left"
                                   Content="Use matching HW theos to price verticals"
                                   EditValue="{Binding AutomationConfig.UseMatchingHwTheosForPricing3WayVerticals}"
                                   IsEnabled="{Binding AutomationConfig.LoopingEnabled, Converter={StaticResource BooleanNegationConverter}}" />

                </Grid>
            </GroupBox>
        </dx:DXTabItem>
    </dx:DXTabControl>
</UserControl>
