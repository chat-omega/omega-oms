<Window x:Class="ZeroPlus.Oms.AddIn.Ribbon.Views.MainWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ViewModels="clr-namespace:ZeroPlus.Oms.AddIn.Ribbon.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:ZeroPlus.Oms.AddIn.Ribbon.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title=""
        Width="400"
        Height="250"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">
    <Window.DataContext>
        <ViewModels:MainWindowViewModel />
    </Window.DataContext>
    <i:Interaction.Behaviors>
        <ViewModels:CloseWindowBehavior CloseTrigger="{Binding CloseTrigger}" />
    </i:Interaction.Behaviors>
    <Window.Resources>
        <FontFamily x:Key="AgencyFB">
            ../../Fonts/#Agency FB
        </FontFamily>
        <FontFamily x:Key="ZPLufga">
            ../../Fonts/ZP Lufga/#ZP Lufga
        </FontFamily>
        <FontFamily x:Key="Montserrat">
            ../../Fonts/Montserrat/#Montserrat
        </FontFamily>
        <ViewModels:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <ViewModels:BooleanToVisibilityConverter x:Key="BooleanToVisibilityInverseConverter"
                                                 Inverse="True" />
        <Style x:Key="loginButtonStyle"
               TargetType="{x:Type Button}">
            <Style.Triggers>
                <Trigger Property="IsMouseCaptured" Value="True">
                    <Setter Property="Background" Value="#60CA60" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3c7d3c" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="BorderBrush" Value="#1D673F" />
            <Setter Property="Background" Value="#1D673F" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="saveButtonStyle"
               TargetType="{x:Type CheckBox}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#C0C0C0" />
                </Trigger>
                <Trigger Property="IsChecked" Value="False">
                    <Setter Property="Background" Value="#333337" />
                </Trigger>
            </Style.Triggers>
            <Setter Property="BorderThickness" Value="0" />
        </Style>

    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
            <RowDefinition Height="15" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Image Grid.Row="1"
               Grid.Column="0"
               Grid.ColumnSpan="3"
               Width="230"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"
               Source="../../Images/ZeroPlus_RGB_WordMark_Full-Color.png" />

        <Grid Grid.Row="2"
              Grid.Column="0"
              Grid.ColumnSpan="3"
              Width="230"
              Margin="5,5,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Row="0"
                       Background="#333337">
                <Image Width="24"
                       Height="20"
                       DockPanel.Dock="Left"
                       Source="../../Images/Actions_User.png" />

                <CheckBox Margin="3,0"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          HorizontalContentAlignment="Center"
                          DockPanel.Dock="Right"
                          IsChecked="{Binding SaveUser}"
                          IsTabStop="False"
                          Style="{StaticResource saveButtonStyle}"
                          ToolTip="Save Username" />

                <TextBox Height="22"
                         VerticalContentAlignment="Center"
                         BorderBrush="#333337"
                         FontFamily="{StaticResource Montserrat}"
                         FontSize="12"
                         Text="{Binding Username}" />
            </DockPanel>

            <DockPanel Grid.Row="1"
                       Margin="0,7,0,0"
                       Background="#333337">
                <Image Width="24"
                       Height="20"
                       DockPanel.Dock="Left"
                       Source="../../Images/Key.png" />

                <PasswordBox Height="22"
                             VerticalContentAlignment="Center"
                             BorderBrush="#333337"
                             Foreground="#A8A8AA">
                    <i:Interaction.Behaviors>
                        <ViewModels:PasswordBoxBindingBehavior Password="{Binding SecurePassword}" />
                    </i:Interaction.Behaviors>
                </PasswordBox>
            </DockPanel>

            <Button Grid.Row="2"
                    Width="100"
                    Height="24"
                    Margin="0,10,0,0"
                    HorizontalContentAlignment="Center"
                    Command="{Binding LoginCommand}"
                    Content="Login"
                    FontFamily="{StaticResource ZPLufga}"
                    FontSize="13"
                    IsDefault="True"
                    Style="{StaticResource loginButtonStyle}" />
        </Grid>

        <!--<dx:WaitIndicator Grid.Row="2"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          Content="{Binding BusyMessage}"
                          DeferedVisibility="{Binding IsBusy}"
                          IsTabStop="False" />-->

        <StackPanel Grid.Row="3"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
            <TextBlock Margin="5,0,0,0"
                       HorizontalAlignment="Left"
                       FontFamily="{StaticResource ZPLufga}"
                       FontSize="11"
                       Foreground="#8E8E82"
                       Text="{Binding VersionString}" />
            <TextBlock Margin="5,0"
                       HorizontalAlignment="Center"
                       FontFamily="{StaticResource Montserrat}"
                       FontSize="11"
                       Foreground="#1D673F"
                       Text="{Binding UpdateStatus}" />
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Center"
                   FontFamily="{StaticResource Montserrat}"
                   Foreground="#F26543"
                   Text="{Binding Message}" />

        <Image Grid.Row="3"
               Grid.Column="2"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               RenderOptions.BitmapScalingMode="HighQuality"
               Source="../../Images/WarningCircled.png"
               ToolTip="Auth Server Disconnected"
               Visibility="{Binding AuthConnected, Converter={StaticResource BooleanToVisibilityInverseConverter}}" />

    </Grid>
</Window>
