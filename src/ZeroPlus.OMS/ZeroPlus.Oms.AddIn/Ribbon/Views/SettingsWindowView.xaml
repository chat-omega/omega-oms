<Window x:Class="ZeroPlus.Oms.AddIn.Ribbon.Views.SettingsWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:helpers="clr-namespace:ZeroPlus.Oms.AddIn.Ribbon.Helpers"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:ZeroPlus.Oms.AddIn.Ribbon.ViewModels"
        Title="Settings"
        Width="620"
        Height="300"
        d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
        DataContext="{helpers:DISource Type=viewmodels:SettingsViewModel}"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <TabControl Grid.Row="1"
                    Grid.Column="1"
                    TabStripPlacement="Left">
            <TabItem Header="Connections">
                <Grid Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Content="Auto Trader" />

                    <DockPanel Grid.Row="0"
                               Grid.Column="1"
                               Margin="5,0,0,0">

                        <TextBox Width="250"
                                 Margin="0,2,0,0"
                                 Text="{Binding AutoTraderServerAddress, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Width="100"
                                 Margin="5,2,0,0"
                                 HorizontalAlignment="Left"
                                 Text="{Binding AutoTraderServerPort, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Content="Derivatives" />

                    <DockPanel Grid.Row="1"
                               Grid.Column="1"
                               Margin="5,0,0,0">

                        <TextBox Width="250"
                                 Margin="0,2,0,0"
                                 Text="{Binding ServerAddress, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Width="100"
                                 Margin="5,2,0,0"
                                 HorizontalAlignment="Left"
                                 Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>


                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Vertical" Margin="0,2,0,0">
                        <Button Content="+" Width="24" Height="24" Padding="0,0,0,1" FontSize="14" FontWeight="Bold" ToolTip="Add"
                                Command="{Binding AddNewRaptorClientConfigCommand}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="5,0,2,0">
                        <ItemsControl x:Name="RaptorClientConfigsContainer" ItemsSource="{Binding RaptorClientConfigs, UpdateSourceTrigger=PropertyChanged}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBox Width="250" Text="{Binding ServerAddress, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Width="100" Margin="5,0,5,0" Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Content="×" Width="24" Height="24" Padding="0,0,0,1" FontSize="14" FontWeight="Bold" ToolTip="Remove"
                                                Command="{Binding DataContext.RemoveRaptorClientConfigCommand, ElementName=RaptorClientConfigsContainer}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Label Grid.Row="3"
                           Grid.Column="0"
                           Content="EMA" />

                    <DockPanel Grid.Row="3"
                               Grid.Column="1"
                               Margin="5,0,0,0">

                        <TextBox Width="250"
                                 Margin="0,2,0,0"
                                 Text="{Binding EmaServerAddress, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Width="100"
                                 Margin="5,2,0,0"
                                 HorizontalAlignment="Left"
                                 Text="{Binding EmaServerPort, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <Label Grid.Row="4"
                           Grid.Column="0"
                           Content="Hanweck" />

                    <DockPanel Grid.Row="4"
                               Grid.Column="1"
                               Margin="5,0,0,0">

                        <TextBox Width="250"
                                 Margin="0,2,0,0"
                                 Text="{Binding OmsCore.Config.HanweckAddress}" />

                        <TextBox Width="100"
                                 Margin="5,2,0,0"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OmsCore.Config.HanweckPort}" />
                    </DockPanel>

                    <Label Grid.Row="5"
                           Grid.Column="0"
                           Content="Interpolator" />

                    <DockPanel Grid.Row="5"
                               Grid.Column="1"
                               Margin="5,0,0,0">

                        <TextBox Width="250"
                                 Margin="0,2,0,0"
                                 Text="{Binding InterpolatorServerAddress, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Width="100"
                                 Margin="5,2,0,0"
                                 HorizontalAlignment="Left"
                                 Text="{Binding InterpolatorServerPort, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <Label Grid.Row="6"
                           Grid.Column="0"
                           Content="Quote" />

                    <DockPanel Grid.Row="6"
                               Grid.Column="1"
                               Margin="5,0,0,0">
                        <TextBox Width="250"
                                 Margin="0,2,0,0"
                                 HorizontalAlignment="Left"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding OmsCore.Config.QuoteAddress}" />
                        <TextBox Width="100"
                                 Margin="5,2,0,0"
                                 HorizontalAlignment="Left"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding OmsCore.Config.QuotePort}" />
                    </DockPanel>

                    <Label Grid.Row="7"
                           Grid.Column="0"
                           Content="Transactions" />

                    <DockPanel Grid.Row="7"
                               Grid.Column="1"
                               Margin="5,0,0,0">

                        <TextBox Width="250"
                                 Margin="0,2,0,0"
                                 Text="{Binding TransactionsServerAddress, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Width="100"
                                 Margin="5,2,0,0"
                                 HorizontalAlignment="Left"
                                 Text="{Binding TransactionsServerPort, UpdateSourceTrigger=PropertyChanged}" />

                    </DockPanel>

                    <StackPanel Grid.Row="8"
                                Grid.Column="1"
                                Margin="0,5,5,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">

                        <CheckBox Margin="5,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="Connect on startup"
                                  IsChecked="{Binding OmsCore.Config.ConnectClientsOnStartupV2}" />
                    </StackPanel>

                </Grid>
            </TabItem>
            <TabItem Header="Doms Manager">
                <Grid Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,2,0,0"
                           Content="Manager Address" />

                    <DockPanel Grid.Row="0"
                               Grid.Column="1"
                               Margin="5,2,0,0">
                        <TextBox Width="250"
                                 HorizontalAlignment="Left"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding OmsCore.Config.DominatorsManagerOmsAddress}" />
                        <TextBox Width="100"
                                 Margin="3,0,0,0"
                                 HorizontalAlignment="Left"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding OmsCore.Config.DominatorsManagerOmsPort}" />
                    </DockPanel>

                    <CheckBox Grid.Row="1"
                              Grid.Column="1"
                              Margin="5,2,0,0"
                              Content="Enabled"
                              IsChecked="{Binding OmsCore.Config.DominatorClientEnabled}" />
                </Grid>
            </TabItem>
        </TabControl>

        <Label Grid.Row="2"
               Grid.Column="1"
               Content="{Binding Message}" />
    </Grid>
</Window>
